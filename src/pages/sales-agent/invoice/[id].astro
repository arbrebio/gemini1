---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Facture — Arbre Bio</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; color: #1a1a1a; background: #d8d8d8; }

    /* ── Action bar (hidden on print) ──────────────────────────── */
    #action-bar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: #194642; padding: 10px 20px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 10px rgba(0,0,0,.3);
    }
    #action-bar h1 { color: #fff; font-size: 13.5px; font-weight: 700; }
    .action-btns { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 7px 13px; border-radius: 6px; font-size: 12px; font-weight: 600;
      cursor: pointer; border: none; text-decoration: none;
    }
    .btn-white  { background: #fff; color: #194642; }
    .btn-green  { background: #25D366; color: #fff; }
    .btn-blue   { background: #2563eb; color: #fff; }
    .btn-ghost  { background: rgba(255,255,255,.15); color: #fff; }

    /* ── Page wrapper ───────────────────────────────────────────── */
    #page-wrap { padding: 72px 20px 48px; max-width: 800px; margin: 0 auto; }

    /* ── Invoice card ───────────────────────────────────────────── */
    .invoice { background: #fff; box-shadow: 0 6px 30px rgba(0,0,0,.18); }

    /* ══════════════════════════════════════════════════════════════
       HEADER — white page with diagonal dark-green wave top-right
    ══════════════════════════════════════════════════════════════ */
    .inv-header {
      position: relative;
      height: 185px;
      overflow: hidden;
    }
    /* The diagonal green swoosh — SVG approach */
    .header-wave {
      position: absolute; top: 0; right: 0; width: 100%; height: 100%;
      pointer-events: none;
    }
    /* Logo circle — top-left, sits on white area */
    .header-logo {
      position: absolute; top: 22px; left: 30px; z-index: 2;
    }
    .header-logo svg { width: 72px; height: 72px; }
    /* FACTURE label — inside the green wave, top-right */
    .header-invoice-label {
      position: absolute; top: 28px; right: 36px; z-index: 2;
      text-align: right; color: #fff;
    }
    .header-invoice-label .lbl { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; opacity: .85; }
    .header-invoice-label .num { font-size: 17px; font-weight: 800; letter-spacing: 1.5px; margin-top: 4px; }

    /* ── Company info (below logo) ─────────────────────────────── */
    .inv-company {
      padding: 6px 30px 0 30px;
      font-size: 11px; line-height: 1.75; color: #333;
    }
    .inv-company .co-name { font-size: 12.5px; font-weight: 700; color: #194642; margin-bottom: 1px; }

    /* ── Client block (right side, below wave) ─────────────────── */
    .inv-client {
      position: absolute; bottom: 14px; right: 36px; z-index: 2;
      text-align: right; font-size: 11.5px; line-height: 1.7; color: #333;
    }
    .inv-client .cl-label { font-size: 11px; color: #555; }
    .inv-client .cl-name  { font-weight: 700; font-size: 13px; color: #111; }

    /* ── Date row ──────────────────────────────────────────────── */
    .inv-date {
      padding: 10px 30px 6px;
      font-size: 11.5px; color: #333;
    }
    .inv-date strong { color: #194642; }

    /* ══════════════════════════════════════════════════════════════
       ITEMS TABLE
    ══════════════════════════════════════════════════════════════ */
    .table-wrap { padding: 0 30px; }
    table.items {
      width: 100%; border-collapse: collapse; font-size: 12px;
      border: 1px solid #c8d5c0;
    }
    table.items thead tr { background: #194642; }
    table.items thead th {
      padding: 9px 12px; color: #fff;
      font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
      text-align: left;
    }
    table.items thead th:not(:first-child) { text-align: right; }
    table.items tbody tr { border-bottom: 1px solid #e0e8db; }
    table.items tbody tr:nth-child(even) { background: #f7faf5; }
    table.items td { padding: 10px 12px; vertical-align: top; font-size: 12px; color: #222; }
    table.items td:not(:first-child) { text-align: right; }
    /* Empty filler rows */
    table.items tr.empty td { height: 28px; color: transparent; }

    /* ── Table validity note ────────────────────────────────────── */
    .table-note {
      padding: 6px 30px 10px;
      font-size: 10.5px; color: #666; font-style: italic;
    }

    /* ══════════════════════════════════════════════════════════════
       BOTTOM SECTION — conditions left | amount box right
    ══════════════════════════════════════════════════════════════ */
    .inv-bottom {
      display: flex; gap: 20px;
      padding: 12px 30px 18px;
      align-items: flex-start;
    }
    /* LEFT: conditions */
    .inv-conditions { flex: 1.1; font-size: 10.5px; line-height: 1.65; color: #333; }
    .inv-conditions .cond-title {
      font-size: 11px; font-weight: 700; color: #111;
      margin-bottom: 4px; text-decoration: underline;
    }
    .inv-conditions .pay-title {
      font-size: 11px; font-weight: 700; color: #111;
      margin-top: 10px; margin-bottom: 3px; text-decoration: underline;
    }
    .inv-conditions .bank-line { font-size: 11px; line-height: 1.7; color: #222; }

    /* RIGHT: amount box + seal */
    .inv-right { flex: 0.9; display: flex; flex-direction: column; align-items: flex-end; gap: 12px; }
    .amount-box {
      background: #194642; color: #fff;
      padding: 14px 20px; width: 100%;
      font-size: 12.5px; font-weight: 700;
      display: flex; align-items: center; justify-content: space-between;
    }
    .amount-box .am-label { font-size: 11px; font-weight: 600; opacity: .85; white-space: nowrap; }
    .amount-box .am-value { font-size: 16px; font-weight: 900; white-space: nowrap; margin-left: 10px; }
    .seal-area { display: flex; justify-content: flex-end; }
    .seal-area svg { width: 80px; height: 80px; }

    /* ══════════════════════════════════════════════════════════════
       FOOTER — three icons, white background
    ══════════════════════════════════════════════════════════════ */
    .inv-footer {
      border-top: 1px solid #e0e8db;
      padding: 10px 30px;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 11px; color: #555;
    }
    .inv-footer .foot-item { display: flex; align-items: center; gap: 5px; }
    .inv-footer .foot-icon { color: #194642; font-size: 13px; }

    /* ── Loading / error ─────────────────────────────────────────── */
    #loading   { text-align: center; padding: 80px 20px; color: #555; font-size: 15px; }
    #error-msg { display: none; text-align: center; padding: 60px 20px; color: #c00; font-size: 15px; }

    /* ══════════════════════════════════════════════════════════════
       PRINT
    ══════════════════════════════════════════════════════════════ */
    @media print {
      body { background: #fff; }
      #action-bar { display: none !important; }
      #page-wrap { padding: 0; max-width: none; }
      .invoice { box-shadow: none; }
    }
  </style>
</head>
<body>

<!-- ── Action bar ──────────────────────────────────────────────── -->
<div id="action-bar">
  <h1>📄 Facture — Arbre Bio Africa</h1>
  <div class="action-btns">
    <button class="btn btn-white" onclick="window.print()">
      <i class="fas fa-download"></i> Télécharger / Imprimer
    </button>
    <a id="btn-whatsapp" class="btn btn-green" href="#" target="_blank">
      <i class="fab fa-whatsapp"></i> WhatsApp
    </a>
    <a id="btn-email" class="btn btn-blue" href="#">
      <i class="fas fa-envelope"></i> Email
    </a>
    <button class="btn btn-ghost" onclick="history.back()">
      <i class="fas fa-arrow-left"></i> Retour
    </button>
  </div>
</div>

<div id="page-wrap">
  <div id="loading">⏳ Chargement de la facture…</div>
  <div id="error-msg">❌ <span id="error-text">Erreur de chargement</span></div>
  <div id="invoice-content" style="display:none;"></div>
</div>

<script is:inline>
(function () {
  var token  = localStorage.getItem('agentToken');
  var saleId = window.location.pathname.split('/').filter(Boolean).pop();
  if (!token) { window.location.href = '/sales-agent/login'; return; }

  /* ── French number-to-words ──────────────────────────────────── */
  var ONES = ['','un','deux','trois','quatre','cinq','six','sept','huit','neuf',
              'dix','onze','douze','treize','quatorze','quinze','seize',
              'dix-sept','dix-huit','dix-neuf'];
  var TENS = ['','','vingt','trente','quarante','cinquante','soixante',
              'soixante','quatre-vingt','quatre-vingt'];
  function h(n) {
    if (!n) return '';
    var r = '';
    if (n >= 100) {
      var q = Math.floor(n/100);
      r = (q===1?'cent':ONES[q]+'-cent') + (n%100===0&&q>1?'s':'');
      n = n%100; if (n) r += '-';
    }
    if (n >= 20) {
      var t=Math.floor(n/10), o=n%10;
      if (t===7||t===9) r += TENS[t]+'-'+ONES[10+o];
      else { r+=TENS[t]; if(t===8){if(!o)r+='s';} else if(o===1)r+='-et-un'; else if(o)r+='-'+ONES[o]; }
    } else if (n) r += ONES[n];
    return r;
  }
  function numberToWords(n) {
    n = Math.round(Math.abs(n)); if (!n) return 'Zéro';
    var p=[];
    if(n>=1e9){var b=Math.floor(n/1e9);p.push(h(b)+'-milliard'+(b>1?'s':''));n%=1e9;}
    if(n>=1e6){var m=Math.floor(n/1e6);p.push(h(m)+'-million'+(m>1?'s':''));n%=1e6;}
    if(n>=1e3){var k=Math.floor(n/1e3);p.push(k===1?'mille':h(k)+'-mille');n%=1e3;}
    if(n)p.push(h(n));
    var w=p.join('-'); return w[0].toUpperCase()+w.slice(1);
  }

  function fmt(n)    { return new Intl.NumberFormat('fr-FR').format(Number(n)); }
  function fmtDate(d){ return d?new Date(d).toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'}):''; }

  var PAY = {
    wire_transfer:'Virement bancaire', orange_money:'Orange Money',
    mtn_money:'MTN Money',moov_money:'Moov Money',wave:'WAVE',cash:'Espèces'
  };

  /* ────────────────────────────────────────────────────────────────
     SVG ASSETS
  ──────────────────────────────────────────────────────────────── */

  /* Arbre Bio circular logo (white circle + dark green tree) */
  var LOGO_SVG =
    '<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">' +
    '<circle cx="50" cy="50" r="49" fill="#fff" stroke="#194642" stroke-width="2"/>' +
    '<circle cx="50" cy="50" r="43" fill="none" stroke="#194642" stroke-width="1"/>' +
    /* trunk */ '<rect x="47" y="60" width="6" height="20" rx="3" fill="#194642"/>' +
    /* left branch */ '<line x1="50" y1="70" x2="36" y2="62" stroke="#194642" stroke-width="2.5" stroke-linecap="round"/>' +
    /* right branch */ '<line x1="50" y1="66" x2="65" y2="57" stroke="#194642" stroke-width="2.5" stroke-linecap="round"/>' +
    /* canopy layers */ '<ellipse cx="50" cy="45" rx="15" ry="17" fill="#194642"/>' +
    '<ellipse cx="37" cy="52" rx="10" ry="11" fill="#194642"/>' +
    '<ellipse cx="63" cy="52" rx="10" ry="11" fill="#194642"/>' +
    /* top highlight */ '<ellipse cx="50" cy="38" rx="8" ry="9" fill="#2a6b60" opacity=".6"/>' +
    '</svg>';

  /* Diagonal green wave SVG — fills the header area */
  /* The wave starts at ~38% from left at top, sweeps to ~25% at bottom */
  function headerWaveSVG(w, h) {
    return '<svg width="' + w + '" height="' + h + '" viewBox="0 0 ' + w + ' ' + h + '" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">' +
      '<path d="M ' + (w*0.38) + ' 0 Q ' + (w*0.30) + ' ' + (h*0.5) + ' ' + (w*0.26) + ' ' + h + ' L ' + w + ' ' + h + ' L ' + w + ' 0 Z" fill="#194642"/>' +
      '</svg>';
  }

  /* Arbre Bio stamp / seal (circular, used in payment section) */
  var SEAL_SVG =
    '<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">' +
    '<circle cx="50" cy="50" r="48" stroke="#194642" stroke-width="2.5" fill="none"/>' +
    '<circle cx="50" cy="50" r="41" stroke="#194642" stroke-width="1" fill="none"/>' +
    /* tree */ '<rect x="47" y="58" width="6" height="18" rx="3" fill="#194642"/>' +
    '<ellipse cx="50" cy="44" rx="13" ry="15" fill="#194642"/>' +
    '<ellipse cx="38" cy="51" rx="9" ry="10" fill="#194642"/>' +
    '<ellipse cx="62" cy="51" rx="9" ry="10" fill="#194642"/>' +
    /* curved text top */ '<path id="tArc" d="M 12 50 A 38 38 0 0 1 88 50" fill="none"/>' +
    '<text font-size="8.5" font-weight="700" fill="#194642" letter-spacing="2" font-family="Arial,sans-serif">' +
      '<textPath href="#tArc" startOffset="10%">ORGANIC TREE ARBRE BIO</textPath>' +
    '</text>' +
    /* curved text bottom */ '<path id="bArc" d="M 18 56 A 32 32 0 0 0 82 56" fill="none"/>' +
    '<text font-size="7" fill="#194642" letter-spacing="1.5" font-family="Arial,sans-serif">' +
      '<textPath href="#bArc" startOffset="12%">CÔTE D\'IVOIRE · AFRICA</textPath>' +
    '</text>' +
    '</svg>';

  /* ────────────────────────────────────────────────────────────────
     RENDER INVOICE HTML
  ──────────────────────────────────────────────────────────────── */
  function render(data) {
    var sale   = data.sale;
    var items  = data.items  || [];
    var client = data.client || {};
    var total  = Number(sale.total_amount);
    var date   = fmtDate(sale.validated_at || sale.created_at);

    var clientName    = client.company_name || sale.client_name;
    var clientPhone   = client.phone   || '';
    var clientEmail   = client.email   || '';
    var clientAddr    = client.address || '';
    var clientCity    = client.city    || '';

    /* Build table rows */
    var rowsHtml = items.map(function(it) {
      return '<tr>' +
        '<td>' + it.product_name + '</td>' +
        '<td>' + fmt(it.quantity) + '</td>' +
        '<td>' + fmt(it.unit_price) + ' F CFA</td>' +
        '<td><strong>' + fmt(it.line_total) + ' F CFA</strong></td>' +
        '</tr>';
    }).join('');

    /* Add 3 empty filler rows to match the PDF look */
    var fillerRows = '';
    for (var i = 0; i < 3; i++) {
      fillerRows += '<tr class="empty"><td>&nbsp;</td><td></td><td></td><td></td></tr>';
    }

    var html =
    '<div class="invoice">' +

      /* ═══ HEADER ═══ */
      '<div class="inv-header">' +
        /* Green wave background */
        '<div class="header-wave">' + headerWaveSVG(800, 185) + '</div>' +
        /* Logo top-left */
        '<div class="header-logo">' + LOGO_SVG + '</div>' +
        /* FACTURE label inside wave */
        '<div class="header-invoice-label">' +
          '<div class="lbl">FACTURE</div>' +
          '<div class="num">N: ' + (sale.invoice_number || '—') + '</div>' +
        '</div>' +
        /* Client block bottom-right (over white area) */
        '<div class="inv-client">' +
          '<div class="cl-label">Facturé à :</div>' +
          '<div class="cl-name">' + clientName + '</div>' +
          (clientAddr  ? '<div>' + clientAddr + '</div>'  : '') +
          (clientPhone ? '<div>' + clientPhone + '</div>' : '') +
          (clientCity  ? '<div>' + clientCity + '</div>'  : '') +
        '</div>' +
      '</div>' +

      /* ═══ COMPANY INFO ═══ */
      '<div class="inv-company">' +
        '<div class="co-name">Arbre Bio Côte d\'Ivoire</div>' +
        '01 BP 6664 ABIDJAN 01<br/>' +
        'RCCM: CI-ABJ-03-2023-B13-12469<br/>' +
        'NCC: 25052130<br/>' +
        'Email: farms@arbrebio.com<br/>' +
        'Tel: (+225) 05 00 55 25 25' +
      '</div>' +

      /* ═══ DATE ═══ */
      '<div class="inv-date">Date : <strong>' + date + '</strong></div>' +

      /* ═══ TABLE ═══ */
      '<div class="table-wrap">' +
        '<table class="items">' +
          '<thead><tr>' +
            '<th style="width:46%">Description</th>' +
            '<th style="width:10%">Qté</th>' +
            '<th style="width:22%">Prix UHT</th>' +
            '<th style="width:22%">Total HT</th>' +
          '</tr></thead>' +
          '<tbody>' + rowsHtml + fillerRows + '</tbody>' +
        '</table>' +
      '</div>' +

      /* ═══ TABLE NOTE ═══ */
      '<div class="table-note">* Ce devis est valable pendant 4 jours à partir de sa date d\'émission.</div>' +

      /* ═══ BOTTOM SECTION ═══ */
      '<div class="inv-bottom">' +

        /* LEFT: conditions + payment method */
        '<div class="inv-conditions">' +
          '<div class="cond-title">Conditions de règlements :</div>' +
          '<p>Pour toutes les commandes passées chez Arbre Bio, il est impératif de verser 100% du montant net à payer par virement après réception de la facture. La livraison est effectuée entre 2 à 25 jours ouvrables après réception du paiement dans son intégralité et selon la disponibilité des produits.</p>' +
          '<p style="margin-top:4px">Toutes les ventes sont définitives, nous ne retournons ni n\'échangeons aucun produit merci de vérifier que la livraison est conforme, nous n\'accepterons aucun remboursements après la livraison.</p>' +
          '<div class="pay-title">MÉTHODE DE PAIEMENT:</div>' +
          '<div class="bank-line">' +
            'BNI Bank compte bancaire :<br/>' +
            'CI092 01021 000115840024 78<br/>' +
            'Par VIREMENT à l\'ordre de<br/>' +
            'ARBRE BIO Côte d\'Ivoire.' +
            (sale.payment_method ? '<br/>Mode: <strong>' + (PAY[sale.payment_method]||sale.payment_method) + '</strong>' : '') +
            (sale.transaction_reference ? '<br/>Réf: <strong>' + sale.transaction_reference + '</strong>' : '') +
          '</div>' +
        '</div>' +

        /* RIGHT: amount box + seal */
        '<div class="inv-right">' +
          '<div class="amount-box">' +
            '<span class="am-label">MONTANT NET A PAYER :</span>' +
            '<span class="am-value">' + fmt(total) + ' FR CFA</span>' +
          '</div>' +
          '<div class="seal-area">' + SEAL_SVG + '</div>' +
          '<div style="font-size:10px;color:#666;font-style:italic;text-align:right;margin-top:-6px">' +
            numberToWords(total) + ' Francs CFA' +
          '</div>' +
        '</div>' +
      '</div>' +

      /* ═══ FOOTER ═══ */
      '<div class="inv-footer">' +
        '<div class="foot-item"><i class="fas fa-map-marker-alt foot-icon"></i> 01 BP 6664 ABJ 01</div>' +
        '<div class="foot-item"><i class="fab fa-facebook foot-icon"></i> @arbrebio</div>' +
        '<div class="foot-item"><i class="fas fa-globe foot-icon"></i> www.arbrebio.com</div>' +
      '</div>' +

    '</div>'; /* .invoice */

    return { html, clientPhone, clientEmail, total, invoiceNumber: sale.invoice_number, clientName: sale.client_name };
  }

  /* ── Share links ─────────────────────────────────────────────── */
  function buildShareLinks(info) {
    var url  = window.location.href;
    var wa   = encodeURIComponent(
      'Bonjour ' + info.clientName + ',\n\n' +
      '✅ Votre vente a été validée par Arbre Bio Africa.\n' +
      'Facture N° ' + info.invoiceNumber + '\n' +
      'Montant : ' + new Intl.NumberFormat('fr-FR').format(info.total) + ' FCFA\n\n' +
      '🔗 ' + url + '\n\nMerci pour votre confiance.\n— Arbre Bio Africa'
    );
    var subj = encodeURIComponent('Facture ' + info.invoiceNumber + ' — Arbre Bio Africa');
    var body = encodeURIComponent(
      'Bonjour ' + info.clientName + ',\n\n' +
      'Veuillez trouver ci-joint votre facture N° ' + info.invoiceNumber + '.\n\n' +
      'Montant total : ' + new Intl.NumberFormat('fr-FR').format(info.total) + ' FCFA\n' +
      'Lien : ' + url + '\n\n' +
      'Cordialement,\nArbre Bio Africa\nfarms@arbrebio.com\n(+225) 05 00 55 25 25'
    );
    document.getElementById('btn-whatsapp').href =
      info.clientPhone
        ? 'https://wa.me/' + info.clientPhone.replace(/\D/g,'') + '?text=' + wa
        : 'https://wa.me/?text=' + wa;
    document.getElementById('btn-email').href =
      info.clientEmail
        ? 'mailto:' + info.clientEmail + '?subject=' + subj + '&body=' + body
        : 'mailto:?subject=' + subj + '&body=' + body;
  }

  /* ── Fetch & render ──────────────────────────────────────────── */
  fetch('/api/sales-agent/invoice?id=' + saleId, {
    headers: { Authorization: 'Bearer ' + token }
  })
  .then(function(r) {
    if (r.status === 401) { window.location.href = '/sales-agent/login'; return null; }
    return r.json();
  })
  .then(function(data) {
    if (!data) return;
    document.getElementById('loading').style.display = 'none';
    if (data.error) {
      document.getElementById('error-text').textContent = data.error;
      document.getElementById('error-msg').style.display = 'block';
      return;
    }
    var info = render(data);
    var el   = document.getElementById('invoice-content');
    el.innerHTML  = info.html;
    el.style.display = 'block';
    buildShareLinks(info);
    document.title = 'Facture ' + (data.sale.invoice_number || '') + ' — Arbre Bio';
  })
  .catch(function(err) {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error-text').textContent = err.message;
    document.getElementById('error-msg').style.display = 'block';
  });
})();
</script>
</body>
</html>
