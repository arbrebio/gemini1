---
export const prerender = false;
const SUPABASE_URL     = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="icon" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" type="image/png" />
  <link rel="icon" href="/favicon.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon.png" sizes="16x16" type="image/png" />
  <link rel="manifest" href="/manifest-agent.json" />
  <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
  <title>Mon Compte — Arbre Bio Africa</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #194642 0%, #2a5e59 50%, #194642 100%);
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      padding: 1.5rem;
    }
    .card {
      background: white; border-radius: 20px; padding: 2rem;
      width: 100%; max-width: 440px; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .logo-section { text-align: center; margin-bottom: 1.5rem; }
    .logo-section img { height: 52px; width: auto; border-radius: 12px; background: #194642; padding: 6px; margin-bottom: 0.75rem; }
    .forced-badge {
      display: inline-flex; align-items: center; gap: 0.4rem;
      background: #fff7ed; border: 1px solid #fed7aa; color: #c2410c;
      border-radius: 20px; padding: 0.35rem 0.9rem; font-size: 0.78rem;
      font-weight: 600; margin-bottom: 0.5rem;
    }
    .title { font-size: 1.25rem; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .subtitle { font-size: 0.8rem; color: #6b7280; }
    .divider { height: 1px; background: #f3f4f6; margin: 1.25rem 0; }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 0.4rem; }
    .input-wrapper { position: relative; }
    .form-input {
      width: 100%; padding: 0.75rem 1rem 0.75rem 2.75rem;
      border: 2px solid #e5e7eb; border-radius: 10px; font-size: 0.9rem;
      color: #111827; outline: none; transition: border-color 0.15s;
      padding-right: 3rem; -webkit-appearance: none;
    }
    .form-input:focus { border-color: #194642; }
    .form-input.error { border-color: #ef4444; }
    .input-icon { position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); color: #9ca3af; font-size: 0.9rem; }
    .toggle-pw { position: absolute; right: 0.875rem; top: 50%; transform: translateY(-50%); color: #9ca3af; background: none; border: none; cursor: pointer; padding: 0.25rem; }
    .strength-bar { height: 4px; border-radius: 2px; margin-top: 6px; background: #e5e7eb; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 2px; transition: width .3s, background .3s; width: 0%; }
    .strength-label { font-size: 0.7rem; margin-top: 4px; font-weight: 500; }
    .req-list { margin-top: 6px; }
    .req-item { display: flex; align-items: center; gap: 6px; font-size: 0.72rem; color: #9ca3af; margin-bottom: 2px; transition: color .15s; }
    .req-item.met { color: #16a34a; }
    .req-item i { width: 12px; text-align: center; }
    .alert { display: none; border-radius: 8px; padding: 0.75rem 1rem; font-size: 0.82rem; margin-bottom: 1rem; align-items: center; gap: 0.5rem; }
    .alert.show { display: flex; }
    .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #16a34a; }
    .submit-btn {
      width: 100%; padding: 0.875rem; background: #194642; color: white;
      border: none; border-radius: 10px; font-size: 0.95rem; font-weight: 600;
      cursor: pointer; transition: opacity 0.15s; margin-top: 0.5rem;
    }
    .submit-btn:hover:not(:disabled) { opacity: 0.9; }
    .submit-btn:disabled { opacity: 0.55; cursor: not-allowed; }
    .back-link { display: block; text-align: center; margin-top: 1rem; font-size: 0.8rem; color: #6b7280; text-decoration: none; }
    .back-link:hover { color: #194642; }
    .section-title { font-size: 0.95rem; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .section-sub { font-size: 0.78rem; color: #6b7280; margin-bottom: 1rem; }
    .avatar-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; }
    .avatar-btn {
      position: relative; width: 64px; height: 64px; border-radius: 9999px; flex-shrink: 0;
      background: #e6f4f1; color: #194642; display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; border: 2px solid #e5e7eb; cursor: pointer; overflow: hidden; padding: 0;
    }
    .avatar-btn img { width: 100%; height: 100%; object-fit: cover; }
    .avatar-btn .cam-overlay {
      position: absolute; inset: 0; background: rgba(0,0,0,0.35); color: white;
      display: flex; align-items: center; justify-content: center; font-size: 0.85rem; opacity: 0;
      transition: opacity 0.15s;
    }
    .avatar-btn:hover .cam-overlay { opacity: 1; }
    .name-form { flex: 1; min-width: 0; }
    .name-inputs { display: flex; gap: 0.5rem; }
    .name-inputs .form-input { padding-left: 0.9rem; }
    .save-name-btn {
      margin-top: 0.6rem; padding: 0.5rem 1rem; background: #194642; color: white; border: none;
      border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer;
    }
    .save-name-btn:disabled { opacity: 0.55; cursor: not-allowed; }
  </style>
</head>
<body>
  <script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
    window.__AGENT_SUPABASE_URL__ = SUPABASE_URL;
    window.__AGENT_SUPABASE_KEY__ = SUPABASE_ANON_KEY;
  </script>

  <div class="card">
    <div class="logo-section">
      <img src="/logo.png" alt="Arbre Bio Africa" />
    </div>

    <!-- Forced-change banner (shown when must_change_password) -->
    <div id="forced-banner" style="display:none;margin-bottom:1rem;">
      <div class="forced-badge"><i class="fas fa-shield-alt"></i> Mot de passe temporaire</div>
      <div class="title">Créez votre mot de passe</div>
      <div class="subtitle">Votre compte a été créé par un administrateur. Choisissez un mot de passe personnel pour continuer.</div>
    </div>

    <!-- Voluntary change header -->
    <div id="voluntary-header">
      <div class="title">Mon Compte</div>
      <div class="subtitle">Gérez vos informations personnelles et votre mot de passe.</div>
    </div>

    <div class="divider"></div>

    <!-- Profile section (name + avatar) -->
    <div id="profile-section">
      <div class="section-title">Profil</div>
      <div class="section-sub">Votre nom et votre photo, tels qu'affichés dans le portail.</div>

      <div id="profile-alert-error" class="alert alert-error"><i class="fas fa-exclamation-circle"></i><span id="profile-alert-error-text"></span></div>
      <div id="profile-alert-success" class="alert alert-success"><i class="fas fa-check-circle"></i><span>Profil mis à jour.</span></div>

      <div class="avatar-row">
        <button type="button" class="avatar-btn" id="avatar-btn" title="Changer la photo de profil">
          <span id="avatar-inner"><i class="fas fa-user"></i></span>
          <span class="cam-overlay"><i class="fas fa-camera"></i></span>
        </button>
        <input type="file" id="avatar-file-input" accept="image/*" class="hidden" style="display:none" />

        <div class="name-form">
          <label class="form-label" for="input-first-name">Prénom &amp; Nom</label>
          <div class="name-inputs">
            <input id="input-first-name" type="text" class="form-input" style="padding-left:0.9rem" placeholder="Prénom" />
            <input id="input-last-name" type="text" class="form-input" style="padding-left:0.9rem" placeholder="Nom" />
          </div>
          <button type="button" id="save-name-btn" class="save-name-btn">Enregistrer le nom</button>
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="section-title">Mot de passe</div>
    <div class="section-sub">Mettez à jour votre mot de passe de connexion.</div>

    <!-- Alerts -->
    <div id="alert-error" class="alert alert-error"><i class="fas fa-exclamation-circle"></i><span id="alert-error-text"></span></div>
    <div id="alert-success" class="alert alert-success"><i class="fas fa-check-circle"></i><span>Mot de passe modifié avec succès ! Redirection…</span></div>

    <form id="pw-form">
      <!-- Current password -->
      <div class="form-group">
        <label class="form-label" for="input-current">Mot de passe actuel</label>
        <div class="input-wrapper">
          <i class="fas fa-lock input-icon"></i>
          <input id="input-current" type="password" class="form-input" autocomplete="current-password" required placeholder="••••••••" />
          <button type="button" class="toggle-pw" data-target="input-current"><i class="fas fa-eye"></i></button>
        </div>
      </div>

      <!-- New password -->
      <div class="form-group">
        <label class="form-label" for="input-new">Nouveau mot de passe</label>
        <div class="input-wrapper">
          <i class="fas fa-key input-icon"></i>
          <input id="input-new" type="password" class="form-input" autocomplete="new-password" required placeholder="Min. 8 caractères" />
          <button type="button" class="toggle-pw" data-target="input-new"><i class="fas fa-eye"></i></button>
        </div>
        <div class="strength-bar"><div id="strength-fill" class="strength-fill"></div></div>
        <div id="strength-label" class="strength-label" style="color:#9ca3af"></div>
        <div class="req-list">
          <div class="req-item" id="req-len"><i class="fas fa-circle-xmark"></i> Au moins 8 caractères</div>
          <div class="req-item" id="req-upper"><i class="fas fa-circle-xmark"></i> Une majuscule</div>
          <div class="req-item" id="req-num"><i class="fas fa-circle-xmark"></i> Un chiffre</div>
          <div class="req-item" id="req-diff"><i class="fas fa-circle-xmark"></i> Différent du mot de passe actuel</div>
        </div>
      </div>

      <!-- Confirm new password -->
      <div class="form-group">
        <label class="form-label" for="input-confirm">Confirmer le nouveau mot de passe</label>
        <div class="input-wrapper">
          <i class="fas fa-check-double input-icon"></i>
          <input id="input-confirm" type="password" class="form-input" autocomplete="new-password" required placeholder="••••••••" />
          <button type="button" class="toggle-pw" data-target="input-confirm"><i class="fas fa-eye"></i></button>
        </div>
        <div id="match-hint" style="font-size:0.7rem;margin-top:4px"></div>
      </div>

      <button type="submit" id="submit-btn" class="submit-btn" disabled>
        <span id="btn-text">Enregistrer le nouveau mot de passe</span>
      </button>
    </form>

    <a href="/sales-agent/" id="back-link" class="back-link" style="display:none">← Retour au tableau de bord</a>
  </div>

  <script is:inline>
  (function () {
    var token = localStorage.getItem('agentToken');
    var profile = null;
    try { profile = JSON.parse(localStorage.getItem('agentProfile') || 'null'); } catch {}

    if (!token) { window.location.href = '/sales-agent/login/'; return; }

    var isForced = profile && profile.must_change_password;

    if (isForced) {
      document.getElementById('forced-banner').style.display = '';
      document.getElementById('voluntary-header').style.display = 'none';
    } else {
      document.getElementById('back-link').style.display = '';
    }

    // ── Profile: avatar + name ───────────────────────────────────────────────
    function splitName(fullName) {
      var parts = (fullName || '').trim().split(/\s+/);
      return { first: parts[0] || '', last: parts.slice(1).join(' ') };
    }

    function renderAvatar(url) {
      var inner = document.getElementById('avatar-inner');
      inner.innerHTML = url ? '<img src="' + url + '" alt="Profil" />' : '<i class="fas fa-user"></i>';
    }

    if (profile) {
      var n = splitName(profile.full_name);
      document.getElementById('input-first-name').value = n.first;
      document.getElementById('input-last-name').value = n.last;
      renderAvatar(profile.avatar_url);
    }

    // Refresh from server in case it changed elsewhere
    (async function loadFreshProfile() {
      try {
        var res = await fetch('/api/sales-agent/auth/', { headers: { Authorization: 'Bearer ' + token } });
        if (!res.ok) return;
        var data = await res.json();
        if (data.profile) {
          profile = data.profile;
          localStorage.setItem('agentProfile', JSON.stringify(profile));
          var n2 = splitName(profile.full_name);
          document.getElementById('input-first-name').value = n2.first;
          document.getElementById('input-last-name').value = n2.last;
          renderAvatar(profile.avatar_url);
        }
      } catch {}
    })();

    function showProfileError(msg) {
      document.getElementById('profile-alert-success').classList.remove('show');
      var box = document.getElementById('profile-alert-error');
      document.getElementById('profile-alert-error-text').textContent = msg;
      box.classList.add('show');
      setTimeout(function () { box.classList.remove('show'); }, 4000);
    }
    function showProfileSuccess() {
      document.getElementById('profile-alert-error').classList.remove('show');
      var box = document.getElementById('profile-alert-success');
      box.classList.add('show');
      setTimeout(function () { box.classList.remove('show'); }, 3000);
    }

    document.getElementById('save-name-btn').addEventListener('click', async function () {
      var first = document.getElementById('input-first-name').value.trim();
      var last = document.getElementById('input-last-name').value.trim();
      var fullName = (first + ' ' + last).trim();
      if (fullName.length < 2) { showProfileError('Veuillez entrer votre prénom et nom.'); return; }

      var btn = this;
      btn.disabled = true;
      try {
        var res = await fetch('/api/sales-agent/profile/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
          body: JSON.stringify({ full_name: fullName }),
        });
        var data = await res.json();
        if (!res.ok) { showProfileError(data.error || 'Une erreur est survenue.'); return; }
        profile = { ...profile, full_name: data.profile.full_name };
        localStorage.setItem('agentProfile', JSON.stringify(profile));
        showProfileSuccess();
      } catch {
        showProfileError('Erreur réseau. Vérifiez votre connexion.');
      } finally {
        btn.disabled = false;
      }
    });

    var avatarBtn = document.getElementById('avatar-btn');
    var avatarFileInput = document.getElementById('avatar-file-input');
    avatarBtn.addEventListener('click', function () { avatarFileInput.click(); });

    avatarFileInput.addEventListener('change', async function () {
      var file = avatarFileInput.files && avatarFileInput.files[0];
      if (!file) return;

      var allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
      if (!allowedTypes.includes(file.type)) {
        showProfileError('Seuls les formats JPG, PNG, WebP ou GIF sont autorisés.');
        avatarFileInput.value = '';
        return;
      }
      if (file.size > 2 * 1024 * 1024) {
        showProfileError('La photo doit faire moins de 2 Mo.');
        avatarFileInput.value = '';
        return;
      }

      var fd = new FormData();
      fd.append('file', file);

      try {
        var res = await fetch('/api/sales-agent/upload-avatar/', {
          method: 'POST',
          headers: { Authorization: 'Bearer ' + token },
          body: fd,
        });
        var data = await res.json();
        if (!res.ok) { showProfileError(data.error || 'Échec du téléversement.'); return; }
        renderAvatar(data.avatar_url);
        profile = { ...profile, avatar_url: data.avatar_url };
        localStorage.setItem('agentProfile', JSON.stringify(profile));
        showProfileSuccess();
      } catch {
        showProfileError('Erreur réseau. Vérifiez votre connexion.');
      } finally {
        avatarFileInput.value = '';
      }
    });

    // ── Password toggle buttons ──────────────────────────────────────────────
    document.querySelectorAll('.toggle-pw').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-target'));
        var icon = btn.querySelector('i');
        if (target.type === 'password') {
          target.type = 'text'; icon.className = 'fas fa-eye-slash';
        } else {
          target.type = 'password'; icon.className = 'fas fa-eye';
        }
      });
    });

    // ── Strength meter ───────────────────────────────────────────────────────
    var inputNew     = document.getElementById('input-new');
    var inputCurrent = document.getElementById('input-current');
    var inputConfirm = document.getElementById('input-confirm');

    function checkStrength(pw, current) {
      var score = 0;
      var metLen   = pw.length >= 8;
      var metUpper = /[A-Z]/.test(pw);
      var metNum   = /[0-9]/.test(pw);
      var metDiff  = pw.length > 0 && pw !== current;
      if (metLen)   score++;
      if (metUpper) score++;
      if (metNum)   score++;
      if (pw.length >= 12) score++;

      setReq('req-len',   metLen);
      setReq('req-upper', metUpper);
      setReq('req-num',   metNum);
      setReq('req-diff',  metDiff);

      var fill   = document.getElementById('strength-fill');
      var label  = document.getElementById('strength-label');
      var pct    = [0, 25, 50, 75, 100][score] || 0;
      var colors = ['#e5e7eb', '#ef4444', '#f59e0b', '#84cc16', '#16a34a'];
      var labels = ['', 'Très faible', 'Faible', 'Bon', 'Fort'];
      fill.style.width  = pct + '%';
      fill.style.background = colors[score] || '#e5e7eb';
      label.textContent = labels[score] || '';
      label.style.color  = colors[score] || '#9ca3af';

      return metLen && metDiff;
    }

    function setReq(id, met) {
      var el = document.getElementById(id);
      el.classList.toggle('met', met);
      el.querySelector('i').className = met ? 'fas fa-circle-check' : 'fas fa-circle-xmark';
    }

    function validateForm() {
      var pw      = inputNew.value;
      var current = inputCurrent.value;
      var confirm = inputConfirm.value;
      var ok      = checkStrength(pw, current) && pw === confirm && current.length > 0;
      document.getElementById('submit-btn').disabled = !ok;
    }

    inputNew.addEventListener('input', validateForm);
    inputCurrent.addEventListener('input', validateForm);
    inputConfirm.addEventListener('input', function () {
      var hint = document.getElementById('match-hint');
      var pw = inputNew.value; var conf = inputConfirm.value;
      if (!conf) { hint.textContent = ''; return; }
      if (pw === conf) { hint.textContent = '✓ Les mots de passe correspondent'; hint.style.color = '#16a34a'; }
      else { hint.textContent = '✗ Les mots de passe ne correspondent pas'; hint.style.color = '#ef4444'; }
      validateForm();
    });

    // ── Submit ───────────────────────────────────────────────────────────────
    document.getElementById('pw-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      var btn     = document.getElementById('submit-btn');
      var btnText = document.getElementById('btn-text');
      var errBox  = document.getElementById('alert-error');
      var sucBox  = document.getElementById('alert-success');

      errBox.classList.remove('show');
      btn.disabled = true;
      btnText.textContent = 'Enregistrement…';

      try {
        var res = await fetch('/api/sales-agent/change-password/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + token,
          },
          body: JSON.stringify({
            current_password: inputCurrent.value,
            new_password:     inputNew.value,
          }),
        });

        var data = await res.json();

        if (!res.ok) {
          document.getElementById('alert-error-text').textContent = data.error || 'Une erreur est survenue.';
          errBox.classList.add('show');
          btn.disabled = false;
          btnText.textContent = 'Enregistrer le nouveau mot de passe';
          return;
        }

        // Update cached profile
        if (profile) {
          profile.must_change_password = false;
          localStorage.setItem('agentProfile', JSON.stringify(profile));
        }

        sucBox.classList.add('show');
        document.getElementById('pw-form').style.display = 'none';

        setTimeout(function () { window.location.href = '/sales-agent/'; }, 2200);
      } catch (err) {
        document.getElementById('alert-error-text').textContent = 'Erreur réseau. Vérifiez votre connexion.';
        errBox.classList.add('show');
        btn.disabled = false;
        btnText.textContent = 'Enregistrer le nouveau mot de passe';
      }
    });
  })();
  </script>
</body>
</html>
