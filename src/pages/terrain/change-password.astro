---
export const prerender = false;
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow" />
  <title>Changer le mot de passe — Arbre Bio Africa</title>
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="stylesheet" href="/terrain/assets/style.css">
</head>
<body>
<div class="login-page" style="grid-template-columns:1fr;">
  <div class="login-panel">
    <div class="login-logo">
      <div class="login-logo-icon">🔑</div>
      <div class="login-logo-name">Arbre Bio Africa</div>
      <div class="login-logo-sub">Plateforme Terrain</div>
    </div>
    <div class="login-title">Nouveau mot de passe requis</div>
    <div class="login-desc">Pour votre sécurité, choisissez un nouveau mot de passe avant de continuer.</div>

    <div id="cp-error" class="alert alert-error" style="display:none">
      <span>⚠</span><span id="cp-error-msg"></span>
    </div>

    <form id="cp-form" novalidate>
      <div class="form-group">
        <label class="form-label" for="current">Mot de passe actuel (temporaire) <span class="required">*</span></label>
        <input class="form-control" type="password" id="current" required autocomplete="current-password">
      </div>
      <div class="form-group">
        <label class="form-label" for="new1">Nouveau mot de passe <span class="required">*</span></label>
        <input class="form-control" type="password" id="new1" required minlength="8" autocomplete="new-password" placeholder="Au moins 8 caractères">
      </div>
      <div class="form-group">
        <label class="form-label" for="new2">Confirmer le nouveau mot de passe <span class="required">*</span></label>
        <input class="form-control" type="password" id="new2" required minlength="8" autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:11px;" id="cp-btn">
        Mettre à jour le mot de passe
      </button>
    </form>
  </div>
</div>

<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  window.__TERRAIN_SUPABASE_URL__ = SUPABASE_URL;
  window.__TERRAIN_SUPABASE_KEY__ = SUPABASE_ANON_KEY;
</script>
<script>
  import { getTerrainToken, getTerrainProfile, setTerrainSession, terrainFetch } from '../../lib/terrainClient';

  const token = getTerrainToken();
  const profile = getTerrainProfile();
  if (!token || !profile) window.location.href = '/terrain/login/';

  const form = document.getElementById('cp-form') as HTMLFormElement;
  const errorDiv = document.getElementById('cp-error')!;
  const errorMsg = document.getElementById('cp-error-msg')!;
  const btn = document.getElementById('cp-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.style.display = 'none';
    const current_password = (document.getElementById('current') as HTMLInputElement).value;
    const new1 = (document.getElementById('new1') as HTMLInputElement).value;
    const new2 = (document.getElementById('new2') as HTMLInputElement).value;

    if (new1.length < 8) {
      errorMsg.textContent = 'Le nouveau mot de passe doit contenir au moins 8 caractères.';
      errorDiv.style.display = 'flex';
      return;
    }
    if (new1 !== new2) {
      errorMsg.textContent = 'Les mots de passe ne correspondent pas.';
      errorDiv.style.display = 'flex';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Mise à jour…';

    try {
      const res = await terrainFetch('/api/terrain/change-password/', {
        method: 'POST',
        body: JSON.stringify({ current_password, new_password: new1 }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Échec de la mise à jour');

      // Re-authenticate with the new password to obtain a fresh access
      // token — changing the password can invalidate the token that was
      // used to make the change-password request itself, so reusing it
      // for the next page's session risks an immediate, confusing logout.
      const supabaseUrl = (window as any).__TERRAIN_SUPABASE_URL__;
      const supabaseKey = (window as any).__TERRAIN_SUPABASE_KEY__;
      const signInRes = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', apikey: supabaseKey },
        body: JSON.stringify({ email: profile!.email, password: new1 }),
      });
      const signInData = await signInRes.json();

      if (signInRes.ok && signInData.access_token) {
        setTerrainSession(signInData.access_token, { ...profile!, must_change_password: false });
      } else if (token && profile) {
        // Fallback: reuse the old token rather than block the user entirely.
        setTerrainSession(token, { ...profile, must_change_password: false });
      }
      window.location.href = profile!.role === 'super_admin' ? '/terrain/admin/dashboard/' : '/terrain/portal/dashboard/';
    } catch (err: any) {
      errorMsg.textContent = err.message || 'Une erreur est survenue.';
      errorDiv.style.display = 'flex';
      btn.disabled = false;
      btn.textContent = 'Mettre à jour le mot de passe';
    }
  });
</script>
</body>
</html>
