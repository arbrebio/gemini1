---
export const prerender = false;
import TerrainLayout from '../../../layouts/TerrainLayout.astro';
---
<TerrainLayout title="Gestion des tâches" role="super_admin" active="projects">
  <header class="main-header">
    <div>
      <div class="page-title" id="hdr-title">Chargement…</div>
      <div class="page-subtitle" id="hdr-subtitle"></div>
    </div>
    <div class="header-actions" id="hdr-actions"></div>
  </header>

  <div class="page-body">
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">Total</div><div class="stat-value" id="st-total">—</div></div>
      <div class="stat-card"><div class="stat-label">À faire</div><div class="stat-value" id="st-todo">—</div></div>
      <div class="stat-card"><div class="stat-label">En cours / Révision</div><div class="stat-value" id="st-active">—</div></div>
      <div class="stat-card"><div class="stat-label">Terminées</div><div class="stat-value" id="st-done">—</div></div>
    </div>

    <div class="card" style="margin-top:16px;padding:16px" id="project-info"></div>

    <div style="margin-top:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px" id="kanban-board">
      <div class="card kanban-col" data-col="todo"><div class="card-header"><span class="card-title">À faire</span></div><div class="kanban-cards" id="col-todo"></div></div>
      <div class="card kanban-col" data-col="in_progress"><div class="card-header"><span class="card-title">En cours</span></div><div class="kanban-cards" id="col-in_progress"></div></div>
      <div class="card kanban-col" data-col="review"><div class="card-header"><span class="card-title">En révision</span></div><div class="kanban-cards" id="col-review"></div></div>
      <div class="card kanban-col" data-col="done"><div class="card-header"><span class="card-title">Terminé</span></div><div class="kanban-cards" id="col-done"></div></div>
    </div>
  </div>

  <!-- Task modal (add/edit) -->
  <div class="modal-backdrop" id="modal-task">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="task-modal-title">Nouvelle tâche</div>
        <button class="modal-close" id="btn-close-task">&times;</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="t-id">
        <div class="form-group"><label class="form-label">Titre <span class="required">*</span></label><input class="form-control" id="t-title" required></div>
        <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" id="t-description" rows="3"></textarea></div>
        <div class="form-grid">
          <div class="form-group"><label class="form-label">Priorité</label>
            <select class="form-control" id="t-priority"><option value="medium">Moyenne</option><option value="high">Haute</option><option value="low">Basse</option></select>
          </div>
          <div class="form-group"><label class="form-label">Catégorie</label>
            <select class="form-control" id="t-category">
              <option value="">—</option><option>Serre</option><option>Irrigation</option><option>Substrat</option><option>Cultures</option><option>Équipements</option><option>Administratif</option><option>Autre</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Échéance</label><input class="form-control" type="date" id="t-due"></div>
          <div class="form-group"><label class="form-label">Statut</label>
            <select class="form-control" id="t-status"><option value="todo">À faire</option><option value="in_progress">En cours</option><option value="review">En révision</option><option value="done">Terminé</option></select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Assignés</label>
          <div class="check-group" id="t-assignees-group"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" id="btn-cancel-task">Annuler</button>
        <button class="btn btn-primary" id="btn-save-task">Enregistrer</button>
      </div>
    </div>
  </div>

  <!-- Task detail panel -->
  <div class="modal-backdrop" id="modal-task-detail">
    <div class="modal" style="max-width:560px">
      <div class="modal-header">
        <div class="modal-title" id="td-title">Détail de la tâche</div>
        <button class="modal-close" id="btn-close-detail">&times;</button>
      </div>
      <div class="modal-body" id="td-body"></div>
      <div class="modal-footer" id="td-footer"></div>
    </div>
  </div>
</TerrainLayout>

<script>
  import { requireTerrainAuth, terrainFetch, formatDate, formatDateTime, esc, taskStatusLabels, taskPriorityLabels } from '../../../lib/terrainClient';

  const me = requireTerrainAuth();
  const params = new URLSearchParams(window.location.search);
  const projectId = params.get('projectId');
  const isAdmin = me?.role === 'super_admin';

  let project: any = null;
  let tasks: any[] = [];
  let teamUsers: any[] = []; // only fetchable by admin; engineers/technicians reuse the assignees already on tasks

  if (me && projectId) init();
  else if (me) document.getElementById('project-info')!.innerHTML = `<div class="empty-state"><div class="empty-title">Projet non spécifié</div></div>`;

  async function init() {
    const [projRes] = await Promise.all([terrainFetch(`/api/terrain/projects/?id=${projectId}`)]);
    const projData = await projRes.json();
    if (!projRes.ok) { document.getElementById('project-info')!.innerHTML = `<div class="empty-state"><div class="empty-title">Projet introuvable</div></div>`; return; }
    project = projData.project;

    if (isAdmin) {
      const usersRes = await terrainFetch('/api/terrain/users/');
      teamUsers = (await usersRes.json()).users || [];
    }

    document.getElementById('hdr-title')!.textContent = project.client_name;
    document.getElementById('hdr-subtitle')!.textContent = 'Gestion des tâches du projet';
    if (isAdmin) {
      document.getElementById('hdr-actions')!.innerHTML = `<button class="btn btn-primary" id="btn-new-task">+ Nouvelle tâche</button>`;
      document.getElementById('btn-new-task')!.addEventListener('click', () => openTaskModal());
    }
    document.getElementById('project-info')!.innerHTML = `
      <div style="display:flex;flex-wrap:wrap;gap:24px">
        <div><div class="detail-label">Client</div><div class="fw-600">${esc(project.client_name)}</div></div>
        <div><div class="detail-label">Téléphone</div><div>${esc(project.client_phone) || '—'}</div></div>
        <div><div class="detail-label">Zone</div><div>${esc(project.zone) || '—'}</div></div>
        <div><div class="detail-label">Agent</div><div>${esc(project.terrain_profiles?.full_name) || '—'}</div></div>
        <div><a href="/terrain/admin/project-view/?projectId=${project.id}" class="btn btn-sm btn-secondary">Voir les visites</a></div>
      </div>
    `;

    await loadTasks();
  }

  async function loadTasks() {
    const res = await terrainFetch(`/api/terrain/tasks/?project_id=${projectId}`);
    const data = await res.json();
    tasks = data.tasks || [];
    renderStats();
    renderBoard();
  }

  function renderStats() {
    const counts = { todo: 0, in_progress: 0, review: 0, done: 0 };
    tasks.forEach(t => counts[t.status as keyof typeof counts]++);
    document.getElementById('st-total')!.textContent = String(tasks.length);
    document.getElementById('st-todo')!.textContent = String(counts.todo);
    document.getElementById('st-active')!.textContent = String(counts.in_progress + counts.review);
    document.getElementById('st-done')!.textContent = String(counts.done);
  }

  function assigneeInitials(id: string): string {
    const u = teamUsers.find(u => u.id === id);
    const name = u?.full_name || '?';
    return name.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);
  }

  function renderBoard() {
    (['todo', 'in_progress', 'review', 'done'] as const).forEach(status => {
      const col = document.getElementById(`col-${status}`)!;
      const colTasks = tasks.filter(t => t.status === status);
      col.innerHTML = colTasks.map(t => `
        <div class="card" draggable="${isAdmin || isMine(t)}" data-task-id="${t.id}" style="padding:12px;margin-bottom:10px;cursor:pointer">
          <div class="fw-600" style="font-size:0.9rem">${esc(t.title)}</div>
          ${t.description ? `<div class="text-xs text-muted" style="margin:4px 0">${esc(t.description).slice(0, 80)}</div>` : ''}
          <div style="display:flex;gap:6px;align-items:center;margin-top:8px;flex-wrap:wrap">
            <span class="badge ${priorityColor(t.priority)}">${taskPriorityLabels[t.priority] || t.priority}</span>
            ${t.category ? `<span class="badge badge-gray">${esc(t.category)}</span>` : ''}
            ${t.due_date ? `<span class="badge badge-gray">📅 ${formatDate(t.due_date)}</span>` : ''}
          </div>
          ${(t.assignees || []).length ? `<div style="display:flex;gap:4px;margin-top:8px">${(t.assignees || []).slice(0, 4).map((a: string) => `<div class="user-avatar" style="width:24px;height:24px;font-size:0.65rem">${esc(assigneeInitials(a))}</div>`).join('')}</div>` : ''}
        </div>
      `).join('');
    });

    document.querySelectorAll('[data-task-id]').forEach(card => {
      card.addEventListener('click', () => openDetail((card as HTMLElement).dataset.taskId!));
      if (isAdmin) {
        card.addEventListener('dragstart', (e) => { (e as DragEvent).dataTransfer?.setData('text/plain', (card as HTMLElement).dataset.taskId!); });
      }
    });
    if (isAdmin) {
      document.querySelectorAll('.kanban-col').forEach(colEl => {
        colEl.addEventListener('dragover', (e) => e.preventDefault());
        colEl.addEventListener('drop', async (e) => {
          e.preventDefault();
          const taskId = (e as DragEvent).dataTransfer?.getData('text/plain');
          const newStatus = (colEl as HTMLElement).dataset.col!;
          if (taskId) await updateTask(taskId, { status: newStatus });
        });
      });
    }
  }

  function isMine(t: any): boolean {
    return me ? (t.assignees || []).includes(me.id) : false;
  }
  function priorityColor(p: string): string {
    return p === 'high' ? 'badge-red' : p === 'low' ? 'badge-gray' : 'badge-amber';
  }

  // ── Add / Edit task modal (admin only) ──────────────────────────────
  function openTaskModal(task?: any) {
    (document.getElementById('task-modal-title'))!.textContent = task ? 'Modifier la tâche' : 'Nouvelle tâche';
    (document.getElementById('t-id') as HTMLInputElement).value = task?.id || '';
    (document.getElementById('t-title') as HTMLInputElement).value = task?.title || '';
    (document.getElementById('t-description') as HTMLTextAreaElement).value = task?.description || '';
    (document.getElementById('t-priority') as HTMLSelectElement).value = task?.priority || 'medium';
    (document.getElementById('t-category') as HTMLSelectElement).value = task?.category || '';
    (document.getElementById('t-due') as HTMLInputElement).value = task?.due_date || '';
    (document.getElementById('t-status') as HTMLSelectElement).value = task?.status || 'todo';

    const group = document.getElementById('t-assignees-group')!;
    group.innerHTML = teamUsers.filter(u => u.role !== 'super_admin').map(u => `
      <label class="check-item"><input type="checkbox" value="${u.id}" class="assignee-check" ${(task?.assignees || []).includes(u.id) ? 'checked' : ''}> ${esc(u.full_name)}</label>
    `).join('');

    document.getElementById('modal-task')!.classList.add('open');
  }
  document.getElementById('btn-close-task')?.addEventListener('click', () => document.getElementById('modal-task')!.classList.remove('open'));
  document.getElementById('btn-cancel-task')?.addEventListener('click', () => document.getElementById('modal-task')!.classList.remove('open'));

  document.getElementById('btn-save-task')?.addEventListener('click', async () => {
    const id = (document.getElementById('t-id') as HTMLInputElement).value;
    const title = (document.getElementById('t-title') as HTMLInputElement).value.trim();
    if (!title) { (window as any).UI?.toast('Le titre est requis.', 'error'); return; }

    const payload: Record<string, any> = {
      title,
      description: (document.getElementById('t-description') as HTMLTextAreaElement).value.trim() || null,
      priority: (document.getElementById('t-priority') as HTMLSelectElement).value,
      category: (document.getElementById('t-category') as HTMLSelectElement).value || null,
      due_date: (document.getElementById('t-due') as HTMLInputElement).value || null,
      status: (document.getElementById('t-status') as HTMLSelectElement).value,
      assignees: Array.from(document.querySelectorAll<HTMLInputElement>('.assignee-check')).filter(c => c.checked).map(c => c.value),
    };

    if (id) {
      await updateTask(id, payload);
    } else {
      const res = await terrainFetch('/api/terrain/tasks/', { method: 'POST', body: JSON.stringify({ ...payload, project_id: projectId }) });
      if (!res.ok) { (window as any).UI?.toast('Échec de la création.', 'error'); return; }
      await loadTasks();
      (window as any).UI?.toast('Tâche créée.', 'success');
    }
    document.getElementById('modal-task')!.classList.remove('open');
  });

  async function updateTask(id: string, payload: Record<string, any>) {
    const res = await terrainFetch('/api/terrain/tasks/', { method: 'PUT', body: JSON.stringify({ id, ...payload }) });
    if (!res.ok) { (window as any).UI?.toast('Échec de la mise à jour.', 'error'); return; }
    await loadTasks();
  }

  // ── Task detail panel ────────────────────────────────────────────────
  async function openDetail(id: string) {
    const res = await terrainFetch(`/api/terrain/tasks/?id=${id}`);
    const data = await res.json();
    if (!res.ok) { (window as any).UI?.toast('Impossible de charger la tâche.', 'error'); return; }
    const t = data.task;

    (document.getElementById('td-title'))!.textContent = t.title;
    document.getElementById('td-body')!.innerHTML = `
      ${t.description ? `<p class="text-sm" style="margin-bottom:12px">${esc(t.description)}</p>` : ''}
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
        <span class="badge ${priorityColor(t.priority)}">${taskPriorityLabels[t.priority] || t.priority}</span>
        ${t.category ? `<span class="badge badge-gray">${esc(t.category)}</span>` : ''}
        ${t.due_date ? `<span class="badge badge-gray">📅 ${formatDate(t.due_date)}</span>` : ''}
        <span class="badge badge-blue">${taskStatusLabels[t.status] || t.status}</span>
      </div>

      <div class="profile-section-title">Photos de preuve (${(t.photos || []).length})</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px;margin-bottom:8px" id="td-photos">
        ${(t.photos || []).map((p: any) => `<a href="${esc(p.photo_url)}" target="_blank"><img src="${esc(p.photo_url)}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px"></a>`).join('')}
      </div>
      <input type="file" id="td-photo-input" accept="image/*" style="display:none">
      <button type="button" class="btn btn-sm btn-secondary" id="btn-add-td-photo">📷 Ajouter une photo</button>

      <div class="profile-section-title" style="margin-top:16px">Commentaires</div>
      <div id="td-comments" style="max-height:180px;overflow-y:auto;margin-bottom:8px">
        ${(t.comments || []).map((c: any) => `
          <div style="padding:8px 0;border-bottom:1px solid #f1f1f1">
            <div class="text-xs fw-600">${esc(c.terrain_profiles?.full_name || '—')} <span class="text-muted" style="font-weight:400">· ${formatDateTime(c.created_at)}</span></div>
            <div class="text-sm">${esc(c.text)}</div>
          </div>
        `).join('') || '<p class="text-xs text-muted">Aucun commentaire</p>'}
      </div>
      <div style="display:flex;gap:8px">
        <input class="form-control" id="td-comment-input" placeholder="Ajouter un commentaire…">
        <button type="button" class="btn btn-sm btn-primary" id="btn-add-comment">Envoyer</button>
      </div>
    `;

    const canEdit = isAdmin || isMine(t);
    document.getElementById('td-footer')!.innerHTML = `
      ${t.status !== 'done' && canEdit ? '<button class="btn btn-primary" id="btn-complete-task">✓ Marquer terminée</button>' : ''}
      ${isAdmin ? '<button class="btn btn-secondary" id="btn-edit-task">Modifier</button><button class="btn btn-danger" id="btn-delete-task">Supprimer</button>' : ''}
    `;

    document.getElementById('btn-add-td-photo')?.addEventListener('click', () => (document.getElementById('td-photo-input') as HTMLInputElement).click());
    document.getElementById('td-photo-input')?.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const fd = new FormData(); fd.append('file', file); fd.append('folder', 'tasks');
      const upRes = await terrainFetch('/api/terrain/upload/', { method: 'POST', body: fd });
      const upData = await upRes.json();
      if (!upRes.ok) { (window as any).UI?.toast(upData.error || 'Échec.', 'error'); return; }
      await terrainFetch('/api/terrain/task-photos/', { method: 'POST', body: JSON.stringify({ task_id: id, photo_url: upData.url }) });
      await loadTasks();
      openDetail(id);
    });

    document.getElementById('btn-add-comment')?.addEventListener('click', async () => {
      const input = document.getElementById('td-comment-input') as HTMLInputElement;
      const text = input.value.trim();
      if (!text) return;
      await terrainFetch('/api/terrain/task-comments/', { method: 'POST', body: JSON.stringify({ task_id: id, text }) });
      openDetail(id);
    });

    document.getElementById('btn-complete-task')?.addEventListener('click', async () => {
      await terrainFetch('/api/terrain/tasks/', { method: 'PUT', body: JSON.stringify({ id, action: 'complete' }) });
      await loadTasks();
      document.getElementById('modal-task-detail')!.classList.remove('open');
      (window as any).UI?.toast('Tâche terminée.', 'success');
    });
    document.getElementById('btn-edit-task')?.addEventListener('click', () => {
      document.getElementById('modal-task-detail')!.classList.remove('open');
      openTaskModal(t);
    });
    document.getElementById('btn-delete-task')?.addEventListener('click', async () => {
      if (!confirm('Supprimer définitivement cette tâche ?')) return;
      await terrainFetch('/api/terrain/tasks/', { method: 'DELETE', body: JSON.stringify({ id }) });
      document.getElementById('modal-task-detail')!.classList.remove('open');
      await loadTasks();
      (window as any).UI?.toast('Tâche supprimée.', 'success');
    });

    document.getElementById('modal-task-detail')!.classList.add('open');
  }
  document.getElementById('btn-close-detail')?.addEventListener('click', () => document.getElementById('modal-task-detail')!.classList.remove('open'));
</script>
