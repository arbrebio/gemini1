---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const LANGS = ['en', 'fr', 'es', 'af'] as const;
type Lang = typeof LANGS[number];

const queryLang = Astro.url.searchParams.get('lang') as Lang | null;
const headerLang = (Astro.request.headers.get('accept-language') || '').slice(0, 2).toLowerCase() as Lang;
const lang: Lang = (queryLang && LANGS.includes(queryLang))
  ? queryLang
  : (LANGS.includes(headerLang) ? headerLang : 'en');

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  { auth: { autoRefreshToken: false, persistSession: false } },
);

const { data: post, error } = await supabase
  .from('admin_blog_posts')
  .select('id, slug, title, description, content, author, category, featured, image_url, video_url, links, tags, published_at, created_at')
  .eq('status', 'published')
  .eq('slug', slug)
  .single();

if (error || !post) return Astro.redirect('/blog');

function resolve(obj: Record<string, string> | null | undefined): string {
  if (!obj) return '';
  return obj[lang] || obj['en'] || Object.values(obj).find(v => v) || '';
}

const title       = resolve(post.title);
const description = resolve(post.description);
const content     = resolve(post.content);

const CATEGORY_LABELS: Record<string, string> = {
  'irrigation':     'Irrigation',
  'greenhouse':     'Greenhouse',
  'substrates':     'Substrates',
  'farming-tips':   'Farming Tips',
  'digital-farming':'Digital Farming',
};

const LANG_LABELS: Record<Lang, string> = {
  en: 'EN', fr: 'FR', es: 'ES', af: 'AF',
};

const BACK_LABEL: Record<Lang, string> = {
  en: 'Back to Blog',
  fr: 'Retour au Blog',
  es: 'Volver al Blog',
  af: 'Terug na Blog',
};

const SHARE_LABEL: Record<Lang, string> = {
  en: 'Share This Article',
  fr: 'Partager cet article',
  es: 'Compartir este artículo',
  af: 'Deel hierdie artikel',
};

const VIDEO_LABEL: Record<Lang, string> = {
  en: 'Watch Video',
  fr: 'Regarder la vidéo',
  es: 'Ver el vídeo',
  af: 'Kyk video',
};

const LINKS_LABEL: Record<Lang, string> = {
  en: 'Useful Links',
  fr: 'Liens utiles',
  es: 'Enlaces útiles',
  af: 'Nuttige skakels',
};

const CTA_TITLE: Record<Lang, string> = {
  en: 'Need Expert Advice?',
  fr: 'Besoin de conseils d\'experts ?',
  es: '¿Necesita asesoramiento experto?',
  af: 'Deskundige advies nodig?',
};

const CTA_BODY: Record<Lang, string> = {
  en: 'Our team is here to help you implement these solutions on your farm.',
  fr: 'Notre équipe est là pour vous aider à mettre en œuvre ces solutions sur votre exploitation.',
  es: 'Nuestro equipo está aquí para ayudarle a implementar estas soluciones en su granja.',
  af: 'Ons span is hier om u te help om hierdie oplossings op u plaas te implementeer.',
};

const CONTACT_LABEL: Record<Lang, string> = {
  en: 'Contact Us', fr: 'Nous contacter', es: 'Contáctenos', af: 'Kontak ons',
};

const FEATURED_LABEL: Record<Lang, string> = {
  en: 'Featured', fr: 'En vedette', es: 'Destacado', af: 'Uitgestald',
};

const BY_LABEL: Record<Lang, string> = {
  en: 'By', fr: 'Par', es: 'Por', af: 'Deur',
};

const localeMap: Record<Lang, string> = {
  en: 'en-US', fr: 'fr-FR', es: 'es-ES', af: 'af-ZA',
};
const formatDate = (d: string) =>
  new Intl.DateTimeFormat(localeMap[lang], { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(d));

const pubDate = post.published_at || post.created_at;

function buildVideoEmbed(url: string): string | null {
  if (!url) return null;
  const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}?rel=0&modestbranding=1`;
  const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  return null;
}

const videoEmbed  = post.video_url ? buildVideoEmbed(post.video_url) : null;
const videoDirect = post.video_url && !videoEmbed ? post.video_url : null;
const hasVideo    = Boolean(videoEmbed || videoDirect);

const links: Array<{ label: string; url: string }> = Array.isArray(post.links) ? post.links : [];

const langSwitcher = LANGS.map(l => ({
  code: l,
  label: LANG_LABELS[l],
  url: `/blog/p/${slug}?lang=${l}`,
  hasContent: Boolean((post.title as Record<string, string>)?.[l]),
}));

// Canonical blog-index path for "back" link
const backHref = lang === 'en' ? '/blog' : `/${lang}/blog`;
---

<Layout title={title || 'Blog'} description={description} image={post.image_url ?? undefined}>

  <!-- ── Hero ────────────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[50vh] flex items-end">
    <!-- Background: image or gradient fallback -->
    <div class="absolute inset-0 z-0">
      {post.image_url ? (
        <img
          src={post.image_url}
          alt={title}
          class="w-full h-full object-cover"
          loading="eager"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[#194642] via-[#1f5550] to-[#2a6659]"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/50 to-black/20"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 pb-10 pt-24">
      <!-- Language switcher -->
      {langSwitcher.some(l => l.hasContent) && (
        <div class="flex gap-2 mb-5 flex-wrap">
          {langSwitcher.filter(l => l.hasContent).map(l => (
            <a
              href={l.url}
              class:list={[
                "px-3 py-1 text-xs font-semibold rounded-full border transition-colors",
                l.code === lang
                  ? "border-white bg-white text-[#194642]"
                  : "border-white/50 text-white hover:border-white hover:bg-white/10",
              ]}
            >
              {l.label}
            </a>
          ))}
        </div>
      )}

      <!-- Category + date -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide">
          {CATEGORY_LABELS[post.category] ?? post.category}
        </span>
        <span class="text-white/70 text-sm">{formatDate(pubDate)}</span>
        {post.featured && (
          <span class="inline-flex items-center gap-1 text-yellow-400 text-sm font-medium">
            <i class="fas fa-star text-xs"></i>{FEATURED_LABEL[lang]}
          </span>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-5xl font-bold text-white max-w-4xl leading-tight mb-3">
        {title}
      </h1>

      <!-- Author -->
      <p class="text-white/70 text-sm">{BY_LABEL[lang]} <span class="text-white font-medium">{post.author}</span></p>
    </div>
  </section>

  <!-- ── Article body ─────────────────────────────────────────────────────────── -->
  <div class="bg-white">
    <div class="max-w-4xl mx-auto px-4 py-12">

      <!-- Back link -->
      <a
        href={backHref}
        class="inline-flex items-center text-[#194642] hover:text-primary font-medium text-sm mb-10 transition-colors"
      >
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        {BACK_LABEL[lang]}
      </a>

      <!-- Description lead -->
      {description && (
        <p class="text-xl text-gray-600 leading-relaxed mb-10 pb-10 border-b border-gray-100">
          {description}
        </p>
      )}

      <!-- Content -->
      {content ? (
        <div class="prose prose-lg max-w-none
          prose-headings:font-bold prose-headings:text-gray-900
          prose-p:text-gray-700 prose-p:leading-relaxed
          prose-a:text-[#194642] prose-a:underline
          prose-img:rounded-xl prose-img:shadow-md
          prose-ul:text-gray-700 prose-ol:text-gray-700
          prose-strong:text-gray-900"
          set:html={content}
        />
      ) : (
        <p class="text-gray-400 italic py-8 text-center">
          Content not available in this language.
        </p>
      )}

      <!-- ── Video section ─────────────────────────────────────────────────── -->
      {hasVideo && (
        <div class="mt-14">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-[#194642] flex items-center justify-center flex-shrink-0">
              <i class="fas fa-play text-white text-xs ml-0.5"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">{VIDEO_LABEL[lang]}</h2>
          </div>

          <div class="rounded-2xl overflow-hidden shadow-xl bg-gray-900">
            {videoEmbed ? (
              <div class="relative w-full" style="padding-bottom:56.25%;">
                <iframe
                  src={videoEmbed}
                  title={title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                  class="absolute inset-0 w-full h-full"
                  loading="lazy"
                ></iframe>
              </div>
            ) : (
              <video
                controls
                preload="metadata"
                class="w-full max-h-[520px] object-contain"
                style="background:#000"
              >
                <source src={videoDirect!} />
              </video>
            )}
          </div>
        </div>
      )}

      <!-- ── External links ────────────────────────────────────────────────── -->
      {links.length > 0 && (
        <div class="mt-12 p-6 bg-[#f0f7f6] rounded-2xl border border-[#194642]/10">
          <h3 class="text-base font-bold text-[#194642] mb-4 flex items-center gap-2">
            <i class="fas fa-link text-sm"></i>
            {LINKS_LABEL[lang]}
          </h3>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-[#194642] hover:underline font-medium text-sm"
                >
                  <i class="fas fa-arrow-right text-xs opacity-60"></i>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- ── Share buttons ─────────────────────────────────────────────────── -->
      <div class="mt-12 pt-8 border-t border-gray-100">
        <h3 class="text-base font-bold text-gray-700 mb-4">{SHARE_LABEL[lang]}</h3>
        <div class="flex flex-wrap gap-3">
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
            target="_blank" rel="noopener noreferrer"
            class="bg-[#1877F2] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity inline-flex items-center text-sm font-medium gap-2"
          >
            <i class="fa-brands fa-facebook-f"></i>Facebook
          </a>
          <a
            href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
            target="_blank" rel="noopener noreferrer"
            class="bg-[#1DA1F2] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity inline-flex items-center text-sm font-medium gap-2"
          >
            <i class="fa-brands fa-twitter"></i>Twitter
          </a>
          <a
            href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(description)}`}
            target="_blank" rel="noopener noreferrer"
            class="bg-[#0A66C2] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity inline-flex items-center text-sm font-medium gap-2"
          >
            <i class="fa-brands fa-linkedin-in"></i>LinkedIn
          </a>
          <a
            href={`https://wa.me/?text=${encodeURIComponent(`${title} – ${Astro.url.href}`)}`}
            target="_blank" rel="noopener noreferrer"
            class="bg-[#25D366] text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity inline-flex items-center text-sm font-medium gap-2"
          >
            <i class="fa-brands fa-whatsapp"></i>WhatsApp
          </a>
          <a
            href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`Check out this article: ${Astro.url.href}`)}`}
            class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity inline-flex items-center text-sm font-medium gap-2"
          >
            <i class="fa-solid fa-envelope"></i>Email
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- ── CTA ──────────────────────────────────────────────────────────────────── -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">{CTA_TITLE[lang]}</h2>
      <p class="text-xl text-white/80 mb-8 max-w-xl mx-auto">{CTA_BODY[lang]}</p>
      <a
        href="/contact"
        class="bg-white text-primary px-8 py-3 rounded-full text-base font-semibold hover:bg-opacity-90 inline-flex items-center gap-2"
      >
        {CONTACT_LABEL[lang]}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>
