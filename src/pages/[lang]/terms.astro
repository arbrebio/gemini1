---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, getStaticPaths } from '../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<Layout
  title={t('terms.title')}
  description={t('terms.description')}
>
  <div class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8 md:p-12">
        <h1 class="text-3xl font-bold mb-8">{t('terms.heading')}</h1>
        
        <!-- Introduction -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.intro.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.intro.text')}
          </p>
        </section>

        <!-- Scope of Agreement -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.scope.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.scope.text1')}
          </p>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.scope.text2')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('terms.sections.scope.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <!-- Products & Services Terms -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.products.title')}</h2>
          <h3 class="text-lg font-medium mb-3">{t('terms.sections.products.specs.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.products.specs.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('terms.sections.products.install.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.products.install.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('terms.sections.products.maintenance.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.products.maintenance.text')}
          </p>
        </section>

        <!-- Ordering & Payment Terms -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.ordering.title')}</h2>
          <h3 class="text-lg font-medium mb-3">{t('terms.sections.ordering.pricing.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.ordering.pricing.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('terms.sections.ordering.payment.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.ordering.payment.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('terms.sections.ordering.payment.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>

          <h3 class="text-lg font-medium mb-3">{t('terms.sections.ordering.late.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.ordering.late.text')}
          </p>
        </section>

        <!-- Delivery & Installation -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.delivery.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.delivery.text1')}
          </p>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.delivery.text2')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('terms.sections.delivery.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <!-- Warranties & Liabilities -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.warranties.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.warranties.text1')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('terms.sections.warranties.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.warranties.text2')}
          </p>
        </section>

        <!-- Returns & Refunds -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.returns.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.returns.text')}
          </p>
        </section>

        <!-- Force Majeure -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.force.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.force.text')}
          </p>
        </section>

        <!-- Dispute Resolution -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.disputes.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.disputes.text')}
          </p>
        </section>

        <!-- Privacy & Data Protection -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.privacy.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.privacy.text')}
          </p>
        </section>

        <!-- Modifications to Terms -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.modifications.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.modifications.text')}
          </p>
        </section>

        <!-- Contact Information -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('terms.sections.contact.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('terms.sections.contact.text')}
          </p>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-medium mb-2">{t('terms.sections.contact.abidjan')}</h3>
            <p class="text-gray-700">Cocody Riviera 3, Jacque Prevert 2</p>
            <p class="text-gray-700">Phone: +225 21 21 80 69 50</p>
            <p class="text-gray-700">Email: farms@arbrebio.com</p>
            
            <h3 class="font-medium mb-2 mt-4">{t('terms.sections.contact.capeTown')}</h3>
            <p class="text-gray-700">Van Biljon Business Park, Winelands Cl</p>
            <p class="text-gray-700">Stikland Industrial, Cape Town, 7530</p>
            <p class="text-gray-700">Phone: +27 79 533 0267</p>
            <p class="text-gray-700">Email: CPT@arbrebio.com</p>
          </div>
        </section>

        <div class="text-gray-600 text-sm">
          <p>{t('terms.lastUpdated')} {new Date().toLocaleDateString(lang === 'en' ? 'en-US' : lang === 'fr' ? 'fr-FR' : lang === 'es' ? 'es-ES' : 'af-ZA', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        </div>
      </div>
    </div>
  </div>
</Layout>