---
import Layout from '../../layouts/Layout.astro';
import StructuredData from '../../components/StructuredData.astro';
import { useTranslations, getStaticPaths } from '../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);

// Main solution categories
const solutionCategories = [
  {
    id: "greenhouses",
    title: t('solutions.main.greenhouses.title'),
    subtitle: t('solutions.main.greenhouses.subtitle'),
    icon: "🌿",
    image: "https://imgur.com/IZGz47e.jpg",
    description: t('solutions.main.greenhouses.description'),
    benefits: t('solutions.main.greenhouses.benefits'),
    solutions: [
      {
        name: t('solutions.main.greenhouses.items.highTech.name'),
        description: t('solutions.main.greenhouses.items.highTech.description'),
        image: "https://imgur.com/w7OS5f6.jpg",
        link: "/greenhouses/high-tech"
      },
      {
        name: t('solutions.main.greenhouses.items.nets.name'),
        description: t('solutions.main.greenhouses.items.nets.description'),
        image: "https://imgur.com/lAI3XeF.jpg",
        link: "/greenhouses/accessories"
      },
      {
        name: t('solutions.main.greenhouses.items.climate.name'),
        description: t('solutions.main.greenhouses.items.climate.description'),
        image: "https://imgur.com/xn6Qik0.jpg",
        link: "/greenhouses/high-tech"
      }
    ]
  },
  {
    id: "irrigation",
    title: t('solutions.main.irrigation.title'),
    subtitle: t('solutions.main.irrigation.subtitle'),
    icon: "💧",
    image: "https://imgur.com/oe3gOtV.jpg",
    description: t('solutions.main.irrigation.description'),
    benefits: t('solutions.main.irrigation.benefits'),
    solutions: [
      {
        name: t('solutions.main.irrigation.items.drip.name'),
        description: t('solutions.main.irrigation.items.drip.description'),
        image: "https://imgur.com/33OuKiU.jpg",
        link: "/irrigation/drip-systems"
      },
      {
        name: t('solutions.main.irrigation.items.filtration.name'),
        description: t('solutions.main.irrigation.items.filtration.description'),
        image: "https://imgur.com/AVECFTr.jpg",
        link: "/irrigation/drip-systems"
      },
      {
        name: t('solutions.main.irrigation.items.controllers.name'),
        description: t('solutions.main.irrigation.items.controllers.description'),
        image: "https://imgur.com/OJ0Dbgb.jpg",
        link: "/irrigation/controllers"
      }
    ]
  },
  {
    id: "substrates",
    title: t('solutions.main.substrates.title'),
    subtitle: t('solutions.main.substrates.subtitle'),
    icon: "🌱",
    image: "https://imgur.com/YnDCEmp.jpg",
    description: t('solutions.main.substrates.description'),
    benefits: t('solutions.main.substrates.benefits'),
    solutions: [
      {
        name: t('solutions.main.substrates.items.coco.name'),
        description: t('solutions.main.substrates.items.coco.description'),
        image: "https://imgur.com/WgMc6pm.jpg",
        link: "/substrates/growing-solutions"
      },
      {
        name: t('solutions.main.substrates.items.soil.name'),
        description: t('solutions.main.substrates.items.soil.description'),
        image: "https://imgur.com/Yc1gQqw.jpg",
        link: "/substrates/growing-solutions"
      }
    ]
  },
  {
    id: "services",
    title: t('solutions.main.services.title'),
    subtitle: t('solutions.main.services.subtitle'),
    icon: "🚜",
    image: "https://imgur.com/DJUivfa.jpg",
    description: t('solutions.main.services.description'),
    benefits: t('solutions.main.services.benefits'),
    solutions: [
      {
        name: t('solutions.main.services.items.turnkey.name'),
        description: t('solutions.main.services.items.turnkey.description'),
        image: "https://imgur.com/CPZXVHq.jpg",
        link: "/projects"
      },
      {
        name: t('solutions.main.services.items.installation.name'),
        description: t('solutions.main.services.items.installation.description'),
        image: "https://imgur.com/EhAcgNJ.jpg",
        link: "/contact"
      }
    ]
  }
];

// Success metrics
const impactMetrics = [
  { value: t('solutions.metrics.yield.value'), label: t('solutions.metrics.yield.label'), description: t('solutions.metrics.yield.description') },
  { value: t('solutions.metrics.water.value'), label: t('solutions.metrics.water.label'), description: t('solutions.metrics.water.description') },
  { value: t('solutions.metrics.pests.value'), label: t('solutions.metrics.pests.label'), description: t('solutions.metrics.pests.description') },
  { value: t('solutions.metrics.projects.value'), label: t('solutions.metrics.projects.label'), description: t('solutions.metrics.projects.description') }
];

// Testimonials from farmers
const testimonials = [
  {
    quote: t('solutions.testimonials.items.marie.quote'),
    author: t('solutions.testimonials.items.marie.author'),
    role: t('solutions.testimonials.items.marie.role'),
    location: t('solutions.testimonials.items.marie.location'),
    image: "https://imgur.com/YbVGmcu.jpg"
  },
  {
    quote: t('solutions.testimonials.items.emmanuel.quote'),
    author: t('solutions.testimonials.items.emmanuel.author'),
    role: t('solutions.testimonials.items.emmanuel.role'),
    location: t('solutions.testimonials.items.emmanuel.location'),
    image: "https://imgur.com/qreTzRX.jpg"
  }
];
---

<Layout
  title={t('solutions.title')}
  description={t('solutions.description')}
>
  <StructuredData
    type="WebPage"
    data={{
      title: t('solutions.title'),
      description: t('solutions.description'),
      url: "https://arbrebio.com/solutions"
    }}
  />
  <!-- Hero Section with Video Background -->
  <section class="relative h-[80vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?ixlib=rb-4.0.3"
        alt={t("solutions.heroImage")} 
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10 text-center md:text-left">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 animate-fade-in">
          {t('solutions.hero.title')}
          <span class="block text-2xl md:text-3xl mt-4 text-primary-100">{t('solutions.hero.subtitle')}</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 mb-8 animate-slide-up">
          {t('solutions.hero.description')}
        </p>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a 
            href="#solutions"
            class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-all duration-300 transform hover:scale-105 animate-slide-up"
            style="animation-delay: 200ms;"
          >
            {t('solutions.hero.explore')}
          </a>
          <a 
            href="/contact"
            class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-all duration-300 transform hover:scale-105 animate-slide-up"
            style="animation-delay: 400ms;"
          >
            {t('solutions.hero.contact')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Metrics Section -->
  <section class="py-12 bg-primary">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {impactMetrics.map((metric) => (
          <div class="text-center text-white">
            <div class="text-4xl font-bold mb-2">{metric.value}</div>
            <div class="text-lg font-medium mb-1">{metric.label}</div>
            <div class="text-sm opacity-80">{metric.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Main Solutions Section -->
  <section id="solutions" class="py-20">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">{t('solutions.main.title')}</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          {t('solutions.main.description')}
        </p>
      </div>
      
      {solutionCategories.map((category, index) => (
        <div id={category.id} class={`mb-24 ${index !== 0 ? 'pt-16' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <div class="flex items-center mb-4">
                <div class="text-4xl mr-4">{category.icon}</div>
                <h3 class="text-3xl font-bold">{category.title}</h3>
              </div>
              <p class="text-xl text-primary font-medium mb-4">{category.subtitle}</p>
              <p class="text-gray-600 mb-8">{category.description}</p>
              
              <div class="bg-gray-50 p-6 rounded-lg mb-8">
                <h4 class="font-bold text-lg mb-4">{t('solutions.main.benefits')}</h4>
                <ul class="space-y-3">
                  {category.benefits.map((benefit) => (
                    <li class="flex items-start">
                      <svg class="w-6 h-6 text-primary mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span>{benefit}</span>
                    </li>
                  ))}
                </ul>
              </div>
              
              <a 
                href={`/${category.id}`}
                class="inline-flex items-center text-primary font-semibold hover:text-primary-600 transition-colors"
              >
                {t('solutions.main.learnMore')} {category.title.toLowerCase()}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img 
                src={category.image}
                alt={category.title}
                class="w-full h-[500px] object-cover rounded-lg shadow-lg"
                loading="lazy"
              />
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {category.solutions.map((solution) => (
              <a 
                href={solution.link}
                class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 group"
              >
                <div class="h-48 overflow-hidden">
                  <img 
                    src={solution.image}
                    alt={solution.name}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                  />
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{solution.name}</h3>
                  <p class="text-gray-600">{solution.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-16">{t('solutions.testimonials.title')}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        {testimonials.map((testimonial) => (
          <div class="bg-white p-8 rounded-lg shadow-lg relative">
            <div class="absolute -top-6 left-8">
              <div class="w-12 h-12 rounded-full overflow-hidden border-4 border-white shadow-md">
                <img 
                  src={testimonial.image}
                  alt={testimonial.author}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="pt-6">
              <p class="text-gray-600 italic mb-6">"{testimonial.quote}"</p>
              <div>
                <p class="font-bold">{testimonial.author}</p>
                <p class="text-sm text-gray-500">{testimonial.role}, {testimonial.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Success Stories Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">{t('solutions.successStories.title')}</h2>
      <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
        {t('solutions.successStories.description')}
      </p>
      <a 
        href="/success-stories" 
        class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300 inline-flex items-center"
      >
        {t('solutions.successStories.button')}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{t('solutions.cta.title')}</h2>
      <p class="text-xl text-white mb-8">{t('solutions.cta.description')}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a 
          href="/contact" 
          class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90 transition-all duration-300 transform hover:scale-105"
        >
          {t('solutions.cta.schedule')}
        </a>
        <a 
          href="https://wa.me/2250799295643" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 transition-all duration-300 transform hover:scale-105 flex items-center justify-center"
        >
          <i class="fab fa-whatsapp mr-2"></i>
          {t('solutions.cta.whatsapp')}
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out;
  }

  .animate-slide-up {
    animation: slideUp 1s ease-out;
  }

  [style*="animation-delay"] {
    opacity: 0;
    animation-fill-mode: forwards;
  }
</style>