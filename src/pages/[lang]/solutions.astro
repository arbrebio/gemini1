---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useT } from "../../lib/translations";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const categories = [
  {
    id: "greenhouses",
    title: T.protectedFarming,
    subtitle: T.protectedFarmingSub,
    icon: "챨혺혣쩔",
    image: "https://imgur.com/IZGz47e.jpg",
    description: T.protectedFarmingDesc,
    benefits: [T.pfB1, T.pfB2, T.pfB3, T.pfB4],
    solutions: [
      { name: lang === 'fr' ? 'Serres Tropicales High-Tech' : lang === 'es' ? 'Invernaderos Tropicales High-Tech' : 'Ho횄짬-Tegnologie Tropiese Kweekhuise', description: T.greenhouseServiceDesc, image: "https://imgur.com/w7OS5f6.jpg", link: `${p}/greenhouses/high-tech` },
      { name: lang === 'fr' ? "Filets et Films Anti-Insectes" : lang === 'es' ? 'Redes y Pel횄짯culas Anti-Insectos' : 'Insekwerende Nette en Films', description: lang === 'fr' ? "Filets et films agricoles de qualit횄짤 premium qui prot횄짢gent les cultures." : lang === 'es' ? "Redes y pel횄짯culas agr횄짯colas de calidad premium que protegen los cultivos." : "Premium kwaliteit landbou nette en films wat gewasse beskerm.", image: "https://imgur.com/lAI3XeF.jpg", link: `${p}/greenhouses/accessories` },
      { name: lang === 'fr' ? 'Syst횄짢mes de Contr횄쨈le Climatique' : lang === 'es' ? 'Sistemas de Control Clim횄징tico' : 'Klimaatbeheerstelsels', description: lang === 'fr' ? "Syst횄짢mes d'automatisation avanc횄짤s pour un contr횄쨈le pr횄짤cis de la temp횄짤rature, humidit횄짤 et ventilation." : lang === 'es' ? "Sistemas de automatizaci횄쨀n avanzados para control preciso de temperatura, humedad y ventilaci횄쨀n." : "Gevorderde outomatiseringstelsels vir presiese beheer van temperatuur, humiditeit en ventilasie.", image: "https://imgur.com/xn6Qik0.jpg", link: `${p}/greenhouses/high-tech` },
    ]
  },
  {
    id: "irrigation",
    title: T.waterMgmt,
    subtitle: T.waterMgmtSub,
    icon: "챨혺혪짠",
    image: "https://imgur.com/oe3gOtV.jpg",
    description: T.waterMgmtDesc,
    benefits: [T.wmB1, T.wmB2, T.wmB3, T.wmB4],
    solutions: [
      { name: T.dripTitle, description: T.irrigationServiceDesc, image: "https://imgur.com/33OuKiU.jpg", link: `${p}/irrigation/drip-systems` },
      { name: lang === 'fr' ? 'Filtration & Fertirrigation Intelligente' : lang === 'es' ? 'Filtraci횄쨀n y Fertigaci횄쨀n Inteligente' : 'Slim Filtrasie & Fertirrigation', description: lang === 'fr' ? "Syst횄짢mes int횄짤gr횄짤s de filtration d'eau et injection d'engrais." : lang === 'es' ? "Sistemas integrados de filtraci횄쨀n de agua e inyecci횄쨀n de fertilizantes." : "Ge횄짱ntegreerde stelsels vir waterfiltrering en voedingstofinjeksie.", image: "https://imgur.com/AVECFTr.jpg", link: `${p}/irrigation/drip-systems` },
      { name: T.digitalTitle, description: T.digitalDesc, image: "https://imgur.com/OJ0Dbgb.jpg", link: `${p}/irrigation/controllers` },
    ]
  },
  {
    id: "substrates",
    title: T.substrateSolutions,
    subtitle: T.substrateSolutionsSub,
    icon: "챨혺혣짹",
    image: "https://imgur.com/YnDCEmp.jpg",
    description: T.substrateSolutionsDesc,
    benefits: [T.ssB1, T.ssB2, T.ssB3, T.ssB4],
    solutions: [
      { name: lang === 'fr' ? 'Fibre de Coco & Coir' : lang === 'es' ? 'Fibra de Coco & Coir' : 'Koko-turfmos & Coir', description: lang === 'fr' ? "Solutions de culture premium pour l'hydroponique et les p횄짤pini횄짢res." : lang === 'es' ? "Soluciones de cultivo premium para hidropon횄짯a y viveros." : "Premium groei oplossings vir hidroponies en kwekery.", image: "https://imgur.com/WgMc6pm.jpg", link: `${p}/substrates/growing-solutions` },
      { name: lang === 'fr' ? 'Amendements Organiques du Sol' : lang === 'es' ? 'Enmiendas Org횄징nicas del Suelo' : 'Organiese Grondverbeteringsmiddels', description: lang === 'fr' ? "Produits naturels d'enrichissement du sol pour une meilleure sant횄짤 des cultures." : lang === 'es' ? "Productos naturales de enriquecimiento del suelo para mejor salud de cultivos." : "Natuurlike grondverryking produkte vir verbeterde gewasgesondheid.", image: "https://imgur.com/Yc1gQqw.jpg", link: `${p}/substrates/growing-solutions` },
    ]
  },
];
---

<Layout title={`${T.solutionsTitle} | Arbre Bio Africa`} description={T.solutionsSubtitle}>

  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/2Pt8VXW.jpg" alt="Solutions" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.solutionsTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.solutionsSubtitle}</p>
    </div>
  </section>

  {categories.map((category, categoryIndex) => (
    <section class="py-20" id={category.id}>
      <div class="container mx-auto px-4">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center ${categoryIndex % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
          <div class={categoryIndex % 2 !== 0 ? 'lg:order-2' : ''}>
            <div class="text-5xl mb-6">{category.icon}</div>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">{category.title}</h2>
            <p class="text-xl text-primary mb-6">{category.subtitle}</p>
            <p class="text-gray-600 mb-8 leading-relaxed">{category.description}</p>
            <ul class="space-y-4 mb-8">
              {category.benefits.map(benefit => (
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-gray-700">{benefit}</span>
                </li>
              ))}
            </ul>
            <div class="grid grid-cols-1 gap-4">
              {category.solutions.map(solution => (
                <a href={solution.link} class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg hover:bg-primary/5 transition-colors group">
                  <img src={solution.image} alt={solution.name} class="w-16 h-16 object-cover rounded"/>
                  <div>
                    <h4 class="font-bold group-hover:text-primary transition-colors">{solution.name}</h4>
                    <p class="text-sm text-gray-600">{solution.description}</p>
                  </div>
                  <svg class="w-5 h-5 text-primary ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              ))}
            </div>
          </div>
          <div class={categoryIndex % 2 !== 0 ? 'lg:order-1' : ''}>
            <img src={category.image} alt={category.title} class="w-full h-[500px] object-cover rounded-lg shadow-xl"/>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

</Layout>
