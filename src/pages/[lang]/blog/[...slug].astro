---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

// Generate paths for all blog posts in all 3 non-English languages.
// Each route tries to serve the translated post; falls back to English.
export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const langs = ['fr', 'es', 'af'] as const;

  // Build base-slug → English post map
  const enMap = new Map<string, (typeof allPosts)[number]>();
  allPosts
    .filter(p => p.slug.startsWith('en/'))
    .forEach(p => enMap.set(p.slug.replace(/^en\//, ''), p));

  // Build lang/base-slug → translated post map
  const transMap = new Map<string, (typeof allPosts)[number]>();
  allPosts
    .filter(p => !p.slug.startsWith('en/'))
    .forEach(p => transMap.set(p.slug, p));

  const paths = [];
  for (const lang of langs) {
    for (const [baseSlug, enPost] of enMap) {
      const translatedPost = transMap.get(`${lang}/${baseSlug}`);
      paths.push({
        params: { lang, slug: baseSlug },
        props: { post: translatedPost ?? enPost },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params as { lang: Language };
const { post } = Astro.props;
const { Content } = await post.render();
const T = useT(lang as any);
const p = `/${lang}`;

// Labels with inline fallbacks for the back-button and more-articles link
// Category label translations
const categoryLabels: Record<string, Record<string, string>> = {
  fr: {
    'irrigation':     'Irrigation',
    'greenhouse':     'Serre',
    'substrates':     'Substrats',
    'farming-tips':   'Conseils Agricoles',
    'digital-farming':'Agriculture Numérique',
  },
  es: {
    'irrigation':     'Riego',
    'greenhouse':     'Invernadero',
    'substrates':     'Sustratos',
    'farming-tips':   'Consejos Agrícolas',
    'digital-farming':'Agricultura Digital',
  },
  af: {
    'irrigation':     'Besproeiing',
    'greenhouse':     'Kweekhuis',
    'substrates':     'Substrate',
    'farming-tips':   'Boerdery Wenke',
    'digital-farming':'Digitale Boerdery',
  },
};
const translateCategory = (cat: string) =>
  (categoryLabels[lang]?.[cat]) ?? cat.replace('-', ' ');

const backLabel =
  lang === 'fr' ? 'Retour au Blog' :
  lang === 'es' ? 'Volver al Blog' :
  lang === 'af' ? 'Terug na Blog' : 'Back to Blog';

const moreLabel =
  lang === 'fr' ? "Plus d'articles" :
  lang === 'es' ? 'Más artículos' :
  lang === 'af' ? 'Meer artikels' : 'More articles';

const shareLabel =
  lang === 'fr' ? 'Partager cet article' :
  lang === 'es' ? 'Compartir este artículo' :
  lang === 'af' ? 'Deel hierdie artikel' : 'Share This Article';

const localeMap: Record<string, string> = { fr: 'fr-FR', es: 'es-ES', af: 'af-ZA', en: 'en-US' };
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(localeMap[lang] || 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<Layout title={post.data.title} description={post.data.description} image={post.data.image}>

  <!-- Hero -->
  <section class="relative h-[45vh] flex items-end pb-12">
    <div class="absolute inset-0 z-0">
      <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-primary text-white text-sm px-3 py-1 rounded-full capitalize">{translateCategory(post.data.category)}</span>
          <span class="text-white/80 text-sm">{formatDate(post.data.pubDate)}</span>
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-2">{post.data.title}</h1>
        <p class="text-white/80">{T.byAuthor} {post.data.author}</p>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">

        <!-- Back to blog -->
        <a href={`${p}/blog`} class="inline-flex items-center text-primary hover:text-primary-600 font-semibold mb-8 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          {backLabel}
        </a>

        <!-- Article body -->
        <article class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-primary prose-img:rounded-xl prose-img:shadow-lg">
          <Content/>
        </article>

        <!-- Author & Share -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="text-primary font-bold text-sm">{post.data.author.charAt(0)}</span>
              </div>
              <div>
                <p class="font-semibold text-gray-800">{post.data.author}</p>
                <p class="text-sm text-gray-500">Arbre Bio Africa</p>
              </div>
            </div>
            <a href={`${p}/blog`} class="inline-flex items-center bg-primary text-white px-5 py-2.5 rounded-full hover:bg-primary-600 transition-colors text-sm font-medium">
              {moreLabel}
            </a>
          </div>

          <!-- Social sharing -->
          <h3 class="text-lg font-bold mb-4">{shareLabel}</h3>
          <div class="flex flex-wrap gap-3">
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="bg-[#1877F2] text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors inline-flex items-center" aria-label="Facebook">
              <i class="fa-brands fa-facebook-f mr-2"></i>Facebook
            </a>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" class="bg-[#1DA1F2] text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors inline-flex items-center" aria-label="Twitter">
              <i class="fa-brands fa-twitter mr-2"></i>Twitter
            </a>
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(post.data.title)}&summary=${encodeURIComponent(post.data.description)}`} target="_blank" rel="noopener noreferrer" class="bg-[#0A66C2] text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors inline-flex items-center" aria-label="LinkedIn">
              <i class="fa-brands fa-linkedin-in mr-2"></i>LinkedIn
            </a>
            <a href={`https://wa.me/?text=${encodeURIComponent(`${post.data.title} - ${Astro.url.href}`)}`} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors inline-flex items-center" aria-label="WhatsApp">
              <i class="fa-brands fa-whatsapp mr-2"></i>WhatsApp
            </a>
            <a href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent(`${Astro.url.href}`)}`} class="bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors inline-flex items-center" aria-label="Email">
              <i class="fa-solid fa-envelope mr-2"></i>Email
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">{T.ctaTitle}</h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-primary text-white px-8 py-3 rounded-full text-lg hover:bg-primary-600 transition-colors">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

</Layout>
