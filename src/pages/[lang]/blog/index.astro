---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

// Category label translations
const categoryLabels: Record<string, Record<string, string>> = {
  fr: {
    'irrigation':     'Irrigation',
    'greenhouse':     'Serre',
    'substrates':     'Substrats',
    'farming-tips':   'Conseils Agricoles',
    'digital-farming':'Agriculture Numérique',
  },
  es: {
    'irrigation':     'Riego',
    'greenhouse':     'Invernadero',
    'substrates':     'Sustratos',
    'farming-tips':   'Consejos Agrícolas',
    'digital-farming':'Agricultura Digital',
  },
  af: {
    'irrigation':     'Besproeiing',
    'greenhouse':     'Kweekhuis',
    'substrates':     'Substrate',
    'farming-tips':   'Boerdery Wenke',
    'digital-farming':'Digitale Boerdery',
  },
};
const translateCategory = (cat: string) =>
  (categoryLabels[lang]?.[cat]) ?? cat.replace('-', ' ');

const allPosts = await getCollection('blog');

// Use posts for this language; fall back to English when no translation exists
const langPosts = allPosts.filter(post => post.slug.startsWith(`${lang}/`));
const enPosts   = allPosts.filter(post => post.slug.startsWith('en/'));

// Build a map of base-slug → translated post (or English fallback)
const baseSlugMap = new Map<string, (typeof allPosts)[number]>();
enPosts.forEach(post => {
  const base = post.slug.replace(/^en\//, '');
  baseSlugMap.set(base, post); // default: English
});
langPosts.forEach(post => {
  const base = post.slug.replace(new RegExp(`^${lang}/`), '');
  baseSlugMap.set(base, post); // override with translation if available
});

const posts = [...baseSlugMap.values()].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = posts.filter(post => post.data.featured);
const regularPosts  = posts.filter(post => !post.data.featured);

// URL slug always uses the base slug (without language prefix)
const urlSlug = (post: (typeof allPosts)[number]) =>
  post.slug.replace(new RegExp(`^(en|fr|es|af)/`), '');

const localeMap: Record<string, string> = { fr: 'fr-FR', es: 'es-ES', af: 'af-ZA', en: 'en-US' };
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(localeMap[lang] || 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<Layout title={`${T.blogTitle} | Arbre Bio Africa`} description={T.blogSubtitle}>

  <section class="relative h-[40vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/zyqmr7i.jpg" alt="Modern Agriculture" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.blogTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.blogSubtitle}</p>
    </div>
  </section>

  {featuredPosts.length > 0 && (
    <section class="py-16">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold mb-8">{T.featuredArticles}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredPosts.map(post => (
            <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
              <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover"/>
              <div class="p-6">
                <div class="flex items-center mb-4">
                  <span class="text-sm text-gray-500">{formatDate(post.data.pubDate)}</span>
                  <span class="mx-2">•</span>
                  <span class="text-sm text-primary capitalize">{translateCategory(post.data.category)}</span>
                </div>
                <h3 class="text-xl font-bold mb-2 hover:text-primary">
                  <a href={`${p}/blog/${urlSlug(post)}`}>{post.data.title}</a>
                </h3>
                <p class="text-gray-600 mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-gray-500">{T.byAuthor} {post.data.author}</span>
                  <a href={`${p}/blog/${urlSlug(post)}`} class="text-primary hover:text-primary-dark font-semibold inline-flex items-center">
                    {T.readMore}
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8">{T.latestArticles}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {regularPosts.map(post => (
          <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover"/>
            <div class="p-6">
              <div class="flex items-center mb-4">
                <span class="text-sm text-gray-500">{formatDate(post.data.pubDate)}</span>
                <span class="mx-2">•</span>
                <span class="text-sm text-primary capitalize">{translateCategory(post.data.category)}</span>
              </div>
              <h3 class="text-xl font-bold mb-2 hover:text-primary">
                <a href={`${p}/blog/${urlSlug(post)}`}>{post.data.title}</a>
              </h3>
              <p class="text-gray-600 mb-4">{post.data.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-500">{T.byAuthor} {post.data.author}</span>
                <a href={`${p}/blog/${urlSlug(post)}`} class="text-primary hover:text-primary-dark font-semibold inline-flex items-center">
                  {T.readMore}
                  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.stayUpdated}</h2>
      <p class="text-xl text-white mb-8">{T.newsletterSub}</p>
      <form class="max-w-lg mx-auto flex gap-4">
        <input type="email" placeholder={T.enterEmail} class="flex-1 px-4 py-3 rounded-full focus:outline-none focus:ring-2 focus:ring-white"/>
        <button type="submit" class="bg-white text-primary px-8 py-3 rounded-full hover:bg-opacity-90">{T.subscribe}</button>
      </form>
    </div>
  </section>

</Layout>
