---
export const prerender = false;

import Layout from "../../../layouts/Layout.astro";
import { useCareerT } from "../../../lib/careerTranslations";
import type { Language } from "../../../lib/i18n";

const { lang, jobSlug } = Astro.params as { lang: Language; jobSlug: string };
const T = useCareerT(lang);

const typeLabels: Record<string, string> = {
  full_time: T.fullTime, part_time: T.partTime,
  contract: T.contract, internship: T.internship, volunteer: T.volunteer
};
---

<Layout title={`${T.careers} | Arbre Bio Africa`} description={T.careerPageDesc}>

  <!-- Breadcrumb -->
  <div class="bg-[#f0f9f0] border-b border-gray-200 py-3">
    <div class="container mx-auto px-4">
      <nav class="flex items-center gap-2 text-sm text-gray-600">
        <a href={`/${lang}`} class="hover:text-[#194642]">Home</a>
        <span>/</span>
        <a href={`/${lang}/careers`} class="hover:text-[#194642]">{T.careers}</a>
        <span>/</span>
        <span id="breadcrumb-title" class="text-[#194642] font-medium">...</span>
      </nav>
    </div>
  </div>

  <!-- Loading state -->
  <div id="page-loading" class="flex justify-center items-center py-32">
    <div class="animate-spin w-12 h-12 border-4 border-[#194642] border-t-transparent rounded-full"></div>
  </div>

  <!-- Job content (populated by JS) -->
  <div id="job-content" class="hidden">
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

          <!-- Main content -->
          <div class="lg:col-span-2">
            <a href={`/${lang}/careers`} class="inline-flex items-center gap-2 text-[#194642] hover:underline mb-6 text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              {T.backToJobs}
            </a>
            <div id="job-tags" class="flex flex-wrap gap-2 mb-4"></div>
            <h1 id="job-title" class="text-3xl md:text-4xl font-bold text-[#194642] mb-6"></h1>

            <div class="prose max-w-none">
              <h2 class="text-xl font-bold text-[#194642] mb-3">{T.jobDescription}</h2>
              <div id="job-description" class="text-gray-700 leading-relaxed mb-8"></div>

              <div id="requirements-section" class="hidden">
                <h2 class="text-xl font-bold text-[#194642] mb-3">{T.requirements}</h2>
                <div id="job-requirements" class="text-gray-700 leading-relaxed mb-8"></div>
              </div>
            </div>

            <div class="bg-[#f0f9f0] rounded-xl p-6 mt-8">
              <h2 class="text-xl font-bold text-[#194642] mb-3">{T.howToApply}</h2>
              <p class="text-gray-700 mb-4">{T.applicationFormDesc}</p>
              <a id="apply-btn" href="#" class="inline-block bg-[#194642] text-white font-bold px-8 py-3 rounded-lg hover:bg-[#2a5e59] transition-colors">
                {T.applyForPosition}
              </a>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-1">
            <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 sticky top-6">
              <h3 class="font-bold text-[#194642] text-lg mb-4">Job Details</h3>
              <div class="space-y-4 text-sm">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[#194642] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                  <div>
                    <p class="font-semibold text-gray-800">{T.location}</p>
                    <p id="job-location" class="text-gray-600"></p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[#194642] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  <div>
                    <p class="font-semibold text-gray-800">{T.jobType}</p>
                    <p id="job-type" class="text-gray-600"></p>
                  </div>
                </div>
                <div id="dept-row" class="flex items-start gap-3 hidden">
                  <svg class="w-5 h-5 text-[#194642] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                  <div>
                    <p class="font-semibold text-gray-800">{T.department}</p>
                    <p id="job-dept" class="text-gray-600"></p>
                  </div>
                </div>
                <div id="deadline-row" class="flex items-start gap-3 hidden">
                  <svg class="w-5 h-5 text-[#194642] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <div>
                    <p class="font-semibold text-gray-800">{T.closingDate}</p>
                    <p id="job-deadline" class="text-gray-600"></p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[#194642] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
                  <div>
                    <p class="font-semibold text-gray-800">{T.availablePositions}</p>
                    <p id="job-positions" class="text-gray-600"></p>
                  </div>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-gray-200">
                <a id="apply-btn-side" href="#" class="block w-full text-center bg-[#194642] text-white font-bold px-6 py-3 rounded-lg hover:bg-[#2a5e59] transition-colors">
                  {T.applyNow}
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </div>

  <!-- Error state -->
  <div id="job-error" class="hidden text-center py-32">
    <div class="text-6xl mb-4">🔍</div>
    <h2 class="text-2xl font-bold text-gray-800 mb-2">Job not found</h2>
    <a href={`/${lang}/careers`} class="text-[#194642] underline">{T.backToJobs}</a>
  </div>

</Layout>

<script define:vars={{ lang, jobSlug, typeLabels }}>
  async function loadJob() {
    const slug = window.location.pathname.split('/').pop();
    try {
      const res = await fetch(`/api/careers/jobs?slug=${slug}`);
      const data = await res.json();
      const job = data.job;
      if (!job) throw new Error('not found');

      document.getElementById('page-loading').classList.add('hidden');
      document.getElementById('job-content').classList.remove('hidden');

      const title = job[`title_${lang}`] || job.title_en;
      const description = job[`description_${lang}`] || job.description_en;
      const requirements = job[`requirements_${lang}`] || job.requirements_en;

      document.title = `${title} | Arbre Bio Africa`;
      document.getElementById('breadcrumb-title').textContent = title;
      document.getElementById('job-title').textContent = title;
      document.getElementById('job-description').innerHTML = description;
      document.getElementById('job-location').textContent = job.location;
      document.getElementById('job-type').textContent = typeLabels[job.job_type] || job.job_type;
      document.getElementById('job-positions').textContent = `${job.positions}`;

      if (requirements) {
        document.getElementById('requirements-section').classList.remove('hidden');
        document.getElementById('job-requirements').innerHTML = requirements;
      }
      if (job.department) {
        document.getElementById('dept-row').classList.remove('hidden');
        document.getElementById('job-dept').textContent = job.department;
      }
      if (job.deadline) {
        document.getElementById('deadline-row').classList.remove('hidden');
        document.getElementById('job-deadline').textContent = new Date(job.deadline).toLocaleDateString();
      }

      // Type badge
      const tagsEl = document.getElementById('job-tags');
      tagsEl.innerHTML = `
        <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-full">
          ${typeLabels[job.job_type] || job.job_type}
        </span>
        ${job.department ? `<span class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1.5 rounded-full">${job.department}</span>` : ''}
      `;

      // Set apply links
      const applyUrl = `/${lang}/careers/apply/${job.slug}`;
      document.getElementById('apply-btn').href = applyUrl;
      document.getElementById('apply-btn-side').href = applyUrl;

    } catch (e) {
      document.getElementById('page-loading').classList.add('hidden');
      document.getElementById('job-error').classList.remove('hidden');
    }
  }

  loadJob();
</script>
