```
---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, getStaticPaths } from '../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<Layout
  title={t('privacy.title')}
  description={t('privacy.description')}
>
  <div class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8 md:p-12">
        <h1 class="text-3xl font-bold mb-8">{t('privacy.heading')}</h1>

        <!-- Introduction -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.intro.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.intro.text')}
          </p>
        </section>

        <!-- Information We Collect -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.collect.title')}</h2>
          <h3 class="text-lg font-medium mb-3">{t('privacy.collect.personal.title')}</h3>
          <p class="text-gray-700 mb-4">{t('privacy.collect.personal.text')}</p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.collect.personal.list.name')}</li>
            <li>{t('privacy.collect.personal.list.business')}</li>
            <li>{t('privacy.collect.personal.list.delivery')}</li>
            <li>{t('privacy.collect.personal.list.payment')}</li>
            <li>{t('privacy.collect.personal.list.communication')}</li>
          </ul>

          <h3 class="text-lg font-medium mb-3">{t('privacy.collect.technical.title')}</h3>
          <p class="text-gray-700 mb-4">{t('privacy.collect.technical.text')}</p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.collect.technical.list.ip')}</li>
            <li>{t('privacy.collect.technical.list.browser')}</li>
            <li>{t('privacy.collect.technical.list.device')}</li>
            <li>{t('privacy.collect.technical.list.pages')}</li>
            <li>{t('privacy.collect.technical.list.referral')}</li>
          </ul>
        </section>

        <!-- How We Use Your Information -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.use.title')}</h2>
          <p class="text-gray-700 mb-4">{t('privacy.use.text')}</p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.use.list.orders')}</li>
            <li>{t('privacy.use.list.support')}</li>
            <li>{t('privacy.use.list.updates')}</li>
            <li>{t('privacy.use.list.improve')}</li>
            <li>{t('privacy.use.list.marketing')}</li>
            <li>{t('privacy.use.list.legal')}</li>
          </ul>
        </section>

        <!-- Data Sharing & Third Parties -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.sharing.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.sharing.text1')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.sharing.list.providers')}</li>
            <li>{t('privacy.sharing.list.partners')}</li>
            <li>{t('privacy.sharing.list.analytics')}</li>
            <li>{t('privacy.sharing.list.legal')}</li>
          </ul>
          <p class="text-gray-700 mb-4">
            {t('privacy.sharing.text2')}
          </p>
        </section>

        <!-- Data Security Measures -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.security.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.security.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.security.list.encryption')}</li>
            <li>{t('privacy.security.list.access')}</li>
            <li>{t('privacy.security.list.assessments')}</li>
            <li>{t('privacy.security.list.training')}</li>
            <li>{t('privacy.security.list.physical')}</li>
          </ul>
        </section>

        <!-- Cookies & Tracking Technologies -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.cookies.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.cookies.text1')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.cookies.list.essential')}</li>
            <li>{t('privacy.cookies.list.analytics')}</li>
            <li>{t('privacy.cookies.list.marketing')}</li>
          </ul>
          <p class="text-gray-700 mb-4">
            {t('privacy.cookies.text2')}
          </p>
        </section>

        <!-- User Rights & Control -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.rights.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.rights.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.rights.list.access')}</li>
            <li>{t('privacy.rights.list.correct')}</li>
            <li>{t('privacy.rights.list.delete')}</li>
            <li>{t('privacy.rights.list.object')}</li>
            <li>{t('privacy.rights.list.portability')}</li>
            <li>{t('privacy.rights.list.withdraw')}</li>
          </ul>
        </section>

        <!-- Retention of Data -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.retention.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.retention.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li>{t('privacy.retention.list.fulfill')}</li>
            <li>{t('privacy.retention.list.legal')}</li>
            <li>{t('privacy.retention.list.disputes')}</li>
            <li>{t('privacy.retention.list.enforce')}</li>
          </ul>
        </section>

        <!-- International Data Transfers -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.international.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.international.text')}
          </p>
        </section>

        <!-- Children's Privacy -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.children.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.children.text')}
          </p>
        </section>

        <!-- Policy Updates -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.updates.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.updates.text')}
          </p>
        </section>

        <!-- Contact Information -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('privacy.contact.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('privacy.contact.text')}
          </p>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-medium mb-2">{t('privacy.contact.abidjan')}</h3>
            <p class="text-gray-700">Cocody Riviera 3, Jacque Prevert 2</p>
            <p class="text-gray-700">{t('privacy.contact.phone')} +225 21 21 80 69 50</p>
            <p class="text-gray-700">{t('privacy.contact.email')} farms@arbrebio.com</p>
            
            <h3 class="font-medium mb-2 mt-4">{t('privacy.contact.capeTown')}</h3>
            <p class="text-gray-700">Van Biljon Business Park, Winelands Cl</p>
            <p class="text-gray-700">Stikland Industrial, Cape Town, 7530</p>
            <p class="text-gray-700">{t('privacy.contact.phone')} +27 79 533 0267</p>
            <p class="text-gray-700">{t('privacy.contact.email')} CPT@arbrebio.com</p>
          </div>
        </section>

        <div class="text-gray-600 text-sm">
          <p>{t('privacy.lastUpdated')} {new Date().toLocaleDateString(lang === 'fr' ? 'fr-FR' : lang === 'es' ? 'es-ES' : lang === 'af' ? 'af-ZA' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        </div>
      </div>
    </div>
  </div>
</Layout>