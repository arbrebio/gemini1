---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { pt } from "../../lib/pageTranslations";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const p = pt(lang); const legal = p.legal;
const prefix = `/${lang}`;
const pageData = legal.privacy;
---
<Layout title={pageData.title + " | Arbre Bio Africa"} description={pageData.subtitle}>
  <section class="relative h-[30vh] flex items-center bg-primary">
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{pageData.title}</h1>
      <p class="text-xl text-white/90 max-w-2xl">{pageData.subtitle}</p>
    </div>
  </section>
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-8">
        <p class="text-amber-800">{legal.note}</p>
      </div>
      <p class="text-gray-600 mb-6">
        {lang==='fr'?'Pour consulter la version complète de ce document, veuillez':lang==='es'?'Para consultar la versión completa de este documento, por favor':lang==='af'?'Om die volledige weergawe van hierdie dokument te sien, gaan na':'To view the full version of this document, please visit'}
        <a href="/privacy" class="text-primary hover:underline ml-1">arbrebio.com/privacy</a>
      </p>
      <a href={`${prefix}/contact`} class="inline-flex items-center text-primary font-semibold hover:underline">
        {lang==='fr'?'Nous Contacter pour toute question':lang==='es'?'Contáctanos con cualquier pregunta':lang==='af'?'Kontak Ons vir enige vrae':'Contact Us with any questions'}
      </a>
    </div>
  </section>
</Layout>
