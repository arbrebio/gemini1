---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, getStaticPaths } from '../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<Layout
  title={t('cookies.title')}
  description={t('cookies.description')}
>
  <div class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8 md:p-12">
        <h1 class="text-3xl font-bold mb-8">{t('cookies.heading')}</h1>

        <!-- Introduction -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.intro.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.intro.text')}
          </p>
        </section>

        <!-- Types of Cookies -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.types.title')}</h2>
          
          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.types.essential.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.types.essential.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.types.performance.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.types.performance.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.types.functionality.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.types.functionality.text')}
          </p>

          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.types.targeting.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.types.targeting.text')}
          </p>
        </section>

        <!-- How We Use Cookies -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.usage.title')}</h2>
          <p class="text-gray-700 mb-4">{t('cookies.sections.usage.text')}</p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('cookies.sections.usage.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <!-- Third-Party Cookies -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.thirdParty.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.thirdParty.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('cookies.sections.thirdParty.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.thirdParty.note')}
          </p>
        </section>

        <!-- Managing Cookies -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.managing.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.managing.text')}
          </p>
          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.managing.browser.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.managing.browser.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('cookies.sections.managing.browser.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>

          <h3 class="text-lg font-medium mb-3">{t('cookies.sections.managing.instructions.title')}</h3>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.managing.instructions.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            <li><a href="https://support.google.com/chrome/answer/95647" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">{t('cookies.browsers.chrome')}</a></li>
            <li><a href="https://support.mozilla.org/en-US/kb/enhanced-tracking-protection-firefox-desktop" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">{t('cookies.browsers.firefox')}</a></li>
            <li><a href="https://support.microsoft.com/en-us/windows/microsoft-edge-browsing-data-and-privacy-bb8174ba-9d73-dcf2-9b4a-c582b4e640dd" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">{t('cookies.browsers.edge')}</a></li>
            <li><a href="https://support.apple.com/guide/safari/manage-cookies-and-website-data-sfri11471" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Safari</a></li>
          </ul>
        </section>

        <!-- Consent -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.consent.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.consent.text')}
          </p>
          <ul class="list-disc ml-6 text-gray-700 mb-4">
            {t('cookies.sections.consent.items').map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <!-- Data Protection -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.dataProtection.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.dataProtection.text')} <a href="/privacy" class="text-primary hover:underline">{t('cookies.sections.dataProtection.privacyLink')}</a>.
          </p>
        </section>

        <!-- Updates -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.updates.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.updates.text')}
          </p>
        </section>

        <!-- Contact Information -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">{t('cookies.sections.contact.title')}</h2>
          <p class="text-gray-700 mb-4">
            {t('cookies.sections.contact.text')}
          </p>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-medium mb-2">{t('cookies.sections.contact.abidjan')}</h3>
            <p class="text-gray-700">Cocody Riviera 3, Jacque Prevert 2</p>
            <p class="text-gray-700">Phone: +225 21 21 80 69 50</p>
            <p class="text-gray-700">Email: farms@arbrebio.com</p>
            
            <h3 class="font-medium mb-2 mt-4">{t('cookies.sections.contact.capeTown')}</h3>
            <p class="text-gray-700">Van Biljon Business Park, Winelands Cl</p>
            <p class="text-gray-700">Stikland Industrial, Cape Town, 7530</p>
            <p class="text-gray-700">Phone: +27 79 533 0267</p>
            <p class="text-gray-700">Email: CPT@arbrebio.com</p>
          </div>
        </section>

        <div class="text-gray-600 text-sm">
          <p>{t('cookies.lastUpdated')} {new Date().toLocaleDateString(lang === 'en' ? 'en-US' : lang === 'fr' ? 'fr-FR' : lang === 'es' ? 'es-ES' : 'af-ZA', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        </div>
      </div>
    </div>
  </div>
</Layout>