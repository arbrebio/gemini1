---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useTranslations } from "../../lib/i18n";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }

const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
const prefix = `/${lang}`;

const services = [
  { icon: "🌿", title: t("services.greenhouses.title"), description: t("services.greenhouses.description"), link: `${prefix}/greenhouses` },
  { icon: "💧", title: t("services.irrigation.title"), description: t("services.irrigation.description"), link: `${prefix}/irrigation` },
  { icon: "🌱", title: t("services.substrates.title"), description: t("services.substrates.description"), link: `${prefix}/substrates/growing-solutions` },
];

const partners = [
  { name: "Conseil Hévéa Palmier", logo: "https://i.imgur.com/shsj3KH.jpg", website: "https://conseilheveapalmier.ci/" },
  { name: "FIRCA", logo: "https://i.imgur.com/91MTbWi.jpg", website: "https://firca.ci/" },
  { name: t("stats.countries") === "Pays Africains" ? "Banque Mondiale" : "World Bank", logo: "https://i.imgur.com/W55LKPV.jpg", website: "https://www.worldbank.org" },
  { name: "Hortalan", logo: "https://i.imgur.com/hVXMDbV.jpg", website: "https://hortalan.com/" },
  { name: "African Development Bank", logo: "https://i.imgur.com/xUbaryR.jpg", website: "https://www.afdb.org/en" },
  { name: "GIZ", logo: "https://i.imgur.com/g3qxeY3.jpg", website: "https://www.giz.de/en/regions/africa/cote-divoire" },
  { name: "AZUD", logo: "https://i.imgur.com/cYKFakb.jpg", website: "https://azud.com/en/" },
  { name: "Novagric", logo: "https://i.imgur.com/cyocoKN.jpg", website: "https://novagric.com/" },
  { name: "CNRA", logo: "https://i.imgur.com/6an3KC8.jpg", website: "http://cnra.ci/" },
  { name: "PDC2V", logo: "https://i.imgur.com/BMzFHHR.jpg", website: "https://pdc2v.ci/" },
  { name: "OMRI", logo: "https://i.imgur.com/pcM8A7v.jpg", website: "https://www.omri.org/" },
  { name: "INP-HB ESA", logo: "https://i.imgur.com/da88PlP.jpg", website: "https://www.inphb.edu.ci/ecoles/esa" },
];
---

<Layout title={t("hero.title")} description={t("hero.subtitle")} image="https://i.imgur.com/Aab6e6c.jpg">
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://i.imgur.com/Aab6e6c.jpg" alt="Precision agriculture Africa" class="w-full h-full object-cover" loading="eager"/>
      <div class="absolute inset-0 bg-black bg-opacity-55"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4 py-32">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">{t("hero.title")}</h1>
        <p class="text-xl md:text-2xl text-white/90 mb-10 max-w-2xl">{t("hero.subtitle")}</p>
        <div class="flex flex-wrap gap-4">
          <a href={`${prefix}/contact`} class="bg-primary hover:bg-primary-600 text-white px-8 py-4 rounded-full text-lg font-medium transition-all duration-300 transform hover:scale-105 shadow-lg">{t("hero.cta.primary")}</a>
          <a href={`${prefix}/greenhouses`} class="bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white border-2 border-white px-8 py-4 rounded-full text-lg font-medium transition-all duration-300 transform hover:scale-105">{t("hero.cta.secondary")}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("services.title")}</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">{t("services.subtitle")}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((s) => (
          <div class="bg-white rounded-xl shadow-lg p-8 text-center transform hover:-translate-y-2 transition-all duration-300 hover:shadow-xl border border-gray-100">
            <div class="text-5xl mb-5">{s.icon}</div>
            <h3 class="text-xl font-bold mb-3">{s.title}</h3>
            <p class="text-gray-600 mb-6">{s.description}</p>
            <a href={s.link} class="inline-flex items-center text-primary font-semibold hover:text-primary-600 transition-colors gap-1">
              {t("services.learnMore")}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-20 bg-primary text-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><div class="text-5xl font-bold mb-2">10x</div><div class="text-white/80 text-lg">{t("stats.yieldIncrease")}</div></div>
        <div><div class="text-5xl font-bold mb-2">60%</div><div class="text-white/80 text-lg">{t("stats.waterSavings")}</div></div>
        <div><div class="text-5xl font-bold mb-2">500+</div><div class="text-white/80 text-lg">{t("stats.projectsCompleted")}</div></div>
        <div><div class="text-5xl font-bold mb-2">5</div><div class="text-white/80 text-lg">{t("stats.africanCountries")}</div></div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 bg-gray-50 overflow-hidden">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-10 text-gray-800">
        {lang === 'fr' ? 'Nos Partenaires de Confiance' : lang === 'es' ? 'Nuestros Socios de Confianza' : lang === 'af' ? 'Ons Vertroude Vennote' : 'Our Trusted Partners'}
      </h2>
      <div class="partner-scroll flex gap-10 items-center">
        {[...partners, ...partners].map((p) => (
          <a href={p.website} target="_blank" rel="noopener noreferrer" class="flex-shrink-0 grayscale hover:grayscale-0 transition-all duration-300 opacity-60 hover:opacity-100">
            <img src={p.logo} alt={p.name} class="h-10 w-auto object-contain"/>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">{t("cta.title")}</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">{t("cta.subtitle")}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${prefix}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors duration-300 shadow-lg transform hover:scale-105">{t("cta.consultation")}</a>
        <a href="https://wa.me/2250799295643" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-4 rounded-full text-lg hover:opacity-90 transition-opacity duration-300 shadow-lg transform hover:scale-105">{t("cta.whatsapp")}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes partnerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .partner-scroll { animation: partnerScroll 35s linear infinite; width: max-content; }
  .partner-scroll:hover { animation-play-state: paused; }
</style>
