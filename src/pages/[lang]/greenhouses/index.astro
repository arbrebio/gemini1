    faqH2: "Gereelde Vrae oor Kweekhuise",
    faq: [
      { q: "Watter kwekhuistipe kies om in Ivoorkus te begin?", a: "Vir 'n eerste kwekhuisprojek in Ivoorkus beveel ons gewoonlik die tonnelkwekhuis of die beskeie veelspankwekhuis (500 tot 2000 m²) aan. Hierdie strukture bied 'n goeie koste/voordeel-verhouding en laat toe om die nodige ervaring op te doen voordat in hoë-tegnologie belê word. Arbre Bio Africa bied 'n gratis konsultasie om die beste oplossing vir jou terrein, begroting en produksieplan te evalueer." },
      { q: "Hoeveel kos 'n landbou kwekhuis in Ivoorkus?", a: "Die koste wissel aansienlik na gelang van die tipe (tonnel, veelspan, hoë-tegnologie), oppervlakte, geïntegreerde toerusting en finansieringsopsies. As aanduiding kos 'n basiese tonnelkwekhuis tussen 3 000 en 8 000 FCFA/m², 'n veelspan tussen 8 000 en 20 000 FCFA/m², en 'n hoë-tegnologie kwekhuis meer as 30 000 FCFA/m². Arbre Bio Africa stel 'n gratis gedetailleerde kwotasie op." },
      { q: "Watter gewas is die winsgewendste in 'n kwekhuis in Wes-Afrika?", a: "Die winsgewendste gewasse in kweekhuise in Wes-Afrika is gewoonlik kersiestamaties en cocktailtamaties (premiumprys op stedelike en uitvoermarkte), kleurvolle rissies, aromatieke kruie (basil, pietersielie, koljander), slaai en grondlose aarbeie. Winsgewendheid hang ook sterk af van jou toegang tot markte en kommersiële strategie. Ons adviseurs kan jou help om die winsgewendste produksieplan vir jou streek te bepaal." },
      { q: "Weerstaan Arbre Bio Africa kweekhuise uiterste klimaattoestande?", a: "Ja. Al ons kweekhuise is ontwerp om Wes-Afrika se klimaattoestande te weerstaan: sterk winde (tot 120 km/h vir versterkte strukture), stortreëns, intense hitte (tot 45°C in droë seisoen). Die anti-korrosie gegalvaniseerde staalstruktuur, UV-gestabiliseerde filme en ventilasiesisteme word spesifiek gekies vir hul duursaamheid in die trope." },
      { q: "Bied Arbre Bio Africa tegniese ondersteuning na installasie?", a: "Absoluut. Ondersteuning na installasie is kernaan ons model. Ons lei jou span op in kwekhuis bestuur, besproeiing, gewasbestuur en siektebestryding. Ons bied gereelde agronomies opvolgbesoeke en tegniese bystand beskikbaar via WhatsApp en telefoon. Ons doel is dat jou kwekhuis produktief is vanaf die eerste seisoen." },
    ],
  },
};

const c = content[lang] ?? content.fr;

const scriptOpen = '<' + 'script type="application/ld+json">';
const scriptClose = '<' + '/script>';
const jsonLdData = scriptOpen + JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": c.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
}) + scriptClose;
---
<Layout title={c.metaTitle} description={c.metaDesc}>

  {/* Hero */}
  <section class="relative bg-gradient-to-br from-green-900 via-emerald-800 to-teal-700 text-white py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-emerald-300 font-semibold text-sm uppercase tracking-widest mb-4">{c.heroLabel}</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">{c.heroH1}</h1>
      <p class="text-xl text-emerald-100 max-w-3xl mx-auto mb-8">{c.heroSubtitle}</p>
      <div class="flex flex-wrap gap-4 justify-center mb-12">
        <a href={`/${lang}/contact`} class="bg-emerald-500 hover:bg-emerald-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.requestQuote}
        </a>
        <a href={`/${lang}/greenhouses/high-tech`} class="border-2 border-white text-white hover:bg-white hover:text-green-900 font-bold py-3 px-8 rounded-lg transition-colors">
          {c.heroSecondaryBtn}
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {c.stats.map(s => (
          <div class="bg-white/10 backdrop-blur rounded-xl p-4">
            <div class="text-3xl font-bold text-emerald-300">{s.value}</div>
            <div class="text-sm text-emerald-100 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Why Greenhouses in Africa */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-green-900 mb-6">{c.whyH2}</h2>
          <p class="text-gray-700 mb-4 leading-relaxed">{c.whyP1}</p>
          <p class="text-gray-700 mb-4 leading-relaxed">{c.whyP2}</p>
          <p class="text-gray-700 leading-relaxed">{c.whyP3}</p>
        </div>
        <div class="space-y-4">
          {[
            { icon: "sun", title: T.climateAdaptive, desc: T.climateAdaptiveDesc },
            { icon: "greenhouse", title: T.structuralDurability, desc: T.structuralDurabilityDesc },
            { icon: "wind", title: T.smartVentilation, desc: T.smartVentilationDesc },
            { icon: "shield", title: T.advancedCoverage, desc: T.advancedCoverageDesc },
          ].map(item => (
            <div class="flex gap-4 p-4 bg-green-50 rounded-xl">
              <span class="text-2xl flex-shrink-0"><EmojiIcon id={item.icon} size="2rem" /></span>
              <div>
                <div class="font-bold text-green-900 mb-1">{item.title}</div>
                <div class="text-gray-600 text-sm">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Greenhouse Types */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-4">{c.typesH2}</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-12">{c.typesSub}</p>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-green-600 p-6 text-white">
            <div class="text-3xl mb-2"><EmojiIcon id="tent" size="2rem" /></div>
            <h3 class="text-xl font-bold">{c.tunnel.title}</h3>
            <p class="text-green-200 text-sm mt-1">{c.tunnel.tagline}</p>
          </div>
          <div class="p-6">
            <p class="text-gray-600 text-sm mb-4">{c.tunnel.desc}</p>
            <ul class="text-xs text-gray-500 space-y-1">
              {c.tunnel.specs.map(s => <li>✓ {s}</li>)}
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm overflow-hidden border-2 border-emerald-500">
          <div class="bg-emerald-600 p-6 text-white relative">
            <div class="absolute top-2 right-2 bg-yellow-400 text-yellow-900 text-xs font-bold px-2 py-1 rounded">
              {c.multiSpan.popular}
            </div>
            <div class="text-3xl mb-2"><EmojiIcon id="home" size="2rem" /></div>
            <h3 class="text-xl font-bold">{c.multiSpan.title}</h3>
            <p class="text-emerald-200 text-sm mt-1">{c.multiSpan.tagline}</p>
          </div>
          <div class="p-6">
            <p class="text-gray-600 text-sm mb-4">{c.multiSpan.desc}</p>
            <ul class="text-xs text-gray-500 space-y-1">
              {c.multiSpan.specs.map(s => <li>✓ {s}</li>)}
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-blue-800 p-6 text-white">
            <div class="text-3xl mb-2"><EmojiIcon id="factory" size="2rem" /></div>
            <h3 class="text-xl font-bold">{c.highTech.title}</h3>
            <p class="text-blue-200 text-sm mt-1">{c.highTech.tagline}</p>
          </div>
          <div class="p-6">
            <p class="text-gray-600 text-sm mb-4">{c.highTech.desc}</p>
            <ul class="text-xs text-gray-500 space-y-1">
              {c.highTech.specs.map(s => <li>✓ {s}</li>)}
            </ul>
            <a href={`/${lang}/greenhouses/high-tech`} class="mt-4 inline-block text-blue-700 font-semibold text-sm hover:underline">
              {c.highTech.learnMore}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Crops Section */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-4">{c.cropsH2}</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-10">{c.cropsSub}</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {c.crops.map(crop => (
          <div class="bg-green-50 rounded-xl p-4 text-center">
            <div class="text-3xl mb-2"><EmojiIcon id={crop.emoji} size="2rem" /></div>
            <div class="font-bold text-green-900 text-sm">{crop.name}</div>
            <div class="text-xs text-gray-500 mt-1">{crop.detail}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-12">{c.faqH2}</h2>
      <div class="space-y-6">
        {c.faq.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-green-900 text-lg mb-3">{item.q}</h3>
            <p class="text-gray-700 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 px-4 bg-green-900 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">{T.ctaTitle}</h2>
      <p class="text-emerald-200 text-lg mb-8 max-w-2xl mx-auto">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${lang}/contact`} class="bg-emerald-500 hover:bg-emerald-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.freeConsultation}
        </a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

  {/* FAQ Schema */}
  <Fragment set:html={jsonLdData} />

</Layout>
