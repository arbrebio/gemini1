---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, getStaticPaths } from '../../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const specifications = [
  {
    category: t('pages.greenhouse.specifications.structure.category'),
    items: [
      { 
        feature: t('pages.greenhouse.specifications.structure.frameMaterial'), 
        value: t('pages.greenhouse.specifications.structure.frameMaterialValue'), 
        advantage: t('pages.greenhouse.specifications.structure.frameMaterialAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.structure.connectionSystem'), 
        value: t('pages.greenhouse.specifications.structure.connectionSystemValue'), 
        advantage: t('pages.greenhouse.specifications.structure.connectionSystemAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.structure.windResistance'), 
        value: t('pages.greenhouse.specifications.structure.windResistanceValue'), 
        advantage: t('pages.greenhouse.specifications.structure.windResistanceAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.structure.snowLoad'), 
        value: t('pages.greenhouse.specifications.structure.snowLoadValue'), 
        advantage: t('pages.greenhouse.specifications.structure.snowLoadAdvantage') 
      }
    ]
  },
  {
    category: t('pages.greenhouse.specifications.coverage.category'),
    items: [
      { 
        feature: t('pages.greenhouse.specifications.coverage.material'), 
        value: t('pages.greenhouse.specifications.coverage.materialValue'), 
        advantage: t('pages.greenhouse.specifications.coverage.materialAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.coverage.uvProtection'), 
        value: t('pages.greenhouse.specifications.coverage.uvProtectionValue'), 
        advantage: t('pages.greenhouse.specifications.coverage.uvProtectionAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.coverage.thermal'), 
        value: t('pages.greenhouse.specifications.coverage.thermalValue'), 
        advantage: t('pages.greenhouse.specifications.coverage.thermalAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.coverage.warranty'), 
        value: t('pages.greenhouse.specifications.coverage.warrantyValue'), 
        advantage: t('pages.greenhouse.specifications.coverage.warrantyAdvantage') 
      }
    ]
  },
  {
    category: t('pages.greenhouse.specifications.ventilation.category'),
    items: [
      { 
        feature: t('pages.greenhouse.specifications.ventilation.systemType'), 
        value: t('pages.greenhouse.specifications.ventilation.systemTypeValue'), 
        advantage: t('pages.greenhouse.specifications.ventilation.systemTypeAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.ventilation.airExchange'), 
        value: t('pages.greenhouse.specifications.ventilation.airExchangeValue'), 
        advantage: t('pages.greenhouse.specifications.ventilation.airExchangeAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.ventilation.control'), 
        value: t('pages.greenhouse.specifications.ventilation.controlValue'), 
        advantage: t('pages.greenhouse.specifications.ventilation.controlAdvantage') 
      },
      { 
        feature: t('pages.greenhouse.specifications.ventilation.insectProtection'), 
        value: t('pages.greenhouse.specifications.ventilation.insectProtectionValue'), 
        advantage: t('pages.greenhouse.specifications.ventilation.insectProtectionAdvantage') 
      }
    ]
  }
];

const features = [
  {
    title: t('pages.greenhouse.features.climateAdaptive.title'),
    description: t('pages.greenhouse.features.climateAdaptive.description'),
    stats: [
      t('pages.greenhouse.features.climateAdaptive.stats.cooler'),
      t('pages.greenhouse.features.climateAdaptive.stats.humidity'),
      t('pages.greenhouse.features.climateAdaptive.stats.light')
    ],
    image: 'https://imgur.com/XtX9fmQ.jpg'
  },
  {
    title: t('pages.greenhouse.features.structural.title'),
    description: t('pages.greenhouse.features.structural.description'),
    stats: [
      t('pages.greenhouse.features.structural.stats.lifespan'),
      t('pages.greenhouse.features.structural.stats.wind'),
      t('pages.greenhouse.features.structural.stats.load')
    ],
    image: 'https://imgur.com/hKnWqYO.jpg'
  },
  {
    title: t('pages.greenhouse.features.coverage.title'),
    description: t('pages.greenhouse.features.coverage.description'),
    stats: [
      t('pages.greenhouse.features.coverage.stats.warranty'),
      t('pages.greenhouse.features.coverage.stats.light'),
      t('pages.greenhouse.features.coverage.stats.heat')
    ],
    image: 'https://imgur.com/ybRfmvG.jpg'
  },
  {
    title: t('pages.greenhouse.features.ventilation.title'),
    description: t('pages.greenhouse.features.ventilation.description'),
    stats: [
      t('pages.greenhouse.features.ventilation.stats.airChanges'),
      t('pages.greenhouse.features.ventilation.stats.insect'),
      t('pages.greenhouse.features.ventilation.stats.smart')
    ],
    image: 'https://imgur.com/u9CfHxE.jpg'
  }
];

const comparisons = [
  {
    title: t('pages.greenhouse.comparison.connection.title'),
    standard: {
      title: t('pages.greenhouse.comparison.connection.standard'),
      points: [
        t('pages.greenhouse.comparison.connection.standardPoints.point1'),
        t('pages.greenhouse.comparison.connection.standardPoints.point2'),
        t('pages.greenhouse.comparison.connection.standardPoints.point3'),
        t('pages.greenhouse.comparison.connection.standardPoints.point4')
      ]
    },
    premium: {
      title: t('pages.greenhouse.comparison.connection.premium'),
      points: [
        t('pages.greenhouse.comparison.connection.premiumPoints.point1'),
        t('pages.greenhouse.comparison.connection.premiumPoints.point2'),
        t('pages.greenhouse.comparison.connection.premiumPoints.point3'),
        t('pages.greenhouse.comparison.connection.premiumPoints.point4')
      ]
    }
  },
  {
    title: t('pages.greenhouse.comparison.coverageTech.title'),
    standard: {
      title: t('pages.greenhouse.comparison.coverageTech.standard'),
      points: [
        t('pages.greenhouse.comparison.coverageTech.standardPoints.point1'),
        t('pages.greenhouse.comparison.coverageTech.standardPoints.point2'),
        t('pages.greenhouse.comparison.coverageTech.standardPoints.point3'),
        t('pages.greenhouse.comparison.coverageTech.standardPoints.point4')
      ]
    },
    premium: {
      title: t('pages.greenhouse.comparison.coverageTech.premium'),
      points: [
        t('pages.greenhouse.comparison.coverageTech.premiumPoints.point1'),
        t('pages.greenhouse.comparison.coverageTech.premiumPoints.point2'),
        t('pages.greenhouse.comparison.coverageTech.premiumPoints.point3'),
        t('pages.greenhouse.comparison.coverageTech.premiumPoints.point4')
      ]
    }
  }
];
---

<Layout
  title={t('pages.greenhouse.hero.title')}
  description={t('pages.greenhouse.features.climateAdaptive.description')}
>
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://imgur.com/z1onyVl.jpg"
        alt={t('pages.greenhouse.hero.title')} 
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {t('pages.greenhouse.hero.title')}
          <span class="block text-2xl md:text-3xl mt-2">{t('pages.greenhouse.hero.builtForAfrica')}</span>
        </h1>
        <p class="text-xl text-white mb-8 font-medium">
          {t('pages.greenhouse.hero.tagline')}
        </p>
        <div class="flex flex-wrap gap-4">
          <a 
            href="#quote-form"
            class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300"
          >
            {t('pages.greenhouse.hero.requestQuote')}
          </a>
          <a 
            href="#specifications"
            class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm"
          >
            {t('pages.greenhouse.hero.viewSpecifications')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  {features.map((feature, index) => (
    <section class={`py-20 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="container mx-auto px-4">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 0 ? '' : 'lg:flex-row-reverse'}`}>
          <div class={`order-2 ${index % 2 === 0 ? 'lg:order-2' : 'lg:order-1'}`}>
            <img 
              src={feature.image}
              alt={feature.title}
              class="w-full h-[400px] object-cover rounded-lg shadow-lg"
              loading="lazy"
            />
          </div>
          <div class={`order-1 ${index % 2 === 0 ? 'lg:order-1' : 'lg:order-2'}`}>
            <h2 class="text-3xl font-bold mb-6">{feature.title}</h2>
            <p class="text-lg text-gray-600 mb-8">{feature.description}</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              {feature.stats.map((stat) => (
                <div class="bg-white p-4 rounded-lg shadow-md text-center">
                  <p class="text-primary font-bold">{stat}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Specifications Table -->
  <section id="specifications" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('pages.greenhouse.specifications.title')}</h2>
      <div class="space-y-8">
        {specifications.map((category) => (
          <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <div class="bg-primary text-white p-4">
              <h3 class="text-xl font-bold">{category.category}</h3>
            </div>
            <div class="p-4">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {category.items.map((item) => (
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <h4 class="font-bold mb-2">{item.feature}</h4>
                    <p class="text-gray-600 mb-2">{item.value}</p>
                    <p class="text-primary text-sm">{item.advantage}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('pages.greenhouse.comparison.title')}</h2>
      <div class="space-y-12">
        {comparisons.map((comparison) => (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-gray-50 p-8 rounded-lg">
              <h3 class="text-xl font-bold mb-4">{comparison.standard.title}</h3>
              <ul class="space-y-3">
                {comparison.standard.points.map((point) => (
                  <li class="flex items-center text-gray-600">
                    <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-primary/10 p-8 rounded-lg">
              <h3 class="text-xl font-bold mb-4">{comparison.premium.title}</h3>
              <ul class="space-y-3">
                {comparison.premium.points.map((point) => (
                  <li class="flex items-center text-gray-700">
                    <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form Section -->
  <section id="quote-form" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{t('pages.greenhouse.quoteForm.title')}</h2>
        <form class="bg-white p-8 rounded-lg shadow-lg space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t('pages.greenhouse.quoteForm.firstName')} *
              </label>
              <input
                type="text"
                required
                class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t('pages.greenhouse.quoteForm.lastName')} *
              </label>
              <input
                type="text"
                required
                class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.email')} *
            </label>
            <input
              type="email"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.phone')} *
            </label>
            <input
              type="tel"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.projectLocation')} *
            </label>
            <input
              type="text"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              placeholder={t('pages.greenhouse.quoteForm.locationPlaceholder')}
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.greenhouseSize')} *
            </label>
            <input
              type="number"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.timeline')}
            </label>
            <select
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            >
              <option value="immediate">{t('pages.greenhouse.quoteForm.timelineImmediate')}</option>
              <option value="soon">{t('pages.greenhouse.quoteForm.timelineSoon')}</option>
              <option value="planning">{t('pages.greenhouse.quoteForm.timelinePlanning')}</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('pages.greenhouse.quoteForm.additionalRequirements')}
            </label>
            <textarea
              rows="4"
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              placeholder={t('pages.greenhouse.quoteForm.additionalPlaceholder')}
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300"
          >
            {t('pages.greenhouse.quoteForm.submit')}
          </button>
        </form>

        <!-- Trust Indicators -->
        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div>
            <div class="text-4xl mb-4">🏆</div>
            <h3 class="font-bold mb-2">{t('pages.greenhouse.trustIndicators.iso.title')}</h3>
            <p class="text-gray-600">{t('pages.greenhouse.trustIndicators.iso.description')}</p>
          </div>
          <div>
            <div class="text-4xl mb-4">⭐</div>
            <h3 class="font-bold mb-2">{t('pages.greenhouse.trustIndicators.warranty.title')}</h3>
            <p class="text-gray-600">{t('pages.greenhouse.trustIndicators.warranty.description')}</p>
          </div>
          <div>
            <div class="text-4xl mb-4">🌍</div>
            <h3 class="font-bold mb-2">{t('pages.greenhouse.trustIndicators.projects.title')}</h3>
            <p class="text-gray-600">{t('pages.greenhouse.trustIndicators.projects.description')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{t('pages.greenhouse.finalCta.title')}</h2>
      <p class="text-xl text-white mb-8">{t('pages.greenhouse.finalCta.description')}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a 
          href="#quote-form" 
          class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90"
        >
          {t('pages.greenhouse.finalCta.getStarted')}
        </a>
        <a 
          href="https://wa.me/2250799295643" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center"
        >
          <i class="fab fa-whatsapp mr-2"></i>
          {t('pages.greenhouse.finalCta.whatsapp')}
        </a>
      </div>
    </div>
  </section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Arbre Bio Africa Premium Greenhouse",
  "description": "Premium agricultural greenhouses engineered specifically for African climate conditions, featuring climate-adaptive design, superior durability, and smart ventilation systems.",
  "brand": {
    "@type": "Brand",
    "name": "Arbre Bio Africa"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Arbre Bio Africa",
    "url": "https://arbrebio.com"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "XOF",
    "priceValidUntil": "2025-12-31",
    "availability": "https://schema.org/InStock"
  },
  "image": [
    "https://images.unsplash.com/photo-1584968173934-bc0b588b2a4b?ixlib=rb-4.0.3"
  ],
  "features": [
    "Climate-adaptive design",
    "20+ years lifespan",
    "Advanced UV protection",
    "Smart ventilation system",
    "Bolt-lock technology"
  ]
}
</script>