---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const features = [
  { title: T.climateAdaptive, description: T.climateAdaptiveDesc, stats: ['40% cooler interior', '60% humidity control', '92% light transmission'], image: 'https://imgur.com/XtX9fmQ.jpg' },
  { title: T.structuralDurability, description: T.structuralDurabilityDesc, stats: ['20+ years lifespan', '150 km/h wind resistance', '25 kg/mÂ² load capacity'], image: 'https://imgur.com/hKnWqYO.jpg' },
  { title: T.advancedCoverage, description: T.advancedCoverageDesc, stats: ['5-year UV warranty', '92% light transmission', '25% better heat retention'], image: 'https://imgur.com/ybRfmvG.jpg' },
  { title: T.smartVentilation, description: T.smartVentilationDesc, stats: ['60 air changes/hour', '50-mesh insect protection', 'Smart climate control'], image: 'https://imgur.com/u9CfHxE.jpg' },
];

const specifications = [
  { category: 'Structure', items: [['Frame Material', 'Hot-dip galvanized steel', 'Superior corrosion resistance, 20+ years lifespan'], ['Connection System', 'Patented bolt-lock technology', '300% stronger than traditional welded joints'], ['Wind Resistance', 'Up to 150 km/h', 'Exceeds industry standards by 50%'], ['Snow Load', '25 kg/mÂ²', 'Designed for varied climate conditions']] },
  { category: 'Coverage', items: [['Material', 'Multi-layer UV-stabilized polyethylene', '92% light transmission'], ['UV Protection', 'Advanced UV-A/B/C blocking', 'Extended crop protection and film life'], ['Thermal Properties', 'IR heat retention technology', '25% better temperature regulation'], ['Warranty', '5-year UV warranty', 'Industry-leading coverage guarantee']] },
  { category: 'Ventilation', items: [['System Type', 'Automated ridge and side ventilation', 'Perfect climate control'], ['Air Exchange Rate', '45-60 air changes/hour', '50% better than standard systems'], ['Control System', 'Smart climate controller', 'Automated response to weather changes'], ['Insect Protection', '50-mesh anti-insect screens', 'Maximum pest protection']] },
];

const comparisons = [
  {
    title: 'Connection System',
    standard: { title: T.stdWelded, points: ['Limited strength under stress', 'Prone to failure at weld points', 'Cannot be easily repaired', 'Shorter lifespan'] },
    premium: { title: T.boltLock, points: ['300% stronger connection points', 'Distributed stress load', 'Easy maintenance and repairs', '20+ years lifespan'] }
  },
  {
    title: 'Coverage Technology',
    standard: { title: T.basicUV, points: ['Basic UV protection', 'Limited light diffusion', '2-3 year lifespan', 'Poor heat retention'] },
    premium: { title: T.smartFilm, points: ['Complete UV-A/B/C blocking', 'Optimal light diffusion', '5-year warranty', 'Advanced IR heat retention'] }
  },
];
---

<Layout title={`${T.ghHeroTitle} | Arbre Bio Africa`} description={T.ghTagline}>

  <section class="relative min-h-[80vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/z1onyVl.jpg" alt="Arbre Bio Premium Greenhouse" class="w-full h-full object-cover" loading="eager"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.ghHeroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.ghHeroSub}</span>
        </h1>
        <p class="text-xl text-white mb-8 font-medium">{T.ghTagline}</p>
        <div class="flex flex-wrap gap-4">
          <a href="#quote-form" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300">{T.requestQuote}</a>
          <a href="#specifications" class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm">{T.viewSpecs}</a>
        </div>
      </div>
    </div>
  </section>

  {features.map((feature, index) => (
    <section class={`py-20 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
      <div class="container mx-auto px-4">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center`}>
          <div class={index % 2 !== 0 ? 'lg:order-2' : ''}>
            <h2 class="text-3xl font-bold mb-6">{feature.title}</h2>
            <p class="text-gray-600 mb-8 text-lg leading-relaxed">{feature.description}</p>
            <div class="grid grid-cols-3 gap-6">
              {feature.stats.map(stat => (
                <div class="bg-primary/5 p-4 rounded-lg text-center"><p class="text-primary font-bold">{stat}</p></div>
              ))}
            </div>
          </div>
          <div class={index % 2 !== 0 ? 'lg:order-1' : ''}>
            <img src={feature.image} alt={feature.title} class="w-full h-[400px] object-cover rounded-lg shadow-lg"/>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section id="specifications" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.techSpecs}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {specifications.map(spec => (
          <div class="bg-gray-50 rounded-lg p-6">
            <h3 class="text-xl font-bold mb-6 text-center text-primary">{spec.category}</h3>
            <div class="space-y-4">
              {spec.items.map(([feature, value, advantage]) => (
                <div class="bg-white p-4 rounded">
                  <p class="font-medium">{feature}</p>
                  <p class="text-primary font-bold">{value}</p>
                  <p class="text-sm text-gray-500 mt-1">{advantage}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.whyChoose}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {comparisons.map(comparison => (
          <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <h3 class="text-xl font-bold p-6 text-center border-b">{comparison.title}</h3>
            <div class="grid grid-cols-2 divide-x">
              <div class="p-6">
                <h4 class="font-medium text-gray-500 mb-4 text-center">{comparison.standard.title}</h4>
                <ul class="space-y-2">
                  {comparison.standard.points.map(point => (
                    <li class="flex items-center text-sm text-gray-600">
                      <svg class="w-4 h-4 text-red-400 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="p-6 bg-primary/5">
                <h4 class="font-bold text-primary mb-4 text-center">{comparison.premium.title}</h4>
                <ul class="space-y-2">
                  {comparison.premium.points.map(point => (
                    <li class="flex items-center text-sm text-gray-700">
                      <svg class="w-4 h-4 text-primary mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="quote-form" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-8">{T.requestQuote}</h2>
        <form class="space-y-6 bg-gray-50 p-8 rounded-lg">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">{T.firstName}</label><input type="text" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">{T.lastName}</label><input type="text" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/></div>
          </div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">{T.emailAddress}</label><input type="email" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">{T.phoneNumber}</label><input type="tel" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/></div>
          <button type="submit" class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300">{T.requestQuote}</button>
        </form>
      </div>
    </div>
  </section>

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

</Layout>
