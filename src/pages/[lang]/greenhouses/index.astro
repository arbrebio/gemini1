const T = useT(lang as any);
const p = `/${lang}`;

const features = [
  { title: T.climateAdaptive, description: T.climateAdaptiveDesc, stats: ['40% cooler interior', '60% humidity control', '92% light transmission'], image: 'https://imgur.com/XtX9fmQ.jpg' },
  { title: T.structuralDurability, description: T.structuralDurabilityDesc, stats: ['20+ years lifespan', '150 km/h wind resistance', '25 kg/m² load capacity'], image: 'https://imgur.com/hKnWqYO.jpg' },
