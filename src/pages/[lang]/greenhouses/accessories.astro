const A = appsByLang[lang] ?? appsByLang.en;

const structuralComponents = [
  { category: C.archesTrusses, items: [
    { name: "Premium Arch 9600", specs: { material: "Hot-dip galvanized steel Z600", thickness: "2.0-3.0mm", loadCapacity: "55 kg/m²", span: "9.6 meters", coating: "275g/m² zinc" }, certifications: ["ISO 9001:2015","EN 1090-1"], image: "https://imgur.com/Fn2AVYj.jpg" },
    { name: "Reinforced Truss System", specs: { material: "Hot-dip galvanized steel Z600", thickness: "2.5-4.0mm", loadCapacity: "75 kg/m²", span: "8.0-12.0 meters", coating: "275g/m² zinc" }, certifications: ["ISO 9001:2015","EN 1090-1"], image: "https://imgur.com/h9Sd2nf.jpg" },
  ]},
  { category: C.supportSystems, items: [
    { name: "Heavy-Duty Column", specs: { material: "Hot-dip galvanized steel Z600", thickness: "3.0-4.0mm", loadCapacity: "2500 kg vertical", height: "3.0-6.0 meters", coating: "275g/m² zinc" }, certifications: ["ISO 9001:2015","EN 1090-1"], image: "https://imgur.com/9zbYXXU.jpg" },
    { name: "Cross Bracing Kit", specs: { material: "Hot-dip galvanized steel wire", thickness: "8mm diameter", loadCapacity: "1200 kg tension", length: "Customizable", coating: "275g/m² zinc" }, certifications: ["ISO 9001:2015"], image: "https://imgur.com/cgLqE5E.jpg" },
  ]},
];

const fasteners = [
  { category: C.structuralConnectors, items: [
    { name: "Heavy-Duty Bolt Set", specs: { material: "Grade 8.8 steel", size: "M8-M12", torque: "25-85 Nm", coating: "Hot-dip galvanized", standard: "DIN 933" }, applications: A.bolt, image: "https://imgur.com/Sz7oYdN.jpg" },
    { name: "Channel Connector", specs: { material: "Galvanized steel", thickness: "2.5mm", loadCapacity: "850 kg", coating: "Z275", standard: "EN 10346" }, applications: A.channel, image: "https://imgur.com/QGICSpN.jpg" },
  ]},
];

const coverageMaterials = [
  { category: C.filmsSheets, items: [
    { name: "Ultra-Clear EVA Film", specs: { material: "EVA copolymer", thickness: "200 microns", lightTransmission: "91%", uvStability: "48 months", thermalRetention: "85%" }, certifications: ["EN 13206","ISO 4892-2"], image: "https://imgur.com/v1WwRzr.jpg" },
    { name: "Diffused Light Film", specs: { material: "PE-EVA blend", thickness: "200 microns", lightDiffusion: "70%", uvStability: "48 months", thermalRetention: "82%" }, certifications: ["EN 13206","ISO 4892-2"], image: "https://imgur.com/yLyIJMa.jpg" },
  ]},
  { category: C.insectScreens, items: [
    { name: "Anti-Thrip Net", specs: { material: "HDPE monofilament", mesh: "50x25", uvStability: "5 years", airflow: "45%", shading: "22%" }, certifications: ["ISO 9001:2015"], image: "https://imgur.com/KRKFqz1.jpg" },
  ]},
];

