const T = (tr[lang] ?? tr.en) as Record<string, string>;

// Structural components — category names translated, product names stay (technical)
const catNames: Record<string, Record<string, string>> = {
  en: { archesTrusses: "Arches & Trusses", supportSystems: "Support Systems", structuralConnectors: "Structural Connectors", filmsSheets: "Films & Sheets", insectScreens: "Insect Screens" },
  fr: { archesTrusses: "Arcs et Fermes", supportSystems: "Systèmes de Support", structuralConnectors: "Connecteurs Structurels", filmsSheets: "Films et Feuilles", insectScreens: "Grillages Anti-Insectes" },
  es: { archesTrusses: "Arcos y Cerchas", supportSystems: "Sistemas de Soporte", structuralConnectors: "Conectores Estructurales", filmsSheets: "Películas y Láminas", insectScreens: "Mallas Anti-Insectos" },
  af: { archesTrusses: "Boë en Spante", supportSystems: "Ondersteuningstelsel", structuralConnectors: "Strukturele Verbinders", filmsSheets: "Filme en Plate", insectScreens: "Insekskermgaas" },
};
const C = (catNames[lang] ?? catNames.en) as Record<string, string>;

// Applications translation map
const appsByLang: Record<string, Record<string, string[]>> = {
  en: {
    bolt: ["Arch connections","Main frame assembly","Support bracing"],
    channel: ["Purlin connections","Cross member joining","Gutter support"],
    wire: ["Tomato support","Cucumber training","Vine crops"],
    trellis: ["Vertical growing","Plant training","Row crops"],
  },
  fr: {
    bolt: ["Connexions d'arcs","Assemblage du cadre principal","Contreventement de support"],
    channel: ["Connexions de pannes","Jonction des membrures transversales","Support de gouttière"],
    wire: ["Support de tomates","Formation des concombres","Cultures grimpantes"],
    trellis: ["Culture verticale","Formation des plantes","Cultures en rangées"],
  },
  es: {
    bolt: ["Conexiones de arcos","Ensamblaje del marco principal","Arriostramiento de soporte"],
    channel: ["Conexiones de correas","Unión de elementos transversales","Soporte de canalón"],
    wire: ["Soporte de tomates","Entrenamiento de pepinos","Cultivos en enredadera"],
    trellis: ["Cultivo vertical","Entrenamiento de plantas","Cultivos en filas"],
  },
  af: {
    bolt: ["Boogverbindings","Hoofraammontage","Ondersteuningsverstywing"],
    channel: ["Gordynverbindings","Dwarslid-samewerking","Geloopondersteuning"],
    wire: ["Tamatiestut","Komkommeropleiding","Rankgewasse"],
    trellis: ["Vertikale kweek","Plantopleiding","Rylgewasse"],
  },
