---

<Layout title={T.layoutTitle} description={T.layoutDesc}>
  <!-- Hero Section -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/qDUP4Vf.jpg" alt="Professional Greenhouse Components" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.heroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.heroSub}</span>
        </h1>
        <div class="flex flex-wrap gap-4">
          <a href="#quote-form" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300">{T.btnQuote}</a>
          <a href="#technical-specs" class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm">{T.btnSpecs}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Navigation -->
  <section class="py-8 bg-gray-50 sticky top-32 z-30 border-b">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#structural" class="px-4 py-2 rounded-full bg-white shadow-md hover:bg-primary hover:text-white transition-colors">{T.navStructural}</a>
        <a href="#fasteners" class="px-4 py-2 rounded-full bg-white shadow-md hover:bg-primary hover:text-white transition-colors">{T.navFasteners}</a>
        <a href="#coverage" class="px-4 py-2 rounded-full bg-white shadow-md hover:bg-primary hover:text-white transition-colors">{T.navCoverage}</a>
        <a href="#growing" class="px-4 py-2 rounded-full bg-white shadow-md hover:bg-primary hover:text-white transition-colors">{T.navGrowing}</a>
      </div>
    </div>
  </section>

  <!-- Structural Components -->
  <section id="structural" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">{T.secStructural}</h2>
      {structuralComponents.map((category) => (
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-8">{category.category}</h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {category.items.map((item) => (
              <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                  <img src={item.image} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-6">
                  <h4 class="text-xl font-bold mb-4">{item.name}</h4>
                  <div class="space-y-2 mb-4">
                    {Object.entries(item.specs).map(([key, value]) => (
                      <div class="flex justify-between">
                        <span class="text-gray-600 capitalize">{key.replace(/([A-Z])/g, ' $1').trim()}:</span>
                        <span class="font-medium">{value}</span>
                      </div>
                    ))}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {item.certifications.map((cert) => (
                      <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">{cert}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Fasteners Section -->
  <section id="fasteners" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">{T.secFasteners}</h2>
      {fasteners.map((category) => (
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-8">{category.category}</h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {category.items.map((item) => (
              <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                  <img src={item.image} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-6">
                  <h4 class="text-xl font-bold mb-4">{item.name}</h4>
                  <div class="space-y-2 mb-4">
                    {Object.entries(item.specs).map(([key, value]) => (
                      <div class="flex justify-between">
                        <span class="text-gray-600 capitalize">{key.replace(/([A-Z])/g, ' $1').trim()}:</span>
                        <span class="font-medium">{value}</span>
                      </div>
                    ))}
                  </div>
                  <h5 class="font-bold mb-2">{T.lblApplications}</h5>
                  <ul class="space-y-1">
                    {item.applications.map((app) => (
                      <li class="flex items-center text-gray-700">
                        <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        {app}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Coverage Materials -->
  <section id="coverage" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">{T.secCoverage}</h2>
      {coverageMaterials.map((category) => (
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-8">{category.category}</h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {category.items.map((item) => (
              <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                  <img src={item.image} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-6">
                  <h4 class="text-xl font-bold mb-4">{item.name}</h4>
                  <div class="space-y-2 mb-4">
                    {Object.entries(item.specs).map(([key, value]) => (
                      <div class="flex justify-between">
                        <span class="text-gray-600 capitalize">{key.replace(/([A-Z])/g, ' $1').trim()}:</span>
                        <span class="font-medium">{value}</span>
                      </div>
                    ))}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {item.certifications.map((cert) => (
                      <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm">{cert}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Growing Accessories -->
  <section id="growing" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">{T.secGrowing}</h2>
