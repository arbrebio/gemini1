    { name: "Crop Support Wire", specs: { material: "High-tensile steel", diameter: "2.5mm", coating: "Hot-dip galvanized", strength: "700 N/mm²", rollLength: "500m" }, applications: A.wire, image: "https://imgur.com/U8pORSQ.jpg" },
    { name: "Trellis Support System", specs: { material: "Galvanized steel", wireSpacing: "20cm", postHeight: "2.5m", loadCapacity: "45 kg/m", coating: "Z275" }, applications: A.trellis, image: "https://imgur.com/jKVZds5.jpg" },
  ]},
];

type Cert = { name: string; description: string; icon: string };
const certsByLang: Record<string, Cert[]> = {
  en: [
    { name: "ISO 9001:2015", description: "Quality Management System", icon: "medal" },
    { name: "EN 1090-1", description: "Structural Steel Components", icon: "greenhouse" },
    { name: "EN 13206", description: "Greenhouse Covering Materials", icon: "leaf" },
  ],
  fr: [
    { name: "ISO 9001:2015", description: "Système de Management de la Qualité", icon: "medal" },
    { name: "EN 1090-1", description: "Composants en Acier Structurel", icon: "greenhouse" },
    { name: "EN 13206", description: "Matériaux de Couverture pour Serres", icon: "leaf" },
  ],
  es: [
    { name: "ISO 9001:2015", description: "Sistema de Gestión de Calidad", icon: "medal" },
    { name: "EN 1090-1", description: "Componentes de Acero Estructural", icon: "greenhouse" },
    { name: "EN 13206", description: "Materiales de Cobertura para Invernaderos", icon: "leaf" },
  ],
  af: [
