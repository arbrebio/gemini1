---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const stats = [
  { value: '500+', label: T.projectsCompleted, target: '500' },
  { value: '5', label: T.africanCountries, target: '5' },
  { value: '50k+', label: lang === 'fr' ? 'Hectares OptimisÃ©s' : lang === 'es' ? 'HectÃ¡reas Optimizadas' : 'Hektaar Geoptimaliseer', target: '50000' },
  { value: '60%', label: T.waterSavings, target: '60' }
];

const solutions = [
  { icon: 'ð§', title: T.piTitle, description: T.piDesc, stats: [`50% ${T.waterSavings}`, `40% ${T.yieldIncrease}`, '2-year ROI'] },
  { icon: 'ð±', title: T.gsTitle, description: T.gsDesc, stats: [T.organic100, `8x ${T.superiorWater}`, '5-year lifespan'] },
  { icon: 'ðï¸', title: T.gcTitle, description: T.gcDesc, stats: ['40% cooler inside', '90% pest reduction', '20-year durability'] },
  { icon: 'ð±', title: T.digitalTitle, description: T.digitalDesc, stats: ['24/7 monitoring', 'Real-time alerts', 'Data-driven insights'] },
];

const timeline = [
  { year: 2020, event: T.y2020t, description: T.y2020d, icon: 'ð±' },
  { year: 2021, event: T.y2021t, description: T.y2021d, icon: 'ðï¸' },
  { year: 2022, event: T.y2022t, description: T.y2022d, icon: 'ð¤' },
  { year: 2023, event: T.y2023t, description: T.y2023d, icon: 'ð' },
  { year: 2024, event: T.y2024t, description: T.y2024d, icon: 'ð»' },
  { year: 2025, event: T.y2025t, description: T.y2025d, icon: 'ð' },
];
---

<Layout
  title={`${lang === 'fr' ? 'Entreprise' : lang === 'es' ? 'Empresa' : 'Maatskappy'} | Arbre Bio Africa`}
  description={T.companyHeroTagline}
>

  <!-- Hero -->
  <section class="relative h-screen overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="parallax-bg w-full h-[120%] absolute top-0" style="background-image: url('https://imgur.com/2Pt8VXW.jpg'); background-size: cover; background-position: center;"></div>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="relative z-10 h-full flex items-center">
      <div class="container mx-auto px-4">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 animate-fade-in">
          {T.companyHeroTitle}
          <span class="block text-3xl md:text-4xl mt-4 text-primary-100">{T.companyHeroSubtitle}</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-2xl mb-8 animate-slide-up">{T.companyHeroTagline}</p>
        <div class="flex flex-wrap gap-4">
          <a href="#solutions" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-all duration-300 transform hover:scale-105">{T.exploreOurSolutions}</a>
          <a href={`${p}/contact`} class="bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-all duration-300 transform hover:scale-105">{T.contactTitle}</a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center transform hover:scale-105 transition-transform duration-300">
            <div class="text-4xl font-bold text-primary mb-2 counter" data-target={stat.target}>{stat.value}</div>
            <div class="text-gray-600">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full absolute top-0" style="background-image: url('https://images.unsplash.com/photo-1592982537447-6f2a6a0c8b8d?ixlib=rb-4.0.3'); background-size: cover; background-position: center;"></div>
      <div class="absolute inset-0 bg-primary bg-opacity-90 backdrop-blur-sm"></div>
    </div>
    <div class="relative z-10 container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center text-white">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">{T.ourMission}</h2>
        <p class="text-xl leading-relaxed">{T.companyMissionText}</p>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{T.ourLeadership}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
        <div class="text-center">
          <img src="https://imgur.com/LAiwg8o.png" alt={T.ceoName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.ceoName}</h3>
          <p class="text-primary font-semibold mb-3">{T.ceoTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.ceoBio}</p>
        </div>
        <div class="text-center">
          <img src="https://imgur.com/LD5JZto.jpg" alt={T.cooName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.cooName}</h3>
          <p class="text-primary font-semibold mb-3">{T.cooTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.cooBio}</p>
        </div>
        <div class="text-center">
          <img src="https://imgur.com/NU06wJT.jpg" alt={T.marketingName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.marketingName}</h3>
          <p class="text-primary font-semibold mb-3">{T.marketingTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.marketingBio}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section id="solutions" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{T.ourServices}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {solutions.map((solution) => (
          <div class="bg-white rounded-lg shadow-lg p-6 transform hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
            <div class="text-4xl mb-4">{solution.icon}</div>
            <h3 class="text-xl font-bold mb-3">{solution.title}</h3>
            <p class="text-gray-600 mb-4">{solution.description}</p>
            <div class="space-y-2">
              {solution.stats.map((stat) => (
                <div class="flex items-center text-primary">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {stat}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">{T.ourJourney}</h2>
      <div class="max-w-4xl mx-auto space-y-8">
        {timeline.map((item) => (
          <div class="flex gap-6 items-start">
            <div class="bg-primary text-white w-14 h-14 rounded-full flex items-center justify-center text-2xl flex-shrink-0 shadow-lg">{item.icon}</div>
            <div class="bg-gray-50 p-6 rounded-lg shadow-md flex-1 hover:shadow-lg transition-shadow duration-300">
              <div class="text-2xl font-bold text-primary mb-1">{item.year}</div>
              <div class="text-lg font-semibold text-gray-800 mb-2">{item.event}</div>
              <div class="text-gray-600">{item.description}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90 transform hover:scale-105 transition-all duration-300">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 transform hover:scale-105 transition-all duration-300 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .parallax-bg { transform: translateY(var(--scroll-offset, 0)); will-change: transform; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 1s ease-out; }
  .animate-slide-up { animation: slideUp 1s ease-out; }
</style>

<script is:inline>
  const parallaxEls = document.querySelectorAll('.parallax-bg');
  window.addEventListener('scroll', function() {
    parallaxEls.forEach(function(el) { el.style.setProperty('--scroll-offset', (window.scrollY * 0.5) + 'px'); });
  });
  function animateCounter(counter) {
    var targetStr = counter.getAttribute('data-target') || '0';
    var target = parseInt(targetStr.replace(/\D/g, ''), 10);
    if (!target) return;
    var startTime = null;
    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / 1500, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      counter.textContent = Math.round(eased * target).toString();
      if (progress < 1) { requestAnimationFrame(step); }
      else { counter.textContent = counter.getAttribute('data-target') || targetStr; }
    }
    requestAnimationFrame(step);
  }
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { animateCounter(e.target); obs.unobserve(e.target); } });
    }, { threshold: 0.3 });
    document.querySelectorAll('.counter').forEach(function(c) { obs.observe(c); });
  }
</script>
