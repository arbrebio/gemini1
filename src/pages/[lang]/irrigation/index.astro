      t('pages.irrigation.technologies.fertigation.benefits.monitoring'),
      t('pages.irrigation.technologies.fertigation.benefits.waste')
    ],
    image: 'https://imgur.com/NnkgMDq.jpg',
    caseStudy: {
      title: t('pages.irrigation.technologies.fertigation.caseStudy.title'),
      result: t('pages.irrigation.technologies.fertigation.caseStudy.result')
    }
  },
  {
    title: t('pages.irrigation.technologies.digital.title'),
    description: t('pages.irrigation.technologies.digital.description'),
    specs: [
      { label: t('pages.irrigation.technologies.digital.specs.range'), value: t('pages.irrigation.technologies.digital.specs.rangeValue') },
      { label: t('pages.irrigation.technologies.digital.specs.update'), value: t('pages.irrigation.technologies.digital.specs.updateValue') },
      { label: t('pages.irrigation.technologies.digital.specs.battery'), value: t('pages.irrigation.technologies.digital.specs.batteryValue') },
      { label: t('pages.irrigation.technologies.digital.specs.accuracy'), value: t('pages.irrigation.technologies.digital.specs.accuracyValue') }
    ],
    benefits: [
      t('pages.irrigation.technologies.digital.benefits.monitoring'),
      t('pages.irrigation.technologies.digital.benefits.datadriven'),
      t('pages.irrigation.technologies.digital.benefits.remote'),
      t('pages.irrigation.technologies.digital.benefits.predictive')
    ],
    image: 'https://imgur.com/3VCs7hJ.jpg',
    caseStudy: {
      title: t('pages.irrigation.technologies.digital.caseStudy.title'),
      result: t('pages.irrigation.technologies.digital.caseStudy.result')
    }
  },
  {
    title: t('pages.irrigation.technologies.treatment.title'),
    description: t('pages.irrigation.technologies.treatment.description'),
    specs: [
