      { icon: "phone", title: "Pilotage Automatisé & Connecté", desc: "Contrôleurs intelligents avec programmation horaire, capteurs d'humidité, et gestion à distance depuis votre smartphone." },
      { icon: "trophy", title: "ROI Rapide", desc: "Nos clients récupèrent leur investissement en 1 à 2 saisons grâce aux économies d'eau, d'engrais et à l'augmentation des rendements." },
    ],
    productsH2: "Nos Systèmes d'Irrigation",
    productsSub: "De l'irrigation goutte-à-goutte à l'aspersion automatisée, découvrez nos solutions complètes pour chaque type de culture et d'exploitation agricole en Afrique.",
    dripSpecs: ["Goutteurs compensants pression", "Tuyaux anti-colmatage", "Filtres à sable et à disques", "Vannes de secteur automatisées"],
    sprinklerSpecs: ["Asperseurs rotatifs et fixes", "Micro-aspersion sous serre", "Canons d'arrosage grandes surfaces", "Rampes d'arrosage mobiles"],
