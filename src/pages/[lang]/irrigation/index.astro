---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";
import EmojiIcon from '../../../components/EmojiIcon.astro';

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const content: Record<string, {
  metaTitle: string; metaDesc: string;
  heroLabel: string; heroH1: string; heroSubtitle: string;
  statLabels: string[];
  whyH2: string; whyP1: string; whyP2: string; whyP3: string;
  benefits: { icon: string; title: string; desc: string }[];
  productsH2: string; productsSub: string;
  dripSpecs: string[]; sprinklerSpecs: string[]; fertigationSpecs: string[];
  digitalSpecs: string[]; waterSpecs: string[];
  customTitle: string; customDesc: string; customBtn: string;
  processH2: string;
  steps: { title: string; desc: string }[];
  faqH2: string;
  faq: { q: string; a: string }[];
  ctaH2: string; ctaSub: string; ctaSecondary: string;
}> = {
  fr: {
    metaTitle: "Systèmes d'Irrigation Agricole en Afrique | Goutte-à-Goutte, Aspersion & Fertigation | Arbre Bio",
