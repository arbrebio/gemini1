const c = content[lang] ?? content.fr;

const scriptOpen = '<' + 'script type="application/ld+json">';
const scriptClose = '<' + '/script>';
const jsonLdData = scriptOpen + JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": c.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
}) + scriptClose;
---
<Layout title={c.metaTitle} description={c.metaDesc}>

  {/* Hero */}
  <section class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-cyan-700 text-white py-20 px-4 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/irrigation-hero.jpg')] bg-cover bg-center"></div>
    <div class="relative max-w-6xl mx-auto text-center">
      <p class="text-cyan-300 font-semibold text-sm uppercase tracking-widest mb-4">{c.heroLabel}</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">{c.heroH1}</h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto mb-8">{c.heroSubtitle}</p>
      <div class="flex flex-wrap gap-4 justify-center mb-12">
        <a href={`/${lang}/contact`} class="bg-cyan-500 hover:bg-cyan-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.freeConsultation}
        </a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.chatWhatsApp}
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {[
          { value: "70%", label: c.statLabels[0] },
          { value: "2×",  label: c.statLabels[1] },
          { value: "200+",label: c.statLabels[2] },
          { value: "98%", label: c.statLabels[3] },
        ].map(s => (
          <div class="bg-white/10 backdrop-blur rounded-xl p-4">
            <div class="text-3xl font-bold text-cyan-300">{s.value}</div>
            <div class="text-sm text-blue-200 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Why Irrigation Section */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-blue-900 mb-6">{c.whyH2}</h2>
          <p class="text-gray-700 mb-4 leading-relaxed">{c.whyP1}</p>
          <p class="text-gray-700 mb-4 leading-relaxed">{c.whyP2}</p>
          <p class="text-gray-700 leading-relaxed">{c.whyP3}</p>
        </div>
        <div class="space-y-4">
          {c.benefits.map(item => (
            <div class="flex gap-4 p-4 bg-blue-50 rounded-xl">
              <span class="text-2xl flex-shrink-0"><EmojiIcon id={item.icon} size="2rem" /></span>
              <div>
                <div class="font-bold text-blue-900 mb-1">{item.title}</div>
                <div class="text-gray-600 text-sm">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Products Section */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 text-center mb-4">{c.productsH2}</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-12">{c.productsSub}</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-blue-500">
          <div class="text-4xl mb-3"><EmojiIcon id="water" size="2rem" /></div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{T.dripTitle}</h3>
          <p class="text-gray-600 text-sm mb-4">{T.dripDesc}</p>
          <ul class="text-xs text-gray-500 space-y-1">
            {c.dripSpecs.map(s => <li>✓ {s}</li>)}
          </ul>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-cyan-500">
          <div class="text-4xl mb-3"><EmojiIcon id="wave" size="2rem" /></div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{T.sprinklerTitle}</h3>
          <p class="text-gray-600 text-sm mb-4">{T.sprinklerDesc}</p>
          <ul class="text-xs text-gray-500 space-y-1">
            {c.sprinklerSpecs.map(s => <li>✓ {s}</li>)}
          </ul>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-green-500">
          <div class="text-4xl mb-3"><EmojiIcon id="flask" size="2rem" /></div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{T.fertigationTitle}</h3>
          <p class="text-gray-600 text-sm mb-4">{T.fertigationDesc}</p>
          <ul class="text-xs text-gray-500 space-y-1">
            {c.fertigationSpecs.map(s => <li>✓ {s}</li>)}
          </ul>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-purple-500">
          <div class="text-4xl mb-3"><EmojiIcon id="phone" size="2rem" /></div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{T.digitalTitle}</h3>
          <p class="text-gray-600 text-sm mb-4">{T.digitalDesc}</p>
          <ul class="text-xs text-gray-500 space-y-1">
            {c.digitalSpecs.map(s => <li>✓ {s}</li>)}
          </ul>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-orange-500">
          <div class="text-4xl mb-3"><EmojiIcon id="microscope" size="2rem" /></div>
          <h3 class="text-xl font-bold text-blue-900 mb-2">{T.waterTreatmentTitle}</h3>
          <p class="text-gray-600 text-sm mb-4">{T.waterTreatmentDesc}</p>
          <ul class="text-xs text-gray-500 space-y-1">
            {c.waterSpecs.map(s => <li>✓ {s}</li>)}
          </ul>
        </div>

        <div class="bg-gradient-to-br from-blue-600 to-cyan-600 rounded-2xl shadow-sm p-6 text-white">
          <div class="text-4xl mb-3"><EmojiIcon id="target" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-2">{c.customTitle}</h3>
          <p class="text-blue-100 text-sm mb-4">{c.customDesc}</p>
          <a href={`/${lang}/contact`} class="inline-block bg-white text-blue-700 font-bold py-2 px-6 rounded-lg text-sm hover:bg-blue-50 transition-colors">
            {c.customBtn}
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Process Section */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 text-center mb-12">{c.processH2}</h2>
      <div class="space-y-6">
        {c.steps.map((item, i) => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div>
              <h3 class="font-bold text-blue-900 text-lg mb-1">{item.title}</h3>
              <p class="text-gray-600">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 text-center mb-12">{c.faqH2}</h2>
      <div class="space-y-6">
        {c.faq.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-blue-900 text-lg mb-3">{item.q}</h3>
            <p class="text-gray-700 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 px-4 bg-blue-900 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">{c.ctaH2}</h2>
      <p class="text-blue-200 text-lg mb-8 max-w-2xl mx-auto">{c.ctaSub}</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${lang}/contact`} class="bg-cyan-500 hover:bg-cyan-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.freeConsultation}
        </a>
        <a href={`/${lang}/irrigation/drip-systems`} class="border-2 border-white text-white hover:bg-white hover:text-blue-900 font-bold py-3 px-8 rounded-lg transition-colors">
          {c.ctaSecondary}
        </a>
      </div>
    </div>
  </section>

  {/* FAQ Schema */}
  <Fragment set:html={jsonLdData} />

</Layout>
