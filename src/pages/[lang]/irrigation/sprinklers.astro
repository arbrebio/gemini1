        type: ["Besproeiing"],
        pressure: ["Medium druk", "Lae druk"],
        coverage: ["Volle dekking: medium spasiëring", "Volle dekking: klein spasiëring"],
        crops: ["Veldgewasse", "Boorde"],
        trajectory: ["Laag"],
      },
      advantages: ["Optimale waterverspreidingsuniformiteit","Verminderde verdamping in winderige toestande","Duursame UV-beskermde materiale","Maklike onderhoud en skoonmaak","Veelsydige installasie-opsies","Lang produklewe"],
      limitations: ["Beperk tot spesifieke spasiëringsvereistes","Vereis minimum werkdruk","Vaste trajektor hoek"],
    },
    {
      name: "D-NET™ 8550 F.R.",
      shortDescription: "DUURSAME IMPAK SPRINKLER MET VLOEIGEREGULEERDE MONDSTUKKE VIR VELDGEWASSE",
      description: "D-Net™ 8550 F.R. 1/2\" impak sprinklers met 3D diffusiearm en unieke vloeigereguleerde mondstukke waarborg uitstekende gewasuniformiteit vir veldgewasse met spasiëring tot 12×14 meter.",
      image: "https://imgur.com/KWWtez3.jpg",
      catalog: "https://www.netafim.africa/globalassets/products/sprinklers/d-net/8550-f.r/netafim-d-net-8550-fr-technical-product-sheet.pdf",
      features: [
        { title: "Hoë en uniforme opbrengste", description: "Innoverende 3D diffusiearm en unieke vloeigereguleerde mondstukke verseker die hoogste vlak van waterverspreidingsuniformiteit vir konsekwente produksie." },
        { title: "Groter watereffektiwiteit", description: "Uitstekende waterverspreidingsuniformiteit elimineer oor-besproeiing en optimeer watergebruik." },
        { title: "Langdurige prestasie", description: "Taai UV-beskermde materiale weerstaan alle klimaatstoestande en toegepaste chemikalieë vir problemlose werking." },
        { title: "Veelsydige installasie", description: "Installeer op vaste stelsels of op verwisselbare veldstaanders." },
        { title: "Arbeidsbesparende onderhoud", description: "Spesiale mondstuksleutel maak dit maklik om rommel van die mondstuk te verwyder selfs onder druk." },
      ],
      specifications: {
        general: { type: "1/2\" impak sprinkler", design: "3D diffusiearm", trajectory: "24 grade", coverage: "Tot 12×14 m spasiëring" },
        performance: { "Vloeitempo's": "590, 680, 800 L/H", "Drukregulasie": "2,5 tot 4,0 bar", "Trajektor hoek": "24°", "Mondstukke": "Kleurkodering" },
        technical: { "Verspreiding": "Vloeigereguleerde mondstukke", "Inlaatverbinder": "1/2\" manlike skroefdraad" },
      },
      applications: {
        type: ["Besproeiing"],
        pressure: ["Medium druk", "Lae druk"],
        coverage: ["Volle dekking: klein spasiëring"],
        crops: ["Veldgewasse"],
        trajectory: ["Normaal"],
      },
      advantages: ["Hoogste waterverspreidingsuniformiteit","Vloeiregulasie vir konsekwente werkverrigting","UV-beskermde duursame materiale","Maklike onderhoud met spesiale mondstuksleutel","Buigsame installasie-opsies","Kleurgekodineerde mondstukke vir maklike identifikasie"],
      limitations: ["Spesifieke spasiëringsvereistes","Minimum druk vereistes","Vaste trajektor hoek"],
    },
  ],
};
const products = productsByLang[lang] ?? productsByLang.en;

type Cert = { name: string; description: string; icon: string };
const certsByLang: Record<string, Cert[]> = {
  en: [
    { name: "ISO 9001:2015", description: "Manufacturer Quality Management", icon: "medal" },
    { name: "Irrigation Uniformity", description: "Certified and tested flow uniformity", icon: "target" },
    { name: "UV Resistance", description: "Certified for professional agricultural use", icon: "shield" },
  ],
  fr: [
    { name: "ISO 9001:2015", description: "Système de Management de la Qualité du Fabricant", icon: "medal" },
    { name: "Uniformité d'Irrigation", description: "Uniformité de débit certifiée et testée", icon: "target" },
    { name: "Résistance UV", description: "Certifié pour usage agricole professionnel", icon: "shield" },
  ],
  es: [
    { name: "ISO 9001:2015", description: "Sistema de Gestión de Calidad del Fabricante", icon: "medal" },
    { name: "Uniformidad de Riego", description: "Uniformidad de caudal certificada y probada", icon: "target" },
    { name: "Resistencia UV", description: "Certificado para uso agrícola profesional", icon: "shield" },
  ],
  af: [
    { name: "ISO 9001:2015", description: "Vervaardiger Kwaliteitsbestuurstelsel", icon: "medal" },
    { name: "Besproeiingsuniformiteit", description: "Gesertifiseerde en getoetste vloei-uniformiteit", icon: "target" },
    { name: "UV-Weerstand", description: "Gesertifiseer vir professionele landbougebruik", icon: "shield" },
  ],
};
const certifications = certsByLang[lang] ?? certsByLang.en;
---

<Layout title={T.layoutTitle} description={T.layoutDesc}>
  <!-- Hero Section -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/0VWoT9T.jpg" alt="Professional Irrigation Sprinklers" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.heroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.heroSub}</span>
        </h1>
        <p class="text-xl text-white mb-8">{T.heroPara}</p>
        <div class="flex flex-wrap gap-4">
          <a href="#products" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300">{T.btnProducts}</a>
          <a href="#quote-form" class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm">{T.btnQuote}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secProducts}</h2>
      {products.map((product, index) => (
        <div class={`mb-20 ${index !== 0 ? 'border-t pt-20' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <h3 class="text-2xl font-bold mb-4">{product.name}</h3>
              <p class="text-lg font-medium text-primary mb-4">{product.shortDescription}</p>
              <p class="text-gray-600 mb-6">{product.description}</p>
              <div class="space-y-6">
                <div>
                  <h4 class="font-bold mb-3">{T.lblFeatures}</h4>
                  <div class="space-y-4">
                    {product.features.map((feature) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-1">{feature.title}</h5>
                        <p class="text-gray-600 text-sm">{feature.description}</p>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <h4 class="font-bold mb-3">{T.lblSpecs}</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {Object.entries(product.specifications).map(([category, specs]) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-2 capitalize">{category}</h5>
                        <div class="space-y-2">
                          {Object.entries(specs).map(([key, value]) => (
                            <div class="flex justify-between text-sm">
                              <span class="text-gray-600">{key}:</span>
                              <span class="font-medium">{value}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <h4 class="font-bold mb-3">{T.lblApplications}</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {Object.entries(product.applications).map(([category, items]) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-2 capitalize">{category}</h5>
                        <ul class="space-y-1 text-sm">
                          {items.map((item) => (
                            <li class="flex items-center text-gray-700">
                              <svg class="w-4 h-4 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                              </svg>
                              {item}
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <h4 class="font-bold mb-3">{T.lblAdvantages}</h4>
                    <ul class="space-y-2">
                      {product.advantages.map((advantage) => (
                        <li class="flex items-center text-gray-700 text-sm">
                          <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                          </svg>
                          {advantage}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <h4 class="font-bold mb-3">{T.lblLimitations}</h4>
                    <ul class="space-y-2">
                      {product.limitations.map((limitation) => (
                        <li class="flex items-center text-gray-700 text-sm">
                          <svg class="w-4 h-4 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                          </svg>
                          {limitation}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
                <div>
                  <h4 class="font-bold mb-3">{T.lblDocs}</h4>
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <a href={product.catalog} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-primary hover:text-primary-600 transition-colors">
                      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                      {T.btnDownload}
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img src={product.image} alt={product.name} class="w-full h-[400px] object-cover rounded-lg shadow-lg" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secCerts}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {certifications.map((cert) => (
          <div class="bg-white p-6 rounded-lg shadow-lg text-center">
            <div class="text-4xl mb-4"><EmojiIcon id={cert.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold mb-2">{cert.name}</h3>
            <p class="text-gray-600">{cert.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{T.formTitle}</h2>
        <form class="bg-gray-50 p-8 rounded-lg shadow-lg space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblFirstName}</label>
              <input type="text" required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblLastName}</label>
              <input type="text" required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblEmail}</label>
            <input type="email" required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblPhone}</label>
            <input type="tel" required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblProduct}</label>
            <select required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50">
              <option value="">{T.selectProduct}</option>
              {products.map((product) => (<option value={product.name}>{product.name}</option>))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblAppType}</label>
            <select required class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50">
              <option value="">{T.selectAppType}</option>
              <option value="field-crops">{T.optFieldCrops}</option>
              <option value="orchards">{T.optOrchards}</option>
              <option value="other">{T.optOther}</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblArea}</label>
            <input type="number" required min="0.1" step="0.1" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblAdditional}</label>
            <textarea rows="4" class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" placeholder={T.phAdditional}></textarea>
          </div>
          <button type="submit" class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300">{T.btnSubmit}</button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaDesc}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.btnContact}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.btnWhatsapp}
        </a>
      </div>
    </div>
  </section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "D-Net™ 0950 Sprinkler",
  "description": "Professional low trajectory impact sprinkler for uniform under-canopy irrigation, ideal for banana and oil palm plantations.",
  "brand": { "@type": "Brand", "name": "Netafim" },
  "manufacturer": { "@type": "Organization", "name": "Netafim", "url": "https://arbrebio.com" },
  "offers": { "@type": "Offer", "priceCurrency": "XOF", "availability": "https://schema.org/InStock" },
  "image": ["https://imgur.com/vQFO4ob.jpg"]
}
</script>
