---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;
---
<Layout title={`${T.sprinklerTitle} | Arbre Bio Africa`} description={T.irrTagline}>
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/fwHJKYs.jpg" alt="" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-55"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{T.sprinklerTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.irrTagline}</p>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 text-center max-w-2xl mx-auto">
      <p class="text-lg text-gray-600 mb-8">{T.irrTagline}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors">{T.requestQuote}</a>
        <a href={`${p}/irrigation`} class="border-2 border-primary text-primary px-8 py-4 rounded-full text-lg hover:bg-primary/5 transition-colors">{T.exploreSolutions}</a>
      </div>
    </div>
  </section>
</Layout>
