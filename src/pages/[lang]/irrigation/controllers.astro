---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, getLangFromUrl } from '../../../lib/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);



const products = [
  {
    name: t('irrigation.controllers.espTm2.name'),
    shortDescription: t('irrigation.controllers.espTm2.shortDescription'),
    description: t('irrigation.controllers.espTm2.description'),
    image: "https://imgur.com/NaJWgvW.jpg",
    features: [
      t('irrigation.controllers.espTm2.features.wifi'),
      t('irrigation.controllers.espTm2.features.weather'),
      t('irrigation.controllers.espTm2.features.stations'),
      t('irrigation.controllers.espTm2.features.daysOff'),
      t('irrigation.controllers.espTm2.features.installation'),
      t('irrigation.controllers.espTm2.features.programming'),
      t('irrigation.controllers.espTm2.features.programs'),
      t('irrigation.controllers.espTm2.features.manual'),
      t('irrigation.controllers.espTm2.features.display'),
      t('irrigation.controllers.espTm2.features.contractor'),
      t('irrigation.controllers.espTm2.features.delay'),
      t('irrigation.controllers.espTm2.features.sensor'),
      t('irrigation.controllers.espTm2.features.seasonal')
    ],
    specifications: {
      [t('irrigation.controllers.espTm2.specs.operating.title')]: {
        [t('irrigation.controllers.labels.temperature')]: t('irrigation.controllers.espTm2.specs.operating.temperature'),
        [t('irrigation.controllers.labels.storage')]: t('irrigation.controllers.espTm2.specs.operating.storage'),
        [t('irrigation.controllers.labels.humidity')]: t('irrigation.controllers.espTm2.specs.operating.humidity')
      },
      [t('irrigation.controllers.espTm2.specs.electrical.title')]: {
        [t('irrigation.controllers.labels.input')]: {
          [t('irrigation.controllers.specs.standard')]: t('irrigation.controllers.espTm2.specs.electrical.inputStandard'),
          [t('irrigation.controllers.specs.international')]: t('irrigation.controllers.espTm2.specs.electrical.inputInternational')
        },
        [t('irrigation.controllers.labels.output')]: {
          [t('irrigation.controllers.specs.standard')]: t('irrigation.controllers.espTm2.specs.electrical.outputStandard'),
          [t('irrigation.controllers.labels.indoor')]: t('irrigation.controllers.espTm2.specs.electrical.outputIndoor')
        }
      },
      [t('irrigation.controllers.espTm2.specs.dimensions.title')]: {
        [t('irrigation.controllers.specs.standard')]: {
          [t('irrigation.controllers.labels.width')]: t('irrigation.controllers.espTm2.specs.dimensions.standardWidth'),
          [t('irrigation.controllers.labels.height')]: t('irrigation.controllers.espTm2.specs.dimensions.standardHeight'),
          [t('irrigation.controllers.labels.depth')]: t('irrigation.controllers.espTm2.specs.dimensions.standardDepth')
        },
        [t('irrigation.controllers.labels.indoor')]: {
          [t('irrigation.controllers.labels.width')]: t('irrigation.controllers.espTm2.specs.dimensions.indoorWidth'),
          [t('irrigation.controllers.labels.height')]: t('irrigation.controllers.espTm2.specs.dimensions.indoorHeight'),
          [t('irrigation.controllers.labels.depth')]: t('irrigation.controllers.espTm2.specs.dimensions.indoorDepth')
        }
      }
    },
    models: {
      [t('irrigation.controllers.espTm2.models.vac120')]: [
        "TM2-4-120V: 4-station",
        "TM2-6-120V: 6-station",
        "TM2-8-120V: 8-station",
        "TM2-12-120V: 12-station"
      ],
      [t('irrigation.controllers.espTm2.models.vac230')]: [
        "TM2-4-230V: 4-station",
        "TM2-6-230V: 6-station",
        "TM2-8-230V: 8-station",
        "TM2-12-230V: 12-station",
        "TM2I4-230V: 4-station (Indoor)",
        "TM2I6-230V: 6-station (Indoor)",
        "TM2I8-230V: 8-station (Indoor)",
        "TM2I12-230V: 12-station (Indoor)"
      ],
      [t('irrigation.controllers.espTm2.models.australia')]: [
        "TM2-4-AUS: 4-station",
        "TM2-6-AUS: 6-station",
        "TM2-8-AUS: 8-station",
        "TM2-12-AUS: 12-station"
      ]
    },
    accessories: [
      {
        name: "LNKWIFI",
        description: t('irrigation.controllers.espTm2.accessories.lnkwifi')
      },
      {
        name: "WR2-RFC",
        description: t('irrigation.controllers.espTm2.accessories.rainFreeze')
      },
      {
        name: "WR2-48",
        description: t('irrigation.controllers.espTm2.accessories.rainFreeze48')
      },
      {
        name: "RSD-BEx",
        description: t('irrigation.controllers.espTm2.accessories.rainSensor')
      }
    ],
    certifications: {
      [t('irrigation.controllers.espTm2.models.vac120')]: [
        "cULus (US and Canada)",
        "FCC Part 15b (US)",
        "CAN ICES-3(B)/NMB-3(B) (Canada)",
        "NOM-001-SCFI-2018 (Mexico)"
      ],
      [t('irrigation.controllers.espTm2.models.vac230')]: [
        "CE (European Union)",
        "IP24",
        "RCM (Australia and New Zealand)",
        "IRAM (Argentina)",
        "EAC (Eurasian Economic Union)",
        "ICASA (South Africa)",
        "CMAC (Moldova)",
        "Kvalitet (Serbia)",
        "UkrSEPRO (Ukraine)"
      ]
    }
  },
  {
    name: t('irrigation.controllers.st8.name'),
    shortDescription: t('irrigation.controllers.st8.shortDescription'),
    description: t('irrigation.controllers.st8.description'),
    image: "https://imgur.com/U5GEgAP.jpg",
    features: [
      t('irrigation.controllers.st8.features.wifi'),
      t('irrigation.controllers.st8.features.reports'),
      t('irrigation.controllers.st8.features.manual'),
      t('irrigation.controllers.st8.features.seasonal'),
      t('irrigation.controllers.st8.features.scheduling'),
      t('irrigation.controllers.st8.features.alerts'),
      t('irrigation.controllers.st8.features.remote'),
      t('irrigation.controllers.st8.features.setup'),
      t('irrigation.controllers.st8.features.zones'),
      t('irrigation.controllers.st8.features.backup'),
      t('irrigation.controllers.st8.features.sensor'),
      t('irrigation.controllers.st8.features.master')
    ],
    specifications: {
      [t('irrigation.controllers.st8.specs.operating.title')]: {
        [t('irrigation.controllers.labels.timing')]: t('irrigation.controllers.st8.specs.operating.timing'),
        [t('irrigation.controllers.labels.seasonal')]: t('irrigation.controllers.st8.specs.operating.seasonal'),
        [t('irrigation.controllers.labels.startTimes')]: t('irrigation.controllers.st8.specs.operating.startTimes'),
        [t('irrigation.controllers.labels.programs')]: t('irrigation.controllers.st8.specs.operating.programs')
      },
      [t('irrigation.controllers.st8.specs.electrical.title')]: {
        [t('irrigation.controllers.labels.input')]: {
          [t('irrigation.controllers.specs.standard')]: t('irrigation.controllers.st8.specs.electrical.inputStandard'),
          [t('irrigation.controllers.specs.international')]: t('irrigation.controllers.st8.specs.electrical.inputInternational')
        },
        [t('irrigation.controllers.labels.output')]: {
          [t('irrigation.controllers.specs.standard')]: t('irrigation.controllers.st8.specs.electrical.outputStandard'),
          [t('irrigation.controllers.specs.international')]: t('irrigation.controllers.st8.specs.electrical.outputInternational')
        }
      },
      [t('irrigation.controllers.st8.specs.dimensions.title')]: {
        [t('irrigation.controllers.labels.indoor')]: {
          [t('irrigation.controllers.labels.width')]: t('irrigation.controllers.st8.specs.dimensions.indoorWidth'),
          [t('irrigation.controllers.labels.height')]: t('irrigation.controllers.st8.specs.dimensions.indoorHeight'),
          [t('irrigation.controllers.labels.depth')]: t('irrigation.controllers.st8.specs.dimensions.indoorDepth')
        },
        [t('irrigation.controllers.labels.outdoor')]: {
          [t('irrigation.controllers.labels.width')]: t('irrigation.controllers.st8.specs.dimensions.outdoorWidth'),
          [t('irrigation.controllers.labels.height')]: t('irrigation.controllers.st8.specs.dimensions.outdoorHeight'),
          [t('irrigation.controllers.labels.depth')]: t('irrigation.controllers.st8.specs.dimensions.outdoorDepth')
        }
      }
    },
    models: {
      [t('irrigation.controllers.st8.models.indoor')]: [
        "ST8I WIFI",
        "ST8I-2.0 WIFI",
        "ST8I-INTL"
      ],
      [t('irrigation.controllers.st8.models.outdoor')]: [
        "ST8O-2.0",
        "ST8O-AUS"
      ]
    },
    accessories: [
      {
        name: "WR2-RFC",
        description: t('irrigation.controllers.st8.accessories.rainFreeze')
      },
      {
        name: "WR2-48",
        description: t('irrigation.controllers.st8.accessories.rainFreeze48')
      },
      {
        name: "RSD-BEx",
        description: t('irrigation.controllers.st8.accessories.rainSensor')
      }
    ],
    certifications: {
      [t('irrigation.controllers.st8.models.indoor')]: [
        "cULus (US and Canada)",
        "FCC Part 15b (US)",
        "WaterSense (US, ST8I-WIFI only)",
        "CAN ICES-3(B)/NMB-3(B) (Canada)",
        "CE (European Union)",
        "NRCS (South Africa)",
        "SABS (South Africa)"
      ],
      [t('irrigation.controllers.st8.models.outdoor')]: [
        "cULus (US and Canada)",
        "FCC Part 15b (US)",
        "WaterSense (US)",
        "CAN ICES-3(B)/NMB-3(B) (Canada)",
        "CE (European Union)",
        "IPX4",
        "RCM (Australia and New Zealand)"
      ]
    }
  }
];---

<Layout
  title={t('irrigation.controllers.title')}
  description={t('irrigation.controllers.heroDescription')}
>
  <!-- Hero Section -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://imgur.com/Vb6z5ec.jpg"
        alt="Smart Irrigation Controllers" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {t('irrigation.controllers.title')}
          <span class="block text-2xl md:text-3xl mt-2">{t('irrigation.controllers.subtitle')}</span>
        </h1>
        <p class="text-xl text-white mb-8">
          {t('irrigation.controllers.heroDescription')}
        </p>
        <div class="flex flex-wrap gap-4">
          <a 
            href="#products"
            class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300"
          >
            {t('irrigation.controllers.viewProducts')}
          </a>
          <a 
            href="#quote-form"
            class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm"
          >
            {t('irrigation.controllers.requestQuote')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('irrigation.controllers.ourControllers')}</h2>
      
      {products.map((product, index) => (
        <div class={`mb-20 ${index !== 0 ? 'border-t pt-20' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <h3 class="text-2xl font-bold mb-4">{product.name}</h3>
              <p class="text-lg font-medium text-primary mb-4">{product.shortDescription}</p>
              <p class="text-gray-600 mb-6">{product.description}</p>
              
              <div class="space-y-6">
                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.keyFeatures')}:</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {product.features.map((feature) => (
                      <div class="flex items-center text-gray-700">
                        <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        {feature}
                      </div>
                    ))}
                  </div>
                </div>

                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.documentation')}:</h4>
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <a 
                      href={product.name === "ESP-TM2 Series Controllers" 
                        ? "https://www.rainbird.com/sites/default/files/media/documents/2023-05/esp-tm2-tech_spec-itl_1.pdf"
                        : "https://www.rainbird.com/sites/default/files/media/documents/2018-03/man_ST8-WiFi_guide_en_0.pdf"
                      }
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-primary hover:text-primary-600 transition-colors"
                    >
                      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                      {t('irrigation.controllers.downloadCatalog')}
                    </a>
                  </div>
                </div>

                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.techSpecs')}:</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {Object.entries(product.specifications).map(([category, specs]) => {
                      if (typeof specs !== 'object' || specs === null) {
                        return (
                          <div class="bg-gray-50 p-4 rounded-lg">
                            <h5 class="font-semibold mb-2 capitalize">{category}</h5>
                            <div class="text-sm">
                              <span class="font-medium">{String(specs)}</span>
                            </div>
                          </div>
                        );
                      }
                      
                      return (
                        <div class="bg-gray-50 p-4 rounded-lg">
                          <h5 class="font-semibold mb-2 capitalize">{category}</h5>
                          <div class="space-y-2">
                            {Object.entries(specs).map(([key, value]) => {
                              const displayValue = typeof value === 'object' && value !== null 
                                ? JSON.stringify(value) 
                                : String(value);
                              
                              return (
                                <div class="flex justify-between text-sm">
                                  <span class="text-gray-600 capitalize">{key}:</span>
                                  <span class="font-medium">{displayValue}</span>
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>

                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.availableModels')}:</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {Object.entries(product.models).map(([category, models]: [string, any]) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-2">{category}</h5>
                        <ul class="space-y-1 text-sm">
                          {models.map((model: string) => (
                            <li class="text-gray-700">{model}</li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>

                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.compatibleAccessories')}:</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {product.accessories.map((accessory) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-1">{accessory.name}</h5>
                        <p class="text-sm text-gray-600">{accessory.description}</p>
                      </div>
                    ))}
                  </div>
                </div>

                <div>
                  <h4 class="font-bold mb-3">{t('irrigation.controllers.certifications')}:</h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {Object.entries(product.certifications).map(([category, certs]: [string, any]) => (
                      <div class="bg-gray-50 p-4 rounded-lg">
                        <h5 class="font-semibold mb-2">{category}</h5>
                        <ul class="space-y-1 text-sm">
                          {certs.map((cert: string) => (
                            <li class="text-gray-700">{cert}</li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img 
                src={product.image}
                alt={product.name}
                class="w-full h-[400px] object-cover rounded-lg shadow-lg"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{t('irrigation.controllers.form.title')}</h2>
        <form class="bg-white p-8 rounded-lg shadow-lg space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t('irrigation.controllers.form.firstName')} *
              </label>
              <input
                type="text"
                required
                class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">
                {t('irrigation.controllers.form.lastName')} *
              </label>
              <input
                type="text"
                required
                class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('irrigation.controllers.form.email')} *
            </label>
            <input
              type="email"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('irrigation.controllers.form.phone')} *
            </label>
            <input
              type="tel"
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('irrigation.controllers.form.model')} *
            </label>
            <select
              required
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            >
              <option value="">{t('irrigation.controllers.form.selectModel')}</option>
              {products.map((product) => (
                <optgroup label={product.name}>
                  {Object.entries(product.models).flatMap(([category, models]: [string, any]) =>
                    models.map((model: string) => (
                      <option value={model.split(':')[0].trim()}>{model}</option>
                    ))
                  )}
                </optgroup>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('irrigation.controllers.form.zones')} *
            </label>
            <input
              type="number"
              required
              min="1"
              max="12"
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              {t('irrigation.controllers.form.requirements')}
            </label>
            <textarea
              rows="4"
              class="w-full px-4 py-2 rounded-md border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"
              placeholder={t('irrigation.controllers.form.requirementsPlaceholder')}
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300"
          >
            {t('irrigation.controllers.form.submit')}
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{t('irrigation.controllers.cta.title')}</h2>
      <p class="text-xl text-white mb-8">{t('irrigation.controllers.cta.description')}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a 
          href="/contact" 
          class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90"
        >
          {t('irrigation.controllers.cta.contact')}
        </a>
        <a 
          href="https://wa.me/2250799295643" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center"
        >
          <i class="fab fa-whatsapp mr-2"></i>
          {t('irrigation.controllers.cta.whatsapp')}
        </a>
      </div>
    </div>
  </section>
</Layout>