        { title: "Instalación Fácil", description: "Instalación a distancia variable según necesidades específicas del cultivo" },
        { title: "Máxima Durabilidad", description: "Alta resistencia a impactos, fricción y degradación UV" },
      ],
      specifications: {
        "ND Models": { "Flows": "1.1 l/h – 2.2 l/h – 3.1 l/h HND – 3.8 l/h – 7.8 l/h" },
        "PC Models": { "Flows": "2.2 l/h – 3.8 l/h – 7.8 l/h – 12.0 l/h – 25.0 l/h" },
      },
      catalog: "https://azud.com/wp-content/uploads/2022/09/NAVIA-ENG_ESP-1.pdf",
    },
  ],
  af: [
    {
      name: "Netafim Drippers and Driplines",
      brand: "Netafim",
      shortDescription: "Druppelaars, druppellyne en ander emittertipes vir enige gewas, topografie, klimaat en grond.",
      description: "Presisiedruppelaars wat ongeëwenaarde werkverrigting bied vir waterbesparing en verspreidingsuniformiteit.",
      image: "https://imgur.com/vDgiJfa.jpg",
      features: [
        { title: "Universele Versoenbaarheid", description: "Geskik vir enige gewas, topografie, klimaat en grondtipe" },
        { title: "Hulpbroneffektiwiteit", description: "Beduidende besparing op water, kunsmis en energie" },
        { title: "Uniforme Verspreiding", description: "Verseker egalige waterverspreiding vir konsekwente gewasgroei" },
        { title: "Duursaamheid", description: "Robuuste konstruksie vir langtermyn betroubaarheid" },
      ],
      specifications: {
        general: { "Flow rates": "0.4 - 3.8 L/h", "Operating pressure": "0.5 - 4.0 bar", "Filtration requirements": "130 micron", "Wall thickness": "0.63 - 1.2 mm" },
        features: { "Anti-siphon": "Yes", "Anti-drain": "Optional", "Pressure compensating": "Available", "UV resistance": "High" },
      },
      catalog: "https://www.netafim.africa/globalassets/products/flexible--pe-pipes/flexnet-updates/net-pipes-catalog-45.pdf",
    },
    {
      name: "AZUD GREENTEC",
      brand: "AZUD",
      shortDescription: "Mikro-besproeiingspyp met geïntegreerde turbulente druppelaar vir oppervlakbesproeiingsinstallasies",
      description: "Selfregulerende druppelbesproeiingsmikrostelsel met gepatenteerde labirintfiltrasietegnologie.",
      image: "https://imgur.com/JiWIbYy.jpg",
      features: [
        { title: "DS Tegnologie", description: "Maksimale beskerming teen verstopping met selfskoonmaakinslaatfilter" },
        { title: "Hulpbronoptimering", description: "Water- en energiebesparing deur laedrukwerking" },
        { title: "Veelsydige Installasie", description: "Aanpasbaar by verskeie terreintoestande" },
        { title: "Geïntegreerde Stelsel", description: "Verlaagde installasiekoste met groter besproeiingsbeheer" },
      ],
      specifications: {
        "MICRO-IRRIGATION PIPE": { "Diameter": "Ø16", "Coil": "50 m – 100 m – 200 m", "Color": "Brown – Black" },
        "PIPE WITH INTEGRATED DRIPPER": { "Diameter": "Ø16", "Flow rate": "2 l/h", "Framework": "0.35 m – 0.50 m", "Color": "Brown – Black" },
      },
      catalog: "https://azud.com/wp-content/uploads/2022/09/AZUD_GREENTEC-ENG-1.pdf",
    },
    {
      name: "AZUD TUB MICROTUBE",
      brand: "AZUD",
      shortDescription: "Veelsydige mikrobuis vir verskeie besproeiingstoepassings",
      description: "Buigsame mikrobuis-stelsel ontwerp vir presisie waterverspreiding in gespesialiseerde gewasse.",
      image: "https://imgur.com/Wlo5XCh.jpg",
      features: [
        { title: "Premium Materiale", description: "Vervaardig met hoë kwaliteit grondstowwe vir duursaamheid" },
        { title: "Maklike Onderhoud", description: "Vergemaklik onderhoud en toekomstige stelseluitbreidings" },
        { title: "Versterkte Verpakking", description: "Maklike vervoer en berging met stapelbare ontwerp" },
        { title: "Buigsame Installasie", description: "Maklike en buigsame invoeging met druppelaars en aansluitings" },
      ],
      specifications: {
        "PE Models": { "Sizes": "6.5 x 4.5 mm – 8 x 5.6 mm – 8 x 6 mm" },
        "FLEX Models": { "Sizes": "5 x 3.3 mm – 6 x 4 mm – 6.5 x 4 mm – 7 x 4.3 mm" },
      },
      catalog: "https://azud.com/wp-content/uploads/2022/09/AZUD_TUB_microtubo-ENG-1.pdf",
    },
    {
      name: "AZUD NAVIA",
      brand: "AZUD",
      shortDescription: "Selfkompenserende en lekvaste druppelaars vir uitdagende topografie",
      description: "Presisie-aspersiebesproeiingstelsel met uniforme waterverspreiding, ideaal vir groot gewasse.",
      image: "https://imgur.com/RpXe5LH.jpg",
      features: [
        { title: "Wye Werkbereik", description: "Werk onder 'n wye reeks drukke, wat koste optimeer" },
        { title: "Presiese Beheer", description: "Akkurate opening- en sluitdruk vir doeltreffende kunsmisgebruik" },
        { title: "Maklike Installasie", description: "Veranderlike afstandinstallasie gebaseer op spesifieke gewasbehoeftes" },
        { title: "Maksimale Duursaamheid", description: "Hoë weerstand teen impak, wrywing en UV-degradasie" },
      ],
      specifications: {
        "ND Models": { "Flows": "1.1 l/h – 2.2 l/h – 3.1 l/h HND – 3.8 l/h – 7.8 l/h" },
