---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;
---
<Layout title={lang === 'fr' ? "Substrats & Solutions de Culture | Fibre de Coco, Tourbe, Perlite | Arbre Bio Africa" : lang === 'es' ? "Sustratos y Soluciones de Cultivo | Arbre Bio Africa" : "Growing Media & Substrates | Coco Peat, Perlite | Arbre Bio Africa"} description={lang === 'fr' ? "Découvrez nos substrats de culture premium : fibre de coco, tourbe de coco, perlite et vermiculite. Solutions professionnelles pour l'agriculture sous serre et l'hydroponie en Afrique." : lang === 'es' ? "Sustratos de cultivo premium: fibra de coco, turba de coco, perlita. Soluciones para invernaderos en África." : "Premium growing substrates: coco peat, coco fibre, perlite, vermiculite. Professional solutions for greenhouse farming in Africa."}>

  {/* Hero Section */}
  <section class="relative bg-gradient-to-br from-green-900 via-green-800 to-emerald-700 text-white py-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-emerald-300 font-semibold text-sm uppercase tracking-widest mb-4">
        {lang === 'fr' ? 'Substrats & Solutions de Culture' : lang === 'es' ? 'Sustratos de Cultivo' : 'Growing Media & Substrates'}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {lang === 'fr' ? 'Solutions de Culture Premium pour une Agriculture Performante en Afrique' : lang === 'es' ? 'Soluciones de Cultivo Premium para Agricultura en África' : 'Premium Growing Solutions for High-Performance Farming in Africa'}
      </h1>
      <p class="text-xl text-emerald-100 max-w-3xl mx-auto mb-8">
        {lang === 'fr' ? "Arbre Bio Africa vous propose les meilleurs substrats de culture : fibre de coco, tourbe de coco, perlite et vermiculite. Optimisez vos rendements avec des solutions adaptées au climat africain." : lang === 'es' ? "Los mejores sustratos de cultivo: fibra de coco, turba de coco, perlita y vermiculita para agricultura africana." : "The best growing substrates: coco fibre, coco peat, perlite and vermiculite for African agriculture."}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${lang}/contact`} class="bg-emerald-500 hover:bg-emerald-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.requestQuote}
        </a>
        <a href={`/${lang}/substrates`} class="border-2 border-white text-white hover:bg-white hover:text-green-900 font-bold py-3 px-8 rounded-lg transition-colors">
          {T.exploreSolutions}
        </a>
      </div>
    </div>
  </section>

  {/* Introduction Section */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-green-900 mb-6">
            {lang === 'fr' ? "Qu'est-ce qu'un Substrat de Culture ?" : lang === 'es' ? "¿Qué es un Sustrato de Cultivo?" : "What is Growing Media?"}
          </h2>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "Un substrat de culture est le milieu dans lequel les plantes développent leurs racines. Contrairement au sol naturel, un substrat professionnel est formulé pour offrir l'équilibre parfait entre rétention d'eau, aération des racines et apport en nutriments. En agriculture de précision, le choix du substrat détermine directement la qualité et le rendement de votre production." : lang === 'es' ? "Un sustrato de cultivo es el medio en el que las plantas desarrollan sus raíces, formulado para el equilibrio perfecto entre retención de agua, aireación y nutrientes." : "Growing media is the medium in which plants develop their roots, engineered for the perfect balance of water retention, root aeration and nutrient delivery."}
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "En Afrique de l'Ouest, où les conditions climatiques sont souvent extrêmes — chaleur intense, sécheresse, pluies abondantes — l'utilisation de substrats adaptés permet de maîtriser l'environnement racinaire et d'obtenir des récoltes de qualité toute l'année, en serre comme en plein air." : lang === 'es' ? "En África Occidental, los sustratos adaptados permiten controlar el entorno radicular y obtener cosechas de calidad durante todo el año." : "In West Africa, adapted substrates allow you to control the root environment and achieve quality harvests year-round."}
          </p>
          <p class="text-gray-700 leading-relaxed">
            {lang === 'fr' ? "Arbre Bio Africa importe et distribue les substrats de culture les plus performants du marché, sélectionnés spécifiquement pour les conditions africaines : résistance aux températures élevées, compatibilité avec l'irrigation goutte-à-goutte et les systèmes hydroponiques, et adaptation aux cultures tropicales." : lang === 'es' ? "Arbre Bio Africa importa y distribuye los mejores sustratos del mercado, seleccionados específicamente para las condiciones africanas." : "Arbre Bio Africa imports and distributes the highest-performing substrates on the market, selected specifically for African conditions."}
          </p>
        </div>
        <div class="bg-green-50 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-green-900 mb-6">
            {lang === 'fr' ? "Pourquoi Choisir un Substrat Professionnel ?" : lang === 'es' ? "¿Por qué elegir un sustrato profesional?" : "Why Choose Professional Growing Media?"}
          </h3>
          <ul class="space-y-4">
            {[
              lang === 'fr' ? "✅ Rendements jusqu'à 3× supérieurs au sol naturel" : "✅ Yields up to 3× higher than natural soil",
              lang === 'fr' ? "✅ Économie d'eau de 40 à 70% avec l'irrigation goutte-à-goutte" : "✅ Water savings of 40–70% with drip irrigation",
              lang === 'fr' ? "✅ Contrôle précis du pH et de la conductivité électrique (EC)" : "✅ Precise control of pH and electrical conductivity (EC)",
              lang === 'fr' ? "✅ Réduction des maladies racinaires et des pathogènes du sol" : "✅ Reduction of root diseases and soil pathogens",
              lang === 'fr' ? "✅ Compatible avec la culture hors-sol et l'hydroponie" : "✅ Compatible with soil-less and hydroponic culture",
              lang === 'fr' ? "✅ Disponible en Côte d'Ivoire et livraison en Afrique de l'Ouest" : "✅ Available in Côte d'Ivoire, delivery across West Africa"
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-700">
                <span class="text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Products Section */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-4">
        {lang === 'fr' ? "Nos Substrats de Culture" : lang === 'es' ? "Nuestros Sustratos" : "Our Growing Substrates"}
      </h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-12">
        {lang === 'fr' ? "Chaque substrat est sélectionné et testé pour maximiser vos rendements en Afrique. Découvrez notre gamme complète de solutions de culture professionnelles." : lang === 'es' ? "Cada sustrato es seleccionado y probado para maximizar sus rendimientos en África." : "Each substrate is selected and tested to maximise your yields in Africa."}
      </p>
      <div class="grid md:grid-cols-2 gap-8">

        {/* Coco Peat / Fibre de Coco */}
        <div class="bg-white rounded-2xl shadow-sm p-8 border border-green-100">
          <div class="text-4xl mb-4">🥥</div>
          <h3 class="text-2xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Fibre de Coco & Tourbe de Coco (Coco Peat)" : lang === 'es' ? "Fibra de Coco & Turba de Coco" : "Coco Fibre & Coco Peat"}
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "La fibre de coco et la tourbe de coco (coco peat) sont les substrats de culture les plus populaires en agriculture moderne. Issus de la transformation des coques de noix de coco, ces substrats sont 100% naturels, biodégradables et renouvelables." : lang === 'es' ? "La fibra de coco y la turba de coco son los sustratos más populares en agricultura moderna." : "Coco fibre and coco peat are the most popular growing substrates in modern agriculture."}
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "La tourbe de coco possède une capacité de rétention d'eau exceptionnelle (jusqu'à 10 fois son poids) tout en maintenant une excellente aération des racines. Son pH neutre (5,5 à 6,5) est idéal pour la majorité des cultures maraîchères, fruitières et florales." : lang === 'es' ? "La turba de coco tiene una capacidad de retención de agua excepcional y pH neutro ideal para la mayoría de los cultivos." : "Coco peat has exceptional water retention (up to 10× its weight) while maintaining excellent root aeration."}
          </p>
          <div class="bg-green-50 rounded-lg p-4">
            <p class="font-semibold text-green-900 text-sm mb-2">
              {lang === 'fr' ? "Applications idéales :" : lang === 'es' ? "Aplicaciones ideales:" : "Ideal applications:"}
            </p>
            <p class="text-gray-600 text-sm">
              {lang === 'fr' ? "Tomates, poivrons, concombres, fraises, fleurs coupées, culture hydroponique, pépinières, propagation de boutures" : lang === 'es' ? "Tomates, pimientos, pepinos, fresas, flores, hidropónica, viveros" : "Tomatoes, peppers, cucumbers, strawberries, cut flowers, hydroponics, nurseries"}
            </p>
          </div>
        </div>

        {/* Perlite */}
        <div class="bg-white rounded-2xl shadow-sm p-8 border border-green-100">
          <div class="text-4xl mb-4">⚪</div>
          <h3 class="text-2xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Perlite Horticole" : lang === 'es' ? "Perlita Hortícola" : "Horticultural Perlite"}
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "La perlite est un matériau volcanique expansé utilisé pour améliorer le drainage et l'aération des substrats. Légère, stérile et inerte, elle est idéale pour les mélanges de substrats et les cultures hydroponiques." : lang === 'es' ? "La perlita es un material volcánico expandido para mejorar el drenaje y aireación de los sustratos." : "Perlite is an expanded volcanic material used to improve drainage and aeration in growing substrates."}
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "Mélangée à la tourbe de coco ou à d'autres substrats organiques, la perlite améliore significativement la structure du milieu de culture, évite le compactage et favorise le développement racinaire. Elle est particulièrement recommandée pour les cultures sous serre à haute densité de plantation." : lang === 'es' ? "Mezclada con turba de coco, mejora la estructura del sustrato y favorece el desarrollo radicular." : "Mixed with coco peat, perlite significantly improves substrate structure and prevents compaction."}
          </p>
          <div class="bg-green-50 rounded-lg p-4">
            <p class="font-semibold text-green-900 text-sm mb-2">
              {lang === 'fr' ? "Proportions recommandées :" : lang === 'es' ? "Proporciones recomendadas:" : "Recommended ratios:"}
            </p>
            <p class="text-gray-600 text-sm">
              {lang === 'fr' ? "70% coco peat + 30% perlite pour tomates & poivrons | 80% coco + 20% perlite pour fleurs et herbes aromatiques" : lang === 'es' ? "70% coco peat + 30% perlita para tomates | 80% coco + 20% perlita para flores" : "70% coco peat + 30% perlite for tomatoes | 80% coco + 20% perlite for flowers"}
            </p>
          </div>
        </div>

        {/* Vermiculite */}
        <div class="bg-white rounded-2xl shadow-sm p-8 border border-green-100">
          <div class="text-4xl mb-4">🪨</div>
          <h3 class="text-2xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Vermiculite" : "Vermiculite"}
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "La vermiculite est un minéral naturel expansé qui améliore la rétention d'eau et d'éléments nutritifs dans le substrat. Son pouvoir tampon exceptionnel stabilise le pH et facilite l'absorption des nutriments par les plantes." : lang === 'es' ? "La vermiculita mejora la retención de agua y nutrientes en el sustrato." : "Vermiculite improves water and nutrient retention in growing substrates."}
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "Particulièrement utile pour les semis, la propagation de boutures et les cultures sensibles, la vermiculite crée un environnement racinaire stable et favorise la germination rapide des graines. Elle est aussi utilisée pour le stockage et le transport de plants fragiles." : lang === 'es' ? "Especialmente útil para semilleros, propagación de esquejes y cultivos sensibles." : "Particularly useful for seedlings, cutting propagation and sensitive crops."}
          </p>
          <div class="bg-green-50 rounded-lg p-4">
            <p class="text-gray-600 text-sm">
              {lang === 'fr' ? "Idéale pour : semis, pépinières, bouturage, culture de plantes médicinales et aromatiques" : lang === 'es' ? "Ideal para: semilleros, viveros, enraizamiento" : "Ideal for: seedlings, nurseries, rooting cuttings"}
            </p>
          </div>
        </div>

        {/* Mélanges professionnels */}
        <div class="bg-white rounded-2xl shadow-sm p-8 border border-green-100">
          <div class="text-4xl mb-4">🌱</div>
          <h3 class="text-2xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Mélanges Substrats Sur Mesure" : lang === 'es' ? "Mezclas de Sustratos a Medida" : "Custom Substrate Mixes"}
          </h3>
          <p class="text-gray-700 mb-4 leading-relaxed">
            {lang === 'fr' ? "Arbre Bio Africa propose des mélanges de substrats sur mesure, formulés en fonction de votre culture spécifique, de votre système d'irrigation et de vos objectifs de production. Nos agronomes analysent vos besoins et vous proposent la formulation optimale." : lang === 'es' ? "Arbre Bio Africa ofrece mezclas de sustratos a medida según su cultivo e irrigación." : "Arbre Bio Africa offers custom substrate blends formulated to your specific crop, irrigation system and production goals."}
          </p>
          <p class="text-gray-700 leading-relaxed">
            {lang === 'fr' ? "Que vous cultiviez des tomates cerises sous serre high-tech, des fraises en culture hors-sol, ou des plantes aromatiques en hydroponie, nous avons le mélange parfait pour maximiser vos rendements et la qualité de votre production." : lang === 'es' ? "Ya sea tomates cherry en invernadero o fresas sin suelo, tenemos la mezcla perfecta." : "Whether you grow cherry tomatoes in a high-tech greenhouse or hydroponic herbs, we have the perfect mix."}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Applications Section */}
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-12">
        {lang === 'fr' ? "Applications & Systèmes de Culture" : lang === 'es' ? "Aplicaciones y Sistemas de Cultivo" : "Applications & Growing Systems"}
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🏠</div>
          <h3 class="text-xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Culture Sous Serre" : lang === 'es' ? "Cultivo en Invernadero" : "Greenhouse Growing"}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            {lang === 'fr' ? "Nos substrats sont optimisés pour les serres multi-chapelles et tunnels, avec une parfaite compatibilité avec les systèmes d'irrigation goutte-à-goutte intégrés aux serres Arbre Bio." : lang === 'es' ? "Nuestros sustratos están optimizados para invernaderos con riego por goteo." : "Our substrates are optimised for multi-span greenhouses with integrated drip irrigation systems."}
          </p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">💧</div>
          <h3 class="text-xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Hydroponie & Culture Hors-Sol" : lang === 'es' ? "Hidroponía y Cultivo Sin Suelo" : "Hydroponics & Soil-less Culture"}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            {lang === 'fr' ? "La tourbe de coco est le support idéal pour les systèmes hydroponiques NFT, DWC et goutte-à-goutte. Elle offre une excellente stabilité mécanique et une aération racinaire optimale." : lang === 'es' ? "La turba de coco es ideal para NFT, DWC y sistemas hidropónicos." : "Coco peat is the ideal medium for NFT, DWC and drip hydroponic systems."}
          </p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🌿</div>
          <h3 class="text-xl font-bold text-green-900 mb-3">
            {lang === 'fr' ? "Pépinières & Multiplication" : lang === 'es' ? "Viveros y Multiplicación" : "Nurseries & Propagation"}
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            {lang === 'fr' ? "Nos substrats légers et stériles garantissent un excellent taux de germination et de reprise des boutures. Idéal pour les pépinières professionnelles et les producteurs de plants." : lang === 'es' ? "Nuestros sustratos garantizan una excelente germinación y enraizamiento." : "Our light, sterile substrates ensure excellent germination rates and cutting success."}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ Section with Schema */}
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-green-900 text-center mb-12">
        {lang === 'fr' ? "Questions Fréquentes sur les Substrats" : lang === 'es' ? "Preguntas Frecuentes sobre Sustratos" : "Frequently Asked Questions about Substrates"}
      </h2>
      <div class="space-y-6">
        {[
          {
            q: lang === 'fr' ? "Quelle est la différence entre fibre de coco et tourbe de coco ?" : "What is the difference between coco fibre and coco peat?",
            a: lang === 'fr' ? "La fibre de coco (coir fibre) est composée de fibres longues extraites de la coque de noix de coco. Elle offre une excellente aération et drainage. La tourbe de coco (coco peat ou coir pith) est la poudre fine résultant du même processus. Elle est plus fine, retient mieux l'eau et est idéale comme base de substrat. En pratique, les deux sont souvent utilisés en mélange pour obtenir l'équilibre parfait." : "Coco fibre consists of long fibres for drainage; coco peat is the fine powder with superior water retention. Both are often blended.",
          },
          {
            q: lang === 'fr' ? "Les substrats coco sont-ils adaptés au climat de la Côte d'Ivoire et d'Afrique de l'Ouest ?" : "Are coco substrates suitable for West African climates?",
            a: lang === 'fr' ? "Absolument. La tourbe de coco est particulièrement bien adaptée aux pays à climat chaud et humide comme la Côte d'Ivoire, le Ghana, le Sénégal ou le Bénin. Elle résiste aux températures élevées, maintient l'humidité racinaire et se dégrade beaucoup plus lentement que la tourbe de sphaigne sous les tropiques. C'est pour cette raison qu'Arbre Bio Africa recommande la tourbe de coco comme substrat de base dans toutes ses installations." : "Yes. Coco peat is particularly well adapted to hot, humid climates in West Africa and degrades more slowly than sphagnum peat in tropical conditions.",
          },
          {
            q: lang === 'fr' ? "Combien de fois peut-on réutiliser un substrat coco ?" : "How many times can coco substrate be reused?",
            a: lang === 'fr' ? "Un substrat de coco de qualité premium peut être réutilisé 2 à 3 cycles de culture avant nécessiter un remplacement. Entre chaque cycle, il est recommandé de le stériliser à la vapeur ou chimiquement pour éliminer les pathogènes. Arbre Bio Africa peut vous conseiller sur les protocoles de désinfection adaptés à votre situation." : "A premium coco substrate can be reused for 2–3 crop cycles before replacement, with proper sterilisation between cycles.",
          },
          {
            q: lang === 'fr' ? "Quel substrat choisir pour cultiver des tomates sous serre en Afrique ?" : "Which substrate is best for greenhouse tomatoes in Africa?",
            a: lang === 'fr' ? "Pour la culture de tomates sous serre en Afrique, nous recommandons un mélange de 70% tourbe de coco + 30% perlite. Ce mélange offre une rétention d'eau suffisante pour éviter le stress hydrique entre les irrigations, une aération racinaire optimale pour éviter l'asphyxie racinaire, et un excellent drainage pour éviter la stagnation de l'eau. Ce mélange est utilisé avec succès dans nos fermes partenaires en Côte d'Ivoire." : "For greenhouse tomatoes in Africa, we recommend 70% coco peat + 30% perlite for optimal water retention and root aeration.",
          },
          {
            q: lang === 'fr' ? "Arbre Bio Africa livre-t-il les substrats dans toute l'Afrique de l'Ouest ?" : "Does Arbre Bio Africa deliver substrates across West Africa?",
            a: lang === 'fr' ? "Oui. Arbre Bio Africa assure la livraison de substrats de culture dans toute la Côte d'Ivoire ainsi que vers les pays voisins (Ghana, Burkina Faso, Mali, Sénégal, Bénin). Contactez-nous pour un devis de livraison adapté à votre volume de commande." : "Yes. Arbre Bio Africa delivers growing substrates across Côte d'Ivoire and to neighbouring West African countries.",
          }
        ].map((item, i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-green-900 text-lg mb-3">
              {item.q}
            </h3>
            <p class="text-gray-700 leading-relaxed">
              {item.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-16 px-4 bg-green-900 text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">
        {lang === 'fr' ? "Prêt à Optimiser Votre Production ?" : lang === 'es' ? "¿Listo para Optimizar su Producción?" : "Ready to Optimise Your Production?"}
      </h2>
      <p class="text-emerald-200 text-lg mb-8 max-w-2xl mx-auto">
        {lang === 'fr' ? "Contactez nos experts en agriculture de précision pour une recommandation personnalisée de substrats adaptée à votre culture et à votre région." : lang === 'es' ? "Contacte a nuestros expertos para una recomendación personalizada de sustratos." : "Contact our precision agriculture experts for personalised substrate recommendations."}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`/${lang}/contact`} class="bg-emerald-500 hover:bg-emerald-400 text-white font-bold py-3 px-8 rounded-lg transition-colors">
          {T.requestQuote}
