const benefits = benefitsByLang[lang] ?? benefitsByLang.en;
---

<Layout title={T.layoutTitle} description={T.layoutDesc}>
  <!-- Hero Section -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/BAlwmPw.jpg" alt="Premium Coco Peat Products" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.heroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.heroSub}</span>
        </h1>
        <p class="text-xl text-white mb-8">{T.heroPara}</p>
        <div class="flex flex-wrap gap-4">
          <a href="#quote-form" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300">{T.btnQuote}</a>
          <a href="#products" class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm">{T.btnProducts}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secBenefits}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {benefits.map((benefit) => (
          <div class="text-center">
            <div class="text-4xl mb-4"><EmojiIcon id={benefit.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secProducts}</h2>
      {products.map((product, index) => (
        <div class={`mb-20 ${index !== 0 ? 'border-t pt-20' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <div class="bg-primary text-white px-4 py-2 rounded-full inline-block mb-4">{product.type}</div>
              <h3 class="text-2xl font-bold mb-4">{product.name}</h3>
              <p class="text-gray-600 mb-6">{product.description}</p>
              <div class="grid grid-cols-2 gap-4 mb-6">
                {product.specs.map((spec) => (
                  <div class="bg-white p-4 rounded-lg shadow-sm">
                    <div class="text-sm text-gray-500">{spec.label}</div>
                    <div class="font-semibold">{spec.value}</div>
                  </div>
                ))}
              </div>
              <h4 class="font-bold mb-3">{T.lblIdealApps}</h4>
              <div class="space-y-2">
                {product.applications.map((app) => (
                  <div class="flex items-center text-gray-700">
                    <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {app}
                  </div>
                ))}
              </div>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img src={product.image} alt={product.name} class="w-full h-[400px] object-cover rounded-lg shadow-lg" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Production Process -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secProcess}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {processSteps.map((step, index) => (
          <div class="relative">
            {index !== processSteps.length - 1 && (
              <div class="hidden lg:block absolute top-1/2 right-0 w-full h-1 bg-primary/20 transform translate-y-4"></div>
            )}
            <div class="relative z-10 text-center">
              <div class="text-4xl mb-4 bg-primary/10 w-16 h-16 rounded-full flex items-center justify-center mx-auto">
                <EmojiIcon id={step.icon} size="2rem" />
              </div>
              <h3 class="text-xl font-bold mb-2">{step.title}</h3>
              <p class="text-gray-600">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.secCerts}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {certifications.map((cert) => (
          <div class="bg-white p-6 rounded-lg shadow-lg text-center">
            <div class="text-4xl mb-4"><EmojiIcon id={cert.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold mb-2">{cert.name}</h3>
            <p class="text-gray-600">{cert.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="quote-form" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{T.formTitle}</h2>
        <form class="bg-gray-50 p-8 rounded-lg shadow-lg space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblFirstName}</label>
              <input type="text" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblLastName}</label>
              <input type="text" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblEmail}</label>
            <input type="email" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblPhone}</label>
            <input type="tel" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblProductType}</label>
            <select required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50">
              <option value="">{T.selectProduct}</option>
              <option value="type20">{T.optType20}</option>
              <option value="type30">{T.optType30}</option>
              <option value="custom">{T.optCustom}</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblQuantity}</label>
            <input type="number" required min="1" class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{T.lblAdditional}</label>
            <textarea rows="4" class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50" placeholder={T.phAdditional}></textarea>
          </div>
          <button type="submit" class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300">{T.btnSubmit}</button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaDesc}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#quote-form" class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.btnStart}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.btnWhatsapp}
        </a>
      </div>
    </div>
  </section>
</Layout>

