  ],
  af: [
    { title: "Uitstekende Waterretensie", description: "Hou tot 9 keer sy gewig in water, wat besproeiingsfrekwensie verminder", icon: "water" },
    { title: "Optimale Lugverversing", description: "Perfekte lug-tot-water-verhouding wat gesonde wortelontwikkeling bevorder", icon: "wind" },
    { title: "pH-Gebalanseerd", description: "Stabiele pH-vlakke ideaal vir nutriëntopname", icon: "shield" },
    { title: "100% Organies", description: "Natuurlik, hernubaar en ekologies volhoubaar", icon: "plant" },
