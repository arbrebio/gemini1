---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const p = `/${lang}`;
---

<Layout title="Groei Oplossings | Arbre Bio Africa" description="Ontwerp vir maksimum opbrengs en volhoubare groei">
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0"><img src="https://imgur.com/KAh1QAU.jpg" alt="" class="w-full h-full object-cover"/><div class="absolute inset-0 bg-black bg-opacity-55"></div></div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Groei Oplossings</h1>
      <p class="text-xl text-white max-w-2xl">Ontwerp vir maksimum opbrengs en volhoubare groei</p>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
          {[{icon:"💧",title:"Superieure waterretensie",desc:"8x better water retention than traditional soil."},{icon:"🌬️",title:"Optimale belugting",desc:"Fibrous structure enables excellent air circulation for roots."},{icon:"⚗️",title:"pH gebalanseer",desc:"Naturally stable pH between 5.8-6.5."},{icon:"🌿",title:"100% organies",desc:"OMRI certified for organic agriculture."},].map(f => (
            <div class="bg-gray-50 rounded-xl p-6 text-center"><div class="text-3xl mb-3">{f.icon}</div><h3 class="font-bold mb-2">{f.title}</h3><p class="text-gray-600 text-sm">{f.desc}</p></div>
          ))}
        </div>
        <div class="text-center">
          <a href={`${p}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors">Kry 'n Gratis Konsultasie</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
