---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";
import EmojiIcon from '../../../components/EmojiIcon.astro';

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const featureDescs: Record<string, string[]> = {
  fr: [
    "Rétention d'eau 8× supérieure au sol traditionnel. Réduit la fréquence d'irrigation et les coûts en eau.",
    "Structure fibreuse assurant une excellente aération des racines, prévenant l'asphyxie racinaire.",
    "pH naturellement stable entre 5,8-6,5, idéal pour la plupart des cultures maraîchères et fruitières.",
    "Produit naturellement à partir de noix de coco. Certifié OMRI pour l'agriculture biologique.",
  ],
  es: [
    "Retención de agua 8× mejor que el suelo tradicional. Reduce la frecuencia de riego y los costos de agua.",
    "Estructura fibrosa que garantiza excelente circulación de aire en raíces, previniendo la asfixia radicular.",
    "pH naturalmente estable entre 5,8-6,5, ideal para la mayoría de cultivos hortícolas y frutícolas.",
    "Producido naturalmente del coco. Certificado OMRI para agricultura orgánica.",
  ],
  af: [
    "8× beter waterretensie as tradisionele grond. Verminder besproeiingsfrekwensie en waterkoste.",
    "Veselstruktuur verseker uitstekende lugsirkulasie vir wortels, voorkom wortelversmoring.",
    "Natuurlik stabiele pH tussen 5,8-6,5, ideaal vir die meeste groente- en vrugtekultivars.",
    "Natuurlik geproduseer uit klapper. OMRI-gesertifiseer vir organiese landbou.",
  ],
};

const guideContent: Record<string, {
  heading: string; intro: string;
  substrates: { title: string; desc: string; color: string; icon: string }[];
  appsHeading: string;
  apps: { icon: string; name: string; detail: string }[];
  faqHeading: string;
  faq: { q: string; a: string }[];
}> = {
  fr: {
    heading: "Coco Peat, Fibre de Coco & Tourbe de Coco : Guide Complet",
    intro: "Les substrats à base de coco sont la solution hors-sol la plus adaptée aux conditions climatiques africaines. Économiques, durables et performants, ils transforment la productivité des cultures maraîchères, fruitières et florales en Côte d'Ivoire et en Afrique de l'Ouest.",
    substrates: [
      { icon: "coconut", color: "amber", title: "Coco Peat (Tourbe de Coco)", desc: "Substrat hors-sol n°1 en hydroponie : rétention d'eau 8-9× son poids, pH 5,5-6,8, 100% naturel. Idéal tomates, poivrons, concombres, fraises sous serre." },
      { icon: "leaf", color: "green", title: "Fibre de Coco (Coir Fibre)", desc: "Améliore la structure des sols tropicaux africains — augmente la porosité des sols argileux, améliore le drainage et constitue un excellent paillis. Durée de vie 3-5 ans." },
      { icon: "stone", color: "blue", title: "Perlite & Vermiculite", desc: "Compléments minéraux du coco peat : la perlite améliore l'aération, la vermiculite retient les nutriments. Mix optimal : 70% coco + 30% perlite pour cultures hydroponiques." },
    ],
    appsHeading: "Applications des Substrats Coco en Agriculture Africaine",
    apps: [
      { icon: "tomato", name: "Maraîchage sous serre", detail: "Tomates, poivrons, concombres, aubergines" },
      { icon: "strawberry", name: "Cultures fruitières", detail: "Fraises, melons, pastèques" },
      { icon: "flower", name: "Floriculture", detail: "Roses, orchidées, chrysanthèmes" },
      { icon: "plant", name: "Pépinières", detail: "Repiquage et production de plants" },
    ],
    faqHeading: "FAQ : Substrats Coco pour l'Agriculture Africaine",
    faq: [
      { q: "Pourquoi utiliser le coco peat plutôt que la terre en Afrique ?", a: "Le coco peat offre : aucune mauvaise herbe ni pathogène, rétention d'eau 8× supérieure aux sols sableux du Sahel, pH stable et contrôlable, et des rendements 2 à 3× supérieurs à la culture en pleine terre pour les cultures maraîchères." },
      { q: "Comment préparer le coco peat pour une utilisation en culture ?", a: "1) Tremper 1 kg de brique dans 5L d'eau (gonfle à 8-9L). 2) Rincer si EC > 1,5 mS/cm. 3) Ajuster le pH à 5,5-6,5. 4) Mélanger optionnellement avec 20-30% de perlite. Arbre Bio Africa fournit le substrat prêt à l'emploi." },
      { q: "Combien coûte le coco peat en Côte d'Ivoire ?", a: "Arbre Bio Africa propose des briques déshydratées (650g) à partir de 1 500 FCFA, des sacs vrac (50kg) à partir de 25 000 FCFA, et des grow bags prêts à l'emploi. Contactez-nous au +225 05 00 55 25 25 pour un devis personnalisé et des tarifs dégressifs sur volume." },
      { q: "Quelle est la durée de vie du coco peat comme substrat ?", a: "Un substrat coco peat bien géré dure 2 à 3 cycles culturaux (12-18 mois) : rinçage entre chaque culture, désinfection, contrôle de l'EC et du pH. En fin de cycle, le coco peat usagé est un excellent amendement organique pour les sols tropicaux." },
      { q: "Arbre Bio Africa livre-t-il les substrats dans toute l'Afrique ?", a: "Oui, Arbre Bio Africa livre coco peat, fibre de coco, perlite et vermiculite dans toute l'Afrique de l'Ouest : Côte d'Ivoire, Sénégal, Ghana, Burkina Faso, Mali, Togo, Bénin. Formation et suivi technique agronomique inclus." },
    ],
  },
  es: {
    heading: "Coco Peat, Fibra de Coco & Turba de Coco: Guía Completa",
    intro: "Los sustratos de coco son la solución hidropónica más adecuada para las condiciones africanas — económicos, sostenibles y eficaces. Transforman la productividad de los cultivos hortícolas, frutícolas y florales en Côte d'Ivoire y África Occidental.",
    substrates: [
      { icon: "coconut", color: "amber", title: "Coco Peat (Turba de Coco)", desc: "Sustrato hidropónico n°1: retención de agua 8-9× su peso, pH 5,5-6,8, 100% natural. Ideal para tomates, pimientos, pepinos y fresas en invernadero." },
      { icon: "leaf", color: "green", title: "Fibra de Coco (Coir)", desc: "Mejora la estructura del suelo tropical africano — aumenta la porosidad de suelos arcillosos, mejora el drenaje y es un excelente mantillo. Vida útil 3-5 años." },
      { icon: "stone", color: "blue", title: "Perlita y Vermiculita", desc: "Complementos minerales del coco peat: la perlita mejora la aireación, la vermiculita retiene nutrientes. Mix óptimo: 70% coco + 30% perlita para cultivos hidropónicos." },
    ],
    appsHeading: "Aplicaciones de Sustratos Coco en Agricultura Africana",
    apps: [
      { icon: "tomato", name: "Horticultura en invernadero", detail: "Tomates, pimientos, pepinos, berenjenas" },
      { icon: "strawberry", name: "Cultivos frutícolas", detail: "Fresas, melones, sandías" },
      { icon: "flower", name: "Floricultura", detail: "Rosas, orquídeas, crisantemos" },
      { icon: "plant", name: "Viveros", detail: "Trasplante y producción de plántulas" },
    ],
    faqHeading: "FAQ: Sustratos Coco para Agricultura Africana",
    faq: [
      { q: "¿Por qué usar coco peat en lugar de tierra en África?", a: "El coco peat ofrece: ausencia de malezas y patógenos, retención de agua 8× superior a los suelos arenosos del Sahel, pH estable y controlable, y rendimientos 2-3× superiores al cultivo en suelo para hortalizas." },
      { q: "¿Cómo preparar el coco peat para el cultivo?", a: "1) Remojar 1 kg de ladrillo en 5L de agua (se expande a 8-9L). 2) Enjuagar si EC > 1,5 mS/cm. 3) Ajustar pH a 5,5-6,5. 4) Mezclar opcionalmente con 20-30% de perlita. Arbre Bio Africa suministra el sustrato listo para usar." },
      { q: "¿Cuánto cuesta el coco peat en Côte d'Ivoire?", a: "Arbre Bio Africa ofrece ladrillos deshidratados (650g) desde 1.500 FCFA, sacos a granel (50kg) desde 25.000 FCFA, y grow bags listos para usar. Contáctenos al +225 05 00 55 25 25 para una cotización personalizada y tarifas por volumen." },
      { q: "¿Cuánto dura el coco peat como sustrato?", a: "Un sustrato coco peat bien gestionado dura 2-3 ciclos de cultivo (12-18 meses): enjuague entre cultivos, desinfección, control de EC y pH. Al final del ciclo, el coco peat usado es un excelente enmienda orgánica para suelos tropicales." },
      { q: "¿Arbre Bio Africa entrega sustratos en toda África?", a: "Sí, entregamos coco peat, fibra de coco, perlita y vermiculita en toda África Occidental: Côte d'Ivoire, Senegal, Ghana, Burkina Faso, Mali, Togo, Benín. Capacitación y seguimiento técnico agronómico incluidos." },
    ],
  },
  af: {
    heading: "Kokosvesturf, Kokosvesels & Kokosveen: Volledige Gids",
    intro: "Koko-gebaseerde substrate is die mees geskikte grondlose groeimedia vir Afrika se klimaattoestande — bekostigbaar, volhoubaar en hoëprestasie. Hulle transformeer die produktiwiteit van groente-, vrugte- en blomkultivars in Ivoorkus en Wes-Afrika.",
    substrates: [
      { icon: "coconut", color: "amber", title: "Kokosveen (Coco Peat)", desc: "Die nommer 1 grondlose substraat in hidroponies: waterretensie 8-9× sy gewig, pH 5,5-6,8, 100% natuurlik. Ideaal vir tamaties, rissies, komkommers en aarbeie in kweekhuise." },
      { icon: "leaf", color: "green", title: "Kokosvesels (Coir)", desc: "Verbeter Afrikatropiese grondstruktuur — verhoog kleigrond se porositeit, verbeter dreinering en is 'n uitstekende mulch. Lewensduur 3-5 jaar." },
      { icon: "stone", color: "blue", title: "Perliet en Vermiculiet", desc: "Minerale aanvullings vir kokosveen: perliet verbeter belugting, vermiculiet hou voedingstowwe vas. Optimale mengsel: 70% koko + 30% perliet vir hidroponies." },
    ],
    appsHeading: "Koko-Substraat Toepassings in Afrika-Landbou",
    apps: [
      { icon: "tomato", name: "Kwekhuisgroenteboerdery", detail: "Tamaties, rissies, komkommers, eiervrug" },
      { icon: "strawberry", name: "Vrugtekultivars", detail: "Aarbeie, melons, waatlemoen" },
      { icon: "flower", name: "Blommekwekery", detail: "Rose, orgidees, chrysante" },
      { icon: "plant", name: "Kwekery", detail: "Verstek en saailingproduksie" },
    ],
    faqHeading: "Gereelde Vrae: Koko-Substrate vir Afrika-Landbou",
    faq: [
      { q: "Waarom kokosveen eerder as grond gebruik in Afrika?", a: "Kokosveen bied: geen onkruid of patogene nie, waterretensie 8× beter as sanderige Sahelgrond, stabiele beheerbare pH, en 2-3× hoër opbrengste as grondverbouing vir groentekultivars." },
      { q: "Hoe berei jy kokosveen voor vir kultivering?", a: "1) Week 1 kg baksteen in 5L water (swel tot 8-9L). 2) Spoel as EC > 1,5 mS/cm. 3) Stel pH in op 5,5-6,5. 4) Meng opsioneel met 20-30% perliet. Arbre Bio Africa verskaf gebruiksklare substraat." },
      { q: "Hoeveel kos kokosveen in Ivoorkus?", a: "Arbre Bio Africa bied gedehidreerde bakstene (650g) vanaf 1 500 FCFA, sakke in grootmaat (50kg) vanaf 25 000 FCFA, en gebruiksklare grow bags. Kontak ons by +225 05 00 55 25 25 vir 'n persoonlike kwotasie en volumetariewe." },
      { q: "Hoe lank duur kokosveen as substraat?", a: "Goed bestuurde kokosveen duur 2-3 groeiseisoene (12-18 maande): spoel tussen kultivars, steriliseer, monitor EC en pH. Gebruikte kokosveen is 'n uitstekende organiese grondverbeteraar vir tropiese grond." },
      { q: "Lewer Arbre Bio Africa substrate regoor Afrika?", a: "Ja, ons lewer kokosveen, kokosvesels, perliet en vermiculiet regoor Wes-Afrika: Ivoorkus, Senegal, Ghana, Burkina Faso, Mali, Togo, Benin. Opleiding en agronomies tegniese opvolg ingesluit." },
    ],
  },
};

const guide = guideContent[lang] ?? guideContent.fr;
const fDesc = featureDescs[lang] ?? featureDescs.fr;

const benefits = [
  { icon: 'medal', title: T.qualityAssured, desc: T.qualityAssuredDesc },
  { icon: 'plant', title: T.sustainable, desc: T.sustainableDesc },
  { icon: 'handshake', title: T.expertSupport, desc: T.expertSupportDesc },
];
---

<Layout title={({'fr':'Fibre de Coco, Substrat & Tourbe de Coco | Arbre Bio','en':'Coco Peat, Growing Media & Substrates | Arbre Bio Africa','es':'Fibra de Coco, Sustrato & Turba de Coco | Arbre Bio','af':'Kokosvesels & Groeimedia | Arbre Bio Africa'} as Record<string,string>)[lang] || 'Coco Peat, Growing Media & Substrates | Arbre Bio Africa'} description={T.subTagline}>

  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/BAlwmPw.jpg" alt="Premium Growing Solutions" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.subHeroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.subHeroSub}</span>
        </h1>
        <p class="text-xl text-white mb-8">{T.subTagline}</p>
        <a href="#solutions" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300 inline-block">{T.exploreSolutions}</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="text-center">
            <div class="text-4xl mb-4"><EmojiIcon id={benefit.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="solutions" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="https://imgur.com/KAh1QAU.jpg" alt="Growing Solutions" class="w-full h-48 object-cover"/>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">{T.gsTitle}</h3>
            <p class="text-gray-600 mb-4">{T.gsDesc}</p>
            <ul class="space-y-2 mb-4">
              {[T.superiorWater, T.optimalAeration, T.phBalanced, T.organic100].map(feature => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-gray-700">{feature}</span>
                </li>
              ))}
            </ul>
            <a href={`${p}/substrates/growing-solutions`} class="inline-flex items-center text-primary font-semibold hover:text-primary-600">
              {T.learnMore}
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
        <div class="bg-primary/5 rounded-lg p-8 flex flex-col justify-center">
          <h3 class="text-2xl font-bold mb-4">{T.ctaTitle}</h3>
          <p class="text-gray-600 mb-6">{T.ctaSubtitle}</p>
          <a href={`${p}/contact`} class="bg-primary text-white px-6 py-3 rounded-full hover:bg-primary-600 transition-colors text-center">{T.freeConsultation}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { icon: 'water', title: T.superiorWater, desc: fDesc[0] },
          { icon: 'wind', title: T.optimalAeration, desc: fDesc[1] },
          { icon: 'flask', title: T.phBalanced, desc: fDesc[2] },
          { icon: 'leaf', title: T.organic100, desc: fDesc[3] },
        ].map(feature => (
          <div class="text-center p-6 bg-gray-50 rounded-xl">
            <div class="text-4xl mb-4"><EmojiIcon id={feature.icon} size="2rem" /></div>
            <h3 class="font-bold text-lg mb-3">{feature.title}</h3>
            <p class="text-gray-600 text-sm">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white" aria-labelledby="substrats-guide-heading">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 id="substrats-guide-heading" class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {guide.heading}
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          {guide.intro}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {guide.substrates.map((item) => (
          <div class={`bg-${item.color}-50 rounded-2xl p-8 border border-${item.color}-200`}>
            <div class="text-4xl mb-4"><EmojiIcon id={item.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="bg-gray-50 rounded-2xl p-10">
        <h3 class="text-2xl font-bold text-gray-900 mb-6 text-center">
          {guide.appsHeading}
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {guide.apps.map((app) => (
            <div class="bg-white rounded-xl p-5 text-center shadow-sm">
              <div class="text-3xl mb-2"><EmojiIcon id={app.icon} size="2rem" /></div>
              <div class="font-bold text-gray-900 text-sm mb-1">{app.name}</div>
              <div class="text-xs text-gray-500">{app.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50" aria-labelledby="faq-substrats">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 id="faq-substrats" class="text-3xl font-bold text-center text-gray-900 mb-12">
        {guide.faqHeading}
      </h2>
      <div class="space-y-6">
        {guide.faq.map((item) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h3 class="text-lg font-bold text-gray-900 mb-3">{item.q}</h3>
            <p class="text-gray-600 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": guide.faq.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

</Layout>
