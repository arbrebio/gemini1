---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const benefits = [
  { icon: 'ð', title: T.qualityAssured, desc: T.qualityAssuredDesc },
  { icon: 'ð±', title: T.sustainable, desc: T.sustainableDesc },
  { icon: 'ð¨‍ð¾', title: T.expertSupport, desc: T.expertSupportDesc },
];
---

<Layout title={({'fr':'Fibre de Coco, Substrat & Tourbe de Coco | Arbre Bio','en':'Coco Peat, Growing Media & Substrates | Arbre Bio Africa','es':'Fibra de Coco, Sustrato & Turba de Coco | Arbre Bio','af':'Kokosvesels & Groeimedia | Arbre Bio Africa'} as Record<string,string>)[lang] || 'Coco Peat, Growing Media & Substrates | Arbre Bio Africa'} description={T.subTagline}>

  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/BAlwmPw.jpg" alt="Premium Growing Solutions" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.subHeroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.subHeroSub}</span>
        </h1>
        <p class="text-xl text-white mb-8">{T.subTagline}</p>
        <a href="#solutions" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300 inline-block">{T.exploreSolutions}</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="text-center">
            <div class="text-4xl mb-4">{benefit.icon}</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="solutions" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="https://imgur.com/KAh1QAU.jpg" alt="Growing Solutions" class="w-full h-48 object-cover"/>
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">{T.gsTitle}</h3>
            <p class="text-gray-600 mb-4">{T.gsDesc}</p>
            <ul class="space-y-2 mb-4">
              {[T.superiorWater, T.optimalAeration, T.phBalanced, T.organic100].map(feature => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-gray-700">{feature}</span>
                </li>
              ))}
            </ul>
            <a href={`${p}/substrates/growing-solutions`} class="inline-flex items-center text-primary font-semibold hover:text-primary-600">
              {T.learnMore}
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
        <div class="bg-primary/5 rounded-lg p-8 flex flex-col justify-center">
          <h3 class="text-2xl font-bold mb-4">{T.ctaTitle}</h3>
          <p class="text-gray-600 mb-6">{T.ctaSubtitle}</p>
          <a href={`${p}/contact`} class="bg-primary text-white px-6 py-3 rounded-full hover:bg-primary-600 transition-colors text-center">{T.freeConsultation}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { icon: 'ð§', title: T.superiorWater, desc: '8x better water retention than traditional soil. Reduces irrigation frequency and water costs.' },
          { icon: 'ð¬️', title: T.optimalAeration, desc: 'Fibrous structure enables excellent air circulation for roots, preventing root asphyxia.' },
          { icon: '⚗️', title: T.phBalanced, desc: 'Naturally stable pH between 5.8-6.5, ideal for most vegetable and fruit crops.' },
          { icon: 'ð¿', title: T.organic100, desc: 'Produced naturally from coconut. OMRI certified for organic agriculture.' },
        ].map(feature => (
          <div class="text-center p-6 bg-gray-50 rounded-xl">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="font-bold text-lg mb-3">{feature.title}</h3>
            <p class="text-gray-600 text-sm">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.ctaTitle}</h2>
      <p class="text-xl text-white mb-8">{T.ctaSubtitle}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>


  <section class="py-20 bg-white" aria-labelledby="substrats-guide-heading">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 id="substrats-guide-heading" class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {lang === 'fr' ? "Coco Peat, Fibre de Coco & Tourbe de Coco : Guide Complet" : lang === 'es' ? "Coco Peat, Fibra de Coco & Turba de Coco: Guía Completa" : "Coco Peat, Coir Fibre & Coconut Substrate: Complete Guide"}
        </h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          {lang === 'fr' ? "Les substrats à base de coco sont la solution hors-sol la plus adaptée aux conditions climatiques africaines. Économiques, durables et performants, ils transforment la productivité des cultures maraîchères, fruitières et florales en Côte d'Ivoire et en Afrique de l'Ouest." : lang === 'es' ? "Los sustratos de coco son la solución hidropónica más adecuada para las condiciones africanas — económicos, sostenibles y eficaces." : "Coco-based substrates are the most suitable soilless growing media for African conditions — affordable, sustainable and high-performing."}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {[
          { icon: "🥥", title: lang === 'fr' ? "Coco Peat (Tourbe de Coco)" : lang === 'es' ? "Coco Peat (Turba)" : "Coco Peat", desc: lang === 'fr' ? "Substrat hors-sol n°1 en hydroponie : rétention d'eau 8-9× son poids, pH 5,5-6,8, 100% naturel. Idéal tomates, poivrons, concombres, fraises sous serre." : lang === 'es' ? "Sustrato hidropónico n°1: retención de agua 8-9× su peso, pH 5,5-6,8, 100% natural." : "Top soilless substrate: water retention 8-9× its weight, pH 5.5-6.8, 100% natural. Ideal for tomatoes, peppers, cucumbers, strawberries.", color: "amber" },
          { icon: "🌿", title: lang === 'fr' ? "Fibre de Coco (Coir Fibre)" : lang === 'es' ? "Fibra de Coco (Coir)" : "Coconut Coir Fibre", desc: lang === 'fr' ? "Améliore la structure des sols tropicaux africains — augmente la porosité des sols argileux, améliore le drainage et constitue un excellent paillis. Durée de vie 3-5 ans." : lang === 'es' ? "Mejora la estructura del suelo tropical, aumenta la porosidad y el drenaje. Vida útil 3-5 años." : "Improves tropical soil structure — increases clay soil porosity, drainage and is an excellent mulch. Lifespan 3-5 years.", color: "green" },
          { icon: "🪨", title: lang === 'fr' ? "Perlite & Vermiculite" : lang === 'es' ? "Perlita y Vermiculita" : "Perlite & Vermiculite", desc: lang === 'fr' ? "Compléments minéraux du coco peat : la perlite améliore l'aération, la vermiculite retient les nutriments. Mix optimal : 70% coco + 30% perlite pour cultures hydroponiques." : lang === 'es' ? "Complementos minerales: perlita mejora la aireación, vermiculita retiene nutrientes. Mix óptimo: 70% coco + 30% perlita." : "Mineral complements: perlite improves aeration, vermiculite retains nutrients. Optimal mix: 70% coco + 30% perlite.", color: "blue" }
        ].map((item) => (
          <div class={`bg-${item.color}-50 rounded-2xl p-8 border border-${item.color}-200`}>
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="bg-gray-50 rounded-2xl p-10">
        <h3 class="text-2xl font-bold text-gray-900 mb-6 text-center">
          {lang === 'fr' ? "Applications des Substrats Coco en Agriculture Africaine" : lang === 'es' ? "Aplicaciones de Sustratos Coco en Agricultura Africana" : "Coco Substrate Applications in African Agriculture"}
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { icon: "🍅", name: lang === 'fr' ? "Maraîchage sous serre" : "Greenhouse vegs", detail: lang === 'fr' ? "Tomates, poivrons, concombres, aubergines" : "Tomatoes, peppers, cucumbers" },
            { icon: "🍓", name: lang === 'fr' ? "Cultures fruitières" : "Fruit crops", detail: lang === 'fr' ? "Fraises, melons, pastèques" : "Strawberries, melons" },
            { icon: "🌸", name: lang === 'fr' ? "Floriculture" : "Floriculture", detail: lang === 'fr' ? "Roses, orchidées, chrysanthèmes" : "Roses, orchids" },
            { icon: "🌱", name: lang === 'fr' ? "Pépinières" : "Nurseries", detail: lang === 'fr' ? "Repiquage et production de plants" : "Transplanting & seedling production" }
          ].map((app) => (
            <div class="bg-white rounded-xl p-5 text-center shadow-sm">
              <div class="text-3xl mb-2">{app.icon}</div>
              <div class="font-bold text-gray-900 text-sm mb-1">{app.name}</div>
              <div class="text-xs text-gray-500">{app.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50" aria-labelledby="faq-substrats">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 id="faq-substrats" class="text-3xl font-bold text-center text-gray-900 mb-12">
        {lang === 'fr' ? "FAQ : Substrats Coco pour l'Agriculture Africaine" : lang === 'es' ? "FAQ: Sustratos Coco para Agricultura Africana" : "FAQ: Coco Substrates for African Agriculture"}
      </h2>
      <div class="space-y-6">
        {[
          { q: lang === 'fr' ? "Pourquoi utiliser le coco peat plutôt que la terre en Afrique ?" : "Why use coco peat instead of soil in Africa?", a: lang === 'fr' ? "Le coco peat offre : aucune mauvaise herbe ni pathogène, rétention d'eau 8× supérieure aux sols sableux du Sahel, pH stable et contrôlable, et des rendements 2 à 3× supérieurs à la culture en pleine terre pour les cultures maraîchères." : "Coco peat offers: no weeds or pathogens, 8× higher water retention than sandy soils, stable controllable pH, and 2-3× higher yields for vegetable crops." },
          { q: lang === 'fr' ? "Comment préparer le coco peat pour une utilisation en culture ?" : "How to prepare coco peat for growing?", a: lang === 'fr' ? "1) Tremper 1 kg de brique dans 5L d'eau (gonfle à 8-9L). 2) Rincer si EC > 1,5 mS/cm. 3) Ajuster le pH à 5,5-6,5. 4) Mélanger optionnellement avec 20-30% de perlite. Arbre Bio Africa fournit le substrat prêt à l'emploi." : "1) Soak 1kg brick in 5L water (expands to 8-9L). 2) Rinse if EC>1.5 mS/cm. 3) Adjust pH to 5.5-6.5. 4) Optionally mix with 20-30% perlite. We supply ready-to-use substrate." },
          { q: lang === 'fr' ? "Combien coûte le coco peat en Côte d'Ivoire ?" : "How much does coco peat cost in Côte d'Ivoire?", a: lang === 'fr' ? "Arbre Bio Africa propose des briques déshydratées (650g) à partir de 1 500 FCFA, des sacs vrac (50kg) à partir de 25 000 FCFA, et des grow bags prêts à l'emploi. Contactez-nous au +225 05 00 55 25 25 pour un devis personnalisé et des tarifs dégressifs sur volume." : "We offer dehydrated bricks (650g) from 1,500 FCFA, bulk bags (50kg) from 25,000 FCFA, and ready-to-use grow bags. Contact us for volume pricing." },
          { q: lang === 'fr' ? "Quelle est la durée de vie du coco peat comme substrat ?" : "What is the lifespan of coco peat as a substrate?", a: lang === 'fr' ? "Un substrat coco peat bien géré dure 2 à 3 cycles culturaux (12-18 mois) : rinçage entre chaque culture, désinfection, contrôle de l'EC et du pH. En fin de cycle, le coco peat usagé est un excellent amendement organique pour les sols tropicaux." : "Well-managed coco peat lasts 2-3 growing cycles (12-18 months) with rinsing, sterilisation, and EC/pH monitoring. Spent substrate makes excellent organic soil amendment." },
          { q: lang === 'fr' ? "Arbre Bio Africa livre-t-il les substrats dans toute l'Afrique ?" : "Does Arbre Bio Africa deliver substrates across Africa?", a: lang === 'fr' ? "Oui, Arbre Bio Africa livre coco peat, fibre de coco, perlite et vermiculite dans toute l'Afrique de l'Ouest : Côte d'Ivoire, Sénégal, Ghana, Burkina Faso, Mali, Togo, Bénin. Formation et suivi technique agronomique inclus." : "Yes, we deliver coco peat, coir fibre, perlite and vermiculite across West Africa (Côte d'Ivoire, Senegal, Ghana, Burkina Faso, Mali, Togo, Benin) with agronomic training and follow-up." }
        ].map((item) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h3 class="text-lg font-bold text-gray-900 mb-3">{item.q}</h3>
            <p class="text-gray-600 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Pourquoi utiliser le coco peat plutôt que la terre en Afrique ?", "acceptedAnswer": { "@type": "Answer", "text": "Le coco peat offre aucune mauvaise herbe, rétention d eau 8× supérieure aux sols sableux, pH stable, et des rendements 2 à 3× supérieurs en culture maraîchère." } },
      { "@type": "Question", "name": "Comment préparer le coco peat pour une utilisation en culture ?", "acceptedAnswer": { "@type": "Answer", "text": "Tremper 1 kg dans 5L d eau, rincer si EC supérieur à 1,5, ajuster pH à 5,5-6,5, mélanger optionnellement avec 20-30% de perlite." } },
      { "@type": "Question", "name": "Combien coûte le coco peat en Côte d Ivoire ?", "acceptedAnswer": { "@type": "Answer", "text": "Arbre Bio Africa propose des briques à partir de 1 500 FCFA, des sacs 50kg à partir de 25 000 FCFA. Contactez le +225 05 00 55 25 25 pour un devis personnalisé." } },
      { "@type": "Question", "name": "Quelle est la durée de vie du coco peat ?", "acceptedAnswer": { "@type": "Answer", "text": "Un substrat coco peat bien géré dure 2 à 3 cycles culturaux (12-18 mois) avec rinçage, désinfection et contrôle EC/pH." } },
      { "@type": "Question", "name": "Arbre Bio Africa livre-t-il les substrats dans toute l Afrique ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, livraison en Côte d Ivoire, Sénégal, Ghana, Burkina Faso, Mali, Togo et Bénin, avec formation et suivi agronomique inclus." } }
    ]
  })} />


</Layout>
