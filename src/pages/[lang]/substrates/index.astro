---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useTranslations } from "../../../lib/i18n";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
const prefix = `/${lang}`;
const consultLabel = lang==='fr'?'Demander une Consultation Gratuite':lang==='es'?'Solicitar Consulta Gratuita':lang==='af'?"Versoek 'n Gratis Konsultasie":'Request a Free Consultation';
---
<Layout title={t("pages.substrates.hero.title") + " | Arbre Bio Africa"} description={t("pages.substrates.hero.description") || "Arbre Bio Africa precision agriculture solutions"}>
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0"><img src="https://imgur.com/BJnjT1c.jpg" alt="substrates" class="w-full h-full object-cover"/><div class="absolute inset-0 bg-black bg-opacity-55"></div></div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{t("pages.substrates.hero.title")}</h1>
      <p class="text-xl text-white max-w-2xl">{t("pages.substrates.hero.description")}</p>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          <div class="bg-gray-50 rounded-xl p-6 text-center"><div class="text-3xl mb-3">✅</div><h3 class="font-bold mb-2">{t("pages.substrates.benefits.quality") || t("pages.substrates.features.waterRetention") || ""}</h3><p class="text-gray-600 text-sm">{t("pages.substrates.benefits.qualityDesc") || t("pages.substrates.features.aeration") || ""}</p></div>
          <div class="bg-gray-50 rounded-xl p-6 text-center"><div class="text-3xl mb-3">🌿</div><h3 class="font-bold mb-2">{t("pages.substrates.benefits.sustainable") || t("pages.substrates.features.phBalanced") || ""}</h3><p class="text-gray-600 text-sm">{t("pages.substrates.benefits.sustainableDesc") || t("pages.substrates.features.organic") || ""}</p></div>
          <div class="bg-gray-50 rounded-xl p-6 text-center"><div class="text-3xl mb-3">💡</div><h3 class="font-bold mb-2">{t("pages.substrates.benefits.support") || ""}</h3><p class="text-gray-600 text-sm">{t("pages.substrates.benefits.supportDesc") || ""}</p></div>
        </div>
        <div class="text-center">
          <p class="text-lg text-gray-600 mb-8">{t("pages.substrates.hero.description")}</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={`${prefix}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors inline-block">{consultLabel}</a>
            <a href={`${prefix}/solutions`} class="border-2 border-primary text-primary px-8 py-4 rounded-full text-lg hover:bg-primary/5 transition-colors inline-block">{t("services.learnMore")}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
