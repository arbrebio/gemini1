---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { pt } from "../../../lib/pageTranslations";
import type { Language } from "../../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const p = pt(lang); const pr = p.projects;
const prefix = `/${lang}`;
const statValues = ['500+','5','50k+','98%'];
---
<Layout title={pr.meta.title} description={pr.meta.description}>
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0"><img src="https://imgur.com/XtX9fmQ.jpg" alt="Projects" class="w-full h-full object-cover"/><div class="absolute inset-0 bg-black bg-opacity-60"></div></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{pr.hero.title}</h1>
      <p class="text-xl text-white max-w-2xl mx-auto">{pr.hero.subtitle}</p>
    </div>
  </section>

  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {pr.stats.map((label, i) => (<div><div class="text-4xl font-bold mb-1">{statValues[i]}</div><div class="text-white/80">{label}</div></div>))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{pr.sectionTitle}</h2>
      <div class="space-y-12">
        {pr.items.map((proj, index) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 items-center`}>
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <img src={index===0?'https://imgur.com/JXY1XfA.jpg':index===1?'https://imgur.com/XtX9fmQ.jpg':index===2?'https://imgur.com/CEQXAs2.jpg':'https://imgur.com/XxwTJh8.jpg'} alt={proj.title} class="w-full h-72 object-cover rounded-2xl shadow-lg"/>
            </div>
            <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
              <span class="text-primary text-sm font-semibold uppercase tracking-wide">{proj.type}</span>
              <h3 class="text-2xl font-bold mt-2 mb-3">{proj.title}</h3>
              <p class="text-gray-500 mb-3 flex items-center gap-2"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>{proj.location} · {proj.area}</p>
              <p class="text-gray-600 mb-6 leading-relaxed">{proj.description}</p>
              <div class="grid grid-cols-3 gap-4">
                {proj.stats.map(([label, val]) => (<div class="bg-primary/5 rounded-lg p-3 text-center"><div class="text-xl font-bold text-primary">{val}</div><div class="text-xs text-gray-500 mt-1">{label}</div></div>))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">{pr.ctaTitle}</h2>
      <p class="text-xl text-gray-600 mb-8">{pr.ctaText}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${prefix}/contact`} class="bg-primary text-white px-8 py-3 rounded-full text-lg hover:bg-primary-600 transition-colors">{pr.ctaBtn1}</a>
        <a href="https://wa.me/2250799295643" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:opacity-90 transition-opacity">{pr.ctaBtn2}</a>
      </div>
    </div>
  </section>
</Layout>
