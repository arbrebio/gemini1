---
import Layout from "../../../layouts/Layout.astro";
import { getAllLangPaths } from "../../../lib/langPaths";
import { useT } from "../../../lib/translations";
import type { Language } from "../../../lib/i18n";
import EmojiIcon from '../../../components/EmojiIcon.astro';

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;

const featuredProjects = [
  {
    title: "PDC2V Greenhouse Project",
    location: "Abidjan (Brofodoumé), Côte d'Ivoire",
    area: "1 hectare",
    type: "PDC2V Beneficiary Program",
    description: "Construction of two tropical greenhouse (Sawtooth) of 500 m² each + drip irrigation system for producing Bell Pepper, tomato and all type of vegetable crops.",
    image: "https://imgur.com/JXY1XfA.jpg",
    stats: [{ label: "Greenhouse Area", value: "1,000 m²" }, { label: "Expected Production", value: "50 tons/year" }, { label: "Water Efficiency", value: "70%" }]
  },
  {
    title: "Greenhouse Project",
    location: "Bulawayo, Zimbabwe",
    area: "10 hectares",
    type: "Commercial Farm",
    description: "State-of-the-art greenhouse facility producing premium vegetables for local and export markets.",
    image: "https://imgur.com/XtX9fmQ.jpg",
    stats: [{ label: "Annual Production", value: "3,000 tons" }, { label: "Water Savings", value: "65%" }, { label: "Employment", value: "200+ jobs" }]
  },
  {
    title: "Smart Irrigation Project",
    location: "Yamoussoukro, Ivory Coast",
    area: "5 hectares",
    type: "Government-sponsored water management initiative",
    description: "Comprehensive water system integration including water tank installation and management systems.",
    image: "https://imgur.com/CEQXAs2.jpg",
    stats: [{ label: "Water Efficiency", value: "85%" }, { label: "Yield Increase", value: "40%" }, { label: "ROI Period", value: "2 years" }]
  },
  {
    title: "NGO UN-FAO NETHOUSE Project",
    location: "Burkina Faso",
    area: "2 hectares",
    type: "UN-OPS / FAO Project",
    description: "Advanced research facility focusing on sustainable farming practices and crop optimization.",
    image: "https://imgur.com/XxwTJh8.jpg",
    stats: [{ label: "Research Projects", value: "15+" }, { label: "Partner Institutions", value: "8" }, { label: "Training Programs", value: "12/year" }]
  }
];

const pageStats = [
  { value: "500+", label: T.projectsCompleted },
  { value: "12", label: T.africanCountries },
  { value: "50,000+", label: T.hectaresMgmt },
  { value: "98%", label: T.clientSatisfaction },
];
---

<Layout title={`${T.projectsHeroTitle} | Arbre Bio Africa`} description={T.projectsHeroDesc}>

  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/XtX9fmQ.jpg" alt="Agricultural Projects" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {T.projectsHeroTitle}
          <span class="block text-2xl md:text-3xl mt-2">{T.projectsHeroSubtitle}</span>
        </h1>
        <p class="text-xl text-white mb-8">{T.projectsHeroDesc}</p>
        <div class="flex flex-wrap gap-4">
          <a href="#featured" class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300">{T.viewProjects}</a>
          <a href={`${p}/contact`} class="bg-white/10 hover:bg-white/20 text-white border-2 border-white px-8 py-3 rounded-full text-lg transition-colors duration-300 backdrop-blur-sm">{T.startProject}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {pageStats.map(stat => (
          <div class="text-center text-white">
            <div class="text-4xl font-bold mb-2">{stat.value}</div>
            <div class="text-sm opacity-80">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="featured" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.featuredProjects}</h2>
      {featuredProjects.map((project, index) => (
        <div class={`mb-20 ${index !== 0 ? 'border-t pt-20' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <div class="bg-primary text-white px-4 py-2 rounded-full inline-block mb-4">{project.type}</div>
              <h3 class="text-2xl font-bold mb-2">{project.title}</h3>
              <p class="text-gray-600 mb-4">
                <span class="font-semibold">{T.locationLabel}</span> {project.location}<br/>
                <span class="font-semibold">{T.areaLabel}</span> {project.area}
              </p>
              <p class="text-gray-600 mb-6">{project.description}</p>
              <div class="grid grid-cols-3 gap-4">
                {project.stats.map(stat => (
                  <div class="bg-gray-50 p-4 rounded-lg">
                    <div class="text-sm text-gray-500">{stat.label}</div>
                    <div class="font-semibold text-primary">{stat.value}</div>
                  </div>
                ))}
              </div>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img src={project.image} alt={project.title} class="w-full h-[400px] object-cover rounded-lg shadow-lg"/>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.readyStart}</h2>
      <p class="text-xl text-white mb-8">{T.readyStartSub}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.getStarted}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>


  <!-- Expertise Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Nos Domaines d'Expertise en Agriculture de Précision</h2>
      <p class="text-xl text-gray-600 text-center mb-12 max-w-3xl mx-auto">Arbre Bio Africa intervient sur l'ensemble de la chaîne agricole en Côte d'Ivoire et en Afrique de l'Ouest : serres agricoles, irrigation goutte-à-goutte, substrats de culture (fibre de coco, tourbe de coco, perlite) et programmes de fertilisation.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="leaf" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Serres Tunnel &amp; Serres Agricoles</h3>
          <p class="text-gray-600">Installation de serres tunnel, serres multichapelles et serres connectées pour une production intensive hors-sol. Contrôle du microclimat, protection phytosanitaire intégrée — rendements multipliés par 3 à 5 par rapport à la plein-champ.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="water" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Irrigation Goutte-à-Goutte &amp; Aspersion</h3>
          <p class="text-gray-600">Systèmes d'irrigation de précision avec programmateurs intelligents, capteurs d'humidité et fertigation intégrée. Économie d'eau jusqu'à 70 % par rapport à l'irrigation traditionnelle, disponibles pour 0,1 à 50 ha.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="plant" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Substrats : Fibre de Coco &amp; Tourbe de Coco</h3>
          <p class="text-gray-600">Fourniture de fibre de coco (coco peat), tourbe de coco, substrats mixtes et perlite pour la culture hydroponique et hors-sol. Rétention d'eau optimale et porosité idéale pour les racines — adaptés au climat africain.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="flask" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Fertilisation &amp; Nutrition des Plantes</h3>
          <p class="text-gray-600">Plans de fertilisation personnalisés avec engrais hydrosolubles, micro-éléments et biostimulants. Programmes complets pour tomates, poivrons, aubergines, melons et cultures maraîchères africaines.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="microscope" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Protection Phytosanitaire Intégrée</h3>
          <p class="text-gray-600">Lutte intégrée contre les ravageurs et maladies : phytosanitaires homologués, filets anti-insectes, pièges, biocontrôle. Réduction de 60 % de l'utilisation de pesticides chimiques.</p>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4"><EmojiIcon id="chart" size="2rem" /></div>
          <h3 class="text-xl font-bold mb-3 text-gray-800">Conseil &amp; Suivi Agronomique</h3>
          <p class="text-gray-600">Accompagnement agronomique terrain, analyses de sol, bilans phytosanitaires et formations techniques. Suivi des performances et optimisation des rendements en continu pour chaque exploitation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">Questions Fréquentes sur nos Projets Agricoles</h2>
      <p class="text-gray-600 text-center mb-12">Tout ce que vous devez savoir sur nos réalisations en agriculture de précision en Afrique de l'Ouest.</p>
      <div class="space-y-4">
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Quels types de projets agricoles Arbre Bio Africa réalise-t-il en Côte d'Ivoire ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Arbre Bio Africa réalise des projets clés en main d'agriculture de précision : installation de serres tunnel et serres agricoles, systèmes d'irrigation goutte-à-goutte et aspersion, aménagement de cultures hors-sol avec substrats fibre de coco et tourbe de coco, mise en place de programmes de fertilisation et de protection phytosanitaire. Nous intervenons de la conception jusqu'au suivi agronomique post-installation.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Quelle est la superficie minimale pour un projet de serre agricole avec Arbre Bio ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Nous travaillons sur des projets à partir de 500 m² de serre. Nos réalisations vont de petites serres maraîchères de 1 000 m² jusqu'à des fermes modernes de plusieurs hectares. La taille idéale pour une première installation rentable en Côte d'Ivoire est généralement de 2 000 à 5 000 m², avec un retour sur investissement entre 18 et 30 mois selon la culture et le marché visé.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Arbre Bio Africa propose-t-il du financement pour les projets agricoles ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Arbre Bio Africa vous accompagne dans la structuration de votre dossier de financement auprès des institutions financières, fonds d'investissement agricoles et programmes de subvention disponibles en Côte d'Ivoire et en Afrique de l'Ouest. Nous travaillons en partenariat avec Hortalan pour proposer des solutions clés en main incluant équipements, substrats, irrigation et conseil agronomique.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Combien de temps faut-il pour installer une serre tunnel ou un système d'irrigation ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">L'installation d'une serre tunnel de 1 000 m² prend généralement 2 à 4 semaines. Un système d'irrigation goutte-à-goutte pour 1 à 5 ha se met en place en 1 à 3 semaines. Le délai total de démarrage d'un projet complet (serre + irrigation + substrats + première plantation) est de 4 à 8 semaines à partir de la signature du contrat.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Dans quels pays d'Afrique Arbre Bio Africa intervient-il pour ses projets agricoles ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Arbre Bio Africa intervient principalement en Côte d'Ivoire (siège à Abidjan), au Sénégal, au Ghana, au Cameroun et dans l'ensemble de l'Afrique de l'Ouest et subsaharienne. Nous livrons nos substrats (fibre de coco, tourbe de coco), équipements d'irrigation et serres dans toute l'Afrique. Contactez-nous pour un devis adapté à votre pays.</div>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Quels types de projets agricoles Arbre Bio Africa réalise-t-il en Côte d'Ivoire ?","acceptedAnswer":{"@type":"Answer","text":"Arbre Bio Africa réalise des projets clés en main d'agriculture de précision : installation de serres tunnel, serres agricoles, systèmes d'irrigation goutte-à-goutte, substrats fibre de coco et tourbe de coco, programmes de fertilisation et de protection phytosanitaire."}},
      {"@type":"Question","name":"Quelle est la superficie minimale pour un projet de serre agricole ?","acceptedAnswer":{"@type":"Answer","text":"Nous travaillons à partir de 500 m². La taille idéale en Côte d'Ivoire est de 2 000 à 5 000 m², avec retour sur investissement entre 18 et 30 mois."}},
      {"@type":"Question","name":"Arbre Bio Africa propose-t-il du financement pour les projets agricoles ?","acceptedAnswer":{"@type":"Answer","text":"Oui, nous accompagnons dans la structuration du dossier de financement auprès des institutions financières et programmes de subvention en Côte d'Ivoire et en Afrique de l'Ouest."}},
      {"@type":"Question","name":"Combien de temps faut-il pour installer une serre tunnel ou un système d'irrigation ?","acceptedAnswer":{"@type":"Answer","text":"Une serre tunnel de 1 000 m² prend 2 à 4 semaines. Un système d'irrigation goutte-à-goutte pour 1 à 5 ha se met en place en 1 à 3 semaines."}},
      {"@type":"Question","name":"Dans quels pays d'Afrique Arbre Bio Africa intervient-il ?","acceptedAnswer":{"@type":"Answer","text":"Principalement en Côte d'Ivoire (Abidjan), au Sénégal, au Ghana, au Cameroun et dans toute l'Afrique de l'Ouest et subsaharienne."}}
    ]
  }
  </script>

</Layout>
