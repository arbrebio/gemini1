// ── FAQs ───────────────────────────────────────────────────────────────────────
interface FAQ { q: string; a: string; }
const faqByLang: Record<string, FAQ[]> = {
  fr: [
    { q: "Quels rendements peut-on espérer avec une serre et l'irrigation goutte-à-goutte en Afrique ?", a: "Les résultats varient selon la culture, mais en moyenne nos clients obtiennent : tomates 40 à 60 t/ha (vs 8 à 12 t/ha en plein champ), poivrons 45 à 55 t/ha, concombres 60 à 80 t/ha, laitues 30 cycles/an. Ces performances sont rendues possibles grâce à la combinaison serre + irrigation de précision + substrat fibre de coco + fertilisation hydrosoluble adaptée." },
    { q: "Combien d'eau économise-t-on avec l'irrigation goutte-à-goutte par rapport à l'irrigation traditionnelle ?", a: "L'irrigation goutte-à-goutte avec programmateur intelligent permet d'économiser entre 50 % et 70 % d'eau par rapport à l'irrigation par gravité ou aspersion classique. En Côte d'Ivoire, où l'eau représente 30 à 40 % des coûts d'exploitation maraîchère, cette économie est critique pour la rentabilité. Le substrat tourbe de coco amplifie encore cet effet grâce à sa capacité de rétention d'eau supérieure à la terre." },
    { q: "Quel est le retour sur investissement (ROI) typique pour une installation de serre en Afrique de l'Ouest ?", a: "Pour une installation complète (serre tunnel 2 000 m² + irrigation + substrats), le retour sur investissement est généralement atteint en 18 à 36 mois selon la culture et le circuit de distribution. Les cultures à haute valeur ajoutée comme les tomates cerise, poivrons, herbes aromatiques et fraises permettent les ROI les plus rapides (12 à 24 mois). Contactez-nous pour une étude de rentabilité personnalisée." },
    { q: "La fibre de coco (coco peat) est-elle adaptée aux conditions climatiques africaines ?", a: "Oui, la fibre de coco et la tourbe de coco sont particulièrement bien adaptées aux conditions africaines. Contrairement à la tourbe classique, le coco peat résiste à la chaleur, conserve sa structure sur 3 à 5 ans, ne se compacte pas et maintient une porosité stable même sous des températures de 35-40°C. Sa capacité de rétention d'eau (650 % de son poids) et son pH neutre (5,5-6,5) en font le substrat idéal pour la culture maraîchère intensive en Afrique." },
    { q: "Arbre Bio Africa propose-t-il un suivi après installation pour garantir les résultats ?", a: "Oui, chaque projet inclut un programme de suivi agronomique post-installation : visites terrain régulières, analyses de nutriments dans les plantes et substrats, ajustement des programmes de fertilisation et de protection phytosanitaire, formation continue des équipes. Notre objectif est que chaque client atteigne les rendements cibles dans les 2 premières saisons et les maintienne sur le long terme." },
  ],
  es: [
    { q: "¿Qué rendimientos se pueden esperar con un invernadero y riego por goteo en África?", a: "Los resultados varían según el cultivo, pero en promedio nuestros clientes logran: tomates 40 a 60 t/ha (vs 8 a 12 t/ha en campo abierto), pimientos 45 a 55 t/ha, pepinos 60 a 80 t/ha, lechugas 30 ciclos/año. Estos rendimientos son posibles gracias a la combinación invernadero + riego de precisión + sustrato de fibra de coco + fertilización hidrosoluble adaptada." },
    { q: "¿Cuánta agua se ahorra con el riego por goteo comparado con el riego tradicional?", a: "El riego por goteo con programador inteligente ahorra entre un 50% y un 70% de agua en comparación con el riego por gravedad o aspersión convencional. En Côte d'Ivoire, donde el agua representa el 30 al 40% de los costos de operación hortícola, este ahorro es crítico para la rentabilidad. El sustrato de turba de coco amplifica este efecto gracias a su superior capacidad de retención de agua." },
    { q: "¿Cuál es el retorno de inversión típico para una instalación de invernadero en África Occidental?", a: "Para una instalación completa (invernadero túnel de 2.000 m² + riego + sustratos), el retorno de inversión se logra generalmente en 18 a 36 meses según el cultivo y el canal de distribución. Los cultivos de alto valor como tomates cherry, pimientos, hierbas aromáticas y fresas permiten los ROI más rápidos (12 a 24 meses). Contáctenos para un estudio de rentabilidad personalizado." },
    { q: "¿Es la fibra de coco (coco peat) adecuada para las condiciones climáticas africanas?", a: "Sí, la fibra de coco y la turba de coco están particularmente bien adaptadas a las condiciones africanas. A diferencia de la turba clásica, el coco peat resiste el calor, mantiene su estructura durante 3 a 5 años, no se compacta y mantiene una porosidad estable incluso a temperaturas de 35-40°C. Su capacidad de retención de agua (650% de su peso) y pH neutro (5,5-6,5) lo convierten en el sustrato ideal para el cultivo intensivo de hortalizas en África." },
    { q: "¿Ofrece Arbre Bio Africa seguimiento postventa para garantizar los resultados?", a: "Sí, cada proyecto incluye un programa de seguimiento agronómico post-instalación: visitas regulares al campo, análisis de nutrientes en plantas y sustratos, ajuste de programas de fertilización y protección fitosanitaria, formación continua del equipo. Nuestro objetivo es que cada cliente alcance los rendimientos objetivo dentro de las primeras 2 temporadas y los mantenga a largo plazo." },
  ],
  af: [
    { q: "Watter opbrengste kan jy verwag met 'n kweekhuis en druppelbesproeiing in Afrika?", a: "Resultate wissel per gewas, maar gemiddeld behaal ons kliënte: tamaties 40 tot 60 t/ha (vs 8 tot 12 t/ha in oop veld), soetrissies 45 tot 55 t/ha, komkommers 60 tot 80 t/ha, blaarslaai 30 siklusse/jaar. Hierdie prestasies word moontlik gemaak deur die kombinasie kweekhuis + presisiebesproeiing + kokosveselsubs traat + aangepaste wateroplosbare bemesting." },
    { q: "Hoeveel water word gespaar met druppelbesproeiing in vergelyking met tradisionele besproeiing?", a: "Slim druppelbesproeiing bespaar tussen 50% en 70% water in vergelyking met swaartekrag of konvensionele sprinklerbesproeiing. In Côte d'Ivoire, waar water 30 tot 40% van hortikulturele bedryfskoste verteenwoordig, is hierdie besparing krities vir winsgewendheid. Kokosveen substraat versterk hierdie effek verder danksy sy superieure waterretensie kapasiteit." },
    { q: "Wat is die tipiese ROI vir 'n kweekhuis installasie in Wes-Afrika?", a: "Vir 'n volledige installasie (2.000 m² tonnelkweekhuis + besproeiing + substrate), word opbrengs op belegging gewoonlik bereik in 18 tot 36 maande, afhangende van die gewas en distribusiekanaal. Hoëwaarde gewasse soos kersiietamaties, soetrissies, aromatiese kruie en aarbeie maak die vinnigste ROI moontlik (12 tot 24 maande). Kontak ons vir 'n persoonlike winsgewendheidstudie." },
    { q: "Is kokosvesels (coco peat) geskik vir Afrika se klimaatsomstandighede?", a: "Ja, kokosvesels en kokosveen is veral goed aangepas by Afrika-toestande. Anders as klassieke turf weerstaan kokosveen hitte, behou sy struktuur vir 3 tot 5 jaar, kompakteer nie en handhaaf stabiele porositeit selfs by temperature van 35-40°C. Sy waterretensie kapasiteit (650% van sy gewig) en neutrale pH (5,5-6,5) maak dit die ideale substraat vir intensiewe groenteteelt in Afrika." },
    { q: "Bied Arbre Bio Africa na-installasie opvolg om resultate te waarborg?", a: "Ja, elke projek sluit 'n na-installasie agronomiese moniteringsprogram in: gereelde veldbesoeke, voedingstofanalises in plante en substrate, aanpassing van bemestings- en plantbeskerming programme, deurlopende spanopleiding. Ons doel is dat elke kliënt teikenopbrengste bereik binne die eerste 2 seisoene en dit op die lang termyn handhaaf." },
  ],
};
const faqs = faqByLang[lang] ?? faqByLang.fr;
---

<Layout
  title={({'fr':'Histoires de Succès — Résultats Réels | Arbre Bio Africa','es':'Historias de Éxito — Resultados Reales | Arbre Bio Africa','af':'Suksesverhale — Werklike Resultate | Arbre Bio Africa'} as Record<string,string>)[lang] || 'Success Stories | Arbre Bio Africa'}
  description={T.ssHeroDesc}
>

  <!-- Hero -->
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?ixlib=rb-4.0.3" alt={T.ssHeroTitle} class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-55"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.ssHeroTitle}</h1>
      <p class="text-xl text-white max-w-2xl mx-auto">{T.ssHeroSubtitle}</p>
    </div>
  </section>

  <!-- Case Studies -->
  {studies.map((study, index) => (
    <section class={`py-20 ${index % 2 !== 0 ? "bg-gray-50" : "bg-white"}`}>
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold mb-2">{study.title}</h2>
          <p class="text-gray-500 mb-8">{study.client} — {study.location}</p>
          <p class="text-gray-600 mb-8 text-lg">{study.description}</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <div class="bg-red-50 p-6 rounded-lg">
              <h3 class="font-bold text-red-700 mb-3">{T.challenge}</h3>
              <p class="text-gray-700 text-sm">{study.challenge}</p>
            </div>
            <div class="bg-blue-50 p-6 rounded-lg">
              <h3 class="font-bold text-blue-700 mb-3">{T.solution}</h3>
              <p class="text-gray-700 text-sm">{study.solution}</p>
            </div>
            <div class="bg-green-50 p-6 rounded-lg">
              <h3 class="font-bold text-green-700 mb-3">{T.results}</h3>
              <ul class="space-y-1">
                {study.results.map(r => (
                  <li class="text-sm text-gray-700 flex items-start gap-2">
                    <span class="text-green-500 font-bold mt-0.5 flex-shrink-0">✓</span>{r}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div>
              <p class="text-sm font-semibold text-gray-500 mb-2">{T.beforeLabel}</p>
              <img src={study.beforeImage} alt={T.beforeLabel} class="w-full h-48 object-cover rounded-lg shadow"/>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-500 mb-2">{T.afterLabel}</p>
              <img src={study.afterImage} alt={T.afterLabel} class="w-full h-48 object-cover rounded-lg shadow"/>
            </div>
          </div>
          <blockquote class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg">
            <p class="text-gray-700 italic mb-4">"{study.testimonial}"</p>
            <div class="flex items-center gap-3">
              <img src={study.clientImage} alt={study.client} class="w-10 h-10 rounded-full object-cover"/>
              <span class="font-semibold text-primary">{study.client}</span>
            </div>
          </blockquote>
        </div>
      </div>
    </section>
  ))}

  <!-- What Clients Say -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{UI.whatClientsSay}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="flex items-center mb-4">
              <img src={t.image} alt={t.name} class="w-16 h-16 rounded-full object-cover mr-4"/>
              <div>
                <h3 class="font-bold">{t.name}</h3>
                <p class="text-gray-600">{t.role}</p>
                <p class="text-gray-500 text-sm">{t.location}</p>
              </div>
            </div>
            <blockquote class="text-gray-700 italic">"{t.text}"</blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{T.transformFarm}</h2>
      <p class="text-xl text-white mb-8">{T.joinFarmers}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${p}/contact`} class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90">{T.freeConsultation}</a>
        <a href="https://wa.me/2250500552525" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center">
          <i class="fab fa-whatsapp mr-2"></i>{T.chatWhatsApp}
        </a>
      </div>
    </div>
  </section>

  <!-- Measurable Results -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">{UI.resultsTitle}</h2>
      <p class="text-xl text-gray-600 text-center mb-12 max-w-3xl mx-auto">{UI.resultsSubtitle}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {resultCards.map((card) => (
          <div class="bg-white rounded-xl p-8 shadow-md">
            <h3 class={`text-2xl font-bold mb-4 ${card.colorClass} flex items-center gap-2`}>
              <EmojiIcon id={card.icon} size="1.5rem" />{card.title}
            </h3>
            <p class="text-gray-600 mb-4">{card.body}</p>
            <div class="grid grid-cols-3 gap-4">
              <div class="text-center bg-green-50 p-3 rounded-lg">
                <div class="text-2xl font-bold text-green-600">{card.stat1val}</div>
                <div class="text-sm text-gray-600">{card.stat1lbl}</div>
              </div>
              <div class="text-center bg-blue-50 p-3 rounded-lg">
                <div class="text-2xl font-bold text-blue-600">{card.stat2val}</div>
                <div class="text-sm text-gray-600">{card.stat2lbl}</div>
              </div>
              <div class="text-center bg-orange-50 p-3 rounded-lg">
                <div class="text-2xl font-bold text-orange-600">{card.stat3val}</div>
                <div class="text-sm text-gray-600">{card.stat3lbl}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">{UI.faqTitle}</h2>
      <p class="text-gray-600 text-center mb-12">{UI.faqSubtitle}</p>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="border border-gray-200 rounded-lg overflow-hidden">
            <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">{faq.q}</summary>
            <div class="px-6 pb-6 text-gray-600 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

</Layout>
