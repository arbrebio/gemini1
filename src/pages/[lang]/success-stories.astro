---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useTranslations } from "../../lib/i18n";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
const prefix = `/${lang}`;
const titles: Record<string, string> = { fr: 'Histoires de Succès', es: 'Historias de Éxito', af: 'Suksesverhale', en: 'Success Stories' };
const subs: Record<string, string> = { fr: 'Des agriculteurs africains qui ont transformé leurs fermes avec Arbre Bio', es: 'Agricultores africanos que han transformado sus granjas con Arbre Bio', af: "Afrika se boere wat hul plase met Arbre Bio getransformeer het", en: 'African farmers who transformed their farms with Arbre Bio' };
---
<Layout title={titles[lang] + " | Arbre Bio Africa"} description={subs[lang]}>
  <section class="relative h-[45vh] flex items-center">
    <div class="absolute inset-0 z-0"><img src="https://imgur.com/YbVGmcu.jpg" alt="Success Stories" class="w-full h-full object-cover"/><div class="absolute inset-0 bg-black bg-opacity-55"></div></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{titles[lang]}</h1>
      <p class="text-xl text-white max-w-2xl mx-auto">{subs[lang]}</p>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 text-center">
      <p class="text-lg text-gray-600 mb-8">{t("cta.subtitle")}</p>
      <a href={`${prefix}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors inline-block">{t("cta.consultation")}</a>
    </div>
  </section>
</Layout>
