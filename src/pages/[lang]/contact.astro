---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useT } from "../../lib/translations";
import FormValidation from "../../components/FormValidation.astro";
import LoadingSpinner from "../../components/LoadingSpinner.astro";
import { config } from "../../lib/config";
import type { Language } from "../../lib/i18n";
import EmojiIcon from '../../components/EmojiIcon.astro';

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;
---

<Layout title={({'fr':'Contactez Arbre Bio Africa | Devis Gratuit','en':'Contact Arbre Bio Africa | Free Quote','es':'Contacta Arbre Bio Africa | Presupuesto Gratis','af':'Kontak Arbre Bio Africa | Gratis Kwotasie'} as Record<string,string>)[lang]||'Contact Arbre Bio Africa | Free Quote'} description={T.contactSubtitle}>

  <section class="relative h-[40vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/YyhVyLx.jpg" alt="Contact Arbre Bio" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.contactTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.contactSubtitle}</p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <h2 class="text-3xl font-bold mb-6">{T.sendMessageTitle}</h2>
          <form class="space-y-6" id="contact-form">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">{T.firstName} *</label>
                <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/>
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1">{T.lastName} *</label>
                <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/>
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">{T.emailAddress} *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/>
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">{T.phoneNumber} *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"/>
            </div>
            <div>
              <label for="interest" class="block text-sm font-medium text-gray-700 mb-1">{T.interestedIn} *</label>
              <select id="interest" name="interest" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50">
                <option value="">{T.selectOption}</option>
                <option value="Greenhouses">{T.optGreenhouses}</option>
                <option value="Irrigation Systems">{T.optIrrigation}</option>
                <option value="Growing Media">{T.optGrowing}</option>
                <option value="Project Management">{T.optProjects}</option>
                <option value="Other">{T.optOther}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">{T.messageLabel} *</label>
              <textarea id="message" name="message" rows="4" required class="w-full px-4 py-2 rounded-md border border-gray-300 focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50"></textarea>
            </div>
            <button type="submit" class="w-full bg-primary text-white px-8 py-3 rounded-md hover:bg-primary-600 transition-colors duration-300 flex items-center justify-center">
              <span class="mr-2">{T.sendBtn}</span>
              <span class="loading-spinner hidden ml-2"><LoadingSpinner size="sm" color="white"/></span>
            </button>
            <p class="text-sm text-gray-600 mt-2">{T.respondTime}</p>
            <div class="success-message hidden bg-green-50 text-green-800 p-4 rounded-md" role="alert" aria-live="polite">{T.successMsg}</div>
            <div class="error-message hidden bg-red-50 text-red-800 p-4 rounded-md" role="alert" aria-live="assertive"></div>
          </form>
          <FormValidation formId="contact-form" rules={[
            { field: "firstName", required: true, type: "text", maxLength: 50 },
            { field: "lastName", required: true, type: "text", maxLength: 50 },
            { field: "email", required: true, type: "email", maxLength: 100 },
            { field: "phone", required: true, type: "phone", maxLength: 20 },
            { field: "interest", required: true, type: "text" },
            { field: "message", required: true, type: "text", minLength: 10, maxLength: 1000 },
          ]}/>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-bold mb-6">{T.ourOffices}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {config.contact.offices.map((office) => (
                <div class="bg-white p-6 rounded-lg shadow-lg">
                  <h3 class="text-xl font-bold mb-2">{office.city}, {office.country}</h3>
                  <div class="space-y-3 text-gray-600">
                    <p>{office.address}</p>
                    <p><a href={`tel:${office.phone.replace(/\s+/g, "")}`} class="hover:text-primary transition-colors">{office.phone}</a></p>
                    <p><a href={`mailto:${office.email}`} class="hover:text-primary transition-colors">{office.email}</a></p>
                    <p>{office.hours}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="bg-[#25D366] text-white p-8 rounded-lg shadow-lg">
            <h3 class="text-2xl font-bold mb-4">{T.immediateAssistance}</h3>
            <p class="mb-6">{T.waChatExperts}</p>
            <a href={`https://wa.me/${config.contact.whatsappNumber.replace("+", "")}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-white text-[#25D366] px-6 py-3 rounded-md hover:bg-opacity-90 transition-colors">
              <i class="fab fa-whatsapp text-xl mr-2"></i>{T.chatWhatsApp}
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    import { handleFormSubmission } from "../../lib/errorHandling";
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const successMessage = form ? form.querySelector(".success-message") : null;
    const errorMessage = form ? form.querySelector(".error-message") : null;
    const loadingSpinner = form ? form.querySelector(".loading-spinner") : null;
    const submitButton = form ? (form.querySelector('button[type="submit"]') as HTMLButtonElement | null) : null;
    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        successMessage?.classList.add("hidden");
        errorMessage?.classList.add("hidden");
        loadingSpinner?.classList.remove("hidden");
        if (submitButton) { submitButton.disabled = true; submitButton.setAttribute("aria-busy", "true"); }
        try {
          const formData = new FormData(form);
          const pathLang = window.location.pathname.split('/')[1];
          const data = { firstName: formData.get("firstName"), lastName: formData.get("lastName"), email: formData.get("email"), phone: formData.get("phone"), interest: formData.get("interest"), message: formData.get("message"), lang: ['fr','es','af'].includes(pathLang) ? pathLang : 'en' };
          await handleFormSubmission("/api/contact", data, {
            successMessage: "Thank you for your message!",
            onSuccess: () => { successMessage?.classList.remove("hidden"); (form as HTMLFormElement).reset(); },
            onError: (error) => { if (errorMessage) { (errorMessage as HTMLElement).textContent = error; errorMessage.classList.remove("hidden"); } },
          });
        } catch (error) {
          if (errorMessage) { (errorMessage as HTMLElement).textContent = error instanceof Error ? error.message : "An error occurred."; errorMessage.classList.remove("hidden"); }
        } finally {
          loadingSpinner?.classList.add("hidden");
          if (submitButton) { (submitButton as HTMLButtonElement).disabled = false; submitButton.removeAttribute("aria-busy"); }
        }
      });
    }
  </script>


  <!-- Why Contact Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Démarrez votre Projet d'Agriculture de Précision en Afrique</h2>
      <p class="text-xl text-gray-600 text-center mb-12 max-w-3xl mx-auto">Que vous souhaitiez installer une serre agricole, un système d'irrigation goutte-à-goutte, des substrats de culture (fibre de coco, tourbe de coco) ou un programme complet de fertilisation — Arbre Bio Africa vous accompagne de A à Z en Côte d'Ivoire et en Afrique de l'Ouest.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white rounded-xl p-6 shadow-md text-center">
          <div class="text-4xl mb-4"><EmojiIcon id="leaf" size="2rem" /></div>
          <h3 class="text-lg font-bold mb-2">Consultation Agronomique Gratuite</h3>
          <p class="text-gray-600">Évaluation de votre projet, analyse du sol, recommandation de cultures adaptées à votre région. Entièrement gratuit pour tout projet d'agriculture de précision.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md text-center">
          <div class="text-4xl mb-4"><EmojiIcon id="wrench" size="2rem" /></div>
          <h3 class="text-lg font-bold mb-2">Étude Technique &amp; Devis</h3>
          <p class="text-gray-600">Plan d'implantation de serre, dimensionnement du système d'irrigation, choix du substrat (coco peat, tourbe de coco, perlite) et programme de fertilisation personnalisé.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md text-center">
          <div class="text-4xl mb-4"><EmojiIcon id="handshake" size="2rem" /></div>
          <h3 class="text-lg font-bold mb-2">Suivi Projet &amp; Formation</h3>
          <p class="text-gray-600">Installation clés en main, formation technique de vos équipes, suivi agronomique post-installation et optimisation continue des rendements et de la qualité.</p>
        </div>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold mb-3 text-green-800">Partenaire Hortalan en Côte d'Ivoire</h3>
        <p class="text-gray-700 max-w-2xl mx-auto">Arbre Bio Africa est en cours d'établissement d'une joint-venture avec <strong>Hortalan</strong>, leader européen des solutions horticoles et d'agriculture de précision. Ce partenariat vous donnera accès aux technologies agricoles les plus avancées directement depuis la Côte d'Ivoire.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-4">Questions Fréquentes — Démarrer avec Arbre Bio Africa</h2>
      <p class="text-gray-600 text-center mb-12">Tout ce que vous devez savoir avant de lancer votre projet d'agriculture de précision en Afrique.</p>
      <div class="space-y-4">
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Comment démarrer un projet avec Arbre Bio Africa ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">La première étape est simple : remplissez le formulaire ci-dessus ou contactez-nous directement par WhatsApp (+225 05 00 55 25 25). Nous organiseons une consultation gratuite pour comprendre vos besoins, analyser votre site et définir le meilleur projet — serre agricole, irrigation goutte-à-goutte, substrats de culture ou programme complet. Sous 48 heures, vous recevrez un premier retour et une proposition d'étude technique.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Arbre Bio Africa livre-t-il les substrats (fibre de coco, tourbe de coco, perlite) dans toute l'Afrique ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Oui. Nous livrons nos substrats de culture — fibre de coco (coco peat), tourbe de coco, perlite, substrats mixtes — dans toute l'Afrique subsaharienne et de l'Ouest : Côte d'Ivoire, Sénégal, Ghana, Cameroun, Bénin, Togo, Burkina Faso, Mali. Les engrais hydrosolubles et équipements d'irrigation sont également disponibles à l'export. Contactez-nous pour les conditions et tarifs de livraison dans votre pays.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Quel budget minimum faut-il prévoir pour un projet de serre avec Arbre Bio Africa ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Un projet de serre de démarrage (500 à 1 000 m² avec irrigation et substrats) démarre à partir de 3 à 5 millions FCFA. Une installation complète de 2 000 à 5 000 m² avec tout l'équipement (serre, irrigation goutte-à-goutte, substrat fibre de coco, programme de fertilisation) représente un investissement de 15 à 40 millions FCFA selon le niveau d'automatisation. Nous établissons des devis détaillés gratuits sur mesure pour chaque projet.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">Arbre Bio Africa propose-t-il des formations en agriculture de précision ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Oui, nous proposons des formations pratiques en agriculture de précision adaptées à l'Afrique : conduite de culture sous serre, gestion de l'irrigation goutte-à-goutte et de la fertigation, utilisation et réutilisation des substrats fibre de coco et tourbe de coco, programmes de fertilisation et nutrition des plantes, gestion phytosanitaire intégrée. Les formations se déroulent en Côte d'Ivoire ou directement dans votre pays.</div>
        </details>
        <details class="border border-gray-200 rounded-lg overflow-hidden">
          <summary class="p-6 font-semibold cursor-pointer hover:bg-gray-50">En combien de temps Arbre Bio Africa peut-il répondre à une demande de devis ?</summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">Nous nous engageons à répondre à toute demande de devis ou consultation dans un délai de 24 à 48 heures ouvrées. Pour les demandes urgentes, notre WhatsApp (+225 05 00 55 25 25) est disponible du lundi au samedi de 8h à 18h. Pour les projets complexes (grandes surfaces, exportations de substrats, partenariats institutionnels), nous planifions une réunion technique dans la semaine suivant votre demande.</div>
        </details>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Comment démarrer un projet avec Arbre Bio Africa ?","acceptedAnswer":{"@type":"Answer","text":"Remplissez le formulaire ou contactez-nous par WhatsApp (+225 05 00 55 25 25). Consultation gratuite sous 48h pour définir votre projet serre, irrigation, substrats ou programme complet."}},
      {"@type":"Question","name":"Arbre Bio Africa livre-t-il les substrats (fibre de coco, tourbe de coco, perlite) dans toute l'Afrique ?","acceptedAnswer":{"@type":"Answer","text":"Oui, nous livrons en Côte d'Ivoire, Sénégal, Ghana, Cameroun, Bénin, Togo, Burkina Faso, Mali. Substrats, engrais et équipements d'irrigation disponibles à l'export."}},
      {"@type":"Question","name":"Quel budget minimum pour un projet de serre avec Arbre Bio Africa ?","acceptedAnswer":{"@type":"Answer","text":"Un projet de démarrage (500-1000 m²) part de 3 à 5 millions FCFA. Une installation complète (2000-5000 m²) représente 15 à 40 millions FCFA. Devis gratuit sur mesure."}},
      {"@type":"Question","name":"Arbre Bio Africa propose-t-il des formations en agriculture de précision ?","acceptedAnswer":{"@type":"Answer","text":"Oui : formations pratiques serre, irrigation goutte-à-goutte, substrats fibre de coco, fertilisation, phytosanitaire. En Côte d'Ivoire ou dans votre pays."}},
      {"@type":"Question","name":"En combien de temps Arbre Bio Africa répond-il à une demande de devis ?","acceptedAnswer":{"@type":"Answer","text":"Réponse sous 24 à 48h ouvrées. WhatsApp disponible lundi-samedi 8h-18h pour les urgences. Réunion technique planifiée dans la semaine pour les projets complexes."}}
    ]
  }
  </script>

</Layout>
