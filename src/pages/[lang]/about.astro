---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useT } from "../../lib/translations";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;
---

<Layout
  title={`${T.aboutPageTitle} | Arbre Bio Africa`}
  description={`${T.whoWeAreText}`}
>

  <!-- Hero -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/4gQ57MK.jpg" alt="Arbre Bio Africa" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-55"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.aboutPageTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.aboutPageSubtitle}</p>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8">{T.whoWeAre}</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">{T.whoWeAreText}</p>
        <div class="bg-primary/5 border-l-4 border-primary rounded-r-xl p-6">
          <h3 class="text-xl font-bold mb-3">{T.ourMissionShort}</h3>
          <p class="text-gray-700">{T.ourMissionShortText}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Journey -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center">{T.ourJourney}</h2>
        <div class="space-y-6">
          {[
            { year: "2020", title: T.y2020t, desc: T.y2020d },
            { year: "2021", title: T.y2021t, desc: T.y2021d },
            { year: "2022", title: T.y2022t, desc: T.y2022d },
            { year: "2023", title: T.y2023t, desc: T.y2023d },
            { year: "2024", title: T.y2024t, desc: T.y2024d },
            { year: "2025", title: T.y2025t, desc: T.y2025d },
          ].map(item => (
            <div class="flex gap-4 items-start">
              <div class="bg-primary text-white rounded-full w-16 h-12 flex items-center justify-center font-bold flex-shrink-0 text-sm">{item.year}</div>
              <div class="bg-white rounded-lg shadow-sm p-4 flex-1 border border-gray-100">
                <strong class="text-gray-800">{item.title}</strong>
                <p class="text-gray-600 mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Our Leadership -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.ourLeadership}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
        <div class="text-center">
          <img src="https://imgur.com/LAiwg8o.png" alt={T.ceoName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.ceoName}</h3>
          <p class="text-primary font-semibold mb-3">{T.ceoTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.ceoBio}</p>
        </div>
        <div class="text-center">
          <img src="https://imgur.com/LD5JZto.jpg" alt={T.cooName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.cooName}</h3>
          <p class="text-primary font-semibold mb-3">{T.cooTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.cooBio}</p>
        </div>
        <div class="text-center">
          <img src="https://imgur.com/NU06wJT.jpg" alt={T.marketingName} class="w-40 h-40 rounded-full object-cover mx-auto mb-4 shadow-lg"/>
          <h3 class="text-xl font-bold mb-1">{T.marketingName}</h3>
          <p class="text-primary font-semibold mb-3">{T.marketingTitle}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{T.marketingBio}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.ourValues}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center bg-white rounded-xl shadow-md p-8 hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">🌱</div>
          <h3 class="text-xl font-bold mb-3">{T.value1Title}</h3>
          <p class="text-gray-600">{T.value1Desc}</p>
        </div>
        <div class="text-center bg-white rounded-xl shadow-md p-8 hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">💡</div>
          <h3 class="text-xl font-bold mb-3">{T.value2Title}</h3>
          <p class="text-gray-600">{T.value2Desc}</p>
        </div>
        <div class="text-center bg-white rounded-xl shadow-md p-8 hover:shadow-lg transition-shadow">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="text-xl font-bold mb-3">{T.value3Title}</h3>
          <p class="text-gray-600">{T.value3Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">{T.joinUsTitle}</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">{T.joinUsSubtitle}</p>
      <a href={`${p}/contact`} class="bg-white text-primary px-8 py-4 rounded-full text-lg hover:bg-opacity-90 transition-colors duration-300 inline-block font-semibold">{T.getInTouch}</a>
    </div>
  </section>

</Layout>
