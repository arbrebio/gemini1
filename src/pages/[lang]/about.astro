---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, getStaticPaths } from '../../lib/i18n';

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as any);
---

<Layout
  title={t('about.title')}
  description={t('about.description')}
>
  <!-- Hero Section -->
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://imgur.com/4gQ57MK.jpg"
        alt={t("about.teamImage")} 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{t('about.hero.title')}</h1>
      <p class="text-xl text-white max-w-2xl">{t('about.hero.subtitle')}</p>
    </div>
  </section>

  <!-- Who We Are Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">{t('about.whoWeAre.title')}</h2>
        <p class="text-lg text-gray-700 mb-8">
          {t('about.whoWeAre.text')}
        </p>
        <div class="bg-primary/10 p-8 rounded-lg mb-8">
          <h3 class="text-2xl font-bold text-primary mb-4">{t('about.whoWeAre.mission.title')}</h3>
          <p class="text-lg">
            {t('about.whoWeAre.mission.text')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.journey.title')}</h2>
      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-primary"></div>
          
          <!-- Timeline Items -->
          <div class="space-y-12">
            <!-- 2020 -->
            <div class="relative">
              <div class="flex items-center justify-center">
                <div class="bg-primary text-white px-4 py-2 rounded-full mb-4 z-10">2020</div>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-lg ml-4 md:ml-0 md:w-[calc(50%-2rem)] md:float-left">
                <h3 class="font-bold text-lg mb-2">{t('about.journey.timeline.2020.title')}</h3>
                <p class="text-gray-600">{t('about.journey.timeline.2020.text')}</p>
              </div>
            </div>

            <!-- 2021 -->
            <div class="relative">
              <div class="flex items-center justify-center">
                <div class="bg-primary text-white px-4 py-2 rounded-full mb-4 z-10">2021</div>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-lg mr-4 md:mr-0 md:w-[calc(50%-2rem)] md:float-right md:clear-both">
                <h3 class="font-bold text-lg mb-2">{t('about.journey.timeline.2021.title')}</h3>
                <p class="text-gray-600">{t('about.journey.timeline.2021.text')}</p>
              </div>
            </div>

            <!-- 2022 -->
            <div class="relative">
              <div class="flex items-center justify-center">
                <div class="bg-primary text-white px-4 py-2 rounded-full mb-4 z-10">2022</div>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-lg ml-4 md:ml-0 md:w-[calc(50%-2rem)] md:float-left">
                <h3 class="font-bold text-lg mb-2">{t('about.journey.timeline.2022.title')}</h3>
                <p class="text-gray-600">{t('about.journey.timeline.2022.text')}</p>
              </div>
            </div>

            <!-- 2023 -->
            <div class="relative">
              <div class="flex items-center justify-center">
                <div class="bg-primary text-white px-4 py-2 rounded-full mb-4 z-10">2023</div>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-lg mr-4 md:mr-0 md:w-[calc(50%-2rem)] md:float-right md:clear-both">
                <h3 class="font-bold text-lg mb-2">{t('about.journey.timeline.2023.title')}</h3>
                <p class="text-gray-600">{t('about.journey.timeline.2023.text')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership Team Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.leadership.title')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- CEO -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <img
            src="https://imgur.com/LAiwg8o.png"
            alt={t('about.leadership.ceo.name')}
            class="w-48 h-48 rounded-full mx-auto mb-4 object-cover"
          />
          <div class="text-center">
            <h3 class="text-xl font-bold mb-2">{t('about.leadership.ceo.name')}</h3>
            <p class="text-primary font-semibold mb-4">{t('about.leadership.ceo.role')}</p>
            <p class="text-gray-600">
              {t('about.leadership.ceo.bio')}
            </p>
          </div>
        </div>

        <!-- COO -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <img
            src="https://imgur.com/LD5JZto.jpg"
            alt={t('about.leadership.coo.name')}
            class="w-48 h-48 rounded-full mx-auto mb-4 object-cover"
          />
          <div class="text-center">
            <h3 class="text-xl font-bold mb-2">{t('about.leadership.coo.name')}</h3>
            <p class="text-primary font-semibold mb-4">{t('about.leadership.coo.role')}</p>
            <p class="text-gray-600">
              {t('about.leadership.coo.bio')}
            </p>
          </div>
        </div>

        <!-- Marketing Strategy Representative -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <img
            src="https://imgur.com/NU06wJT.jpg"
            alt={t('about.leadership.marketing.name')}
            class="w-48 h-48 rounded-full mx-auto mb-4 object-cover"
          />
          <div class="text-center">
            <h3 class="text-xl font-bold mb-2">{t('about.leadership.marketing.name')}</h3>
            <p class="text-primary font-semibold mb-4">{t('about.leadership.marketing.role')}</p>
            <p class="text-gray-600">
              {t('about.leadership.marketing.bio')}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{t('about.values.title')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-4xl mb-4">🌱</div>
          <h3 class="text-xl font-bold mb-2">{t('about.values.sustainability.title')}</h3>
          <p class="text-gray-600">{t('about.values.sustainability.text')}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">💡</div>
          <h3 class="text-xl font-bold mb-2">{t('about.values.innovation.title')}</h3>
          <p class="text-gray-600">{t('about.values.innovation.text')}</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="text-xl font-bold mb-2">{t('about.values.partnership.title')}</h3>
          <p class="text-gray-600">{t('about.values.partnership.text')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">{t('about.cta.title')}</h2>
      <p class="text-xl text-white mb-8">{t('about.cta.subtitle')}</p>
      <a 
        href="/contact" 
        class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center"
      >
        {t('about.cta.button')}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>