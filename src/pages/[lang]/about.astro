---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { useT } from "../../lib/translations";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const T = useT(lang as any);
const p = `/${lang}`;
---

<Layout title={`${T.aboutPageTitle} | Arbre Bio Africa`} description={T.aboutPageSubtitle}>

  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="https://imgur.com/4gQ57MK.jpg" alt="Arbre Bio Africa" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-black bg-opacity-55"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{T.aboutPageTitle}</h1>
      <p class="text-xl text-white max-w-2xl">{T.aboutPageSubtitle}</p>
    </div>
  </section>

  <!-- Founder Story -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div class="order-2 md:order-1">
            <span class="text-primary font-semibold text-sm uppercase tracking-widest">{T.theFounder}</span>
            <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-6">Sydney Abouna</h2>
            <p class="text-lg text-gray-700 mb-5 leading-relaxed">{T.founderP1}</p>
            <p class="text-lg text-gray-700 mb-5 leading-relaxed">{T.founderP2}</p>
            <p class="text-lg text-gray-700 mb-5 leading-relaxed">{T.founderP3}</p>
            <p class="text-lg text-gray-700 mb-8 leading-relaxed">{T.founderP4}</p>
            <div class="flex flex-wrap gap-4">
              <a href={`${p}/contact`} class="bg-primary text-white px-6 py-3 rounded-full hover:bg-primary-600 transition-colors duration-300 inline-flex items-center gap-2">
                {T.workWithUs}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
              <a href="https://wa.me/2250799295643" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-6 py-3 rounded-full hover:opacity-90 transition-opacity duration-300 inline-flex items-center gap-2">
                {T.whatsappDirect}
              </a>
            </div>
          </div>
          <div class="order-1 md:order-2">
            <img src="https://imgur.com/LD5JZto.jpg" alt="Sydney Abouna - Founder & CEO of Arbre Bio Africa" class="rounded-2xl shadow-2xl w-full object-cover" style="max-height: 580px;"/>
            <div class="mt-4 bg-primary/5 border border-primary/20 rounded-xl p-4 text-center">
              <div class="font-bold text-primary text-lg">Sydney Abouna</div>
              <div class="text-gray-600 text-sm">{T.founderTitleCard}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{T.whatWeDo}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { icon: "🏗️", title: T.gcTitle, desc: T.gcDesc },
            { icon: "💧", title: T.piTitle, desc: T.piDesc },
            { icon: "🌱", title: T.gsTitle, desc: T.gsDesc },
          ].map(card => (
            <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-lg transition-shadow">
              <div class="text-4xl mb-4">{card.icon}</div>
              <h3 class="font-bold text-lg mb-3">{card.title}</h3>
              <p class="text-gray-600">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <div class="text-3xl mb-4">🎯</div>
          <h3 class="text-2xl font-bold mb-4">{T.ourMission}</h3>
          <p class="text-white/90 text-lg leading-relaxed">{T.missionText}</p>
        </div>
        <div>
          <div class="text-3xl mb-4">🌍</div>
          <h3 class="text-2xl font-bold mb-4">{T.ourVision}</h3>
          <p class="text-white/90 text-lg leading-relaxed">{T.visionText}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{T.ourJourney}</h2>
      <div class="max-w-3xl mx-auto space-y-6">
        {[
          { year: "2020", title: T.y2020t, desc: T.y2020d },
          { year: "2021", title: T.y2021t, desc: T.y2021d },
          { year: "2022", title: T.y2022t, desc: T.y2022d },
          { year: "2023", title: T.y2023t, desc: T.y2023d },
          { year: "2024", title: T.y2024t, desc: T.y2024d },
          { year: "2025", title: T.y2025t, desc: T.y2025d },
        ].map(item => (
          <div class="flex gap-4 items-start">
            <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold flex-shrink-0 text-sm">{item.year}</div>
            <div class="bg-gray-50 rounded-lg p-4 flex-1"><strong>{item.title}</strong> — {item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">{T.readyTogether}</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">{T.readyTogetherSub}</p>
      <a href={`${p}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors duration-300 inline-block">{T.getInTouch}</a>
    </div>
  </section>

</Layout>
