---
import Layout from "../../layouts/Layout.astro";
import { getAllLangPaths } from "../../lib/langPaths";
import { pt } from "../../lib/pageTranslations";
import type { Language } from "../../lib/i18n";

export async function getStaticPaths() { return getAllLangPaths(); }
const { lang } = Astro.params as { lang: Language };
const p = pt(lang); const a = p.about; const tl = p.timeline;
const prefix = `/${lang}`;
---
<Layout title={a.meta.title} description={a.meta.description}>
  <section class="relative h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0"><img src="https://imgur.com/4gQ57MK.jpg" alt="Arbre Bio Africa" class="w-full h-full object-cover"/><div class="absolute inset-0 bg-black bg-opacity-55"></div></div>
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{a.hero.title}</h1>
      <p class="text-xl text-white max-w-2xl">{a.hero.subtitle}</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <span class="text-primary font-semibold text-sm uppercase tracking-widest">{a.founderLabel}</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-6">{a.founderName}</h2>
          <p class="text-lg text-gray-700 mb-5 leading-relaxed">{a.p1}</p>
          <p class="text-lg text-gray-700 mb-5 leading-relaxed">{a.p2}</p>
          <p class="text-lg text-gray-700 mb-5 leading-relaxed">{a.p3}</p>
          <p class="text-lg text-gray-700 mb-8 leading-relaxed">{a.p4}</p>
          <div class="flex flex-wrap gap-4">
            <a href={`${prefix}/contact`} class="bg-primary text-white px-6 py-3 rounded-full hover:bg-primary-600 transition-colors inline-flex items-center gap-2">{a.cta}<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
            <a href="https://wa.me/2250799295643" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-6 py-3 rounded-full hover:opacity-90 transition-opacity">{a.whatsapp}</a>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <img src="https://imgur.com/LD5JZto.jpg" alt={`${a.founderName} — ${a.founderTitle}`} class="rounded-2xl shadow-2xl w-full object-cover" style="max-height:580px;"/>
          <div class="mt-4 bg-primary/5 border border-primary/20 rounded-xl p-4 text-center">
            <div class="font-bold text-primary text-lg">{a.founderName}</div>
            <div class="text-gray-600 text-sm">{a.founderTitle}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{a.whatWeDoTitle}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {a.cards.map(c => (
            <div class="bg-white rounded-xl shadow-md p-6 text-center hover:shadow-lg transition-shadow">
              <div class="text-4xl mb-4">{c.icon}</div>
              <h3 class="font-bold text-lg mb-3">{c.title}</h3>
              <p class="text-gray-600">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
        <div><div class="text-3xl mb-4">🎯</div><h3 class="text-2xl font-bold mb-4">{a.missionTitle}</h3><p class="text-white/90 text-lg leading-relaxed">{a.missionText}</p></div>
        <div><div class="text-3xl mb-4">🌍</div><h3 class="text-2xl font-bold mb-4">{a.visionTitle}</h3><p class="text-white/90 text-lg leading-relaxed">{a.visionText}</p></div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">{a.journeyTitle}</h2>
      <div class="max-w-3xl mx-auto space-y-6">
        {tl.map(item => (
          <div class="flex gap-4 items-start">
            <div class="bg-primary text-white rounded-full w-12 h-12 flex items-center justify-center font-bold flex-shrink-0 text-sm">{item.year}</div>
            <div class="bg-gray-50 rounded-lg p-4 flex-1"><strong>{item.event}</strong> — {item.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">{a.ctaTitle}</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">{a.ctaText}</p>
      <a href={`${prefix}/contact`} class="bg-primary text-white px-8 py-4 rounded-full text-lg hover:bg-primary-600 transition-colors inline-block">{a.ctaBtn}</a>
    </div>
  </section>
</Layout>
