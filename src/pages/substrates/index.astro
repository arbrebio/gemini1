---
import Layout from '../../layouts/Layout.astro';
import EmojiIcon from '../../components/EmojiIcon.astro';

const faq = [
  { q: "Why use coco peat instead of regular soil in Africa?", a: "Coco peat offers weed- and pathogen-free growing, water retention 8x greater than sandy Sahel soils, a stable and controllable pH, and yields 2 to 3 times higher than open-field cultivation for vegetable crops." },
  { q: "How do I prepare coco peat for use in cultivation?", a: "1) Soak 1 kg of the compressed block in 5L of water (it expands to 8-9L). 2) Rinse if EC is above 1.5 mS/cm. 3) Adjust pH to 5.5-6.5. 4) Optionally mix with 20-30% perlite. Arbre Bio Africa also supplies ready-to-use substrate." },
  { q: "How much does coco peat cost in Côte d'Ivoire?", a: "Arbre Bio Africa offers dehydrated blocks (650g) starting at 1,500 FCFA, bulk bags (50kg) starting at 25,000 FCFA, and ready-to-use grow bags. Contact us at +225 05 00 55 25 25 for a personalized quote and volume discounts." },
  { q: "How long does coco peat last as a growing substrate?", a: "A well-managed coco peat substrate lasts 2 to 3 growing cycles (12-18 months): rinsing between crops, disinfection, and EC/pH monitoring. At the end of its cycle, used coco peat makes an excellent organic amendment for tropical soils." },
  { q: "Does Arbre Bio Africa deliver substrates across Africa?", a: "Yes, Arbre Bio Africa delivers coco peat, coco fiber, perlite, and vermiculite throughout West Africa: Côte d'Ivoire, Senegal, Ghana, Burkina Faso, Mali, Togo, and Benin. Training and agronomic technical follow-up are included." },
];

const solutions = [
  {
    title: "Growing Solutions",
    description: "Premium organic coco peat and coir products engineered for maximum yield and optimal crop health.",
    image: "/images/content/KAh1QAU.jpg",
    link: "/substrates/growing-solutions/",
    features: [
      "Superior water retention",
      "Optimal aeration",
      "pH balanced",
      "100% organic"
    ]
  }
];

const benefits = [
  {
    title: "Quality Assured",
    description: "All products undergo rigorous testing and meet international quality standards",
    icon: "medal"
  },
  {
    title: "Sustainable",
    description: "Environmentally responsible production methods and materials",
    icon: "plant"
  },
  {
    title: "Expert Support",
    description: "Technical guidance and support from our agricultural specialists",
    icon: "handshake"
  }
];
---

<Layout
  title="Growing Solutions & Soil Amendments"
  description="Discover Arbre Bio Africa's premium growing solutions and soil amendments. Engineered for optimal plant growth and sustainable agriculture."
>
  <!-- Hero Section -->
  <section class="relative h-[50vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/content/BAlwmPw.jpg"
        alt="Premium Growing Solutions" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black bg-opacity-50"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          Premium Growing Solutions
          <span class="block text-2xl md:text-3xl mt-2">For Professional Agriculture</span>
        </h1>
        <p class="text-xl text-white mb-8">
          Engineered for maximum yield and sustainable growth
        </p>
        <a 
          href="#solutions"
          class="bg-primary hover:bg-primary-600 text-white px-8 py-3 rounded-full text-lg transition-colors duration-300 inline-block"
        >
          Explore Solutions
        </a>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {benefits.map((benefit) => (
          <div class="text-center">
            <div class="text-4xl mb-4"><EmojiIcon id={benefit.icon} size="2rem" /></div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section id="solutions" class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Our Solutions</h2>
      
      {solutions.map((solution, index) => (
        <div class={`mb-20 ${index !== 0 ? 'border-t pt-20' : ''}`}>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class={index % 2 === 0 ? 'order-1' : 'order-1 lg:order-2'}>
              <h3 class="text-2xl font-bold mb-4">{solution.title}</h3>
              <p class="text-gray-600 mb-6">{solution.description}</p>
              
              <div class="space-y-3 mb-8">
                {solution.features.map((feature) => (
                  <div class="flex items-center text-gray-700">
                    <svg class="w-5 h-5 text-primary mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {feature}
                  </div>
                ))}
              </div>

              <a 
                href={solution.link}
                class="inline-flex items-center text-primary font-semibold hover:text-primary-600 transition-colors"
              >
                Learn More
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
            <div class={index % 2 === 0 ? 'order-2' : 'order-2 lg:order-1'}>
              <img 
                src={solution.image}
                alt={solution.title}
                class="w-full h-[400px] object-cover rounded-lg shadow-lg"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions About Coco Peat & Substrates</h2>
      <div class="space-y-6">
        {faq.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-bold text-lg mb-3">{item.q}</h3>
            <p class="text-gray-700 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Ready to Transform Your Growing Operation?</h2>
      <p class="text-xl text-white mb-8">Contact us today for expert advice and custom solutions.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact/"
          class="bg-white text-primary px-8 py-3 rounded-full text-lg hover:bg-opacity-90"
        >
          Get Started
        </a>
        <a
          href="https://wa.me/2250500552525"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#25D366] text-white px-8 py-3 rounded-full text-lg hover:bg-opacity-90 inline-flex items-center"
        >
          <i class="fab fa-whatsapp mr-2"></i>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
})}></script>