---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Projects">
  <!-- Toast container -->
  <div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col gap-2 pointer-events-none"></div>

  <!-- Page header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Projects</h1>
      <p class="text-gray-500 text-sm mt-0.5">Manage agricultural projects and tasks</p>
    </div>
    <button
      id="btn-add-project"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition-opacity hover:opacity-90"
      style="background-color:#194642;"
    >
      <i class="fas fa-plus text-xs"></i>
      New Project
    </button>
  </div>

  <!-- Stats bar -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Total</p>
      <p id="stat-total" class="text-2xl font-bold text-gray-800">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Active</p>
      <p id="stat-active" class="text-2xl font-bold text-green-700">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Completed</p>
      <p id="stat-completed" class="text-2xl font-bold text-blue-700">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">On Hold</p>
      <p id="stat-on-hold" class="text-2xl font-bold text-yellow-600">—</p>
    </div>
  </div>

  <!-- Search & filter -->
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 mb-6 flex flex-col md:flex-row gap-3">
    <div class="relative flex-1">
      <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
      <input
        id="search-input"
        type="text"
        placeholder="Search projects by name…"
        class="w-full pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
      />
    </div>
    <div class="w-full md:w-48">
      <select
        id="status-filter"
        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
      >
        <option value="">All Statuses</option>
        <option value="planning">Planning</option>
        <option value="active">Active</option>
        <option value="on_hold">On Hold</option>
        <option value="completed">Completed</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
  </div>

  <!-- Loading state -->
  <div id="grid-loading" class="flex items-center justify-center py-20">
    <i class="fas fa-circle-notch fa-spin text-2xl" style="color:#194642;"></i>
  </div>

  <!-- Empty state -->
  <div id="grid-empty" class="hidden flex-col items-center justify-center py-20 text-center bg-white rounded-lg border border-gray-100 shadow-sm">
    <i class="fas fa-folder-open text-4xl text-gray-300 mb-3"></i>
    <p class="text-gray-500 font-medium">No projects found</p>
    <p class="text-gray-400 text-sm mt-1">Try adjusting your search or create a new project</p>
  </div>

  <!-- Projects grid -->
  <div id="projects-grid" class="hidden grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5"></div>

  <!-- ─── Create/Edit Project Modal ─── -->
  <div id="project-modal" class="fixed inset-0 z-40 hidden">
    <div id="modal-backdrop" class="absolute inset-0 bg-black bg-opacity-40"></div>
    <div class="absolute inset-0 flex items-start justify-center overflow-y-auto py-8 px-4">
      <div class="relative bg-white w-full max-w-2xl rounded-xl shadow-2xl">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <h2 id="modal-title" class="text-lg font-semibold text-gray-800">New Project</h2>
          <button id="modal-close" class="text-gray-400 hover:text-gray-600 transition-colors">
            <i class="fas fa-times text-lg"></i>
          </button>
        </div>
        <form id="project-form" class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input type="hidden" id="form-id" />

          <!-- Name -->
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Project Name <span class="text-red-500">*</span>
            </label>
            <input
              id="form-name"
              type="text"
              required
              placeholder="e.g. Cocoa Yield Improvement Phase 2"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            />
          </div>

          <!-- Description -->
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <textarea
              id="form-description"
              rows="3"
              placeholder="Project goals and scope…"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642] resize-none"
            ></textarea>
          </div>

          <!-- Customer -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Customer</label>
            <select
              id="form-customer"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            >
              <option value="">— None —</option>
            </select>
          </div>

          <!-- Status -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select
              id="form-status"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            >
              <option value="planning">Planning</option>
              <option value="active">Active</option>
              <option value="on_hold">On Hold</option>
              <option value="completed">Completed</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>

          <!-- Start Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
            <input
              id="form-start-date"
              type="date"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            />
          </div>

          <!-- End Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">End Date</label>
            <input
              id="form-end-date"
              type="date"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            />
          </div>

          <!-- Budget -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Budget</label>
            <input
              id="form-budget"
              type="number"
              min="0"
              step="1000"
              placeholder="0"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            />
          </div>

          <!-- Currency -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Currency</label>
            <select
              id="form-currency"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            >
              <option value="XOF">XOF (CFA Franc)</option>
              <option value="USD">USD</option>
              <option value="EUR">EUR</option>
            </select>
          </div>

          <!-- Tags -->
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Tags <span class="text-gray-400 font-normal">(comma-separated)</span>
            </label>
            <input
              id="form-tags"
              type="text"
              placeholder="cocoa, irrigation, phase-2"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
            />
          </div>
        </form>
        <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-100">
          <button
            id="modal-cancel"
            type="button"
            class="px-4 py-2 text-sm font-medium text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
          >
            Cancel
          </button>
          <button
            id="modal-submit"
            type="submit"
            form="project-form"
            class="px-5 py-2 text-sm font-medium text-white rounded-lg transition-opacity hover:opacity-90 disabled:opacity-60"
            style="background-color:#194642;"
          >
            <span id="modal-submit-text">Save Project</span>
            <i id="modal-submit-spinner" class="fas fa-circle-notch fa-spin ml-2 hidden"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── Project Detail Drawer ─── -->
  <div id="drawer-overlay" class="fixed inset-0 z-40 hidden bg-black bg-opacity-30"></div>
  <div
    id="project-drawer"
    class="fixed top-0 right-0 h-full w-full max-w-2xl bg-white shadow-2xl z-50 transform translate-x-full transition-transform duration-300 flex flex-col overflow-hidden"
  >
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h2 id="drawer-title" class="text-lg font-semibold text-gray-800 truncate pr-4">Project Details</h2>
      <button id="drawer-close" class="text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>

    <!-- Drawer loading -->
    <div id="drawer-loading" class="flex items-center justify-center flex-1">
      <i class="fas fa-circle-notch fa-spin text-2xl" style="color:#194642;"></i>
    </div>

    <!-- Drawer content -->
    <div id="drawer-content" class="hidden flex-1 overflow-y-auto">
      <!-- Project info section -->
      <div class="px-6 py-5 border-b border-gray-100">
        <!-- Status badge + action buttons -->
        <div class="flex items-center justify-between mb-4">
          <span id="drawer-status-badge" class="inline-block px-3 py-1 rounded-full text-xs font-semibold"></span>
          <div class="flex items-center gap-2">
            <button
              id="drawer-edit-btn"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors"
            >
              <i class="fas fa-pencil-alt text-xs"></i> Edit
            </button>
            <button
              id="drawer-delete-btn"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-red-200 rounded-lg text-red-600 hover:bg-red-50 transition-colors"
            >
              <i class="fas fa-trash text-xs"></i> Delete
            </button>
          </div>
        </div>

        <!-- Quick status change buttons -->
        <div id="drawer-status-actions" class="flex flex-wrap gap-2 mb-4"></div>

        <!-- Info grid -->
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-0.5">Customer</p>
            <p id="drawer-customer" class="text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-0.5">Budget</p>
            <p id="drawer-budget" class="text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-0.5">Start Date</p>
            <p id="drawer-start-date" class="text-gray-800">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-0.5">End Date</p>
            <p id="drawer-end-date" class="text-gray-800">—</p>
          </div>
        </div>

        <!-- Description -->
        <div class="mt-4">
          <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-0.5">Description</p>
          <p id="drawer-description" class="text-gray-700 text-sm leading-relaxed">—</p>
        </div>

        <!-- Progress bar -->
        <div class="mt-4">
          <div class="flex items-center justify-between mb-1">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Progress</p>
            <p id="drawer-progress-text" class="text-xs text-gray-600 font-medium">0 / 0 tasks</p>
          </div>
          <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
            <div id="drawer-progress-bar" class="h-full rounded-full transition-all" style="background-color:#194642; width:0%"></div>
          </div>
        </div>
      </div>

      <!-- Tasks section -->
      <div class="px-6 py-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-gray-800">Tasks</h3>
          <button
            id="btn-add-task"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg text-white transition-opacity hover:opacity-90"
            style="background-color:#194642;"
          >
            <i class="fas fa-plus text-xs"></i> Add Task
          </button>
        </div>

        <!-- Add task inline form -->
        <div id="add-task-form-wrapper" class="hidden mb-4 bg-gray-50 rounded-lg border border-gray-200 p-4">
          <p class="text-sm font-medium text-gray-700 mb-3">New Task</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="sm:col-span-2">
              <input
                id="task-title"
                type="text"
                placeholder="Task title (required)"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              />
            </div>
            <div class="sm:col-span-2">
              <textarea
                id="task-description"
                rows="2"
                placeholder="Description (optional)"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642] resize-none"
              ></textarea>
            </div>
            <div>
              <select
                id="task-priority"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              >
                <option value="low">Low Priority</option>
                <option value="medium" selected>Medium Priority</option>
                <option value="high">High Priority</option>
                <option value="urgent">Urgent</option>
              </select>
            </div>
            <div>
              <input
                id="task-due-date"
                type="date"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-xs font-medium text-gray-500 mb-1">Assign Employee</label>
              <select
                id="task-assignee-employee"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              >
                <option value="">— No assignee —</option>
              </select>
            </div>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <button
              id="task-save-btn"
              type="button"
              class="px-4 py-2 text-sm text-white rounded-lg transition-opacity hover:opacity-90"
              style="background-color:#194642;"
            >
              Save Task
              <i id="task-save-spinner" class="fas fa-circle-notch fa-spin ml-1 hidden"></i>
            </button>
            <button
              id="task-cancel-btn"
              type="button"
              class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
          </div>
        </div>

        <!-- Edit task inline form -->
        <div id="edit-task-form-wrapper" class="hidden mb-4 bg-blue-50 rounded-lg border border-blue-200 p-4">
          <p class="text-sm font-medium text-gray-700 mb-3">Edit Task</p>
          <input type="hidden" id="edit-task-id" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="sm:col-span-2">
              <input
                id="edit-task-title"
                type="text"
                placeholder="Task title (required)"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              />
            </div>
            <div class="sm:col-span-2">
              <textarea
                id="edit-task-description"
                rows="2"
                placeholder="Description (optional)"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642] resize-none"
              ></textarea>
            </div>
            <div>
              <select
                id="edit-task-status"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              >
                <option value="todo">To Do</option>
                <option value="in_progress">In Progress</option>
                <option value="done">Done</option>
              </select>
            </div>
            <div>
              <select
                id="edit-task-priority"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              >
                <option value="low">Low Priority</option>
                <option value="medium">Medium Priority</option>
                <option value="high">High Priority</option>
                <option value="urgent">Urgent</option>
              </select>
            </div>
            <div>
              <input
                id="edit-task-due-date"
                type="date"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-500 mb-1">Assign Employee</label>
              <select
                id="edit-task-assignee-employee"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642] focus:border-[#194642]"
              >
                <option value="">— No assignee —</option>
              </select>
            </div>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <button
              id="edit-task-save-btn"
              type="button"
              class="px-4 py-2 text-sm text-white rounded-lg transition-opacity hover:opacity-90"
              style="background-color:#194642;"
            >
              Update Task
              <i id="edit-task-save-spinner" class="fas fa-circle-notch fa-spin ml-1 hidden"></i>
            </button>
            <button
              id="edit-task-cancel-btn"
              type="button"
              class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
          </div>
        </div>

        <!-- Kanban columns -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- To Do -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2.5 h-2.5 rounded-full bg-gray-400 flex-shrink-0"></span>
              <p class="text-sm font-semibold text-gray-700">To Do</p>
              <span id="count-todo" class="ml-auto text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">0</span>
            </div>
            <div id="col-todo" class="space-y-2 min-h-12"></div>
          </div>
          <!-- In Progress -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 flex-shrink-0"></span>
              <p class="text-sm font-semibold text-gray-700">In Progress</p>
              <span id="count-in-progress" class="ml-auto text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">0</span>
            </div>
            <div id="col-in-progress" class="space-y-2 min-h-12"></div>
          </div>
          <!-- Done -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
              <p class="text-sm font-semibold text-gray-700">Done</p>
              <span id="count-done" class="ml-auto text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">0</span>
            </div>
            <div id="col-done" class="space-y-2 min-h-12"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirm modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
    <div id="delete-backdrop" class="absolute inset-0 bg-black bg-opacity-40"></div>
    <div class="relative bg-white rounded-xl shadow-2xl p-6 w-full max-w-sm mx-4">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-trash text-red-600"></i>
        </div>
        <div>
          <p class="font-semibold text-gray-800">Delete Project</p>
          <p class="text-sm text-gray-500">This action cannot be undone.</p>
        </div>
      </div>
      <p class="text-sm text-gray-600 mb-5">
        Are you sure you want to delete <span id="delete-project-name" class="font-semibold text-gray-800"></span>?
      </p>
      <div class="flex items-center justify-end gap-3">
        <button id="delete-cancel" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
          Cancel
        </button>
        <button id="delete-confirm" class="px-4 py-2 text-sm bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
          Delete
          <i id="delete-spinner" class="fas fa-circle-notch fa-spin ml-1 hidden"></i>
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // ─── Types ───────────────────────────────────────────────────────────────────
  type Project = {
    id: string;
    name: string;
    description?: string;
    status: string;
    start_date?: string;
    end_date?: string;
    budget?: number;
    budget_currency?: string;
    customer_id?: string;
    admin_customers?: { full_name?: string; company_name?: string };
    tasks_count?: number;
    completed_tasks_count?: number;
  };

  type Task = {
    id: string;
    title: string;
    description?: string;
    status: 'todo' | 'in_progress' | 'done';
    priority: 'low' | 'medium' | 'high' | 'urgent';
    due_date?: string;
    assignee_name?: string;
    assignee_whatsapp?: string;
    employee_id?: string;
    completed_at?: string;
  };

  type Customer = { id: string; full_name?: string; company_name?: string };
  type Employee = { id: string; first_name?: string; last_name?: string; job_title?: string; whatsapp_number?: string; phone?: string };

  // ─── State ───────────────────────────────────────────────────────────────────
  let projects: Project[] = [];
  let customers: Customer[] = [];
  let employees: Employee[] = [];
  let searchValue = '';
  let statusValue = '';
  let activeProjectId: string | null = null;
  let activeProjectTasks: Task[] = [];
  let pendingDeleteId: string | null = null;
  let isSubmitting = false;
  let isTaskSubmitting = false;

  // ─── Helpers ─────────────────────────────────────────────────────────────────
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const container = document.getElementById('toast-container')!;
    const toast = document.createElement('div');
    const bg = type === 'success' ? '#194642' : '#dc2626';
    toast.className = 'pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-lg text-white text-sm shadow-lg';
    toast.style.backgroundColor = bg;
    toast.style.minWidth = '260px';
    toast.innerHTML = `
      <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>
      <span>${message}</span>
    `;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.4s';
      setTimeout(() => toast.remove(), 400);
    }, 3500);
  }

  function esc(str: string | null | undefined): string {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatDate(dateStr: string | null | undefined): string {
    if (!dateStr) return '—';
    try {
      return new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
    } catch { return '—'; }
  }

  function formatBudget(amount: number | undefined, currency: string | undefined): string {
    if (amount == null || amount === 0) return '—';
    const curr = currency || 'XOF';
    try {
      return new Intl.NumberFormat('fr-CI', { style: 'currency', currency: curr, maximumFractionDigits: 0 }).format(amount);
    } catch {
      return `${amount.toLocaleString()} ${curr}`;
    }
  }

  function statusBadgeClasses(status: string): string {
    const map: Record<string, string> = {
      planning:  'bg-gray-100 text-gray-700',
      active:    'bg-green-100 text-green-800',
      on_hold:   'bg-yellow-100 text-yellow-800',
      completed: 'bg-blue-100 text-blue-800',
      cancelled: 'bg-red-100 text-red-700',
    };
    return map[status] ?? 'bg-gray-100 text-gray-700';
  }

  function statusLabel(status: string): string {
    const map: Record<string, string> = {
      planning:  'Planning',
      active:    'Active',
      on_hold:   'On Hold',
      completed: 'Completed',
      cancelled: 'Cancelled',
    };
    return map[status] ?? status;
  }

  function priorityBadgeClasses(priority: string): string {
    const map: Record<string, string> = {
      low:    'bg-gray-100 text-gray-600',
      medium: 'bg-blue-100 text-blue-700',
      high:   'bg-orange-100 text-orange-700',
      urgent: 'bg-red-100 text-red-700',
    };
    return map[priority] ?? 'bg-gray-100 text-gray-600';
  }

  function priorityLabel(priority: string): string {
    return priority.charAt(0).toUpperCase() + priority.slice(1);
  }

  function customerName(p: Project): string {
    if (!p.admin_customers) return '—';
    return p.admin_customers.company_name || p.admin_customers.full_name || '—';
  }

  function progressPercent(p: Project): number {
    const total = p.tasks_count ?? 0;
    const done  = p.completed_tasks_count ?? 0;
    if (total === 0) return 0;
    return Math.round((done / total) * 100);
  }

  // ─── Fetch ───────────────────────────────────────────────────────────────────
  async function fetchProjects() {
    setGridState('loading');
    try {
      const res = await fetch('/api/admin/projects');
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      projects = data.projects ?? [];
      renderStats();
      renderGrid();
    } catch (e: any) {
      setGridState('empty');
      showToast(e.message ?? 'Failed to load projects', 'error');
    }
  }

  async function fetchCustomers() {
    try {
      const res = await fetch('/api/admin/customers');
      if (!res.ok) return;
      const data = await res.json();
      customers = data.customers ?? [];
      populateCustomerSelect('form-customer');
    } catch { /* silent */ }
  }

  async function fetchEmployees() {
    try {
      const res = await fetch('/api/admin/careers/employees');
      if (!res.ok) return;
      const data = await res.json();
      employees = data.employees ?? [];
      populateEmployeeSelects();
    } catch { /* silent */ }
  }

  function populateEmployeeSelects() {
    const selIds = ['task-assignee-employee', 'edit-task-assignee-employee'];
    selIds.forEach(selId => {
      const sel = document.getElementById(selId) as HTMLSelectElement | null;
      if (!sel) return;
      const current = sel.value;
      sel.innerHTML = '<option value="">— No assignee —</option>';
      employees.forEach(emp => {
        const opt = document.createElement('option');
        opt.value = emp.id;
        opt.textContent = `${emp.first_name ?? ''} ${emp.last_name ?? ''}`.trim() + (emp.job_title ? ` (${emp.job_title})` : '');
        opt.dataset.name = `${emp.first_name ?? ''} ${emp.last_name ?? ''}`.trim();
        opt.dataset.whatsapp = emp.whatsapp_number || emp.phone || '';
        sel.appendChild(opt);
      });
      if (current) sel.value = current;
    });
  }

  async function sendWhatsAppNotification(whatsappNumber: string, employeeName: string, taskTitle: string, projectName: string, priority: string, dueDate: string | undefined) {
    if (!whatsappNumber) return;
    try {
      await fetch('/api/admin/whatsapp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          to: whatsappNumber,
          employee_name: employeeName,
          task_title: taskTitle,
          project_name: projectName,
          priority,
          due_date: dueDate,
        }),
      });
    } catch { /* silent — notification failure shouldn't block task save */ }
  }

  function populateCustomerSelect(selectId: string) {
    const sel = document.getElementById(selectId) as HTMLSelectElement | null;
    if (!sel) return;
    const current = sel.value;
    sel.innerHTML = '<option value="">— None —</option>';
    customers.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.id;
      opt.textContent = c.company_name
        ? `${c.full_name ?? ''} (${c.company_name})`
        : (c.full_name ?? c.id);
      sel.appendChild(opt);
    });
    if (current) sel.value = current;
  }

  // ─── Grid render ─────────────────────────────────────────────────────────────
  function setGridState(state: 'loading' | 'empty' | 'data') {
    const loading = document.getElementById('grid-loading')!;
    const empty   = document.getElementById('grid-empty')!;
    const grid    = document.getElementById('projects-grid')!;
    loading.classList.toggle('hidden', state !== 'loading');
    empty.classList.toggle('hidden', state !== 'empty');
    empty.classList.toggle('flex', state === 'empty');
    grid.classList.toggle('hidden', state !== 'data');
  }

  function filteredProjects(): Project[] {
    return projects.filter(p => {
      const matchSearch = !searchValue || p.name.toLowerCase().includes(searchValue.toLowerCase());
      const matchStatus = !statusValue || p.status === statusValue;
      return matchSearch && matchStatus;
    });
  }

  function renderStats() {
    document.getElementById('stat-total')!.textContent    = String(projects.length);
    document.getElementById('stat-active')!.textContent   = String(projects.filter(p => p.status === 'active').length);
    document.getElementById('stat-completed')!.textContent = String(projects.filter(p => p.status === 'completed').length);
    document.getElementById('stat-on-hold')!.textContent  = String(projects.filter(p => p.status === 'on_hold').length);
  }

  function renderGrid() {
    const list = filteredProjects();
    if (!list.length) {
      setGridState('empty');
      return;
    }
    setGridState('data');
    const grid = document.getElementById('projects-grid')!;
    grid.innerHTML = list.map(p => {
      const pct    = progressPercent(p);
      const total  = p.tasks_count ?? 0;
      const done   = p.completed_tasks_count ?? 0;
      const cust   = customerName(p);
      const badge  = statusBadgeClasses(p.status);
      return `
        <div
          class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow cursor-pointer flex flex-col"
          data-project-card="${esc(p.id)}"
        >
          <div class="p-5 flex-1">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="font-semibold text-gray-800 text-base leading-tight">${esc(p.name)}</h3>
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold flex-shrink-0 ${badge}">${statusLabel(p.status)}</span>
            </div>
            ${cust !== '—'
              ? `<p class="text-xs text-gray-500 mb-3"><i class="fas fa-building mr-1"></i>${esc(cust)}</p>`
              : `<p class="text-xs text-gray-400 mb-3">No customer assigned</p>`
            }
            <div class="mb-3">
              <div class="flex items-center justify-between mb-1">
                <p class="text-xs text-gray-500">Progress</p>
                <p class="text-xs text-gray-600 font-medium">${done}/${total} tasks</p>
              </div>
              <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="background-color:#194642; width:${pct}%"></div>
              </div>
            </div>
            <div class="flex items-center justify-between text-xs text-gray-500">
              <span><i class="fas fa-calendar-alt mr-1"></i>${formatDate(p.start_date)}</span>
              ${p.budget ? `<span class="font-medium text-gray-700">${formatBudget(p.budget, p.budget_currency)}</span>` : ''}
            </div>
            ${p.end_date ? `<p class="text-xs text-gray-400 mt-1"><i class="fas fa-flag-checkered mr-1"></i>Due ${formatDate(p.end_date)}</p>` : ''}
          </div>
          <div class="border-t border-gray-100 px-5 py-3 flex items-center gap-2">
            <button
              data-view-project="${esc(p.id)}"
              class="flex-1 text-center text-xs font-medium py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors"
            >
              <i class="fas fa-eye mr-1"></i>View
            </button>
            <button
              data-edit-project="${esc(p.id)}"
              class="flex-1 text-center text-xs font-medium py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors"
            >
              <i class="fas fa-pencil-alt mr-1"></i>Edit
            </button>
            <button
              data-delete-project="${esc(p.id)}"
              class="px-3 text-xs font-medium py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors"
            >
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </div>
      `;
    }).join('');
  }

  // ─── Grid click delegation ───────────────────────────────────────────────────
  document.getElementById('projects-grid')!.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const viewBtn   = target.closest('[data-view-project]') as HTMLElement | null;
    const editBtn   = target.closest('[data-edit-project]') as HTMLElement | null;
    const deleteBtn = target.closest('[data-delete-project]') as HTMLElement | null;
    const card      = target.closest('[data-project-card]') as HTMLElement | null;

    if (viewBtn) {
      openDrawer(viewBtn.dataset.viewProject!);
    } else if (editBtn) {
      const p = projects.find(x => x.id === editBtn.dataset.editProject);
      if (p) openEditModal(p);
    } else if (deleteBtn) {
      const p = projects.find(x => x.id === deleteBtn.dataset.deleteProject);
      if (p) openDeleteModal(p);
    } else if (card && card.dataset.projectCard) {
      openDrawer(card.dataset.projectCard);
    }
  });

  // ─── Drawer ──────────────────────────────────────────────────────────────────
  async function openDrawer(projectId: string) {
    activeProjectId = projectId;
    const drawer        = document.getElementById('project-drawer')!;
    const overlay       = document.getElementById('drawer-overlay')!;
    const drawerLoading = document.getElementById('drawer-loading')!;
    const drawerContent = document.getElementById('drawer-content')!;

    overlay.classList.remove('hidden');
    drawer.classList.remove('translate-x-full');
    drawerLoading.classList.remove('hidden');
    drawerContent.classList.add('hidden');
    hideAddTaskForm();
    hideEditTaskForm();

    try {
      const res = await fetch(`/api/admin/projects?id=${projectId}`);
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      const p: Project & { tasks?: Task[] } = data.project;
      activeProjectTasks = p.tasks ?? [];
      renderDrawerInfo(p);
      renderTasks(activeProjectTasks);
      drawerLoading.classList.add('hidden');
      drawerContent.classList.remove('hidden');
    } catch (e: any) {
      showToast(e.message ?? 'Failed to load project', 'error');
      closeDrawer();
    }
  }

  function renderDrawerInfo(p: Project & { tasks?: Task[] }) {
    document.getElementById('drawer-title')!.textContent = p.name;

    const badge = document.getElementById('drawer-status-badge')!;
    badge.textContent = statusLabel(p.status);
    badge.className = `inline-block px-3 py-1 rounded-full text-xs font-semibold ${statusBadgeClasses(p.status)}`;

    document.getElementById('drawer-customer')!.textContent   = customerName(p);
    document.getElementById('drawer-budget')!.textContent     = formatBudget(p.budget, p.budget_currency);
    document.getElementById('drawer-start-date')!.textContent = formatDate(p.start_date);
    document.getElementById('drawer-end-date')!.textContent   = formatDate(p.end_date);
    document.getElementById('drawer-description')!.textContent = p.description || '—';

    const total = p.tasks_count ?? (p.tasks?.length ?? 0);
    const done  = p.completed_tasks_count ?? (p.tasks?.filter(t => t.status === 'done').length ?? 0);
    const pct   = total === 0 ? 0 : Math.round((done / total) * 100);
    document.getElementById('drawer-progress-text')!.textContent = `${done} / ${total} tasks`;
    (document.getElementById('drawer-progress-bar') as HTMLElement).style.width = `${pct}%`;

    // Status change pill buttons
    const statusActions = document.getElementById('drawer-status-actions')!;
    const allStatuses = ['planning', 'active', 'on_hold', 'completed', 'cancelled'];
    statusActions.innerHTML = allStatuses
      .filter(s => s !== p.status)
      .map(s => `
        <button
          data-set-status="${s}"
          class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded-full border font-medium transition-opacity hover:opacity-80 ${statusBadgeClasses(s)}"
        >
          ${statusLabel(s)}
        </button>
      `).join('');

    statusActions.onclick = async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-set-status]') as HTMLElement | null;
      if (!btn) return;
      await updateProjectStatus(p.id, btn.dataset.setStatus!);
    };

    document.getElementById('drawer-edit-btn')!.onclick = () => {
      const full = projects.find(x => x.id === p.id);
      if (full) openEditModal(full);
    };

    document.getElementById('drawer-delete-btn')!.onclick = () => {
      const full = projects.find(x => x.id === p.id);
      if (full) openDeleteModal(full);
    };
  }

  async function updateProjectStatus(projectId: string, newStatus: string) {
    try {
      const res = await fetch('/api/admin/projects', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: projectId, status: newStatus }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Update failed');
      showToast('Project status updated');
      const idx = projects.findIndex(p => p.id === projectId);
      if (idx !== -1) projects[idx].status = newStatus;
      renderGrid();
      renderStats();
      if (activeProjectId === projectId) openDrawer(projectId);
    } catch (e: any) {
      showToast(e.message, 'error');
    }
  }

  function closeDrawer() {
    const drawer  = document.getElementById('project-drawer')!;
    const overlay = document.getElementById('drawer-overlay')!;
    drawer.classList.add('translate-x-full');
    overlay.classList.add('hidden');
    activeProjectId = null;
    hideAddTaskForm();
    hideEditTaskForm();
  }

  document.getElementById('drawer-close')!.addEventListener('click', closeDrawer);
  document.getElementById('drawer-overlay')!.addEventListener('click', closeDrawer);

  // ─── Tasks rendering ─────────────────────────────────────────────────────────
  function renderTasks(tasks: Task[]) {
    const cols: Record<string, Task[]> = { todo: [], in_progress: [], done: [] };
    tasks.forEach(t => {
      if (t.status in cols) cols[t.status].push(t);
      else cols.todo.push(t);
    });

    const colMap: { status: string; colId: string; countId: string }[] = [
      { status: 'todo',        colId: 'col-todo',        countId: 'count-todo'        },
      { status: 'in_progress', colId: 'col-in-progress', countId: 'count-in-progress' },
      { status: 'done',        colId: 'col-done',        countId: 'count-done'        },
    ];

    colMap.forEach(({ status, colId, countId }) => {
      const col     = document.getElementById(colId)!;
      const countEl = document.getElementById(countId)!;
      const list    = cols[status];
      countEl.textContent = String(list.length);

      if (!list.length) {
        col.innerHTML = '<p class="text-xs text-gray-400 text-center py-3">No tasks</p>';
        return;
      }

      col.innerHTML = list.map(t => {
        const priCls = priorityBadgeClasses(t.priority);
        return `
          <div class="bg-white border border-gray-200 rounded-lg p-3 shadow-sm hover:shadow transition-shadow" data-task-id="${esc(t.id)}">
            <div class="flex items-start justify-between gap-2 mb-2">
              <div class="flex items-start gap-2 flex-1 min-w-0">
                <input
                  type="checkbox"
                  class="mt-0.5 flex-shrink-0 accent-[#194642] cursor-pointer"
                  ${t.status === 'done' ? 'checked' : ''}
                  data-toggle-task="${esc(t.id)}"
                />
                <p
                  class="text-sm text-gray-800 font-medium leading-tight cursor-pointer hover:text-[#194642] ${t.status === 'done' ? 'line-through text-gray-400' : ''}"
                  data-edit-task="${esc(t.id)}"
                >${esc(t.title)}</p>
              </div>
              <button data-delete-task="${esc(t.id)}" class="flex-shrink-0 text-gray-300 hover:text-red-500 transition-colors p-0.5">
                <i class="fas fa-times text-xs"></i>
              </button>
            </div>
            <div class="flex items-center flex-wrap gap-1.5">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium ${priCls}">${priorityLabel(t.priority)}</span>
              ${t.due_date ? `<span class="text-xs text-gray-500"><i class="fas fa-clock mr-0.5"></i>${formatDate(t.due_date)}</span>` : ''}
              ${t.assignee_name ? `<span class="text-xs text-gray-500"><i class="fas fa-user mr-0.5"></i>${esc(t.assignee_name)}</span>` : ''}
            </div>
          </div>
        `;
      }).join('');

      col.addEventListener('click', handleTaskColClick);
      col.addEventListener('change', handleTaskColChange);
    });
  }

  function handleTaskColClick(e: Event) {
    const target    = e.target as HTMLElement;
    const deleteBtn = target.closest('[data-delete-task]') as HTMLElement | null;
    const editBtn   = target.closest('[data-edit-task]') as HTMLElement | null;
    if (deleteBtn) deleteTask(deleteBtn.dataset.deleteTask!);
    else if (editBtn) {
      const task = activeProjectTasks.find(t => t.id === editBtn.dataset.editTask);
      if (task) openEditTaskForm(task);
    }
  }

  function handleTaskColChange(e: Event) {
    const target = e.target as HTMLInputElement;
    if (target.dataset.toggleTask) {
      const taskId  = target.dataset.toggleTask;
      const newStatus = target.checked ? 'done' : 'todo';
      updateTask(taskId, { status: newStatus });
    }
  }

  // ─── Add task ────────────────────────────────────────────────────────────────
  function showAddTaskForm() {
    hideEditTaskForm();
    populateEmployeeSelects();
    document.getElementById('add-task-form-wrapper')!.classList.remove('hidden');
    (document.getElementById('task-title') as HTMLInputElement).focus();
  }

  function hideAddTaskForm() {
    document.getElementById('add-task-form-wrapper')!.classList.add('hidden');
    (document.getElementById('task-title') as HTMLInputElement).value = '';
    (document.getElementById('task-description') as HTMLTextAreaElement).value = '';
    (document.getElementById('task-priority') as HTMLSelectElement).value = 'medium';
    (document.getElementById('task-due-date') as HTMLInputElement).value = '';
    (document.getElementById('task-assignee-employee') as HTMLSelectElement).value = '';
  }

  document.getElementById('btn-add-task')!.addEventListener('click', showAddTaskForm);
  document.getElementById('task-cancel-btn')!.addEventListener('click', hideAddTaskForm);

  document.getElementById('task-save-btn')!.addEventListener('click', async () => {
    if (isTaskSubmitting || !activeProjectId) return;
    const title = (document.getElementById('task-title') as HTMLInputElement).value.trim();
    if (!title) { showToast('Task title is required', 'error'); return; }
    isTaskSubmitting = true;
    const spinner = document.getElementById('task-save-spinner')!;
    const btn = document.getElementById('task-save-btn') as HTMLButtonElement;
    btn.disabled = true;
    spinner.classList.remove('hidden');
    try {
      const empSelect = document.getElementById('task-assignee-employee') as HTMLSelectElement;
      const empOption = empSelect.selectedOptions[0];
      const employee_id = empSelect.value || undefined;
      const assignee_name = empOption?.dataset.name || undefined;
      const assignee_whatsapp = empOption?.dataset.whatsapp || '';
      const priority = (document.getElementById('task-priority') as HTMLSelectElement).value;
      const due_date = (document.getElementById('task-due-date') as HTMLInputElement).value || undefined;

      const res = await fetch('/api/admin/projects', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id:            activeProjectId,
          _action:       'add_task',
          title,
          description:   (document.getElementById('task-description') as HTMLTextAreaElement).value.trim() || undefined,
          priority,
          due_date,
          assignee_name,
          employee_id,
        }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Failed to add task');
      showToast('Task added');
      // Send WhatsApp notification to assigned employee
      if (employee_id && assignee_whatsapp) {
        const project = projects.find(p => p.id === activeProjectId);
        await sendWhatsAppNotification(assignee_whatsapp, assignee_name ?? '', title, project?.name ?? '', priority, due_date);
      }
      hideAddTaskForm();
      const idx = projects.findIndex(p => p.id === activeProjectId);
      if (idx !== -1) projects[idx].tasks_count = (projects[idx].tasks_count ?? 0) + 1;
      await refreshProjectTasks();
      renderGrid();
    } catch (e: any) {
      showToast(e.message, 'error');
    } finally {
      isTaskSubmitting = false;
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  // ─── Edit task ───────────────────────────────────────────────────────────────
  function openEditTaskForm(task: Task & { employee_id?: string }) {
    hideAddTaskForm();
    document.getElementById('edit-task-form-wrapper')!.classList.remove('hidden');
    (document.getElementById('edit-task-id') as HTMLInputElement).value              = task.id;
    (document.getElementById('edit-task-title') as HTMLInputElement).value           = task.title;
    (document.getElementById('edit-task-description') as HTMLTextAreaElement).value  = task.description ?? '';
    (document.getElementById('edit-task-status') as HTMLSelectElement).value         = task.status;
    (document.getElementById('edit-task-priority') as HTMLSelectElement).value       = task.priority;
    (document.getElementById('edit-task-due-date') as HTMLInputElement).value        = task.due_date ? task.due_date.split('T')[0] : '';
    const empSel = document.getElementById('edit-task-assignee-employee') as HTMLSelectElement;
    if (task.employee_id) empSel.value = task.employee_id;
    else empSel.value = '';
    document.getElementById('edit-task-form-wrapper')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideEditTaskForm() {
    document.getElementById('edit-task-form-wrapper')!.classList.add('hidden');
  }

  document.getElementById('edit-task-cancel-btn')!.addEventListener('click', hideEditTaskForm);

  document.getElementById('edit-task-save-btn')!.addEventListener('click', async () => {
    if (isTaskSubmitting || !activeProjectId) return;
    const taskId = (document.getElementById('edit-task-id') as HTMLInputElement).value;
    const title  = (document.getElementById('edit-task-title') as HTMLInputElement).value.trim();
    if (!title) { showToast('Task title is required', 'error'); return; }
    isTaskSubmitting = true;
    const spinner = document.getElementById('edit-task-save-spinner')!;
    const btn = document.getElementById('edit-task-save-btn') as HTMLButtonElement;
    btn.disabled = true;
    spinner.classList.remove('hidden');
    try {
      const empSelect = document.getElementById('edit-task-assignee-employee') as HTMLSelectElement;
      const empOption = empSelect.selectedOptions[0];
      const employee_id = empSelect.value || undefined;
      const assignee_name = empOption?.dataset.name || undefined;
      const assignee_whatsapp = empOption?.dataset.whatsapp || '';
      const priority = (document.getElementById('edit-task-priority') as HTMLSelectElement).value as Task['priority'];
      const due_date = (document.getElementById('edit-task-due-date') as HTMLInputElement).value || undefined;

      await updateTask(taskId, {
        title,
        description:   (document.getElementById('edit-task-description') as HTMLTextAreaElement).value.trim() || undefined,
        status:        (document.getElementById('edit-task-status') as HTMLSelectElement).value as Task['status'],
        priority,
        due_date,
        assignee_name,
        employee_id,
      }, true);
      // Send WhatsApp if employee was assigned
      if (employee_id && assignee_whatsapp) {
        const project = projects.find(p => p.id === activeProjectId);
        await sendWhatsAppNotification(assignee_whatsapp, assignee_name ?? '', title, project?.name ?? '', priority, due_date);
      }
      hideEditTaskForm();
    } finally {
      isTaskSubmitting = false;
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  async function updateTask(taskId: string, updates: Partial<Task>, showSuccess = false) {
    if (!activeProjectId) return;
    try {
      const res = await fetch('/api/admin/projects', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id:       activeProjectId,
          _action:  'update_task',
          task_id:  taskId,
          ...updates,
        }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Update failed');
      if (showSuccess) showToast('Task updated');
      await refreshProjectTasks();
    } catch (e: any) {
      showToast(e.message, 'error');
    }
  }

  async function deleteTask(taskId: string) {
    if (!activeProjectId) return;
    try {
      const res = await fetch('/api/admin/projects', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id:      activeProjectId,
          _action: 'delete_task',
          task_id: taskId,
        }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Delete failed');
      showToast('Task deleted');
      const idx = projects.findIndex(p => p.id === activeProjectId);
      if (idx !== -1) {
        projects[idx].tasks_count = Math.max(0, (projects[idx].tasks_count ?? 1) - 1);
        const delTask = activeProjectTasks.find(t => t.id === taskId);
        if (delTask?.status === 'done') {
          projects[idx].completed_tasks_count = Math.max(0, (projects[idx].completed_tasks_count ?? 1) - 1);
        }
      }
      await refreshProjectTasks();
      renderGrid();
    } catch (e: any) {
      showToast(e.message, 'error');
    }
  }

  async function refreshProjectTasks() {
    if (!activeProjectId) return;
    try {
      const res = await fetch(`/api/admin/projects?action=tasks&project_id=${activeProjectId}`);
      if (!res.ok) return;
      const data = await res.json();
      activeProjectTasks = data.tasks ?? [];
      renderTasks(activeProjectTasks);
      const done  = activeProjectTasks.filter(t => t.status === 'done').length;
      const total = activeProjectTasks.length;
      const pct   = total === 0 ? 0 : Math.round((done / total) * 100);
      document.getElementById('drawer-progress-text')!.textContent = `${done} / ${total} tasks`;
      (document.getElementById('drawer-progress-bar') as HTMLElement).style.width = `${pct}%`;
    } catch { /* silent */ }
  }

  // ─── Create/Edit modal ───────────────────────────────────────────────────────
  function openAddModal() {
    (document.getElementById('project-form') as HTMLFormElement).reset();
    (document.getElementById('form-id') as HTMLInputElement).value = '';
    (document.getElementById('form-currency') as HTMLSelectElement).value = 'XOF';
    (document.getElementById('form-status') as HTMLSelectElement).value   = 'planning';
    document.getElementById('modal-title')!.textContent       = 'New Project';
    document.getElementById('modal-submit-text')!.textContent = 'Save Project';
    populateCustomerSelect('form-customer');
    document.getElementById('project-modal')!.classList.remove('hidden');
  }

  function openEditModal(p: Project) {
    (document.getElementById('project-form') as HTMLFormElement).reset();
    populateCustomerSelect('form-customer');
    (document.getElementById('form-id') as HTMLInputElement).value              = p.id;
    (document.getElementById('form-name') as HTMLInputElement).value            = p.name;
    (document.getElementById('form-description') as HTMLTextAreaElement).value  = p.description ?? '';
    (document.getElementById('form-customer') as HTMLSelectElement).value       = p.customer_id ?? '';
    (document.getElementById('form-status') as HTMLSelectElement).value         = p.status;
    (document.getElementById('form-start-date') as HTMLInputElement).value      = p.start_date ? p.start_date.split('T')[0] : '';
    (document.getElementById('form-end-date') as HTMLInputElement).value        = p.end_date ? p.end_date.split('T')[0] : '';
    (document.getElementById('form-budget') as HTMLInputElement).value          = p.budget != null ? String(p.budget) : '';
    (document.getElementById('form-currency') as HTMLSelectElement).value       = p.budget_currency ?? 'XOF';
    document.getElementById('modal-title')!.textContent       = 'Edit Project';
    document.getElementById('modal-submit-text')!.textContent = 'Update Project';
    document.getElementById('project-modal')!.classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('project-modal')!.classList.add('hidden');
  }

  document.getElementById('btn-add-project')!.addEventListener('click', openAddModal);
  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')!.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')!.addEventListener('click', closeModal);

  (document.getElementById('project-form') as HTMLFormElement).addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
    const spinner   = document.getElementById('modal-submit-spinner')!;
    submitBtn.disabled = true;
    spinner.classList.remove('hidden');

    const id      = (document.getElementById('form-id') as HTMLInputElement).value.trim();
    const tagsRaw = (document.getElementById('form-tags') as HTMLInputElement).value.trim();
    const tags    = tagsRaw ? tagsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];

    const payload: Record<string, any> = {
      name:            (document.getElementById('form-name') as HTMLInputElement).value.trim(),
      description:     (document.getElementById('form-description') as HTMLTextAreaElement).value.trim() || null,
      customer_id:     (document.getElementById('form-customer') as HTMLSelectElement).value || null,
      status:          (document.getElementById('form-status') as HTMLSelectElement).value,
      start_date:      (document.getElementById('form-start-date') as HTMLInputElement).value || null,
      end_date:        (document.getElementById('form-end-date') as HTMLInputElement).value || null,
      budget:          parseFloat((document.getElementById('form-budget') as HTMLInputElement).value) || null,
      budget_currency: (document.getElementById('form-currency') as HTMLSelectElement).value,
      tags,
    };
    if (id) payload.id = id;

    try {
      const res = await fetch('/api/admin/projects', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Save failed');
      showToast(id ? 'Project updated' : 'Project created');
      closeModal();
      await fetchProjects();
    } catch (e: any) {
      showToast(e.message, 'error');
    } finally {
      isSubmitting = false;
      submitBtn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  // ─── Delete modal ────────────────────────────────────────────────────────────
  function openDeleteModal(p: Project) {
    pendingDeleteId = p.id;
    document.getElementById('delete-project-name')!.textContent = p.name;
    const modal = document.getElementById('delete-modal')!;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeDeleteModal() {
    pendingDeleteId = null;
    const modal = document.getElementById('delete-modal')!;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  document.getElementById('delete-cancel')!.addEventListener('click', closeDeleteModal);
  document.getElementById('delete-backdrop')!.addEventListener('click', closeDeleteModal);

  document.getElementById('delete-confirm')!.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    const spinner = document.getElementById('delete-spinner')!;
    const btn     = document.getElementById('delete-confirm') as HTMLButtonElement;
    btn.disabled  = true;
    spinner.classList.remove('hidden');
    try {
      const res = await fetch('/api/admin/projects', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: pendingDeleteId }),
      });
      if (!res.ok) throw new Error((await res.json().catch(() => ({}))).error ?? 'Delete failed');
      showToast('Project deleted');
      if (activeProjectId === pendingDeleteId) closeDrawer();
      closeDeleteModal();
      await fetchProjects();
    } catch (e: any) {
      showToast(e.message, 'error');
    } finally {
      btn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  // ─── Search & filter ─────────────────────────────────────────────────────────
  let searchTimeout: ReturnType<typeof setTimeout>;
  (document.getElementById('search-input') as HTMLInputElement).addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchValue = (e.target as HTMLInputElement).value.trim();
      renderStats();
      renderGrid();
    }, 300);
  });

  (document.getElementById('status-filter') as HTMLSelectElement).addEventListener('change', (e) => {
    statusValue = (e.target as HTMLSelectElement).value;
    renderStats();
    renderGrid();
  });

  // ─── Keyboard ────────────────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (!document.getElementById('project-modal')!.classList.contains('hidden')) {
      closeModal();
    } else if (!document.getElementById('delete-modal')!.classList.contains('hidden')) {
      closeDeleteModal();
    } else if (!document.getElementById('project-drawer')!.classList.contains('translate-x-full')) {
      closeDrawer();
    }
  });

  // ─── Init ────────────────────────────────────────────────────────────────────
  fetchProjects();
  fetchCustomers();
  fetchEmployees();
</script>
