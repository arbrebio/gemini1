---
import AdminLayout from "../../../layouts/AdminLayout.astro";
export const prerender = false;
---

<AdminLayout title="Orders Management">
  <!-- Header -->
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Orders</h1>
      <p class="text-gray-600">Manage customer orders and deliveries</p>
    </div>
    <button
      id="create-order-btn"
      class="flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors"
      style="background-color:#194642;"
    >
      <i class="fas fa-plus"></i>
      Create Order
    </button>
  </div>

  <!-- Stats Bar -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
      <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide">Draft</p>
      <p class="text-2xl font-bold text-gray-600" id="stat-draft">—</p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
      <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide">Confirmed</p>
      <p class="text-2xl font-bold text-blue-600" id="stat-confirmed">—</p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
      <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide">Processing</p>
      <p class="text-2xl font-bold text-yellow-600" id="stat-processing">—</p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
      <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide">Delivered</p>
      <p class="text-2xl font-bold text-green-600" id="stat-delivered">—</p>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
      <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide">Cancelled</p>
      <p class="text-2xl font-bold text-red-600" id="stat-cancelled">—</p>
    </div>
  </div>

  <!-- Search & Filter -->
  <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 mb-6 flex flex-col md:flex-row gap-4">
    <div class="flex-1 relative">
      <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
      <input
        type="text"
        id="search-input"
        placeholder="Search by order number or customer…"
        class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:border-transparent"
        style="--tw-ring-color:#194642;"
      />
    </div>
    <select
      id="status-filter"
      class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2"
    >
      <option value="">All Statuses</option>
      <option value="draft">Draft</option>
      <option value="confirmed">Confirmed</option>
      <option value="processing">Processing</option>
      <option value="shipped">Shipped</option>
      <option value="delivered">Delivered</option>
      <option value="cancelled">Cancelled</option>
    </select>
  </div>

  <!-- Orders Table -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-500">
        <thead class="text-xs text-gray-700 uppercase bg-gray-50">
          <tr>
            <th class="px-6 py-3">Order #</th>
            <th class="px-6 py-3">Customer</th>
            <th class="px-6 py-3">Status</th>
            <th class="px-6 py-3">Total</th>
            <th class="px-6 py-3">Delivery Date</th>
            <th class="px-6 py-3">Created</th>
            <th class="px-6 py-3">Actions</th>
          </tr>
        </thead>
        <tbody id="orders-table-body">
          <tr>
            <td colspan="7" class="px-6 py-10 text-center text-gray-400">
              <i class="fas fa-spinner fa-spin mr-2"></i>Loading orders…
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ===== CREATE / EDIT ORDER MODAL ===== -->
  <div
    id="order-modal"
    class="fixed inset-0 z-50 hidden overflow-y-auto"
    aria-modal="true"
    role="dialog"
  >
    <div class="flex items-start justify-center min-h-screen px-4 pt-10 pb-20">
      <!-- backdrop -->
      <div id="modal-backdrop" class="fixed inset-0 bg-black bg-opacity-50"></div>

      <div class="relative bg-white rounded-xl shadow-xl w-full max-w-3xl z-10">
        <!-- Modal header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-800" id="modal-title">Create Order</h2>
          <button id="modal-close-btn" class="text-gray-400 hover:text-gray-600 transition-colors">
            <i class="fas fa-times text-lg"></i>
          </button>
        </div>

        <!-- Modal body -->
        <div class="px-6 py-5 space-y-5">
          <!-- Customer -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Customer <span class="text-red-500">*</span></label>
            <select id="modal-customer" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2">
              <option value="">Loading customers…</option>
            </select>
          </div>

          <!-- Line Items -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="block text-sm font-medium text-gray-700">Items <span class="text-red-500">*</span></label>
              <button
                id="add-item-btn"
                type="button"
                class="text-xs font-medium px-3 py-1 rounded-lg text-white transition-colors"
                style="background-color:#194642;"
              >
                <i class="fas fa-plus mr-1"></i>Add Item
              </button>
            </div>
            <div class="overflow-x-auto border border-gray-200 rounded-lg">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 text-xs text-gray-600 uppercase">
                  <tr>
                    <th class="px-3 py-2 text-left">Product</th>
                    <th class="px-3 py-2 text-right w-20">Qty</th>
                    <th class="px-3 py-2 text-right w-32">Unit Price</th>
                    <th class="px-3 py-2 text-right w-32">Subtotal</th>
                    <th class="px-3 py-2 w-10"></th>
                  </tr>
                </thead>
                <tbody id="line-items-body">
                  <!-- rows injected by JS -->
                </tbody>
                <tfoot>
                  <tr class="border-t border-gray-200 bg-gray-50">
                    <td colspan="3" class="px-3 py-2 text-right text-sm font-semibold text-gray-700">Total</td>
                    <td class="px-3 py-2 text-right text-sm font-bold text-gray-900" id="modal-total">0 XOF</td>
                    <td></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>

          <!-- Delivery Address -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Delivery Address</label>
            <input
              type="text"
              id="modal-delivery-address"
              placeholder="Full delivery address…"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2"
            />
          </div>

          <!-- Delivery Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Delivery Date</label>
            <input
              type="date"
              id="modal-delivery-date"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2"
            />
          </div>

          <!-- Notes -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
            <textarea
              id="modal-notes"
              rows="3"
              placeholder="Internal notes about this order…"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 resize-none"
            ></textarea>
          </div>
        </div>

        <!-- Modal footer -->
        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3">
          <button id="modal-cancel-btn" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
            Cancel
          </button>
          <button
            id="modal-submit-btn"
            class="px-5 py-2 text-sm font-medium text-white rounded-lg transition-colors flex items-center gap-2"
            style="background-color:#194642;"
          >
            <span id="modal-submit-label">Create Order</span>
            <i id="modal-submit-spinner" class="fas fa-spinner fa-spin hidden"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ORDER DETAIL DRAWER ===== -->
  <div
    id="order-drawer"
    class="fixed inset-y-0 right-0 z-50 w-full max-w-xl bg-white shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col"
  >
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 shrink-0">
      <div>
        <h2 class="text-lg font-semibold text-gray-800" id="drawer-order-number">Order</h2>
        <p class="text-xs text-gray-500" id="drawer-created-at"></p>
      </div>
      <button id="drawer-close-btn" class="text-gray-400 hover:text-gray-600 transition-colors">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>

    <!-- Drawer scrollable body -->
    <div class="flex-1 overflow-y-auto px-6 py-5 space-y-6" id="drawer-body">
      <div class="text-center py-8 text-gray-400">
        <i class="fas fa-spinner fa-spin text-2xl"></i>
      </div>
    </div>

    <!-- Drawer footer -->
    <div class="shrink-0 px-6 py-4 border-t border-gray-200 flex items-center justify-between gap-3 bg-gray-50">
      <button
        id="drawer-delete-btn"
        class="px-4 py-2 text-sm font-medium text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition-colors"
      >
        <i class="fas fa-trash mr-1"></i>Delete
      </button>
      <button
        id="drawer-edit-btn"
        class="px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors"
        style="background-color:#194642;"
      >
        <i class="fas fa-edit mr-1"></i>Edit Order
      </button>
    </div>
  </div>
  <div id="drawer-backdrop" class="fixed inset-0 z-40 bg-black bg-opacity-40 hidden"></div>

  <!-- ===== DELETE CONFIRM DIALOG ===== -->
  <div id="delete-dialog" class="fixed inset-0 z-[60] hidden flex items-center justify-center px-4">
    <div class="fixed inset-0 bg-black bg-opacity-50" id="delete-backdrop"></div>
    <div class="relative bg-white rounded-xl shadow-xl w-full max-w-sm z-10 p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
          <i class="fas fa-exclamation-triangle text-red-600"></i>
        </div>
        <h3 class="text-base font-semibold text-gray-900">Delete Order</h3>
      </div>
      <p class="text-sm text-gray-600 mb-6">Are you sure you want to delete this order? This action cannot be undone.</p>
      <div class="flex justify-end gap-3">
        <button id="delete-cancel-btn" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
          Cancel
        </button>
        <button id="delete-confirm-btn" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors flex items-center gap-2">
          <span>Delete</span>
          <i id="delete-spinner" class="fas fa-spinner fa-spin hidden"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- ===== TOAST CONTAINER ===== -->
  <div id="toast-container" class="fixed bottom-5 right-5 z-[70] flex flex-col gap-2 pointer-events-none"></div>
</AdminLayout>

<script>
  // ─── Types ───────────────────────────────────────────────────────────────────
  interface Customer { id: string; full_name: string; email: string; company_name?: string; phone?: string; }
  interface Product { id: string; name: string; sku?: string; unit_price: number; unit_of_measure?: string; admin_product_categories?: { name: string } | null; }
  interface LineItem { id?: string; product_id: string; quantity: number; unit_price: number; product?: Product; }
  interface HistoryEntry { id: string; status: string; notes?: string; created_at: string; }
  interface Order {
    id: string;
    order_number: string;
    status: string;
    total_amount: number;
    delivery_address?: string;
    delivery_date?: string;
    notes?: string;
    created_at: string;
    customer_id?: string;
    customer?: Customer;
    items?: LineItem[];
    status_history?: HistoryEntry[];
  }

  // ─── State ────────────────────────────────────────────────────────────────
  let allCustomers: Customer[] = [];
  let allProducts: Product[] = [];
  let editingOrderId: string | null = null;
  let drawerOrderId: string | null = null;
  let deletingOrderId: string | null = null;

  // ─── Utilities ────────────────────────────────────────────────────────────
  const fmt = (n: number) => new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'XOF', maximumFractionDigits: 0 }).format(n);
  const fmtDate = (s?: string) => s ? new Date(s).toLocaleDateString('fr-FR') : '—';

  function statusBadge(status: string): string {
    const map: Record<string, string> = {
      draft: 'bg-gray-100 text-gray-700',
      confirmed: 'bg-blue-100 text-blue-700',
      processing: 'bg-yellow-100 text-yellow-700',
      shipped: 'bg-purple-100 text-purple-700',
      delivered: 'bg-green-100 text-green-700',
      cancelled: 'bg-red-100 text-red-700',
    };
    const cls = map[status] || 'bg-gray-100 text-gray-700';
    return `<span class="px-2 py-0.5 rounded-full text-xs font-semibold ${cls}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>`;
  }

  function showToast(message: string, type: 'success' | 'error' | 'info' = 'success') {
    const container = document.getElementById('toast-container')!;
    const colors: Record<string, string> = {
      success: 'bg-green-600',
      error: 'bg-red-600',
      info: 'bg-blue-600',
    };
    const icons: Record<string, string> = {
      success: 'fa-check-circle',
      error: 'fa-times-circle',
      info: 'fa-info-circle',
    };
    const toast = document.createElement('div');
    toast.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-lg text-white text-sm shadow-lg transition-all duration-300 ${colors[type]}`;
    toast.innerHTML = `<i class="fas ${icons[type]}"></i><span>${message}</span>`;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 300);
    }, 3500);
  }

  // ─── API helpers ──────────────────────────────────────────────────────────
  async function apiFetch(url: string, options?: RequestInit) {
    const res = await fetch(url, options);
    const json = await res.json();
    if (!res.ok) throw new Error(json.error || json.message || 'Request failed');
    return json;
  }

  // ─── Stats ────────────────────────────────────────────────────────────────
  async function loadStats() {
    try {
      const data = await apiFetch('/api/admin/orders');
      const orders: Order[] = data.orders || [];
      const counts: Record<string, number> = { draft: 0, confirmed: 0, processing: 0, delivered: 0, cancelled: 0 };
      orders.forEach((o) => { if (counts[o.status] !== undefined) counts[o.status]++; });
      (['draft', 'confirmed', 'processing', 'delivered', 'cancelled'] as const).forEach((s) => {
        const el = document.getElementById(`stat-${s}`);
        if (el) el.textContent = String(counts[s]);
      });
    } catch (e) {
      console.error('Stats error', e);
    }
  }

  // ─── Orders Table ─────────────────────────────────────────────────────────
  async function loadOrders() {
    const tbody = document.getElementById('orders-table-body')!;
    const search = (document.getElementById('search-input') as HTMLInputElement).value;
    const status = (document.getElementById('status-filter') as HTMLSelectElement).value;

    tbody.innerHTML = `<tr><td colspan="7" class="px-6 py-10 text-center text-gray-400"><i class="fas fa-spinner fa-spin mr-2"></i>Loading…</td></tr>`;

    try {
      const params = new URLSearchParams();
      if (search) params.set('search', search);
      if (status) params.set('status', status);
      const data = await apiFetch(`/api/admin/orders?${params}`);
      const orders: Order[] = data.orders || [];

      if (orders.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="px-6 py-10 text-center text-gray-400">No orders found</td></tr>`;
        return;
      }

      tbody.innerHTML = orders.map((order) => `
        <tr class="bg-white border-b hover:bg-gray-50 cursor-pointer order-row" data-id="${order.id}">
          <td class="px-6 py-4 font-medium text-gray-900">#${order.order_number || order.id.slice(0, 8)}</td>
          <td class="px-6 py-4">
            <div class="font-medium text-gray-900">${order.customer?.full_name || '—'}</div>
            <div class="text-xs text-gray-500">${order.customer?.company_name || order.customer?.email || ''}</div>
          </td>
          <td class="px-6 py-4">${statusBadge(order.status)}</td>
          <td class="px-6 py-4 font-medium text-gray-900">${fmt(order.total_amount || 0)}</td>
          <td class="px-6 py-4 text-sm text-gray-600">${fmtDate(order.delivery_date)}</td>
          <td class="px-6 py-4 text-sm text-gray-600">${fmtDate(order.created_at)}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-2" onclick="event.stopPropagation()">
              <button class="text-blue-500 hover:text-blue-700 view-btn p-1" data-id="${order.id}" title="View">
                <i class="fas fa-eye"></i>
              </button>
              <button class="text-yellow-500 hover:text-yellow-700 edit-btn p-1" data-id="${order.id}" title="Edit">
                <i class="fas fa-edit"></i>
              </button>
              <button class="text-red-500 hover:text-red-700 delete-btn p-1" data-id="${order.id}" title="Delete">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      `).join('');

      // Row click → drawer
      document.querySelectorAll('.order-row').forEach((row) => {
        row.addEventListener('click', () => openDrawer((row as HTMLElement).dataset.id!));
      });
      document.querySelectorAll('.view-btn').forEach((btn) => {
        btn.addEventListener('click', () => openDrawer((btn as HTMLElement).dataset.id!));
      });
      document.querySelectorAll('.edit-btn').forEach((btn) => {
        btn.addEventListener('click', () => openEditModal((btn as HTMLElement).dataset.id!));
      });
      document.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', () => openDeleteDialog((btn as HTMLElement).dataset.id!));
      });
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="7" class="px-6 py-10 text-center text-red-500">Error: ${e.message}</td></tr>`;
    }
  }

  // ─── Load reference data ──────────────────────────────────────────────────
  async function loadReferenceData() {
    const [custData, prodData] = await Promise.all([
      apiFetch('/api/admin/customers'),
      apiFetch('/api/admin/products'),
    ]);
    allCustomers = custData.customers || [];
    allProducts = prodData.products || [];
  }

  // ─── Line Items ───────────────────────────────────────────────────────────
  function getLineItems(): LineItem[] {
    const rows = document.querySelectorAll<HTMLTableRowElement>('#line-items-body tr[data-row]');
    return Array.from(rows).map((row) => {
      const productId = (row.querySelector('.li-product') as HTMLSelectElement).value;
      const quantity = parseFloat((row.querySelector('.li-qty') as HTMLInputElement).value) || 1;
      const unitPrice = parseFloat((row.querySelector('.li-price') as HTMLInputElement).value) || 0;
      return { product_id: productId, quantity, unit_price: unitPrice };
    });
  }

  function recalcTotal() {
    const items = getLineItems();
    const total = items.reduce((s, i) => s + i.quantity * i.unit_price, 0);
    const totalEl = document.getElementById('modal-total');
    if (totalEl) totalEl.textContent = fmt(total);
    // update subtotal cells
    document.querySelectorAll<HTMLTableRowElement>('#line-items-body tr[data-row]').forEach((row) => {
      const qty = parseFloat((row.querySelector('.li-qty') as HTMLInputElement).value) || 1;
      const price = parseFloat((row.querySelector('.li-price') as HTMLInputElement).value) || 0;
      const stEl = row.querySelector('.li-subtotal');
      if (stEl) stEl.textContent = fmt(qty * price);
    });
  }

  function buildProductOptions(selectedId = ''): string {
    return allProducts.map((p) => `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>${p.name}${p.sku ? ` (${p.sku})` : ''}</option>`).join('');
  }

  function addLineItemRow(item?: LineItem) {
    const tbody = document.getElementById('line-items-body')!;
    const idx = tbody.querySelectorAll('tr[data-row]').length;
    const tr = document.createElement('tr');
    tr.dataset.row = String(idx);
    tr.className = 'border-t border-gray-100';

    const product = item?.product_id ? allProducts.find((p) => p.id === item.product_id) : null;
    const qty = item?.quantity ?? 1;
    const price = item?.unit_price ?? (product?.unit_price ?? 0);

    tr.innerHTML = `
      <td class="px-3 py-2">
        <select class="li-product w-full px-2 py-1.5 border border-gray-200 rounded text-sm focus:outline-none">
          <option value="">Select product…</option>
          ${buildProductOptions(item?.product_id)}
        </select>
      </td>
      <td class="px-3 py-2">
        <input type="number" min="1" step="1" class="li-qty w-full px-2 py-1.5 border border-gray-200 rounded text-sm text-right focus:outline-none" value="${qty}" />
      </td>
      <td class="px-3 py-2">
        <input type="number" min="0" step="1" class="li-price w-full px-2 py-1.5 border border-gray-200 rounded text-sm text-right focus:outline-none" value="${price}" />
      </td>
      <td class="px-3 py-2 text-right text-sm text-gray-700 li-subtotal">${fmt(qty * price)}</td>
      <td class="px-3 py-2 text-center">
        <button type="button" class="li-remove text-red-400 hover:text-red-600 text-xs"><i class="fas fa-times"></i></button>
      </td>
    `;

    // Product change → auto-fill price
    const productSel = tr.querySelector('.li-product') as HTMLSelectElement;
    const priceInput = tr.querySelector('.li-price') as HTMLInputElement;
    productSel.addEventListener('change', () => {
      const prod = allProducts.find((p) => p.id === productSel.value);
      if (prod) priceInput.value = String(prod.unit_price);
      recalcTotal();
    });
    tr.querySelector('.li-qty')!.addEventListener('input', recalcTotal);
    priceInput.addEventListener('input', recalcTotal);
    tr.querySelector('.li-remove')!.addEventListener('click', () => { tr.remove(); recalcTotal(); });

    tbody.appendChild(tr);
    recalcTotal();
  }

  // ─── Create/Edit Modal ────────────────────────────────────────────────────
  function populateCustomerSelect(selectedId = '') {
    const sel = document.getElementById('modal-customer') as HTMLSelectElement;
    sel.innerHTML = `<option value="">Select customer…</option>` +
      allCustomers.map((c) => `<option value="${c.id}" ${c.id === selectedId ? 'selected' : ''}>${c.full_name}${c.company_name ? ` — ${c.company_name}` : ''}</option>`).join('');
  }

  function resetModal() {
    editingOrderId = null;
    (document.getElementById('modal-title') as HTMLElement).textContent = 'Create Order';
    (document.getElementById('modal-submit-label') as HTMLElement).textContent = 'Create Order';
    populateCustomerSelect();
    document.getElementById('line-items-body')!.innerHTML = '';
    (document.getElementById('modal-delivery-address') as HTMLInputElement).value = '';
    (document.getElementById('modal-delivery-date') as HTMLInputElement).value = '';
    (document.getElementById('modal-notes') as HTMLTextAreaElement).value = '';
    document.getElementById('modal-total')!.textContent = '0 XOF';
    addLineItemRow();
  }

  async function openEditModal(orderId: string) {
    closeDrawer();
    if (allCustomers.length === 0 || allProducts.length === 0) {
      try { await loadReferenceData(); } catch {}
    }
    openModal();
    editingOrderId = orderId;
    (document.getElementById('modal-title') as HTMLElement).textContent = 'Edit Order';
    (document.getElementById('modal-submit-label') as HTMLElement).textContent = 'Save Changes';

    try {
      const data = await apiFetch(`/api/admin/orders?id=${orderId}`);
      const order: Order = data.order || data;
      populateCustomerSelect(order.customer_id || order.customer?.id);
      document.getElementById('line-items-body')!.innerHTML = '';
      (order.items || []).forEach((item) => addLineItemRow(item));
      if ((order.items || []).length === 0) addLineItemRow();
      (document.getElementById('modal-delivery-address') as HTMLInputElement).value = order.delivery_address || '';
      const dd = order.delivery_date ? order.delivery_date.slice(0, 10) : '';
      (document.getElementById('modal-delivery-date') as HTMLInputElement).value = dd;
      (document.getElementById('modal-notes') as HTMLTextAreaElement).value = order.notes || '';
      recalcTotal();
    } catch (e: any) {
      showToast('Failed to load order: ' + e.message, 'error');
    }
  }

  function openModal() {
    const modal = document.getElementById('order-modal')!;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('order-modal')!.classList.add('hidden');
    document.body.style.overflow = '';
  }

  async function submitOrder() {
    const customerId = (document.getElementById('modal-customer') as HTMLSelectElement).value;
    if (!customerId) { showToast('Please select a customer.', 'error'); return; }

    const items = getLineItems();
    if (items.length === 0 || items.some((i) => !i.product_id)) {
      showToast('Please add at least one item with a product selected.', 'error');
      return;
    }

    const payload: any = {
      customer_id: customerId,
      items,
      delivery_address: (document.getElementById('modal-delivery-address') as HTMLInputElement).value,
      delivery_date: (document.getElementById('modal-delivery-date') as HTMLInputElement).value || null,
      notes: (document.getElementById('modal-notes') as HTMLTextAreaElement).value,
    };

    const spinner = document.getElementById('modal-submit-spinner')!;
    const submitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement;
    spinner.classList.remove('hidden');
    submitBtn.disabled = true;

    try {
      if (editingOrderId) {
        payload.id = editingOrderId;
        await apiFetch('/api/admin/orders', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        showToast('Order updated successfully.', 'success');
      } else {
        await apiFetch('/api/admin/orders', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        showToast('Order created successfully.', 'success');
      }
      closeModal();
      loadOrders();
      loadStats();
    } catch (e: any) {
      showToast('Error: ' + e.message, 'error');
    } finally {
      spinner.classList.add('hidden');
      submitBtn.disabled = false;
    }
  }

  // ─── Drawer ───────────────────────────────────────────────────────────────
  async function openDrawer(orderId: string) {
    drawerOrderId = orderId;
    const drawer = document.getElementById('order-drawer')!;
    const backdrop = document.getElementById('drawer-backdrop')!;
    const body = document.getElementById('drawer-body')!;

    backdrop.classList.remove('hidden');
    drawer.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';

    body.innerHTML = `<div class="text-center py-10 text-gray-400"><i class="fas fa-spinner fa-spin text-2xl"></i></div>`;

    try {
      const data = await apiFetch(`/api/admin/orders?id=${orderId}`);
      const order: Order = data.order || data;

      (document.getElementById('drawer-order-number') as HTMLElement).textContent = `Order #${order.order_number || order.id.slice(0, 8)}`;
      (document.getElementById('drawer-created-at') as HTMLElement).textContent = `Created ${fmtDate(order.created_at)}`;

      const itemsHtml = (order.items || []).map((item) => `
        <tr class="border-t border-gray-100">
          <td class="py-2 text-sm text-gray-800">${item.product?.name || item.product_id}</td>
          <td class="py-2 text-sm text-right text-gray-600">${item.quantity}</td>
          <td class="py-2 text-sm text-right text-gray-600">${fmt(item.unit_price)}</td>
          <td class="py-2 text-sm text-right font-medium text-gray-900">${fmt(item.quantity * item.unit_price)}</td>
        </tr>
      `).join('');

      const historyHtml = (order.status_history || []).map((h, i) => `
        <div class="flex gap-3">
          <div class="flex flex-col items-center">
            <div class="w-2.5 h-2.5 rounded-full mt-1" style="background-color:#194642;"></div>
            ${i < (order.status_history!.length - 1) ? '<div class="flex-1 w-px bg-gray-200 mt-1"></div>' : ''}
          </div>
          <div class="pb-4">
            <p class="text-sm font-medium text-gray-800">${h.status.charAt(0).toUpperCase() + h.status.slice(1)}</p>
            ${h.notes ? `<p class="text-xs text-gray-500">${h.notes}</p>` : ''}
            <p class="text-xs text-gray-400">${fmtDate(h.created_at)}</p>
          </div>
        </div>
      `).join('');

      // Status transition buttons
      const nextStatuses: Record<string, {label: string, status: string, color: string}[]> = {
        draft: [{ label: 'Confirm', status: 'confirmed', color: 'bg-blue-600 hover:bg-blue-700' }],
        confirmed: [{ label: 'Mark Processing', status: 'processing', color: 'bg-yellow-600 hover:bg-yellow-700' }],
        processing: [{ label: 'Mark Shipped', status: 'shipped', color: 'bg-purple-600 hover:bg-purple-700' }],
        shipped: [{ label: 'Mark Delivered', status: 'delivered', color: 'bg-green-600 hover:bg-green-700' }],
        delivered: [],
        cancelled: [],
      };
      const transitions = nextStatuses[order.status] || [];
      const transitionBtns = [
        ...transitions.map((t) => `<button class="px-3 py-1.5 text-xs font-medium text-white rounded-lg transition-colors ${t.color} status-change-btn" data-status="${t.status}">${t.label}</button>`),
        order.status !== 'cancelled' && order.status !== 'delivered'
          ? `<button class="px-3 py-1.5 text-xs font-medium text-white rounded-lg bg-red-500 hover:bg-red-600 transition-colors status-change-btn" data-status="cancelled">Cancel Order</button>`
          : '',
      ].join('');

      body.innerHTML = `
        <!-- Customer info -->
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Customer</h3>
          <p class="font-medium text-gray-900">${order.customer?.full_name || '—'}</p>
          ${order.customer?.company_name ? `<p class="text-sm text-gray-600">${order.customer.company_name}</p>` : ''}
          ${order.customer?.email ? `<p class="text-sm text-gray-500">${order.customer.email}</p>` : ''}
          ${order.customer?.phone ? `<p class="text-sm text-gray-500">${order.customer.phone}</p>` : ''}
        </div>

        <!-- Status -->
        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Status</h3>
          <div class="flex items-center gap-2 flex-wrap">
            ${statusBadge(order.status)}
            ${transitionBtns}
          </div>
        </div>

        <!-- Items -->
        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Items</h3>
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-xs text-gray-500">
                <tr>
                  <th class="px-3 py-2 text-left">Product</th>
                  <th class="px-3 py-2 text-right">Qty</th>
                  <th class="px-3 py-2 text-right">Unit Price</th>
                  <th class="px-3 py-2 text-right">Subtotal</th>
                </tr>
              </thead>
              <tbody>${itemsHtml || '<tr><td colspan="4" class="px-3 py-4 text-center text-gray-400">No items</td></tr>'}</tbody>
              <tfoot class="border-t border-gray-200 bg-gray-50">
                <tr>
                  <td colspan="3" class="px-3 py-2 text-right text-sm font-semibold text-gray-700">Total</td>
                  <td class="px-3 py-2 text-right text-sm font-bold text-gray-900">${fmt(order.total_amount || 0)}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

        <!-- Details -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Delivery Date</p>
            <p class="text-sm text-gray-800">${fmtDate(order.delivery_date)}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Delivery Address</p>
            <p class="text-sm text-gray-800">${order.delivery_address || '—'}</p>
          </div>
          ${order.notes ? `
          <div class="col-span-2">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Notes</p>
            <p class="text-sm text-gray-800">${order.notes}</p>
          </div>` : ''}
        </div>

        <!-- Status history -->
        ${(order.status_history || []).length > 0 ? `
        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Status History</h3>
          <div class="space-y-0">${historyHtml}</div>
        </div>` : ''}
      `;

      // Bind status change buttons
      body.querySelectorAll('.status-change-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const newStatus = (btn as HTMLElement).dataset.status!;
          try {
            await apiFetch('/api/admin/orders', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: orderId, status: newStatus }),
            });
            showToast(`Order marked as ${newStatus}.`, 'success');
            openDrawer(orderId);
            loadOrders();
            loadStats();
          } catch (e: any) {
            showToast('Failed to update status: ' + e.message, 'error');
          }
        });
      });

    } catch (e: any) {
      body.innerHTML = `<div class="text-center py-10 text-red-500">Failed to load order: ${e.message}</div>`;
    }
  }

  function closeDrawer() {
    const drawer = document.getElementById('order-drawer')!;
    const backdrop = document.getElementById('drawer-backdrop')!;
    drawer.classList.add('translate-x-full');
    backdrop.classList.add('hidden');
    document.body.style.overflow = '';
    drawerOrderId = null;
  }

  // ─── Delete dialog ────────────────────────────────────────────────────────
  function openDeleteDialog(orderId: string) {
    deletingOrderId = orderId;
    document.getElementById('delete-dialog')!.classList.remove('hidden');
    document.getElementById('delete-dialog')!.classList.add('flex');
  }

  function closeDeleteDialog() {
    deletingOrderId = null;
    document.getElementById('delete-dialog')!.classList.add('hidden');
    document.getElementById('delete-dialog')!.classList.remove('flex');
  }

  async function deleteOrder() {
    if (!deletingOrderId) return;
    const spinner = document.getElementById('delete-spinner')!;
    const btn = document.getElementById('delete-confirm-btn') as HTMLButtonElement;
    spinner.classList.remove('hidden');
    btn.disabled = true;
    try {
      await apiFetch('/api/admin/orders', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: deletingOrderId }),
      });
      showToast('Order deleted.', 'success');
      closeDeleteDialog();
      closeDrawer();
      loadOrders();
      loadStats();
    } catch (e: any) {
      showToast('Delete failed: ' + e.message, 'error');
    } finally {
      spinner.classList.add('hidden');
      btn.disabled = false;
    }
  }

  // ─── Bind static elements ─────────────────────────────────────────────────
  document.getElementById('create-order-btn')!.addEventListener('click', async () => {
    if (allCustomers.length === 0 || allProducts.length === 0) {
      try { await loadReferenceData(); } catch (e: any) { showToast('Failed to load data: ' + e.message, 'error'); return; }
    }
    resetModal();
    openModal();
  });

  document.getElementById('modal-close-btn')!.addEventListener('click', closeModal);
  document.getElementById('modal-cancel-btn')!.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')!.addEventListener('click', closeModal);
  document.getElementById('modal-submit-btn')!.addEventListener('click', submitOrder);
  document.getElementById('add-item-btn')!.addEventListener('click', () => addLineItemRow());

  document.getElementById('drawer-close-btn')!.addEventListener('click', closeDrawer);
  document.getElementById('drawer-backdrop')!.addEventListener('click', closeDrawer);
  document.getElementById('drawer-edit-btn')!.addEventListener('click', () => { if (drawerOrderId) openEditModal(drawerOrderId); });
  document.getElementById('drawer-delete-btn')!.addEventListener('click', () => { if (drawerOrderId) openDeleteDialog(drawerOrderId); });

  document.getElementById('delete-cancel-btn')!.addEventListener('click', closeDeleteDialog);
  document.getElementById('delete-backdrop')!.addEventListener('click', closeDeleteDialog);
  document.getElementById('delete-confirm-btn')!.addEventListener('click', deleteOrder);

  let _searchTimer: ReturnType<typeof setTimeout>;
  document.getElementById('search-input')!.addEventListener('input', () => {
    clearTimeout(_searchTimer);
    _searchTimer = setTimeout(loadOrders, 300);
  });
  document.getElementById('status-filter')!.addEventListener('change', loadOrders);

  // ─── Init ─────────────────────────────────────────────────────────────────
  loadStats();
  loadOrders();
</script>
