---
export const prerender = false;
import AdminLayout from "../../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Sales Agents">
<style>
  .docs-cat-tab {
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1.5px solid #e5e7eb;
    background: white;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .docs-cat-tab:hover { border-color: #194642; color: #194642; }
  .docs-cat-tab.active-cat-tab { background: #194642; color: white; border-color: #194642; }
</style>
  <!-- Toast -->
  <div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col gap-2 pointer-events-none"></div>

  <!-- Create Agent Modal -->
  <div id="create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between p-5 border-b border-gray-100">
        <h2 class="text-lg font-bold text-gray-800">Create Sales Agent</h2>
        <button id="close-create-modal" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>
      <form id="create-form" class="p-5 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name <span class="text-red-500">*</span></label>
          <input id="cf-name" type="text" required placeholder="Jean Kouassi"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email Address <span class="text-red-500">*</span></label>
          <input id="cf-email" type="email" required placeholder="agent@example.com"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password <span class="text-red-500">*</span></label>
          <div class="relative">
            <input id="cf-password" type="password" required minlength="8" placeholder="Min. 8 characters"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            <button type="button" id="toggle-pw" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <i class="fas fa-eye text-sm"></i>
            </button>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone (optional)</label>
          <input id="cf-phone" type="tel" placeholder="+225 07 00 00 00 00"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Link to Employee (optional)</label>
          <select id="cf-employee" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
            <option value="">— No employee link —</option>
          </select>
          <p class="text-xs text-gray-400 mt-1">Links this agent to an existing employee for commission calculation based on hire date.</p>
        </div>
        <div class="flex items-center justify-end gap-3 pt-2">
          <button type="button" id="cancel-create" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
          <button type="submit" id="submit-create" class="px-5 py-2 text-sm font-medium text-white rounded-lg hover:opacity-90" style="background:#194642">
            <i class="fas fa-plus mr-1"></i> Create Agent
          </button>
        </div>
      </form>
      <!-- Credentials display after creation -->
      <div id="credentials-display" class="hidden p-5 border-t border-gray-100">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <p class="text-sm font-semibold text-green-800 mb-1"><i class="fas fa-check-circle mr-1"></i> Agent créé avec succès !</p>
          <!-- Email sent notice -->
          <div class="flex items-center gap-2 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2 mb-3">
            <i class="fas fa-envelope text-blue-500 text-xs"></i>
            <p class="text-xs text-blue-700">
              Les identifiants ont été envoyés automatiquement par email à <strong id="cred-email-notice">—</strong>.
            </p>
          </div>
          <p class="text-xs text-green-700 mb-3">Conservez ces informations — le mot de passe n'est affiché qu'une seule fois.</p>
          <div class="bg-white rounded-lg p-3 border border-green-100 text-sm space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide w-20">Email</span>
              <span id="cred-email" class="font-mono text-gray-800">—</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide w-20">Mot de passe</span>
              <span id="cred-password" class="font-mono font-bold text-gray-800">—</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide w-20">Portail</span>
              <span class="font-mono text-[#194642] text-xs">arbrebio.com/sales-agent/login</span>
            </div>
          </div>
          <button id="copy-creds" class="mt-3 px-3 py-1.5 text-xs font-medium bg-green-700 text-white rounded-lg hover:opacity-90">
            <i class="fas fa-copy mr-1"></i> Copier les identifiants
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Documents Modal -->
  <div id="docs-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col">
      <!-- Header -->
      <div class="flex items-center justify-between p-5 border-b border-gray-100 flex-shrink-0">
        <div>
          <h2 class="text-lg font-bold text-gray-800"><i class="fas fa-folder-open text-[#194642] mr-2"></i>Documents Agent</h2>
          <p id="docs-agent-name" class="text-sm text-gray-500 mt-0.5"></p>
        </div>
        <button id="close-docs-modal" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>

      <!-- Upload Form -->
      <div class="p-4 border-b border-gray-100 bg-gray-50 flex-shrink-0">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Ajouter un document</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <input id="doc-title" type="text" placeholder="Titre du document *"
            class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          <select id="doc-category" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
            <option value="">— Catégorie * —</option>
            <option value="learning">📚 Formation</option>
            <option value="catalog">📖 Catalogue</option>
            <option value="pricing">🏷️ Tarifs</option>
          </select>
          <div class="flex gap-2">
            <label class="flex-1 flex items-center gap-2 border border-dashed border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-500 cursor-pointer hover:border-[#194642] hover:text-[#194642] transition-colors">
              <i class="fas fa-paperclip text-xs"></i>
              <span id="doc-file-label" class="truncate">Choisir un fichier *</span>
              <input id="doc-file" type="file" class="hidden"
                accept=".pdf,.jpg,.jpeg,.png,.webp,.doc,.docx,.xls,.xlsx,.ppt,.pptx" />
            </label>
            <button id="btn-upload-doc"
              class="px-4 py-2 text-sm font-medium text-white rounded-lg hover:opacity-90 whitespace-nowrap"
              style="background:#194642">
              <i class="fas fa-upload mr-1"></i> Envoyer
            </button>
          </div>
        </div>
        <p class="text-xs text-gray-400 mt-2">Formats acceptés : PDF, images, Word, Excel, PowerPoint — 50 Mo max.</p>
      </div>

      <!-- Document list -->
      <div class="flex-1 overflow-y-auto p-4">
        <!-- Category filter tabs -->
        <div class="flex gap-2 mb-4 flex-wrap">
          <button class="docs-cat-tab active-cat-tab" data-cat="all">Tous</button>
          <button class="docs-cat-tab" data-cat="learning">📚 Formation</button>
          <button class="docs-cat-tab" data-cat="catalog">📖 Catalogue</button>
          <button class="docs-cat-tab" data-cat="pricing">🏷️ Tarifs</button>
        </div>
        <div id="docs-list">
          <p class="text-center py-8 text-gray-400 text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Chargement…</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Suspend Modal -->
  <div id="suspend-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
      <div class="p-5 border-b border-gray-100">
        <h2 class="text-lg font-bold text-gray-800">Suspend Agent</h2>
      </div>
      <div class="p-5">
        <label class="block text-sm font-medium text-gray-700 mb-2">Reason for suspension <span class="text-red-500">*</span></label>
        <textarea id="suspend-reason" rows="3" placeholder="Enter the reason…"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400"></textarea>
      </div>
      <div class="flex items-center justify-end gap-3 p-5 border-t border-gray-100">
        <button id="cancel-suspend" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
        <button id="confirm-suspend" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg">Suspend</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-5">
      <h2 class="text-lg font-bold text-gray-800 mb-2">Delete Agent?</h2>
      <p class="text-sm text-gray-600 mb-4">This will permanently delete the agent's login access. Their sales records will be preserved.</p>
      <div class="flex justify-end gap-3">
        <button id="cancel-delete" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Cancel</button>
        <button id="confirm-delete" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg">Delete</button>
      </div>
    </div>
  </div>

  <!-- Reset Password Modal -->
  <div id="reset-pw-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
      <div class="flex items-center justify-between p-5 border-b border-gray-100">
        <div>
          <h2 class="text-lg font-bold text-gray-800">Réinitialiser le mot de passe</h2>
          <p id="reset-pw-agent-name" class="text-sm text-gray-500 mt-0.5"></p>
        </div>
        <button id="close-reset-pw-modal" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>
      <div class="p-5 space-y-4">
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs text-amber-700">
          <i class="fas fa-info-circle mr-1"></i>
          L'agent devra changer ce mot de passe à sa prochaine connexion. Un email lui sera envoyé automatiquement.
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nouveau mot de passe temporaire <span class="text-red-500">*</span></label>
          <div class="flex gap-2">
            <div class="relative flex-1">
              <input id="reset-pw-input" type="text" minlength="8" placeholder="Min. 8 caractères"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <button id="btn-generate-pw" type="button" class="px-3 py-2 text-xs font-medium border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 whitespace-nowrap">
              <i class="fas fa-dice mr-1"></i> Générer
            </button>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 p-5 border-t border-gray-100">
        <button id="cancel-reset-pw" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">Annuler</button>
        <button id="confirm-reset-pw" class="px-4 py-2 text-sm font-medium text-white rounded-lg hover:opacity-90" style="background:#194642">
          <i class="fas fa-key mr-1"></i> Réinitialiser
        </button>
      </div>
    </div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <a href="/admin/sales" class="text-sm text-gray-500 hover:text-[#194642] transition-colors">← Sales</a>
      </div>
      <h1 class="text-2xl font-bold text-gray-800">Sales Agents</h1>
      <p class="text-gray-500 text-sm mt-0.5">Manage sales agent credentials and access</p>
    </div>
    <button id="btn-create-agent" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-white text-sm font-medium hover:opacity-90 transition-opacity" style="background:#194642">
      <i class="fas fa-plus text-xs"></i> Create Agent
    </button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Total Agents</p>
      <p id="stat-total" class="text-2xl font-bold text-gray-800">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Active</p>
      <p id="stat-active" class="text-2xl font-bold text-green-600">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Suspended</p>
      <p id="stat-suspended" class="text-2xl font-bold text-red-500">—</p>
    </div>
  </div>

  <!-- Agents Table -->
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Agent</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contact</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Mot de passe</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Sales (YTD)</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Commission (YTD)</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody id="agents-table-body" class="divide-y divide-gray-50">
          <tr><td colspan="7" class="px-4 py-8 text-center text-gray-400">Loading…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  import { authFetch } from "../../../../lib/supabase";
  const fmt = (n: number) => new Intl.NumberFormat('fr-FR').format(n);
  let selectedAgentId: string | null = null;
  let lastCreatedPassword = '';
  let lastCreatedEmail = '';

  // ── Load employees for linking ─────────────────────────────────────────
  async function loadEmployees() {
    const res = await authFetch('/api/admin/careers/employees');
    if (!res.ok) return;
    const data = await res.json();
    const employees = data.employees || data || [];
    const sel = document.getElementById('cf-employee') as HTMLSelectElement;
    employees.forEach((e: any) => {
      const opt = document.createElement('option');
      opt.value = e.id;
      opt.textContent = `${e.first_name} ${e.last_name} (${e.worker_id})`;
      sel.appendChild(opt);
    });
  }
  loadEmployees();

  // ── Load agents ────────────────────────────────────────────────────────
  async function loadAgents() {
    const res = await authFetch('/api/admin/sales-agents');
    const data = await res.json();
    const agents: any[] = data.agents || [];

    document.getElementById('stat-total')!.textContent = String(agents.length);
    document.getElementById('stat-active')!.textContent = String(agents.filter(a => a.is_active).length);
    document.getElementById('stat-suspended')!.textContent = String(agents.filter(a => !a.is_active).length);

    const tbody = document.getElementById('agents-table-body')!;
    if (!agents.length) {
      tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-8 text-center text-gray-400">No sales agents created yet. Click "Create Agent" to get started.</td></tr>';
      return;
    }
    tbody.innerHTML = agents.map(a => {
      const ytd = a.sales_ytd || {};
      const emp = a.career_employees;
      // Password column: show temp password if still set, otherwise show status
      const pwCell = a.temp_password
        ? `<div class="flex items-center gap-1">
             <span class="font-mono text-xs bg-amber-50 border border-amber-200 text-amber-800 px-2 py-0.5 rounded select-all" id="pw-${a.id}">${a.temp_password}</span>
             <button class="btn-copy-pw text-gray-400 hover:text-gray-600" data-pw="${a.temp_password}" title="Copy"><i class="fas fa-copy text-xs"></i></button>
           </div>
           <div class="text-xs text-amber-600 mt-0.5 flex items-center gap-1"><i class="fas fa-clock text-xs"></i> En attente de changement</div>`
        : `<div class="flex items-center gap-1 text-xs text-green-600"><i class="fas fa-check-circle"></i> Modifié par l'agent</div>`;

      return `<tr class="hover:bg-gray-50 transition-colors" data-id="${a.id}">
        <td class="px-4 py-3">
          <div class="font-medium text-gray-800">${a.full_name}</div>
          <div class="text-xs text-gray-400">${a.worker_id || '—'}</div>
          ${emp ? `<div class="text-xs text-blue-600">${emp.job_title || ''}</div>` : ''}
        </td>
        <td class="px-4 py-3 text-gray-600">
          <div>${a.email}</div>
          ${a.phone ? `<div class="text-xs text-gray-400">${a.phone}</div>` : ''}
        </td>
        <td class="px-4 py-3">${pwCell}</td>
        <td class="px-4 py-3 text-center">
          <div class="text-gray-800 font-medium">${ytd.total || 0} total</div>
          <div class="text-xs text-green-600">${ytd.validated || 0} validated</div>
          <div class="text-xs text-yellow-600">${ytd.pending || 0} pending</div>
        </td>
        <td class="px-4 py-3 text-right font-semibold text-[#194642]">${fmt(ytd.commission || 0)} FCFA</td>
        <td class="px-4 py-3 text-center">
          <span class="px-2 py-0.5 rounded-full text-xs font-medium ${a.is_active ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
            ${a.is_active ? '<i class="fas fa-check mr-1"></i>Active' : '<i class="fas fa-ban mr-1"></i>Suspended'}
          </span>
          ${!a.is_active && a.suspended_reason ? `<div class="text-xs text-gray-400 mt-0.5 max-w-24 truncate" title="${a.suspended_reason}">${a.suspended_reason}</div>` : ''}
        </td>
        <td class="px-4 py-3 text-center">
          <div class="flex items-center justify-center gap-2 flex-wrap">
            ${a.is_active
              ? `<button class="btn-suspend px-2 py-1 text-xs font-medium border border-red-200 text-red-600 rounded-lg hover:bg-red-50" data-id="${a.id}"><i class="fas fa-ban mr-1"></i>Suspendre</button>`
              : `<button class="btn-activate px-2 py-1 text-xs font-medium border border-green-200 text-green-600 rounded-lg hover:bg-green-50" data-id="${a.id}"><i class="fas fa-check mr-1"></i>Activer</button>`
            }
            <button class="btn-reset-pw px-2 py-1 text-xs font-medium border border-blue-200 text-blue-600 rounded-lg hover:bg-blue-50" data-id="${a.id}" data-name="${a.full_name}"><i class="fas fa-key mr-1"></i>Réinitialiser MDP</button>
            <button class="btn-docs px-2 py-1 text-xs font-medium border border-[#194642] text-[#194642] rounded-lg hover:bg-green-50" data-id="${a.id}" data-name="${a.full_name}"><i class="fas fa-folder-open mr-1"></i>Documents</button>
            <button class="btn-delete px-2 py-1 text-xs font-medium border border-gray-200 text-gray-500 rounded-lg hover:bg-gray-50" data-id="${a.id}"><i class="fas fa-trash"></i></button>
          </div>
        </td>
      </tr>`;
    }).join('');

    document.querySelectorAll('.btn-suspend').forEach(btn => {
      btn.addEventListener('click', () => openSuspendModal(btn.getAttribute('data-id')!));
    });
    document.querySelectorAll('.btn-activate').forEach(btn => {
      btn.addEventListener('click', () => toggleAgent(btn.getAttribute('data-id')!, 'activate'));
    });
    document.querySelectorAll('.btn-delete').forEach(btn => {
      btn.addEventListener('click', () => openDeleteModal(btn.getAttribute('data-id')!));
    });
    document.querySelectorAll('.btn-reset-pw').forEach(btn => {
      btn.addEventListener('click', () => openResetPwModal(btn.getAttribute('data-id')!, btn.getAttribute('data-name')!));
    });
    document.querySelectorAll('.btn-docs').forEach(btn => {
      btn.addEventListener('click', () => openDocsModal(btn.getAttribute('data-id')!, btn.getAttribute('data-name')!));
    });
    document.querySelectorAll('.btn-copy-pw').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(btn.getAttribute('data-pw')!).then(() => showToast('Mot de passe copié !', 'success'));
      });
    });
  }
  loadAgents();

  // ── Create agent ───────────────────────────────────────────────────────
  document.getElementById('btn-create-agent')?.addEventListener('click', () => {
    (document.getElementById('create-form') as HTMLFormElement)!.reset();
    document.getElementById('credentials-display')!.classList.add('hidden');
    document.getElementById('submit-create')!.textContent = 'Create Agent';
    document.getElementById('create-modal')!.classList.remove('hidden');
  });

  document.getElementById('close-create-modal')?.addEventListener('click', () => {
    document.getElementById('create-modal')!.classList.add('hidden');
    loadAgents();
  });
  document.getElementById('cancel-create')?.addEventListener('click', () => {
    document.getElementById('create-modal')!.classList.add('hidden');
    loadAgents();
  });

  document.getElementById('toggle-pw')?.addEventListener('click', () => {
    const input = document.getElementById('cf-password') as HTMLInputElement;
    const icon = document.querySelector('#toggle-pw i')!;
    if (input.type === 'password') {
      input.type = 'text';
      icon.className = 'fas fa-eye-slash text-sm';
    } else {
      input.type = 'password';
      icon.className = 'fas fa-eye text-sm';
    }
  });

  document.getElementById('create-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-create') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Creating…';

    const body = {
      full_name: (document.getElementById('cf-name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('cf-email') as HTMLInputElement).value.trim(),
      password: (document.getElementById('cf-password') as HTMLInputElement).value,
      phone: (document.getElementById('cf-phone') as HTMLInputElement).value.trim() || undefined,
      employee_id: (document.getElementById('cf-employee') as HTMLSelectElement).value || undefined,
    };

    lastCreatedEmail = body.email;
    lastCreatedPassword = body.password;

    const res = await authFetch('/api/admin/sales-agents', {
      method: 'POST',
      body: JSON.stringify(body),
    });
    const data = await res.json();

    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-plus mr-1"></i> Create Agent';

    if (data.error) {
      showToast(data.error, 'error');
      return;
    }

    // Show credentials
    document.getElementById('cred-email')!.textContent = lastCreatedEmail;
    document.getElementById('cred-email-notice')!.textContent = lastCreatedEmail;
    document.getElementById('cred-password')!.textContent = lastCreatedPassword;
    document.getElementById('credentials-display')!.classList.remove('hidden');
    (document.getElementById('create-form') as HTMLElement)!.classList.add('hidden');
    showToast(`✅ Compte créé — identifiants envoyés à ${lastCreatedEmail}`, 'success');
  });

  document.getElementById('copy-creds')?.addEventListener('click', () => {
    const text = `Email: ${lastCreatedEmail}\nMot de passe: ${lastCreatedPassword}\nPortail: https://arbrebio.com/sales-agent/login`;
    navigator.clipboard.writeText(text).then(() => showToast('Credentials copied!', 'success'));
  });

  // ── Suspend / Activate ─────────────────────────────────────────────────
  function openSuspendModal(id: string) {
    selectedAgentId = id;
    (document.getElementById('suspend-reason') as HTMLTextAreaElement).value = '';
    document.getElementById('suspend-modal')!.classList.remove('hidden');
  }

  document.getElementById('cancel-suspend')?.addEventListener('click', () => {
    document.getElementById('suspend-modal')!.classList.add('hidden');
  });

  document.getElementById('confirm-suspend')?.addEventListener('click', async () => {
    const reason = (document.getElementById('suspend-reason') as HTMLTextAreaElement).value.trim();
    if (!reason) { showToast('Please provide a reason.', 'error'); return; }
    await toggleAgent(selectedAgentId!, 'suspend', reason);
    document.getElementById('suspend-modal')!.classList.add('hidden');
  });

  async function toggleAgent(id: string, action: 'suspend' | 'activate', reason?: string) {
    const res = await authFetch('/api/admin/sales-agents', {
      method: 'PUT',
      body: JSON.stringify({ id, action, reason }),
    });
    const data = await res.json();
    if (data.error) { showToast(data.error, 'error'); return; }
    showToast(action === 'activate' ? 'Agent activated.' : 'Agent suspended.', 'success');
    loadAgents();
  }

  // ── Delete ─────────────────────────────────────────────────────────────
  function openDeleteModal(id: string) {
    selectedAgentId = id;
    document.getElementById('delete-modal')!.classList.remove('hidden');
  }
  document.getElementById('cancel-delete')?.addEventListener('click', () => {
    document.getElementById('delete-modal')!.classList.add('hidden');
  });
  document.getElementById('confirm-delete')?.addEventListener('click', async () => {
    document.getElementById('delete-modal')!.classList.add('hidden');
    const res = await authFetch('/api/admin/sales-agents', {
      method: 'DELETE',
      body: JSON.stringify({ id: selectedAgentId }),
    });
    const data = await res.json();
    if (data.error) { showToast(data.error, 'error'); return; }
    showToast('Agent deleted.', 'success');
    loadAgents();
  });

  // ── Reset Password ────────────────────────────────────────────────────
  function openResetPwModal(id: string, name: string) {
    selectedAgentId = id;
    document.getElementById('reset-pw-agent-name')!.textContent = name;
    (document.getElementById('reset-pw-input') as HTMLInputElement).value = '';
    document.getElementById('reset-pw-modal')!.classList.remove('hidden');
  }

  document.getElementById('close-reset-pw-modal')?.addEventListener('click', () => {
    document.getElementById('reset-pw-modal')!.classList.add('hidden');
  });
  document.getElementById('cancel-reset-pw')?.addEventListener('click', () => {
    document.getElementById('reset-pw-modal')!.classList.add('hidden');
  });

  document.getElementById('btn-generate-pw')?.addEventListener('click', () => {
    const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#';
    let pw = '';
    for (let i = 0; i < 12; i++) pw += chars[Math.floor(Math.random() * chars.length)];
    (document.getElementById('reset-pw-input') as HTMLInputElement).value = pw;
  });

  document.getElementById('confirm-reset-pw')?.addEventListener('click', async () => {
    const newPassword = (document.getElementById('reset-pw-input') as HTMLInputElement).value.trim();
    if (!newPassword || newPassword.length < 8) {
      showToast('Le mot de passe doit contenir au moins 8 caractères.', 'error');
      return;
    }
    const btn = document.getElementById('confirm-reset-pw') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Réinitialisation…';

    const res = await authFetch('/api/admin/sales-agents', {
      method: 'PUT',
      body: JSON.stringify({ id: selectedAgentId, action: 'reset-password', new_password: newPassword }),
    });
    const data = await res.json();

    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-key mr-1"></i> Réinitialiser';

    if (data.error) { showToast(data.error, 'error'); return; }
    showToast('Mot de passe réinitialisé. Un email a été envoyé à l\'agent.', 'success');
    document.getElementById('reset-pw-modal')!.classList.add('hidden');
    loadAgents();
  });

  // ── Documents Modal ────────────────────────────────────────────────────
  let docsAgentId: string | null = null;
  let allAdminDocs: any[] = [];
  let activeCat = 'all';

  function openDocsModal(agentId: string, agentName: string) {
    docsAgentId = agentId;
    activeCat = 'all';
    document.getElementById('docs-agent-name')!.textContent = agentName;
    // reset form
    (document.getElementById('doc-title') as HTMLInputElement).value = '';
    (document.getElementById('doc-category') as HTMLSelectElement).value = '';
    (document.getElementById('doc-file') as HTMLInputElement).value = '';
    document.getElementById('doc-file-label')!.textContent = 'Choisir un fichier *';
    // reset tabs
    document.querySelectorAll('.docs-cat-tab').forEach(t => t.classList.remove('active-cat-tab'));
    document.querySelector('.docs-cat-tab[data-cat="all"]')?.classList.add('active-cat-tab');
    document.getElementById('docs-modal')!.classList.remove('hidden');
    loadAdminDocs();
  }

  document.getElementById('close-docs-modal')?.addEventListener('click', () => {
    document.getElementById('docs-modal')!.classList.add('hidden');
  });

  // File input label update
  document.getElementById('doc-file')?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    document.getElementById('doc-file-label')!.textContent = file ? file.name : 'Choisir un fichier *';
  });

  // Category tab filter
  document.querySelectorAll('.docs-cat-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.docs-cat-tab').forEach(t => t.classList.remove('active-cat-tab'));
      tab.classList.add('active-cat-tab');
      activeCat = tab.getAttribute('data-cat') || 'all';
      renderAdminDocs();
    });
  });

  async function loadAdminDocs() {
    if (!docsAgentId) return;
    const listEl = document.getElementById('docs-list')!;
    listEl.innerHTML = '<p class="text-center py-8 text-gray-400 text-sm"><i class="fas fa-spinner fa-spin mr-2"></i>Chargement…</p>';
    try {
      const res = await authFetch(`/api/admin/agent-documents?agent_id=${docsAgentId}`);
      const data = await res.json();
      allAdminDocs = data.documents || [];
      renderAdminDocs();
    } catch {
      listEl.innerHTML = '<p class="text-center py-8 text-red-400 text-sm">Erreur de chargement.</p>';
    }
  }

  function renderAdminDocs() {
    const listEl = document.getElementById('docs-list')!;
    const filtered = activeCat === 'all' ? allAdminDocs : allAdminDocs.filter(d => d.category === activeCat);
    if (!filtered.length) {
      listEl.innerHTML = '<p class="text-center py-8 text-gray-400 text-sm"><i class="fas fa-folder-open mr-2"></i>Aucun document dans cette catégorie.</p>';
      return;
    }
    const catLabels: Record<string, string> = { learning: '📚 Formation', catalog: '📖 Catalogue', pricing: '🏷️ Tarifs' };
    const catColors: Record<string, string> = {
      learning: 'bg-blue-50 text-blue-700 border-blue-100',
      catalog: 'bg-green-50 text-green-700 border-green-100',
      pricing: 'bg-yellow-50 text-yellow-700 border-yellow-100',
    };
    listEl.innerHTML = `<div class="space-y-2">${filtered.map(doc => {
      const size = doc.file_size < 1024 * 1024
        ? `${(doc.file_size / 1024).toFixed(0)} Ko`
        : `${(doc.file_size / (1024 * 1024)).toFixed(1)} Mo`;
      const catColor = catColors[doc.category] || 'bg-gray-50 text-gray-700 border-gray-100';
      return `<div class="flex items-center gap-3 p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors">
        <i class="fas fa-file-alt text-gray-400 text-lg flex-shrink-0"></i>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-800 truncate">${escapeHtmlAdmin(doc.title)}</p>
          <div class="flex items-center gap-2 mt-0.5">
            <span class="text-xs px-2 py-0.5 rounded-full border ${catColor} font-medium">${catLabels[doc.category] ?? doc.category}</span>
            <span class="text-xs text-gray-400">${escapeHtmlAdmin(doc.file_name)}</span>
            <span class="text-xs text-gray-300">·</span>
            <span class="text-xs text-gray-400">${size}</span>
          </div>
        </div>
        <button class="btn-delete-doc flex-shrink-0 w-7 h-7 rounded-lg border border-red-200 text-red-500 hover:bg-red-50 flex items-center justify-center" data-id="${doc.id}" title="Supprimer">
          <i class="fas fa-trash text-xs pointer-events-none"></i>
        </button>
      </div>`;
    }).join('')}</div>`;

    document.querySelectorAll('.btn-delete-doc').forEach(btn => {
      btn.addEventListener('click', () => deleteDoc(btn.getAttribute('data-id')!));
    });
  }

  // Upload document — 3-step flow to bypass Vercel's 4.5 MB body limit:
  // 1. Get a Supabase signed upload URL (tiny JSON request via Vercel)
  // 2. PUT the file DIRECTLY from browser to Supabase (no Vercel in the middle)
  // 3. Save metadata via Vercel API (tiny JSON request)
  document.getElementById('btn-upload-doc')?.addEventListener('click', async () => {
    if (!docsAgentId) return;
    const titleInput = document.getElementById('doc-title') as HTMLInputElement;
    const catSelect  = document.getElementById('doc-category') as HTMLSelectElement;
    const fileInput  = document.getElementById('doc-file') as HTMLInputElement;
    const btn        = document.getElementById('btn-upload-doc') as HTMLButtonElement;

    const title    = titleInput.value.trim();
    const category = catSelect.value;
    const file     = fileInput.files?.[0];

    if (!title)    { showToast('Veuillez saisir un titre.', 'error'); return; }
    if (!category) { showToast('Veuillez choisir une catégorie.', 'error'); return; }
    if (!file)     { showToast('Veuillez sélectionner un fichier.', 'error'); return; }

    btn.disabled = true;

    try {
      // ── Step 1: obtain signed upload URL ───────────────────────────────
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Préparation…';
      const presignRes = await authFetch('/api/admin/agent-documents-presign', {
        method: 'POST',
        body: JSON.stringify({
          agent_id:  docsAgentId,
          title,
          category,
          file_name: file.name,
          file_type: file.type,
          file_size: file.size,
        }),
      });
      const presignData = await presignRes.json();
      if (presignData.error) { showToast(presignData.error, 'error'); return; }

      const { signed_url, file_path } = presignData;

      // ── Step 2: upload file DIRECTLY to Supabase (bypasses Vercel) ─────
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Envoi du fichier…';
      const uploadRes = await fetch(signed_url, {
        method: 'PUT',
        headers: { 'Content-Type': file.type },
        body: file,
      });
      if (!uploadRes.ok) {
        const errText = await uploadRes.text().catch(() => uploadRes.statusText);
        throw new Error(`Erreur d'envoi: ${errText}`);
      }

      // ── Step 3: save metadata via API ──────────────────────────────────
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Enregistrement…';
      const metaRes = await authFetch('/api/admin/agent-documents', {
        method: 'POST',
        body: JSON.stringify({
          agent_id:  docsAgentId,
          title,
          category,
          file_name: file.name,
          file_path,
          file_type: file.type,
          file_size: file.size,
        }),
      });
      const metaData = await metaRes.json();
      if (metaData.error) { showToast(metaData.error, 'error'); return; }

      // ── Reset form ─────────────────────────────────────────────────────
      titleInput.value = '';
      catSelect.value  = '';
      fileInput.value  = '';
      document.getElementById('doc-file-label')!.textContent = 'Choisir un fichier *';
      showToast('Document ajouté avec succès !', 'success');
      loadAdminDocs();

    } catch (err: any) {
      showToast(err.message || 'Erreur lors de l\'envoi.', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-upload mr-1"></i> Envoyer';
    }
  });

  async function deleteDoc(docId: string) {
    if (!confirm('Supprimer ce document ?')) return;
    const res = await authFetch('/api/admin/agent-documents', {
      method: 'DELETE',
      body: JSON.stringify({ id: docId }),
    });
    const data = await res.json();
    if (data.error) { showToast(data.error, 'error'); return; }
    showToast('Document supprimé.', 'success');
    loadAdminDocs();
  }

  function escapeHtmlAdmin(s: string): string {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ── Toast ──────────────────────────────────────────────────────────────
  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const c = document.getElementById('toast-container')!;
    const t = document.createElement('div');
    const color = type === 'success' ? 'bg-green-600' : 'bg-red-600';
    t.className = `pointer-events-auto ${color} text-white px-4 py-3 rounded-lg shadow-lg text-sm flex items-center gap-2 max-w-sm`;
    t.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>${msg}`;
    c.appendChild(t);
    setTimeout(() => t.remove(), 4000);
  }
</script>
