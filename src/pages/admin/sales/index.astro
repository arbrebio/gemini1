---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Sales Management">
  <!-- Toast -->
  <div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col gap-2 pointer-events-none"></div>

  <!-- Validation Modal -->
  <div id="validate-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between p-5 border-b border-gray-100">
        <h2 class="text-lg font-bold text-gray-800" id="modal-title">Validate Sale</h2>
        <button id="close-modal" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>
      <div class="p-5 space-y-4">
        <div id="modal-content" class="text-sm text-gray-700 space-y-2"></div>
        <!-- Proof preview -->
        <div id="proof-container" class="hidden border border-gray-200 rounded-lg overflow-hidden">
          <p class="text-xs font-medium text-gray-500 px-3 py-2 bg-gray-50 border-b">Proof of Payment</p>
          <div id="proof-preview" class="p-2"></div>
        </div>
        <!-- Rejection reason -->
        <div id="rejection-section" class="hidden">
          <label class="block text-sm font-medium text-gray-700 mb-1">Rejection Reason <span class="text-red-500">*</span></label>
          <textarea id="rejection-reason" rows="3" placeholder="Explain why this sale is rejected…"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-500"></textarea>
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 p-5 border-t border-gray-100">
        <button id="btn-reject" class="px-4 py-2 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 border border-red-200 rounded-lg transition-colors">
          <i class="fas fa-times mr-1"></i> Reject
        </button>
        <button id="btn-validate" class="px-4 py-2 text-sm font-medium text-white rounded-lg transition-opacity hover:opacity-90" style="background:#194642">
          <i class="fas fa-check mr-1"></i> Validate
        </button>
      </div>
    </div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Sales Management</h1>
      <p class="text-gray-500 text-sm mt-0.5">Review, validate, and track all agent sales</p>
    </div>
    <a href="/admin/sales/agents" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
      <i class="fas fa-user-tie text-xs"></i> Manage Agents
    </a>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Total Sales</p>
      <p id="stat-total" class="text-2xl font-bold text-gray-800">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Pending</p>
      <p id="stat-pending" class="text-2xl font-bold text-yellow-600">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Validated</p>
      <p id="stat-validated" class="text-2xl font-bold text-green-600">—</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4">
      <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Commission Paid</p>
      <p id="stat-commission" class="text-2xl font-bold text-[#194642]">—</p>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex border-b border-gray-200 mb-4 gap-2">
    <button class="tab-btn active-tab px-4 py-2 text-sm font-medium border-b-2 transition-colors" data-tab="all">All Sales</button>
    <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors" data-tab="pending">⏳ Pending</button>
    <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors" data-tab="validated">✅ Validated</button>
    <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors" data-tab="report">📊 Commission Report</button>
  </div>

  <!-- Filters (All/Pending/Validated tabs) -->
  <div id="filters-bar" class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 mb-4 flex flex-col md:flex-row gap-3">
    <select id="filter-agent" class="w-full md:w-48 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642]">
      <option value="">All Agents</option>
    </select>
    <select id="filter-year" class="w-full md:w-32 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642]">
    </select>
    <input type="text" id="filter-search" placeholder="Search client or product…"
      class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642]" />
  </div>

  <!-- Sales Table -->
  <div id="tab-all" class="tab-content">
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Agent</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Payment</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody id="sales-table-body" class="divide-y divide-gray-50">
            <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div id="load-more-container" class="mt-4 text-center hidden">
      <button id="btn-load-more" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50">Load More</button>
    </div>
  </div>

  <!-- Commission Report Tab -->
  <div id="tab-report" class="tab-content hidden">
    <div class="flex items-center gap-3 mb-4">
      <label class="text-sm font-medium text-gray-700">Year:</label>
      <select id="report-year" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#194642]"></select>
    </div>
    <div class="bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Agent</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Total Sales</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Validated</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Pending</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Validated Amount</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Rate</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Commission</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody id="report-table-body" class="divide-y divide-gray-50">
            <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">Select year to view report</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .active-tab { color: #194642; border-color: #194642; }
  .tab-btn:not(.active-tab) { color: #6b7280; border-color: transparent; }
</style>

<script>
  const fmt = (n: number) => new Intl.NumberFormat('fr-FR').format(n);
  const fmtDate = (d: string) => new Date(d).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' });

  const PAYMENT_LABELS: Record<string, string> = {
    wire_transfer: 'Wire Transfer', orange_money: 'Orange Money',
    mtn_money: 'MTN Money', moov_money: 'Moov Money', wave: 'WAVE', cash: 'Cash',
  };

  const STATUS_BADGE: Record<string, string> = {
    pending: '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700"><i class="fas fa-clock text-xs"></i> Pending</span>',
    validated: '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700"><i class="fas fa-check text-xs"></i> Validated</span>',
    rejected: '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700"><i class="fas fa-times text-xs"></i> Rejected</span>',
  };

  let currentTab = 'all';
  let currentSaleId: string | null = null;
  let currentOffset = 0;
  let agents: any[] = [];
  let allSales: any[] = [];

  // ── Year selectors ────────────────────────────────────────────────────
  const currentYear = new Date().getFullYear();
  function populateYearSelects() {
    const selects = ['filter-year', 'report-year'];
    selects.forEach(id => {
      const sel = document.getElementById(id) as HTMLSelectElement | null;
      if (!sel) return;
      sel.innerHTML = '';
      for (let y = currentYear; y >= currentYear - 4; y--) {
        const opt = document.createElement('option');
        opt.value = String(y);
        opt.textContent = String(y);
        sel.appendChild(opt);
      }
    });
  }
  populateYearSelects();

  // ── Load agents for filter dropdown ──────────────────────────────────
  async function loadAgents() {
    const res = await fetch('/api/admin/sales-agents');
    const data = await res.json();
    agents = data.agents || [];
    const sel = document.getElementById('filter-agent') as HTMLSelectElement;
    agents.forEach(a => {
      const opt = document.createElement('option');
      opt.value = a.id;
      opt.textContent = a.full_name;
      sel.appendChild(opt);
    });
  }
  loadAgents();

  // ── Load sales ────────────────────────────────────────────────────────
  async function loadSales(append = false) {
    if (!append) currentOffset = 0;
    const status = currentTab === 'pending' ? 'pending' : currentTab === 'validated' ? 'validated' : '';
    const year = (document.getElementById('filter-year') as HTMLSelectElement)?.value || currentYear;
    const agentId = (document.getElementById('filter-agent') as HTMLSelectElement)?.value || '';
    const search = (document.getElementById('filter-search') as HTMLInputElement)?.value?.toLowerCase() || '';

    const params = new URLSearchParams({ year: String(year), limit: '50', offset: String(currentOffset) });
    if (status) params.set('status', status);
    if (agentId) params.set('agent_id', agentId);

    const res = await fetch(`/api/admin/sales?${params}`);
    const data = await res.json();
    const sales: any[] = data.sales || [];

    // Update stats
    if (!append) {
      document.getElementById('stat-total')!.textContent = String((data.counts?.pending ?? 0) + (data.counts?.validated ?? 0) + (data.counts?.rejected ?? 0));
      document.getElementById('stat-pending')!.textContent = String(data.counts?.pending ?? 0);
      document.getElementById('stat-validated')!.textContent = String(data.counts?.validated ?? 0);
      // Commission from validated sales in this response
      const comm = sales.filter((s:any) => s.status === 'validated').reduce((sum: number, s: any) => sum + Number(s.commission_amount), 0);
      document.getElementById('stat-commission')!.textContent = fmt(comm) + ' FCFA';
    }

    if (!append) allSales = sales;
    else allSales = [...allSales, ...sales];

    const filtered = allSales.filter(s => {
      if (!search) return true;
      return s.client_name?.toLowerCase().includes(search) || s.product_name?.toLowerCase().includes(search);
    });

    renderSalesTable(filtered);
    const loadMoreBtn = document.getElementById('load-more-container');
    if (loadMoreBtn) loadMoreBtn.classList.toggle('hidden', sales.length < 50);
    currentOffset += sales.length;
  }

  function renderSalesTable(sales: any[]) {
    const tbody = document.getElementById('sales-table-body')!;
    if (!sales.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">No sales found.</td></tr>';
      return;
    }
    tbody.innerHTML = sales.map(s => {
      const agent = s.sales_agent_profiles;
      const isPending = s.status === 'pending';
      return `<tr class="hover:bg-gray-50 transition-colors">
        <td class="px-4 py-3 text-gray-600 whitespace-nowrap">${fmtDate(s.created_at)}</td>
        <td class="px-4 py-3">
          <div class="font-medium text-gray-800">${agent?.full_name || s.agent_name}</div>
          <div class="text-xs text-gray-400">${agent?.worker_id || s.worker_id || ''}</div>
        </td>
        <td class="px-4 py-3 font-medium text-gray-800">${s.client_name}</td>
        <td class="px-4 py-3 text-gray-600">
          <div>${s.product_name}</div>
          <div class="text-xs text-gray-400">Qty: ${s.quantity}</div>
        </td>
        <td class="px-4 py-3 text-right font-semibold text-gray-800 whitespace-nowrap">${fmt(Number(s.total_amount))} <span class="text-xs font-normal text-gray-400">FCFA</span></td>
        <td class="px-4 py-3 text-gray-600 whitespace-nowrap">${PAYMENT_LABELS[s.payment_method] || s.payment_method}</td>
        <td class="px-4 py-3 text-center">${STATUS_BADGE[s.status] || s.status}</td>
        <td class="px-4 py-3 text-center">
          <button class="btn-view-sale px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors ${isPending ? 'bg-[#194642] text-white border-[#194642] hover:opacity-80' : 'bg-white text-gray-700 border-gray-200 hover:bg-gray-50'}"
            data-id="${s.id}">
            ${isPending ? '<i class="fas fa-check mr-1"></i> Validate' : '<i class="fas fa-eye mr-1"></i> View'}
          </button>
        </td>
      </tr>`;
    }).join('');

    document.querySelectorAll('.btn-view-sale').forEach(btn => {
      btn.addEventListener('click', () => openSaleModal(btn.getAttribute('data-id')!));
    });
  }

  // ── Sale validation modal ─────────────────────────────────────────────
  async function openSaleModal(id: string) {
    currentSaleId = id;
    const sale = allSales.find(s => s.id === id);
    if (!sale) return;

    const isPending = sale.status === 'pending';
    document.getElementById('modal-title')!.textContent = isPending ? 'Validate Sale' : 'Sale Details';
    document.getElementById('btn-validate')!.style.display = isPending ? 'inline-flex' : 'none';
    document.getElementById('btn-reject')!.style.display = isPending ? 'inline-flex' : 'none';
    document.getElementById('rejection-section')!.classList.add('hidden');
    (document.getElementById('rejection-reason') as HTMLTextAreaElement).value = '';

    const content = document.getElementById('modal-content')!;
    content.innerHTML = `
      <div class="grid grid-cols-2 gap-3">
        <div><span class="text-gray-400">Agent:</span> <strong>${sale.agent_name}</strong> (${sale.worker_id || 'N/A'})</div>
        <div><span class="text-gray-400">Date:</span> ${fmtDate(sale.created_at)}</div>
        <div><span class="text-gray-400">Client:</span> <strong>${sale.client_name}</strong></div>
        <div><span class="text-gray-400">Product:</span> ${sale.product_name}</div>
        <div><span class="text-gray-400">Qty:</span> ${sale.quantity} × ${fmt(Number(sale.unit_price))} FCFA</div>
        <div><span class="text-gray-400">Total:</span> <strong class="text-lg text-[#194642]">${fmt(Number(sale.total_amount))} FCFA</strong></div>
        <div><span class="text-gray-400">Payment:</span> ${PAYMENT_LABELS[sale.payment_method] || sale.payment_method}</div>
        <div><span class="text-gray-400">Reference:</span> ${sale.transaction_reference || '—'}</div>
        <div><span class="text-gray-400">Commission:</span> ${sale.commission_rate}% = <strong>${fmt(Number(sale.commission_amount))} FCFA</strong></div>
        <div><span class="text-gray-400">Status:</span> ${STATUS_BADGE[sale.status] || sale.status}</div>
        ${sale.notes ? `<div class="col-span-2"><span class="text-gray-400">Notes:</span> ${sale.notes}</div>` : ''}
        ${sale.rejection_reason ? `<div class="col-span-2 p-2 bg-red-50 rounded-lg"><span class="text-red-600 font-medium">Rejection reason:</span> ${sale.rejection_reason}</div>` : ''}
      </div>`;

    // Proof preview
    const proofContainer = document.getElementById('proof-container')!;
    const proofPreview = document.getElementById('proof-preview')!;
    if (sale.proof_url) {
      proofContainer.classList.remove('hidden');
      const isImage = /\.(jpg|jpeg|png|webp)$/i.test(sale.proof_url) || sale.proof_url.includes('image');
      const isPdf = /\.pdf$/i.test(sale.proof_url) || sale.proof_url.includes('pdf');
      if (isImage) {
        proofPreview.innerHTML = `<img src="${sale.proof_url}" alt="Proof" class="max-h-64 mx-auto rounded object-contain" />`;
      } else if (isPdf) {
        proofPreview.innerHTML = `<iframe src="${sale.proof_url}" class="w-full h-64 rounded" title="Proof PDF"></iframe>`;
      } else {
        proofPreview.innerHTML = `<a href="${sale.proof_url}" target="_blank" class="text-blue-600 underline text-sm flex items-center gap-1"><i class="fas fa-file"></i> View proof document</a>`;
      }
    } else {
      proofContainer.classList.add('hidden');
    }

    document.getElementById('validate-modal')!.classList.remove('hidden');
  }

  document.getElementById('close-modal')?.addEventListener('click', () => {
    document.getElementById('validate-modal')!.classList.add('hidden');
  });

  document.getElementById('validate-modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('validate-modal')) {
      document.getElementById('validate-modal')!.classList.add('hidden');
    }
  });

  document.getElementById('btn-validate')?.addEventListener('click', () => doValidate('validate'));
  document.getElementById('btn-reject')?.addEventListener('click', () => {
    const rejectionSection = document.getElementById('rejection-section')!;
    if (rejectionSection.classList.contains('hidden')) {
      rejectionSection.classList.remove('hidden');
      return;
    }
    doValidate('reject');
  });

  async function doValidate(action: 'validate' | 'reject') {
    if (!currentSaleId) return;
    const reason = (document.getElementById('rejection-reason') as HTMLTextAreaElement).value.trim();
    if (action === 'reject' && !reason) {
      showToast('Please provide a rejection reason.', 'error');
      return;
    }

    const btn = document.getElementById(action === 'validate' ? 'btn-validate' : 'btn-reject') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Processing…';

    const res = await fetch('/api/admin/sales', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: currentSaleId, action, rejection_reason: reason }),
    });
    const data = await res.json();

    btn.disabled = false;
    btn.innerHTML = action === 'validate' ? '<i class="fas fa-check mr-1"></i> Validate' : '<i class="fas fa-times mr-1"></i> Reject';

    if (data.error) {
      showToast(data.error, 'error');
      return;
    }
    showToast(action === 'validate' ? 'Sale validated successfully.' : 'Sale rejected.', 'success');
    document.getElementById('validate-modal')!.classList.add('hidden');
    loadSales();
  }

  // ── Commission Report ─────────────────────────────────────────────────
  async function loadReport() {
    const year = (document.getElementById('report-year') as HTMLSelectElement)?.value || currentYear;
    const res = await fetch(`/api/admin/sales?stats=true&year=${year}`);
    const data = await res.json();
    const report: any[] = data.report || [];

    const tbody = document.getElementById('report-table-body')!;
    if (!report.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">No data for this year.</td></tr>';
      return;
    }
    tbody.innerHTML = report.map(r => `
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3">
          <div class="font-medium text-gray-800">${r.full_name}</div>
          <div class="text-xs text-gray-400">${r.worker_id || r.email}</div>
        </td>
        <td class="px-4 py-3 text-center text-gray-700">${r.total_count}</td>
        <td class="px-4 py-3 text-center text-green-700 font-medium">${r.validated_count}</td>
        <td class="px-4 py-3 text-center text-yellow-600">${r.pending_count}</td>
        <td class="px-4 py-3 text-right text-gray-800">${fmt(r.validated_amount)} FCFA</td>
        <td class="px-4 py-3 text-center">
          <span class="px-2 py-0.5 rounded-full text-xs font-medium ${Number(r.commission_rate) >= 8 ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700'}">
            ${r.commission_rate ?? '—'}%
          </span>
        </td>
        <td class="px-4 py-3 text-right font-bold text-[#194642]">${fmt(r.commission_earned)} FCFA</td>
        <td class="px-4 py-3 text-center">
          <span class="px-2 py-0.5 rounded-full text-xs font-medium ${r.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">
            ${r.is_active ? 'Active' : 'Inactive'}
          </span>
        </td>
      </tr>`).join('');
  }

  // ── Tab switching ─────────────────────────────────────────────────────
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active-tab'));
      btn.classList.add('active-tab');
      currentTab = btn.getAttribute('data-tab') || 'all';

      const filtersBar = document.getElementById('filters-bar');
      if (currentTab === 'report') {
        filtersBar?.classList.add('hidden');
        document.getElementById('tab-all')!.classList.add('hidden');
        document.getElementById('tab-report')!.classList.remove('hidden');
        loadReport();
      } else {
        filtersBar?.classList.remove('hidden');
        document.getElementById('tab-all')!.classList.remove('hidden');
        document.getElementById('tab-report')!.classList.add('hidden');
        loadSales();
      }
    });
  });

  // ── Event listeners ───────────────────────────────────────────────────
  document.getElementById('btn-load-more')?.addEventListener('click', () => loadSales(true));
  document.getElementById('filter-agent')?.addEventListener('change', () => loadSales());
  document.getElementById('filter-year')?.addEventListener('change', () => loadSales());
  document.getElementById('report-year')?.addEventListener('change', () => loadReport());
  let searchTimer: any;
  document.getElementById('filter-search')?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => loadSales(), 350);
  });

  // ── Toast ─────────────────────────────────────────────────────────────
  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const c = document.getElementById('toast-container')!;
    const t = document.createElement('div');
    const color = type === 'success' ? 'bg-green-600' : 'bg-red-600';
    t.className = `pointer-events-auto ${color} text-white px-4 py-3 rounded-lg shadow-lg text-sm flex items-center gap-2 max-w-sm`;
    t.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>${msg}`;
    c.appendChild(t);
    setTimeout(() => t.remove(), 4000);
  }

  // ── Initial load ──────────────────────────────────────────────────────
  loadSales();
</script>
