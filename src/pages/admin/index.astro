---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
        <p class="text-gray-600">Overview of your agricultural operations</p>
    </div>

    <!-- Key Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Sales -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">Total Revenue</h3>
                <div class="bg-green-100 text-green-600 p-2 rounded-lg">
                    <i class="fas fa-dollar-sign"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span
                    class="text-2xl font-bold text-gray-900"
                    id="total-revenue">Loading...</span
                >
                <span
                    class="text-green-500 text-sm font-medium flex items-center"
                >
                    <i class="fas fa-arrow-up mr-1"></i> 12%
                </span>
            </div>
            <p class="text-xs text-gray-400 mt-1">vs last month</p>
        </div>

        <!-- Active Projects -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">
                    Active Projects
                </h3>
                <div class="bg-blue-100 text-blue-600 p-2 rounded-lg">
                    <i class="fas fa-project-diagram"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span
                    class="text-2xl font-bold text-gray-900"
                    id="active-projects">Loading...</span
                >
                <span class="text-blue-500 text-sm font-medium">
                    On track
                </span>
            </div>
            <p class="text-xs text-gray-400 mt-1">Greenhouses & Irrigation</p>
        </div>

        <!-- Pending Orders -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">
                    Pending Orders
                </h3>
                <div class="bg-orange-100 text-orange-600 p-2 rounded-lg">
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span
                    class="text-2xl font-bold text-gray-900"
                    id="pending-orders">Loading...</span
                >
                <span class="text-orange-500 text-sm font-medium">
                    Needs attention
                </span>
            </div>
            <p class="text-xs text-gray-400 mt-1">Orders + agent sales awaiting action</p>
        </div>

        <!-- Low Stock Items -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">
                    Low Stock Alerts
                </h3>
                <div class="bg-red-100 text-red-600 p-2 rounded-lg">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-gray-900" id="low-stock"
                    >Loading...</span
                >
                <span class="text-red-500 text-sm font-medium">
                    Restock needed
                </span>
            </div>
            <p class="text-xs text-gray-400 mt-1">Items below threshold</p>
        </div>

        <!-- Total Customers -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">
                    Total Customers
                </h3>
                <div class="bg-teal-100 text-teal-600 p-2 rounded-lg">
                    <i class="fas fa-user-friends"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span
                    class="text-2xl font-bold text-gray-900"
                    id="total-customers">Loading...</span
                >
            </div>
            <p class="text-xs text-gray-400 mt-1">Registered clients</p>
        </div>

        <!-- Active Suppliers -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-gray-500 text-sm font-medium">
                    Active Suppliers
                </h3>
                <div class="bg-indigo-100 text-indigo-600 p-2 rounded-lg">
                    <i class="fas fa-truck"></i>
                </div>
            </div>
            <div class="flex items-baseline gap-2">
                <span
                    class="text-2xl font-bold text-gray-900"
                    id="active-suppliers">Loading...</span
                >
            </div>
            <p class="text-xs text-gray-400 mt-1">Procurement partners</p>
        </div>
    </div>

    <!-- Recent Activity & Charts -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Recent Orders -->
        <div
            class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 lg:col-span-2"
        >
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-gray-800">Recent Activity</h3>
                <a
                    href="/admin/sales/"
                    class="text-primary text-sm font-medium hover:underline"
                    >View All</a
                >
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-gray-500">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                        <tr>
                            <th class="px-4 py-3">Source</th>
                            <th class="px-4 py-3">Ref / Customer</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Amount</th>
                            <th class="px-4 py-3">Date</th>
                        </tr>
                    </thead>
                    <tbody id="recent-orders-table">
                        <tr>
                            <td colspan="5" class="px-4 py-4 text-center"
                                >Loading activity...</td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <h3 class="text-lg font-bold text-gray-800 mb-6">Quick Actions</h3>
            <div class="space-y-3">
                <a
                    href="/admin/orders/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-blue-100 text-blue-600 p-2 rounded-lg">
                        <i class="fas fa-plus"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">
                            Create New Order
                        </p>
                        <p class="text-xs text-gray-500">Process a new sale</p>
                    </div>
                </a>

                <a
                    href="/admin/customers/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-green-100 text-green-600 p-2 rounded-lg">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">Add Customer</p>
                        <p class="text-xs text-gray-500">Register new client</p>
                    </div>
                </a>

                <a
                    href="/admin/projects/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-purple-100 text-purple-600 p-2 rounded-lg">
                        <i class="fas fa-hard-hat"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">Start Project</p>
                        <p class="text-xs text-gray-500">New installation</p>
                    </div>
                </a>

                <a
                    href="/admin/suppliers/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-orange-100 text-orange-600 p-2 rounded-lg">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">Add Supplier</p>
                        <p class="text-xs text-gray-500">Manage procurement</p>
                    </div>
                </a>

                <a
                    href="/admin/inventory/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-red-100 text-red-600 p-2 rounded-lg">
                        <i class="fas fa-box"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">Manage Inventory</p>
                        <p class="text-xs text-gray-500">Products & stock</p>
                    </div>
                </a>

                <a
                    href="/admin/careers/"
                    class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors"
                >
                    <div class="bg-teal-100 text-teal-600 p-2 rounded-lg">
                        <i class="fas fa-users"></i>
                    </div>
                    <div>
                        <p class="font-medium text-gray-900">HR & Careers</p>
                        <p class="text-xs text-gray-500">Employees & jobs</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    import { supabase } from "../../lib/supabase";

    // The business runs through two parallel order-taking channels: the
    // legacy manual admin_orders table and sales_records (the sales-agent
    // portal, the actual live channel — see project memory: dual-portal
    // sales system). Every metric below combines both so the dashboard
    // reflects real activity instead of only the (usually empty) legacy table.
    function escHtml(input: unknown): string {
        return String(input ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    const fmtCurrency = (n: number) =>
        new Intl.NumberFormat("fr-FR", {
            style: "currency",
            currency: "XOF",
            maximumFractionDigits: 0,
        }).format(n);

    async function loadDashboardData() {
        try {
            // 1. Recent Activity — merge admin_orders + sales_records, newest first.
            const [{ data: orders, error: ordersError }, { data: sales, error: salesError }] =
                await Promise.all([
                    supabase
                        .from("admin_orders")
                        .select(
                            `id, order_number, status, total_amount, created_at, admin_customers (full_name)`,
                        )
                        .order("created_at", { ascending: false })
                        .limit(5),
                    supabase
                        .from("sales_records")
                        .select("id, client_name, agent_name, status, total_amount, created_at")
                        .order("created_at", { ascending: false })
                        .limit(5),
                ]);

            type ActivityRow = {
                source: "Order" | "Sale";
                ref: string;
                status: string;
                amount: number;
                date: string;
            };

            const activity: ActivityRow[] = [];

            if (!ordersError && orders) {
                for (const order of orders) {
                    activity.push({
                        source: "Order",
                        ref: `#${order.order_number} — ${(order.admin_customers as any)?.full_name || "Unknown"}`,
                        status: order.status,
                        amount: order.total_amount || 0,
                        date: order.created_at,
                    });
                }
            }

            if (!salesError && sales) {
                for (const sale of sales) {
                    activity.push({
                        source: "Sale",
                        ref: `${sale.client_name} — ${sale.agent_name}`,
                        status: sale.status,
                        amount: sale.total_amount || 0,
                        date: sale.created_at,
                    });
                }
            }

            activity.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

            const tbody = document.getElementById("recent-orders-table");
            if (tbody) {
                const top = activity.slice(0, 5);
                if (top.length === 0) {
                    tbody.innerHTML =
                        '<tr><td colspan="5" class="px-4 py-4 text-center">No activity found</td></tr>';
                } else {
                    const statusClass = (status: string) =>
                        ["delivered", "validated"].includes(status)
                            ? "bg-green-100 text-green-800"
                            : ["processing", "confirmed"].includes(status)
                              ? "bg-blue-100 text-blue-800"
                              : ["cancelled", "rejected"].includes(status)
                                ? "bg-red-100 text-red-800"
                                : "bg-gray-100 text-gray-800";

                    tbody.innerHTML = top
                        .map(
                            (row) => `
              <tr class="bg-white border-b hover:bg-gray-50">
                <td class="px-4 py-3">
                  <span class="px-2 py-1 text-xs font-semibold rounded-full ${row.source === "Sale" ? "bg-purple-100 text-purple-800" : "bg-slate-100 text-slate-800"}">
                    ${row.source}
                  </span>
                </td>
                <td class="px-4 py-3 font-medium text-gray-900">${escHtml(row.ref)}</td>
                <td class="px-4 py-3">
                  <span class="px-2 py-1 text-xs font-semibold rounded-full ${statusClass(row.status)}">
                    ${escHtml(row.status.toUpperCase())}
                  </span>
                </td>
                <td class="px-4 py-3">${fmtCurrency(row.amount)}</td>
                <td class="px-4 py-3">${new Date(row.date).toLocaleDateString()}</td>
              </tr>
            `,
                        )
                        .join("");
                }
            }

            // 2. Metrics — each one combines every sector that feeds it live.
            const [
                { count: pendingOrdersCount },
                { count: pendingSalesCount },
                { count: projectCount },
                { count: lowStockCount },
                { count: customerCount },
                { count: supplierCount },
                { data: deliveredOrders },
                { data: validatedSales },
            ] = await Promise.all([
                supabase
                    .from("admin_orders")
                    .select("*", { count: "exact", head: true })
                    .in("status", ["draft", "confirmed", "processing"]),
                supabase
                    .from("sales_records")
                    .select("*", { count: "exact", head: true })
                    .eq("status", "pending"),
                supabase
                    .from("admin_projects")
                    .select("*", { count: "exact", head: true })
                    .in("status", ["planning", "in_progress"]),
                supabase
                    .from("admin_products")
                    .select("*", { count: "exact", head: true })
                    .lt("stock_quantity", 10), // Simplified check
                supabase.from("admin_customers").select("*", { count: "exact", head: true }),
                supabase
                    .from("suppliers")
                    .select("*", { count: "exact", head: true })
                    .eq("status", "active"),
                supabase.from("admin_orders").select("total_amount").eq("status", "delivered"),
                supabase.from("sales_records").select("total_amount").eq("status", "validated"),
            ]);

            document.getElementById("pending-orders")!.textContent = String(
                (pendingOrdersCount || 0) + (pendingSalesCount || 0),
            );
            document.getElementById("active-projects")!.textContent =
                projectCount?.toString() || "0";
            document.getElementById("low-stock")!.textContent =
                lowStockCount?.toString() || "0";
            document.getElementById("total-customers")!.textContent =
                customerCount?.toString() || "0";
            document.getElementById("active-suppliers")!.textContent =
                supplierCount?.toString() || "0";

            // Total Revenue — delivered admin orders + validated agent sales.
            const ordersRevenue = (deliveredOrders || []).reduce(
                (sum, o: any) => sum + Number(o.total_amount || 0),
                0,
            );
            const salesRevenue = (validatedSales || []).reduce(
                (sum, s: any) => sum + Number(s.total_amount || 0),
                0,
            );
            document.getElementById("total-revenue")!.textContent = fmtCurrency(
                ordersRevenue + salesRevenue,
            );
        } catch (error) {
            console.error("Error loading dashboard:", error);
        }
    }

    loadDashboardData();
</script>
