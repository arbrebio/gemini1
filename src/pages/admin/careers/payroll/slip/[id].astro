---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Bulletin de paie — Arbre Bio</title>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; color: #1a1a1a; background: #d8d8d8; }
      #action-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 200;
        background: #194642; padding: 10px 20px;
        display: flex; align-items: center; justify-content: space-between;
        box-shadow: 0 2px 10px rgba(0,0,0,.3);
      }
      #action-bar h1 { color: #fff; font-size: 13.5px; font-weight: 700; }
      .action-btns { display: flex; gap: 8px; flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 13px; border-radius: 6px; font-size: 12px; font-weight: 600;
        cursor: pointer; border: none; text-decoration: none;
      }
      .btn-white { background: #fff; color: #194642; }
      .btn-ghost { background: rgba(255,255,255,.15); color: #fff; }
      #page-wrap { padding: 72px 20px 48px; max-width: 840px; margin: 0 auto; }
      #loading { text-align: center; padding: 80px 20px; color: #555; font-size: 15px; }
      #error-msg { display: none; text-align: center; padding: 60px 20px; color: #c00; font-size: 15px; }
      #conges-editor {
        display: none; background: #fff; border: 1px solid #c8d5c0; border-radius: 8px;
        padding: 16px 20px; margin: 0 auto 16px; max-width: 800px; font-size: 12.5px;
      }
      #conges-editor h2 { font-size: 13px; color: #194642; margin-bottom: 10px; }
      #conges-editor .row { display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 10px; }
      #conges-editor label { display: block; font-size: 10.5px; color: #5b6f66; text-transform: uppercase; margin-bottom: 3px; }
      #conges-editor input { border: 1px solid #c8d5c0; border-radius: 5px; padding: 5px 8px; font-size: 12.5px; }
      #conges-editor .date-pair { display: flex; gap: 6px; align-items: center; }
      #conges-status { font-size: 11.5px; color: #5b6f66; margin-left: 8px; }
      @media print { #conges-editor { display: none !important; } }
    </style>
  </head>
  <body>
    <div id="action-bar">
      <h1>📄 Bulletin de paie — Arbre Bio Africa</h1>
      <div class="action-btns">
        <button class="btn btn-white" onclick="window.print()">
          <i class="fas fa-download"></i> Télécharger / Imprimer
        </button>
        <button class="btn btn-ghost" onclick="history.back()">
          <i class="fas fa-arrow-left"></i> Retour
        </button>
      </div>
    </div>

    <div id="page-wrap">
      <div id="loading">⏳ Chargement du bulletin…</div>
      <div id="error-msg">❌ <span id="error-text">Erreur de chargement</span></div>

      <div id="conges-editor">
        <h2><i class="fas fa-umbrella-beach"></i> Congés pris pendant cette période (brouillon uniquement)</h2>
        <div class="row">
          <div>
            <label for="cg-jours">Jours de congé pris (ce mois)</label>
            <input id="cg-jours" type="number" min="0" step="0.5" value="0" style="width:100px" />
          </div>
          <div class="date-pair"><label>Congé 1</label> Du <input id="cg-du-0" type="date" /> Au <input id="cg-au-0" type="date" /></div>
          <div class="date-pair"><label>Congé 2</label> Du <input id="cg-du-1" type="date" /> Au <input id="cg-au-1" type="date" /></div>
          <div class="date-pair"><label>Congé 3</label> Du <input id="cg-du-2" type="date" /> Au <input id="cg-au-2" type="date" /></div>
        </div>
        <div class="row">
          <div>
            <label for="cg-acquis-manuel">Jours acquis — correction manuelle</label>
            <input id="cg-acquis-manuel" type="number" step="0.1" value="0" style="width:120px" />
          </div>
          <div>
            <label for="cg-fiscaux-seed">Jours fiscaux — initialiser/corriger (depuis un vrai bulletin SAGE)</label>
            <input id="cg-fiscaux-seed" type="number" step="1" placeholder="laisser vide = auto +30/mois" style="width:260px" />
          </div>
          <button id="btn-save-conges" class="btn btn-white" style="background:#194642;color:#fff">
            <i class="fas fa-save"></i> Enregistrer
          </button>
          <span id="conges-status"></span>
        </div>
      </div>

      <div id="bulletin-content" style="display:none;"></div>
    </div>

    <script>
      import { supabase } from '../../../../../lib/supabase';
      import { BULLETIN_CSS, renderBulletin } from '../../../../../lib/payroll/renderBulletin';

      const styleTag = document.createElement('style');
      styleTag.textContent = BULLETIN_CSS;
      document.head.appendChild(styleTag);

      const loading = document.getElementById('loading')!;
      const errorMsg = document.getElementById('error-msg')!;
      const errorText = document.getElementById('error-text')!;
      const content = document.getElementById('bulletin-content')!;
      const congesEditor = document.getElementById('conges-editor')!;
      const congesStatus = document.getElementById('conges-status')!;
      const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

      function showError(message: string) {
        loading.style.display = 'none';
        errorText.textContent = message;
        errorMsg.style.display = 'block';
      }

      let slipId = '';

      async function load() {
        slipId = window.location.pathname.split('/').filter(Boolean).pop() || '';
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          window.location.href = '/admin/login/';
          return;
        }
        try {
          const res = await fetch(`/api/admin/careers/payroll-slips?id=${encodeURIComponent(slipId)}`, {
            headers: { Authorization: `Bearer ${session.access_token}` },
          });
          const data = await res.json();
          if (!res.ok || !data.slip) throw new Error(data.error || 'Bulletin introuvable');
          content.innerHTML = renderBulletin(data.slip);
          loading.style.display = 'none';
          content.style.display = 'block';
          const emp = data.slip.profile_snapshot?.employee?.full_name || '';
          document.title = `Bulletin de paie ${data.slip.profile_snapshot?.matricule || ''} — ${emp}`;

          if (data.slip.status === 'draft') {
            const conges = data.slip.conges || {};
            $('cg-jours').value = conges._conge_pris_periode ?? 0;
            $('cg-acquis-manuel').value = conges.jours_acquis ?? 0;
            $('cg-fiscaux-seed').value = conges._jours_fiscaux_seed ?? '';
            (conges.dates || []).slice(0, 3).forEach((d: any, i: number) => {
              $(`cg-du-${i}`).value = d.du || '';
              $(`cg-au-${i}`).value = d.au || '';
            });
            congesEditor.style.display = 'block';
          }
        } catch (e: any) {
          showError(e.message || 'Erreur de chargement');
        }
      }

      document.getElementById('btn-save-conges')!.addEventListener('click', async () => {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) return;
        const dates = [0, 1, 2]
          .map((i) => ({ du: $(`cg-du-${i}`).value, au: $(`cg-au-${i}`).value }))
          .filter((d) => d.du && d.au);
        congesStatus.textContent = 'Enregistrement…';
        try {
          const res = await fetch('/api/admin/careers/payroll-slips', {
            method: 'POST',
            headers: { Authorization: `Bearer ${session.access_token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'update_conges',
              slip_id: slipId,
              jours_pris: Number($('cg-jours').value || 0),
              jours_acquis_manuel: Number($('cg-acquis-manuel').value || 0),
              jours_fiscaux_seed: $('cg-fiscaux-seed').value === '' ? null : Number($('cg-fiscaux-seed').value),
              dates,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error);
          congesStatus.textContent = '✅ Enregistré';
          await load();
        } catch (e: any) {
          congesStatus.textContent = `❌ ${e.message || 'Erreur'}`;
        }
      });

      load();
    </script>
  </body>
</html>
