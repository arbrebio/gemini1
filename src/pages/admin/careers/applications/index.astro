---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Applications">
  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Applications</h1>
      <p class="text-gray-500 text-sm mt-1">Review and manage job applications</p>
    </div>
    <div class="flex gap-2">
      <select id="filter-status" class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#194642]">
        <option value="">All Statuses</option>
        <option value="submitted">Submitted</option>
        <option value="under_review">Under Review</option>
        <option value="interview_scheduled">Interview Scheduled</option>
        <option value="interview_done">Interview Done</option>
        <option value="offer_sent">Offer Sent</option>
        <option value="hired">Hired</option>
        <option value="rejected">Rejected</option>
        <option value="withdrawn">Withdrawn</option>
      </select>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
    <div id="apps-table">
      <div class="flex justify-center py-16">
        <div class="animate-spin w-8 h-8 border-4 border-[#194642] border-t-transparent rounded-full"></div>
      </div>
    </div>
  </div>

  <!-- Application Detail Modal -->
  <div id="app-modal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-start justify-center p-4 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl my-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 id="app-modal-title" class="font-bold text-lg text-gray-800">Application Detail</h2>
        <button id="app-modal-close" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>
      <div id="app-modal-content" class="p-6">Loading...</div>
    </div>
  </div>
</AdminLayout>

<script>
  const statusColors: Record<string, string> = {
    submitted: 'bg-blue-100 text-blue-700',
    under_review: 'bg-yellow-100 text-yellow-700',
    interview_scheduled: 'bg-purple-100 text-purple-700',
    interview_done: 'bg-indigo-100 text-indigo-700',
    offer_sent: 'bg-orange-100 text-orange-700',
    hired: 'bg-green-100 text-green-700',
    rejected: 'bg-red-100 text-red-700',
    withdrawn: 'bg-gray-100 text-gray-700',
  };

  const statusList = ['submitted','under_review','interview_scheduled','interview_done','offer_sent','hired','rejected','withdrawn'];

  let allApps: any[] = [];

  async function loadApps(status = '') {
    const url = status ? `/api/admin/careers/applications?status=${status}` : '/api/admin/careers/applications';
    const res = await fetch(url);
    const data = await res.json();
    allApps = data.applications || [];
    renderApps();
  }

  function renderApps() {
    const container = document.getElementById('apps-table')!;
    if (!allApps.length) {
      container.innerHTML = '<div class="px-6 py-16 text-center text-gray-400 text-sm">No applications found.</div>';
      return;
    }
    container.innerHTML = `
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-6 py-3 text-left">Applicant</th>
            <th class="px-6 py-3 text-left">Position</th>
            <th class="px-6 py-3 text-left">Status</th>
            <th class="px-6 py-3 text-left">Submitted</th>
            <th class="px-6 py-3 text-left">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          ${allApps.map(a => `
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <p class="font-medium text-gray-800">${a.first_name} ${a.last_name}</p>
                <p class="text-xs text-gray-500">${a.email}</p>
              </td>
              <td class="px-6 py-4 text-gray-600 text-xs">${a.career_jobs?.title_en || '—'}</td>
              <td class="px-6 py-4">
                <span class="px-2.5 py-1 rounded-full text-xs font-medium ${statusColors[a.status] || 'bg-gray-100'}">${a.status.replace(/_/g,' ')}</span>
              </td>
              <td class="px-6 py-4 text-gray-500 text-xs">${new Date(a.submitted_at).toLocaleDateString()}</td>
              <td class="px-6 py-4">
                <button onclick="viewApp('${a.id}')" class="text-[#194642] hover:underline text-xs font-medium mr-3">View</button>
                <button onclick="deleteApp('${a.id}','${(a.first_name+' '+a.last_name).replace(/'/g,"\\'")}') " class="text-red-500 hover:underline text-xs font-medium">Delete</button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  (window as any).viewApp = async (id: string) => {
    const modal = document.getElementById('app-modal')!;
    const content = document.getElementById('app-modal-content')!;
    modal.classList.remove('hidden');
    content.innerHTML = '<div class="flex justify-center py-12"><div class="animate-spin w-8 h-8 border-4 border-[#194642] border-t-transparent rounded-full"></div></div>';

    const res = await fetch(`/api/admin/careers/applications?id=${id}`);
    const data = await res.json();
    const a = data.application;
    if (!a) { content.innerHTML = '<p class="text-red-500">Failed to load.</p>'; return; }

    const job = a.career_jobs;
    const docs = a.career_documents || [];
    const timeline = (a.career_application_timeline || []).sort((x: any, y: any) => new Date(x.created_at).getTime() - new Date(y.created_at).getTime());

    document.getElementById('app-modal-title')!.textContent = `${a.first_name} ${a.last_name}`;
    content.innerHTML = `
      <div class="space-y-6">
        <!-- Info grid -->
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div><p class="text-gray-500">Position</p><p class="font-semibold">${job?.title_en || '—'}</p></div>
          <div><p class="text-gray-500">Email</p><p class="font-semibold">${a.email}</p></div>
          <div><p class="text-gray-500">Phone</p><p class="font-semibold">${a.phone || '—'}</p></div>
          <div><p class="text-gray-500">City</p><p class="font-semibold">${a.city || '—'}</p></div>
          <div><p class="text-gray-500">Submitted</p><p class="font-semibold">${new Date(a.submitted_at).toLocaleString()}</p></div>
          <div><p class="text-gray-500">Token</p><p class="font-mono text-xs text-[#194642]">${a.portal_token}</p></div>
        </div>

        ${a.cover_letter ? `<div><p class="text-sm font-semibold text-gray-700 mb-1">Cover Letter</p><p class="text-sm text-gray-600 bg-gray-50 rounded-lg p-3 whitespace-pre-wrap">${a.cover_letter}</p></div>` : ''}

        <!-- Docs -->
        ${docs.length ? `
          <div>
            <p class="text-sm font-semibold text-gray-700 mb-2">Documents</p>
            <div class="space-y-2">${docs.map((d: any) => {
              const isImage = d.mime_type && d.mime_type.startsWith('image/');
              const icon = d.doc_type === 'cv' ? 'fa-file-alt'
                : d.doc_type === 'id_card' ? 'fa-id-card'
                : d.doc_type === 'diploma' ? 'fa-graduation-cap'
                : isImage ? 'fa-file-image'
                : 'fa-file-pdf';
              const docLabel = d.doc_type === 'cv' ? 'CV / Resume'
                : d.doc_type === 'id_card' ? 'ID Card'
                : d.doc_type === 'diploma' ? 'Diploma'
                : d.doc_type === 'certificate' ? 'Certificate'
                : d.doc_type === 'cover_letter' ? 'Cover Letter'
                : 'Other Document';
              const url = d.signed_url || d.file_url || '';
              return `<div class="flex items-center justify-between bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 gap-3">
                <div class="flex items-center gap-2 min-w-0">
                  <i class="fas ${icon} text-[#194642] text-base flex-shrink-0"></i>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-gray-800 truncate">${d.file_name}</p>
                    <p class="text-xs text-gray-400 capitalize">${docLabel}</p>
                  </div>
                </div>
                ${url ? `<div class="flex gap-2 flex-shrink-0">
                  <a href="${url}" target="_blank" rel="noopener noreferrer"
                    class="bg-[#194642] text-white text-xs font-medium px-3 py-1.5 rounded-lg hover:bg-[#2a5e59] transition-colors flex items-center gap-1">
                    <i class="fas fa-eye text-xs"></i> View
                  </a>
                  <a href="${url}" download="${d.file_name}"
                    class="bg-gray-200 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-lg hover:bg-gray-300 transition-colors flex items-center gap-1">
                    <i class="fas fa-download text-xs"></i> Download
                  </a>
                </div>` : `<span class="text-xs text-red-400 flex-shrink-0">URL unavailable</span>`}
              </div>`;
            }).join('')}</div>
          </div>
        ` : ''}

        <!-- Status update form -->
        <div class="border-t border-gray-100 pt-4">
          <p class="text-sm font-semibold text-gray-700 mb-3">Update Status</p>
          <div class="space-y-3">
            <select id="new-status-${a.id}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
              ${statusList.map(s => `<option value="${s}" ${a.status === s ? 'selected' : ''}>${s.replace(/_/g,' ')}</option>`).join('')}
            </select>
            <input id="new-note-${a.id}" type="text" placeholder="Optional note to applicant" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            <div class="flex items-center gap-2">
              <input type="checkbox" id="notify-${a.id}" checked class="rounded" />
              <label for="notify-${a.id}" class="text-sm text-gray-600">Send email notification to applicant</label>
            </div>
            <button onclick="updateStatus('${a.id}')" class="bg-[#194642] text-white font-semibold px-5 py-2 rounded-lg hover:bg-[#2a5e59] transition-colors text-sm">Update Status</button>
          </div>
        </div>

        <!-- Timeline -->
        ${timeline.length ? `
          <div class="border-t border-gray-100 pt-4">
            <p class="text-sm font-semibold text-gray-700 mb-3">Timeline</p>
            <div class="space-y-2">
              ${timeline.map((t: any) => `
                <div class="flex items-start gap-3 text-sm">
                  <div class="w-2 h-2 rounded-full bg-[#194642] mt-1.5 flex-shrink-0"></div>
                  <div>
                    <span class="font-medium">${t.status.replace(/_/g,' ')}</span>
                    ${t.note ? `<span class="text-gray-500"> — ${t.note}</span>` : ''}
                    <p class="text-xs text-gray-400">${new Date(t.created_at).toLocaleString()}</p>
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        ` : ''}

        <!-- Convert to employee (if hired) -->
        <div class="border-t border-gray-100 pt-4">
          <p class="text-sm font-semibold text-gray-700 mb-3">Hire as Employee</p>
          <div class="grid grid-cols-2 gap-3">
            <input id="emp-title-${a.id}" type="text" placeholder="Job title" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            <input id="emp-dept-${a.id}" type="text" placeholder="Department" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            <input id="emp-start-${a.id}" type="date" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
          <button onclick="createEmployee('${a.id}')" class="mt-3 bg-green-600 text-white font-semibold px-5 py-2 rounded-lg hover:bg-green-700 transition-colors text-sm">
            <i class="fas fa-id-card mr-2"></i>Generate Worker ID & Employee Card
          </button>
        </div>
      </div>
    `;
  };

  (window as any).updateStatus = async (id: string) => {
    const status = (document.getElementById(`new-status-${id}`) as HTMLSelectElement).value;
    const note = (document.getElementById(`new-note-${id}`) as HTMLInputElement).value.trim();
    const notify = (document.getElementById(`notify-${id}`) as HTMLInputElement).checked;

    const res = await fetch('/api/admin/careers/applications', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, status, note: note || null, notify_applicant: notify }),
    });
    const data = await res.json();
    if (!res.ok) { alert(data.error || 'Update failed'); return; }
    alert('Status updated successfully!');
    document.getElementById('app-modal')!.classList.add('hidden');
    await loadApps((document.getElementById('filter-status') as HTMLSelectElement).value);
  };

  (window as any).createEmployee = async (appId: string) => {
    const jobTitle = (document.getElementById(`emp-title-${appId}`) as HTMLInputElement).value.trim();
    const department = (document.getElementById(`emp-dept-${appId}`) as HTMLInputElement).value.trim();
    const startDate = (document.getElementById(`emp-start-${appId}`) as HTMLInputElement).value;

    if (!jobTitle) { alert('Please enter a job title.'); return; }

    const res = await fetch('/api/admin/careers/employees', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ application_id: appId, job_title: jobTitle, department, start_date: startDate }),
    });
    const data = await res.json();
    if (!res.ok) { alert(data.error || 'Failed to create employee'); return; }
    alert(`Employee created! Worker ID: ${data.employee.worker_id}`);
    document.getElementById('app-modal')!.classList.add('hidden');
    window.location.href = '/admin/careers/employees';
  };

  (window as any).deleteApp = async (id: string, name: string) => {
    if (!confirm(`Delete application from ${name}?`)) return;
    await fetch('/api/admin/careers/applications', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    await loadApps((document.getElementById('filter-status') as HTMLSelectElement).value);
  };

  document.getElementById('app-modal-close')!.addEventListener('click', () => {
    document.getElementById('app-modal')!.classList.add('hidden');
  });
  document.getElementById('filter-status')!.addEventListener('change', (e) => {
    loadApps((e.target as HTMLSelectElement).value);
  });

  // Check URL for ?id= to auto-open
  const urlId = new URLSearchParams(window.location.search).get('id');

  loadApps().then(() => {
    if (urlId) (window as any).viewApp(urlId);
  });
</script>
