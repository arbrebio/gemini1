---
import AdminLayout from "../../../../layouts/AdminLayout.astro";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<AdminLayout title="Employees">
  <!-- Config passed to client script via data attributes (PUBLIC vars only) -->
  <div id="app-config" data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey} class="hidden"></div>

  <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Employees</h1>
      <p class="text-gray-500 text-sm mt-1">Manage employee records and digital ID cards</p>
    </div>
    <button id="btn-add-employee" class="bg-[#194642] text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-[#2a5e59] transition-colors flex items-center gap-2 text-sm">
      <i class="fas fa-plus"></i> Add Employee
    </button>
  </div>

  <!-- ── Add Employee Modal ──────────────────────────────────────── -->
  <div id="add-emp-modal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[92vh] overflow-y-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 sticky top-0 bg-white z-10">
        <h2 class="font-bold text-lg text-gray-800">Add New Employee</h2>
        <button id="add-emp-close" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>

      <form id="add-emp-form" class="p-6 space-y-5" autocomplete="off">

        <!-- Photo upload -->
        <div class="flex items-center gap-5">
          <div id="photo-preview" class="w-20 h-20 rounded-full bg-gray-100 border-2 border-dashed border-gray-300 flex items-center justify-center overflow-hidden flex-shrink-0">
            <i class="fas fa-user text-gray-300 text-2xl"></i>
          </div>
          <div class="flex-1">
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Employee Photo</label>
            <label class="flex items-center gap-2 cursor-pointer bg-[#194642]/5 hover:bg-[#194642]/10 text-[#194642] text-xs font-semibold px-4 py-2 rounded-lg transition-colors border border-[#194642]/20 w-fit">
              <i class="fas fa-upload text-xs"></i> Upload Photo
              <input type="file" id="ne-photo-file" accept="image/*" class="hidden" />
            </label>
            <p class="text-xs text-gray-400 mt-1">JPG, PNG — max 5 MB</p>
            <div id="photo-upload-status" class="hidden text-xs mt-1"></div>
          </div>
        </div>

        <!-- ID Card upload + auto-scan -->
        <div class="border-t border-dashed border-gray-200 pt-4">
          <div class="flex items-center justify-between mb-3">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">ID Card Scan <span class="text-[#194642] font-bold">(Auto-fill)</span></p>
            <span class="text-xs text-gray-400 italic">Upload front to auto-detect personal info</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Front -->
            <div>
              <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Front Side</p>
              <div id="id-front-preview" class="relative w-full h-32 rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 flex flex-col items-center justify-center overflow-hidden transition-all">
                <i class="fas fa-id-card text-gray-300 text-3xl mb-1"></i>
                <span class="text-xs text-gray-400">No image</span>
              </div>
              <label class="mt-2 flex items-center gap-2 cursor-pointer bg-[#194642]/5 hover:bg-[#194642]/10 text-[#194642] text-xs font-semibold px-3 py-2 rounded-lg transition-colors border border-[#194642]/20 w-fit">
                <i class="fas fa-camera text-xs"></i> Upload Front
                <input type="file" id="ne-id-front" accept="image/*" class="hidden" />
              </label>
              <div id="id-front-status" class="hidden text-xs mt-1.5 flex items-center gap-1.5"></div>
            </div>
            <!-- Back -->
            <div>
              <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Back Side</p>
              <div id="id-back-preview" class="relative w-full h-32 rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 flex flex-col items-center justify-center overflow-hidden transition-all">
                <i class="fas fa-id-card text-gray-300 text-3xl mb-1"></i>
                <span class="text-xs text-gray-400">No image</span>
              </div>
              <label class="mt-2 flex items-center gap-2 cursor-pointer bg-[#194642]/5 hover:bg-[#194642]/10 text-[#194642] text-xs font-semibold px-3 py-2 rounded-lg transition-colors border border-[#194642]/20 w-fit">
                <i class="fas fa-camera text-xs"></i> Upload Back
                <input type="file" id="ne-id-back" accept="image/*" class="hidden" />
              </label>
              <div id="id-back-status" class="hidden text-xs mt-1.5 flex items-center gap-1.5"></div>
            </div>
          </div>
          <!-- Scanned fields summary -->
          <div id="id-scan-summary" class="hidden mt-3 bg-[#f0f9f0] border border-[#194642]/20 rounded-xl p-3">
            <p class="text-xs font-bold text-[#194642] mb-2 flex items-center gap-1.5"><i class="fas fa-magic"></i> Fields auto-filled from ID card:</p>
            <div id="id-scan-fields" class="flex flex-wrap gap-1.5 text-xs"></div>
            <p class="text-xs text-gray-500 mt-2 italic">You can edit any field below. All data is editable.</p>
          </div>
          <!-- Hidden fields storing ID URLs -->
          <input type="hidden" id="ne-id-front-url" />
          <input type="hidden" id="ne-id-back-url" />
          <input type="hidden" id="ne-id-number" />
          <input type="hidden" id="ne-id-expiry" />
        </div>

        <!-- Personal info -->
        <div class="border-t border-dashed border-gray-200 pt-4">
          <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Personal Information</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">First Name *</label>
              <input id="ne-fname" type="text" required class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Middle Name</label>
              <input id="ne-mname" type="text" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Last Name *</label>
              <input id="ne-lname" type="text" required class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Date of Birth *</label>
              <input id="ne-birthdate" type="date" required class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Nationality</label>
              <input id="ne-nationality" type="text" placeholder="e.g. Ivoirian" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Gender</label>
              <select id="ne-gender" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
                <option value="">— Select —</option>
                <option value="M">Male</option>
                <option value="F">Female</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Email *</label>
              <input id="ne-email" type="email" required class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Phone</label>
              <input id="ne-phone" type="text" placeholder="+225 00 00 00 00 00" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-3">
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Address</label>
              <input id="ne-address" type="text" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">City</label>
              <input id="ne-city" type="text" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
          </div>
          <div class="mt-3">
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Country</label>
            <input id="ne-country" type="text" value="Côte d'Ivoire" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
        </div>

        <!-- Employment info -->
        <div class="border-t border-dashed border-gray-200 pt-4">
          <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Employment Details</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Job Title *</label>
              <input id="ne-title" type="text" required class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Department</label>
              <input id="ne-dept" type="text" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Start Date</label>
              <input id="ne-start" type="date" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Contract Type</label>
              <select id="ne-contract-type" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
                <option value="CDI">CDI (Permanent)</option>
                <option value="CDD">CDD (Fixed-term)</option>
                <option value="Stage">Stage (Internship)</option>
                <option value="Freelance">Freelance</option>
                <option value="Volontaire">Volontaire</option>
              </select>
            </div>
          </div>
        </div>

        <div id="ne-error" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-red-700 text-sm"></div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="ne-cancel" class="px-5 py-2.5 border border-gray-200 rounded-lg text-gray-700 hover:bg-gray-50 text-sm font-medium">Cancel</button>
          <button type="submit" id="ne-submit" class="bg-[#194642] text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-[#2a5e59] text-sm flex items-center gap-2">
            <i class="fas fa-id-card"></i>
            <span id="ne-submit-text">Create Employee</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Success Card Modal ──────────────────────────────────────── -->
  <div id="success-modal" class="fixed inset-0 z-50 hidden bg-black/60 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
      <div class="bg-gradient-to-br from-[#194642] to-[#2a5e59] p-6 text-white text-center">
        <div class="w-24 h-24 rounded-full bg-white/20 mx-auto mb-3 overflow-hidden flex items-center justify-center border-4 border-white/40">
          <img id="sc-photo" src="" alt="" class="w-full h-full object-cover hidden" />
          <i id="sc-photo-icon" class="fas fa-user text-white/60 text-3xl"></i>
        </div>
        <h2 id="sc-name" class="text-2xl font-bold"></h2>
        <p id="sc-title" class="text-[#4ade80] text-sm mt-1"></p>
      </div>
      <div class="p-6 space-y-4">
        <div class="bg-[#f0f9f0] rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1 uppercase tracking-wide font-semibold">Worker ID</p>
          <p id="sc-worker-id" class="font-mono text-2xl font-bold text-[#194642] tracking-wider"></p>
        </div>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 font-medium">Email</p>
            <p id="sc-email" class="text-gray-800 font-medium truncate"></p>
          </div>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 font-medium">Department</p>
            <p id="sc-dept" class="text-gray-800 font-medium"></p>
          </div>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 font-medium">Start Date</p>
            <p id="sc-start" class="text-gray-800 font-medium"></p>
          </div>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 font-medium">Contract</p>
            <p id="sc-contract" class="text-gray-800 font-medium"></p>
          </div>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-center text-green-700 text-sm font-medium">
          <i class="fas fa-check-circle mr-1.5"></i> Employee record created successfully
        </div>
        <button id="sc-done" class="w-full bg-[#194642] text-white font-semibold py-2.5 rounded-lg hover:bg-[#2a5e59] transition-colors text-sm">
          Done
        </button>
      </div>
    </div>
  </div>

  <!-- ── Employee Grid ───────────────────────────────────────────── -->
  <div id="employees-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="col-span-full flex justify-center py-16">
      <div class="animate-spin w-8 h-8 border-4 border-[#194642] border-t-transparent rounded-full"></div>
    </div>
  </div>

  <!-- ── Edit Employee Modal ─────────────────────────────────────── -->
  <div id="emp-modal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-start justify-center p-4 overflow-y-auto">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-xl my-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="font-bold text-lg text-gray-800">Edit Employee</h2>
        <button id="emp-modal-close" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
      </div>
      <div id="emp-modal-content" class="p-6">Loading...</div>
    </div>
  </div>
</AdminLayout>

<script>
  // @ts-nocheck
  // Read PUBLIC env values injected via data attributes
  const _cfg = document.getElementById('app-config');
  const supabaseUrl = _cfg.dataset.supabaseUrl!;
  const supabaseAnonKey = _cfg.dataset.supabaseAnonKey!;

  const statusColors: Record<string, string> = {
    active: 'bg-green-100 text-green-700',
    inactive: 'bg-gray-100 text-gray-600',
    terminated: 'bg-red-100 text-red-700',
    on_leave: 'bg-yellow-100 text-yellow-700',
  };

  // ── Photo preview ────────────────────────────────────────────────
  let uploadedPhotoUrl: string | null = null;

  document.getElementById('ne-photo-file').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) {
      showPhotoStatus('File too large (max 5 MB)', 'error');
      return;
    }

    // Show local preview immediately
    const reader = new FileReader();
    reader.onload = ev => {
      const preview = document.getElementById('photo-preview');
      preview.innerHTML = `<img src="${ev.target.result}" class="w-full h-full object-cover" />`;
    };
    reader.readAsDataURL(file);

    // Upload to Supabase Storage
    showPhotoStatus('Uploading...', 'loading');
    try {
      const ext = file.name.split('.').pop();
      const path = `employees/${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
      const uploadRes = await fetch(
        `${supabaseUrl}/storage/v1/object/employee-photos/${path}`,
        {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${supabaseAnonKey}`,
            'Content-Type': file.type,
            'x-upsert': 'true',
          },
          body: file,
        }
      );
      if (uploadRes.ok) {
        uploadedPhotoUrl = `${supabaseUrl}/storage/v1/object/public/employee-photos/${path}`;
        showPhotoStatus('Photo uploaded successfully', 'success');
      } else {
        // Storage bucket may not exist yet — keep local preview, skip URL
        uploadedPhotoUrl = null;
        showPhotoStatus('Photo selected (will be saved as URL later)', 'warn');
      }
    } catch {
      uploadedPhotoUrl = null;
      showPhotoStatus('Upload failed — photo preview only', 'warn');
    }
  });

  function showPhotoStatus(msg, type) {
    const el = document.getElementById('photo-upload-status');
    el.classList.remove('hidden');
    const colors = { success: 'text-green-600', error: 'text-red-600', warn: 'text-yellow-600', loading: 'text-gray-500' };
    el.className = `text-xs mt-1 ${colors[type] || 'text-gray-500'}`;
    el.textContent = msg;
  }

  // ── ID Card scan ─────────────────────────────────────────────────
  const AUTO_FILL_MAP: Record<string, string> = {
    first_name: 'ne-fname',
    middle_name: 'ne-mname',
    last_name: 'ne-lname',
    birth_date: 'ne-birthdate',
    nationality: 'ne-nationality',
    address: 'ne-address',
    city: 'ne-city',
    country: 'ne-country',
  };

  function setIdStatus(side: 'front' | 'back', msg: string, type: 'loading' | 'success' | 'error' | 'warn') {
    const el = document.getElementById(`id-${side}-status`)!;
    el.classList.remove('hidden');
    const icons = { loading: 'fa-spinner fa-spin text-gray-500', success: 'fa-check-circle text-green-600', error: 'fa-times-circle text-red-500', warn: 'fa-exclamation-circle text-yellow-500' };
    el.innerHTML = `<i class="fas ${icons[type]}"></i> <span class="${type === 'success' ? 'text-green-600' : type === 'error' ? 'text-red-500' : 'text-gray-600'}">${msg}</span>`;
  }

  async function handleIdUpload(side: 'front' | 'back', file: File) {
    // Show image preview
    const previewEl = document.getElementById(`id-${side}-preview`)!;
    const reader = new FileReader();
    reader.onload = ev => {
      previewEl.innerHTML = `<img src="${ev.target?.result}" class="w-full h-full object-cover" />`;
    };
    reader.readAsDataURL(file);

    setIdStatus(side, 'Scanning ID card with AI...', 'loading');

    const fd = new FormData();
    fd.append('image', file);
    fd.append('side', side);

    try {
      const res = await fetch('/api/admin/careers/scan-id', { method: 'POST', body: fd });
      const data = await res.json();

      if (!res.ok || data.error) {
        setIdStatus(side, data.error || 'Scan failed — fill fields manually', 'error');
        return;
      }

      // Store the image URL
      if (data.image_url) {
        (document.getElementById(side === 'front' ? 'ne-id-front-url' : 'ne-id-back-url') as HTMLInputElement).value = data.image_url;
      }

      const fields = data.fields || {};
      const filled: string[] = [];

      if (side === 'front') {
        // Auto-fill text inputs
        for (const [field, inputId] of Object.entries(AUTO_FILL_MAP)) {
          if (fields[field]) {
            const el = document.getElementById(inputId) as HTMLInputElement;
            if (el && !el.value) {
              el.value = fields[field];
              el.classList.add('ring-2', 'ring-[#4ade80]', 'border-[#4ade80]');
              setTimeout(() => el.classList.remove('ring-2', 'ring-[#4ade80]', 'border-[#4ade80]'), 3000);
              filled.push(field.replace(/_/g, ' '));
            }
          }
        }

        // Gender select
        if (fields.gender) {
          const genderEl = document.getElementById('ne-gender') as HTMLSelectElement;
          if (genderEl && !genderEl.value) {
            genderEl.value = fields.gender;
            filled.push('gender');
          }
        }

        // ID number + expiry
        if (fields.id_number) {
          (document.getElementById('ne-id-number') as HTMLInputElement).value = fields.id_number;
          filled.push('ID number');
        }
        if (fields.id_card_expiry) {
          (document.getElementById('ne-id-expiry') as HTMLInputElement).value = fields.id_card_expiry;
          filled.push('ID expiry');
        }
      } else {
        // Back side: fill address/city if still empty, update ID number/expiry if found
        if (fields.address && !(document.getElementById('ne-address') as HTMLInputElement).value) {
          (document.getElementById('ne-address') as HTMLInputElement).value = fields.address;
          filled.push('address');
        }
        if (fields.city && !(document.getElementById('ne-city') as HTMLInputElement).value) {
          (document.getElementById('ne-city') as HTMLInputElement).value = fields.city;
          filled.push('city');
        }
        if (fields.id_number && !(document.getElementById('ne-id-number') as HTMLInputElement).value) {
          (document.getElementById('ne-id-number') as HTMLInputElement).value = fields.id_number;
          filled.push('ID number');
        }
        if (fields.id_card_expiry && !(document.getElementById('ne-id-expiry') as HTMLInputElement).value) {
          (document.getElementById('ne-id-expiry') as HTMLInputElement).value = fields.id_card_expiry;
          filled.push('ID expiry');
        }
      }

      if (filled.length > 0) {
        setIdStatus(side, `Filled: ${filled.join(', ')}`, 'success');
        // Show summary panel
        const summaryEl = document.getElementById('id-scan-summary')!;
        const fieldsEl = document.getElementById('id-scan-fields')!;
        summaryEl.classList.remove('hidden');
        filled.forEach(f => {
          const badge = document.createElement('span');
          badge.className = 'bg-[#194642] text-white px-2 py-0.5 rounded-full capitalize';
          badge.textContent = f;
          fieldsEl.appendChild(badge);
        });
      } else {
        setIdStatus(side, 'Scanned — no new fields detected', 'warn');
      }

    } catch {
      setIdStatus(side, 'Scan error — fill fields manually', 'error');
    }
  }

  document.getElementById('ne-id-front')!.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) handleIdUpload('front', file);
  });
  document.getElementById('ne-id-back')!.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) handleIdUpload('back', file);
  });

  // ── Load & render employees ───────────────────────────────────────
  async function loadEmployees() {
    const res = await fetch('/api/admin/careers/employees');
    const data = await res.json();
    renderEmployees(data.employees || []);
  }

  function renderEmployees(employees) {
    const grid = document.getElementById('employees-grid');
    if (!employees.length) {
      grid.innerHTML = `
        <div class="col-span-full bg-white rounded-xl border border-gray-100 shadow-sm px-6 py-16 text-center">
          <div class="text-5xl mb-4">👥</div>
          <h3 class="text-lg font-bold text-gray-700 mb-1">No employees yet</h3>
          <p class="text-gray-500 text-sm">Add employees directly or convert approved applicants.</p>
        </div>`;
      return;
    }
    grid.innerHTML = employees.map(e => `
      <div class="bg-gradient-to-br from-[#194642] to-[#2a5e59] text-white rounded-xl shadow-lg overflow-hidden">
        <div class="p-5">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 bg-white/20 rounded-full overflow-hidden flex items-center justify-center flex-shrink-0 border-2 border-white/30">
              ${e.photo_url
                ? `<img src="${e.photo_url}" class="w-full h-full object-cover" />`
                : `<i class="fas fa-user text-white/60 text-xl"></i>`}
            </div>
            <div class="min-w-0">
              <h3 class="font-bold text-lg leading-tight truncate">${e.first_name} ${e.last_name}</h3>
              <p class="text-[#4ade80] text-sm truncate">${e.job_title || '—'}</p>
              ${e.department ? `<p class="text-white/60 text-xs">${e.department}</p>` : ''}
            </div>
          </div>
          <div class="bg-white/10 rounded-lg p-3 mb-3">
            <p class="text-white/60 text-xs mb-0.5">Worker ID</p>
            <p class="font-mono text-xl font-bold tracking-wider">${e.worker_id}</p>
          </div>
          <div class="flex items-center justify-between text-xs text-white/60 mb-3">
            <span>Since ${e.start_date ? new Date(e.start_date).toLocaleDateString() : '—'}</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[e.status] || 'bg-white/20 text-white'}">${e.status}</span>
          </div>
          <div class="flex gap-2">
            <button onclick="editEmployee('${e.id}')" class="flex-1 bg-white/20 hover:bg-white/30 text-white font-medium px-3 py-1.5 rounded-lg text-sm transition-colors">
              <i class="fas fa-pen text-xs mr-1"></i> Edit
            </button>
            <button onclick="deleteEmployee('${e.id}','${(e.first_name + ' ' + e.last_name).replace(/'/g, "\\'")}') " class="bg-red-500/30 hover:bg-red-500/50 text-white font-medium px-3 py-1.5 rounded-lg text-sm transition-colors">
              <i class="fas fa-trash text-xs mr-1"></i> Remove
            </button>
          </div>
        </div>
      </div>`).join('');
  }

  // ── Edit employee ─────────────────────────────────────────────────
  window.editEmployee = async (id) => {
    const modal = document.getElementById('emp-modal');
    const content = document.getElementById('emp-modal-content');
    modal.classList.remove('hidden');
    content.innerHTML = '<div class="flex justify-center py-12"><div class="animate-spin w-8 h-8 border-4 border-[#194642] border-t-transparent rounded-full"></div></div>';

    const res = await fetch(`/api/admin/careers/employees?id=${id}`);
    const data = await res.json();
    const e = data.employee;
    if (!e) { content.innerHTML = '<p class="text-red-500">Failed to load.</p>'; return; }

    content.innerHTML = `
      <div class="space-y-4">
        <!-- Photo -->
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-full overflow-hidden bg-gray-100 border border-gray-200 flex items-center justify-center flex-shrink-0">
            ${e.photo_url ? `<img src="${e.photo_url}" class="w-full h-full object-cover" id="edit-photo-preview-img" />` : `<i class="fas fa-user text-gray-300 text-xl" id="edit-photo-preview-icon"></i>`}
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Update Photo</p>
            <label class="flex items-center gap-2 cursor-pointer bg-[#194642]/5 hover:bg-[#194642]/10 text-[#194642] text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors border border-[#194642]/20 w-fit">
              <i class="fas fa-upload text-xs"></i> Upload New Photo
              <input type="file" id="edit-photo-file-${id}" accept="image/*" class="hidden" />
            </label>
            <div id="edit-photo-status-${id}" class="hidden text-xs mt-1 text-gray-500"></div>
          </div>
        </div>
        <input type="hidden" id="eedit-photo-${id}" value="${e.photo_url || ''}" />

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Job Title</label>
            <input id="eedit-title-${id}" type="text" value="${e.job_title || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Department</label>
            <input id="eedit-dept-${id}" type="text" value="${e.department || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Start Date</label>
            <input id="eedit-start-${id}" type="date" value="${e.start_date || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Status</label>
            <select id="eedit-status-${id}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
              <option value="active" ${e.status === 'active' ? 'selected' : ''}>Active</option>
              <option value="inactive" ${e.status === 'inactive' ? 'selected' : ''}>Inactive</option>
              <option value="on_leave" ${e.status === 'on_leave' ? 'selected' : ''}>On Leave</option>
              <option value="terminated" ${e.status === 'terminated' ? 'selected' : ''}>Terminated</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Contract Type</label>
            <select id="eedit-contract-type-${id}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]">
              <option value="CDI" ${(e.contract_type||'CDI') === 'CDI' ? 'selected' : ''}>CDI</option>
              <option value="CDD" ${e.contract_type === 'CDD' ? 'selected' : ''}>CDD</option>
              <option value="Stage" ${e.contract_type === 'Stage' ? 'selected' : ''}>Stage</option>
              <option value="Freelance" ${e.contract_type === 'Freelance' ? 'selected' : ''}>Freelance</option>
              <option value="Volontaire" ${e.contract_type === 'Volontaire' ? 'selected' : ''}>Volontaire</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Phone</label>
            <input id="eedit-phone-${id}" type="text" value="${e.phone || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Address</label>
          <input id="eedit-address-${id}" type="text" value="${e.address || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">City</label>
            <input id="eedit-city-${id}" type="text" value="${e.city || ''}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Country</label>
            <input id="eedit-country-${id}" type="text" value="${e.country || "Côte d'Ivoire"}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Contract URL</label>
          <input id="eedit-contract-${id}" type="text" value="${e.contract_url || ''}" placeholder="https://..." class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#194642]" />
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-sm">
          <p class="font-medium text-gray-700">Worker ID: <span class="font-mono text-[#194642] font-bold">${e.worker_id}</span></p>
          <p class="text-gray-500 mt-1">Email: ${e.email}</p>
        </div>
        <div id="eedit-error-${id}" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-red-700 text-sm"></div>
        <div class="flex justify-end gap-3">
          <button onclick="document.getElementById('emp-modal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50">Cancel</button>
          <button onclick="saveEmployee('${id}')" class="bg-[#194642] text-white font-semibold px-5 py-2 rounded-lg hover:bg-[#2a5e59] text-sm">
            <i class="fas fa-save mr-1.5"></i> Save Changes
          </button>
        </div>
      </div>`;

    // Photo upload in edit mode
    document.getElementById(`edit-photo-file-${id}`).addEventListener('change', async (ev) => {
      const file = ev.target.files[0];
      if (!file) return;
      const statusEl = document.getElementById(`edit-photo-status-${id}`);
      statusEl.classList.remove('hidden');
      statusEl.textContent = 'Uploading...';
      try {
        const ext = file.name.split('.').pop();
        const path = `employees/${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
        const uploadRes = await fetch(
          `${supabaseUrl}/storage/v1/object/employee-photos/${path}`,
          { method: 'POST', headers: { 'Authorization': `Bearer ${supabaseAnonKey}`, 'Content-Type': file.type, 'x-upsert': 'true' }, body: file }
        );
        if (uploadRes.ok) {
          const url = `${supabaseUrl}/storage/v1/object/public/employee-photos/${path}`;
          document.getElementById(`eedit-photo-${id}`).value = url;
          statusEl.textContent = 'Photo uploaded ✓';
          statusEl.className = 'text-xs mt-1 text-green-600';
          // Update preview
          const prevImg = document.getElementById('edit-photo-preview-img');
          const prevIcon = document.getElementById('edit-photo-preview-icon');
          if (prevImg) { prevImg.src = url; }
          else if (prevIcon) {
            prevIcon.outerHTML = `<img src="${url}" class="w-full h-full object-cover" id="edit-photo-preview-img" />`;
          }
        } else {
          statusEl.textContent = 'Upload failed — enter URL manually below';
          statusEl.className = 'text-xs mt-1 text-red-500';
        }
      } catch {
        statusEl.textContent = 'Upload failed';
        statusEl.className = 'text-xs mt-1 text-red-500';
      }
    });
  };

  window.saveEmployee = async (id) => {
    const errDiv = document.getElementById(`eedit-error-${id}`);
    errDiv.classList.add('hidden');
    const updates = {
      id,
      job_title: document.getElementById(`eedit-title-${id}`).value.trim(),
      department: document.getElementById(`eedit-dept-${id}`).value.trim(),
      start_date: document.getElementById(`eedit-start-${id}`).value || null,
      status: document.getElementById(`eedit-status-${id}`).value,
      contract_type: document.getElementById(`eedit-contract-type-${id}`).value,
      phone: document.getElementById(`eedit-phone-${id}`).value.trim() || null,
      address: document.getElementById(`eedit-address-${id}`).value.trim() || null,
      city: document.getElementById(`eedit-city-${id}`).value.trim() || null,
      country: document.getElementById(`eedit-country-${id}`).value.trim() || null,
      contract_url: document.getElementById(`eedit-contract-${id}`).value.trim() || null,
      photo_url: document.getElementById(`eedit-photo-${id}`).value.trim() || null,
    };
    const res = await fetch('/api/admin/careers/employees', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(updates),
    });
    const data = await res.json();
    if (!res.ok) { errDiv.textContent = data.error || 'Save failed'; errDiv.classList.remove('hidden'); return; }
    document.getElementById('emp-modal').classList.add('hidden');
    await loadEmployees();
  };

  window.deleteEmployee = async (id, name) => {
    if (!confirm(`Remove employee record for ${name}? This cannot be undone.`)) return;
    await fetch('/api/admin/careers/employees', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    await loadEmployees();
  };

  // ── Modal controls ────────────────────────────────────────────────
  document.getElementById('emp-modal-close').addEventListener('click', () => {
    document.getElementById('emp-modal').classList.add('hidden');
  });

  function openAddModal() {
    document.getElementById('add-emp-form').reset();
    document.getElementById('ne-error').classList.add('hidden');
    document.getElementById('photo-upload-status').classList.add('hidden');
    document.getElementById('photo-preview').innerHTML = '<i class="fas fa-user text-gray-300 text-2xl"></i>';
    uploadedPhotoUrl = null;
    // Reset ID card section
    document.getElementById('id-front-preview').innerHTML = '<i class="fas fa-id-card text-gray-300 text-3xl mb-1"></i><span class="text-xs text-gray-400">No image</span>';
    document.getElementById('id-back-preview').innerHTML = '<i class="fas fa-id-card text-gray-300 text-3xl mb-1"></i><span class="text-xs text-gray-400">No image</span>';
    document.getElementById('id-front-status').classList.add('hidden');
    document.getElementById('id-back-status').classList.add('hidden');
    document.getElementById('id-scan-summary').classList.add('hidden');
    document.getElementById('id-scan-fields').innerHTML = '';
    document.getElementById('add-emp-modal').classList.remove('hidden');
  }

  document.getElementById('btn-add-employee').addEventListener('click', openAddModal);
  document.getElementById('add-emp-close').addEventListener('click', () => document.getElementById('add-emp-modal').classList.add('hidden'));
  document.getElementById('ne-cancel').addEventListener('click', () => document.getElementById('add-emp-modal').classList.add('hidden'));
  document.getElementById('sc-done').addEventListener('click', () => document.getElementById('success-modal').classList.add('hidden'));

  // ── Submit new employee ───────────────────────────────────────────
  document.getElementById('add-emp-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errDiv = document.getElementById('ne-error')!;
    const submitBtn = document.getElementById('ne-submit') as HTMLButtonElement;
    const submitText = document.getElementById('ne-submit-text')!;
    errDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitText.textContent = 'Creating...';

    const gv = (id: string) => (document.getElementById(id) as HTMLInputElement).value;
    const payload = {
      first_name: gv('ne-fname').trim(),
      middle_name: gv('ne-mname').trim() || null,
      last_name: gv('ne-lname').trim(),
      birth_date: gv('ne-birthdate'),
      email: gv('ne-email').trim(),
      phone: gv('ne-phone').trim() || null,
      nationality: gv('ne-nationality').trim() || null,
      gender: (document.getElementById('ne-gender') as HTMLSelectElement).value || null,
      address: gv('ne-address').trim() || null,
      city: gv('ne-city').trim() || null,
      country: gv('ne-country').trim() || "Côte d'Ivoire",
      job_title: gv('ne-title').trim(),
      department: gv('ne-dept').trim() || null,
      start_date: gv('ne-start') || null,
      contract_type: (document.getElementById('ne-contract-type') as HTMLSelectElement).value,
      photo_url: uploadedPhotoUrl || null,
      id_card_front_url: (document.getElementById('ne-id-front-url') as HTMLInputElement).value || null,
      id_card_back_url: (document.getElementById('ne-id-back-url') as HTMLInputElement).value || null,
      id_number: (document.getElementById('ne-id-number') as HTMLInputElement).value || null,
      id_card_expiry: (document.getElementById('ne-id-expiry') as HTMLInputElement).value || null,
    };

    const res = await fetch('/api/admin/careers/employees', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
    });
    const data = await res.json();

    submitBtn.disabled = false;
    submitText.textContent = 'Create Employee';

    if (!res.ok || data.error) {
      errDiv.textContent = data.error || 'Failed to create employee';
      errDiv.classList.remove('hidden');
      return;
    }

    // Close add modal
    document.getElementById('add-emp-modal')!.classList.add('hidden');

    // Show success card
    const emp = data.employee;
    const g = (id: string) => document.getElementById(id)!;
    g('sc-name').textContent = `${emp.first_name} ${emp.last_name}`;
    g('sc-title').textContent = emp.job_title || '';
    g('sc-worker-id').textContent = emp.worker_id;
    g('sc-email').textContent = emp.email;
    g('sc-dept').textContent = emp.department || '—';
    g('sc-start').textContent = emp.start_date ? new Date(emp.start_date).toLocaleDateString() : '—';
    g('sc-contract').textContent = emp.contract_type || 'CDI';

    const scPhoto = g('sc-photo') as HTMLImageElement;
    const scIcon = g('sc-photo-icon');
    if (emp.photo_url) {
      scPhoto.src = emp.photo_url;
      scPhoto.classList.remove('hidden');
      scIcon.classList.add('hidden');
    } else {
      scPhoto.classList.add('hidden');
      scIcon.classList.remove('hidden');
    }

    g('success-modal').classList.remove('hidden');
    await loadEmployees();
  });

  loadEmployees();
</script>
