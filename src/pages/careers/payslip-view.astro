---
// Employee-facing bulletin print view. The careers portal fetches the slip
// with the employee's portal credentials and stores it in sessionStorage
// before opening this page — no credentials ever hit the URL.
export const prerender = false;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Bulletin de paie — Arbre Bio</title>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; color: #1a1a1a; background: #d8d8d8; }
      #action-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 200;
        background: #194642; padding: 10px 20px;
        display: flex; align-items: center; justify-content: space-between;
        box-shadow: 0 2px 10px rgba(0,0,0,.3);
      }
      #action-bar h1 { color: #fff; font-size: 13.5px; font-weight: 700; }
      .btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 13px; border-radius: 6px; font-size: 12px; font-weight: 600;
        cursor: pointer; border: none; text-decoration: none;
      }
      .btn-white { background: #fff; color: #194642; }
      #page-wrap { padding: 72px 20px 48px; max-width: 840px; margin: 0 auto; }
      #error-msg { display: none; text-align: center; padding: 60px 20px; color: #c00; font-size: 15px; }
    </style>
  </head>
  <body>
    <div id="action-bar">
      <h1>📄 Bulletin de paie — Arbre Bio Africa</h1>
      <button class="btn btn-white" onclick="window.print()">
        <i class="fas fa-download"></i> Télécharger / Imprimer
      </button>
    </div>

    <div id="page-wrap">
      <div id="error-msg">❌ Bulletin indisponible. Retournez au portail et ré-ouvrez votre bulletin.</div>
      <div id="bulletin-content"></div>
    </div>

    <script>
      import { BULLETIN_CSS, renderBulletin } from '../../lib/payroll/renderBulletin';

      const styleTag = document.createElement('style');
      styleTag.textContent = BULLETIN_CSS;
      document.head.appendChild(styleTag);

      try {
        const raw = sessionStorage.getItem('aba_payslip');
        if (!raw) throw new Error('missing');
        const slip = JSON.parse(raw);
        document.getElementById('bulletin-content')!.innerHTML = renderBulletin(slip);
        document.title = `Bulletin de paie ${slip.profile_snapshot?.matricule || ''}`;
      } catch {
        document.getElementById('error-msg')!.style.display = 'block';
      }
    </script>
  </body>
</html>
