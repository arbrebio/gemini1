---
const menuItems = [
    { name: "Dashboard", href: "/admin/", icon: "fa-chart-line" },
    { name: "Blog", href: "/admin/blog/", icon: "fa-newspaper" },
    { name: "Customers", href: "/admin/customers/", icon: "fa-users" },
    { name: "Inventory", href: "/admin/inventory/", icon: "fa-boxes" },
    { name: "Projects", href: "/admin/projects/", icon: "fa-project-diagram" },
    { name: "Suppliers", href: "/admin/suppliers/", icon: "fa-truck" },
    { name: "Careers", href: "/admin/careers/", icon: "fa-briefcase" },
    { name: "Sales", href: "/admin/sales/", icon: "fa-chart-bar" },
    { name: "Settings", href: "/admin/settings/", icon: "fa-cog" },
];

const currentPath = Astro.url.pathname;
---

<aside
    class="bg-[#194642] text-white w-64 min-h-screen flex flex-col transition-all duration-300"
    id="admin-sidebar"
>
    <div class="p-5 flex items-center justify-center border-b border-[#2a5e59]">
        <a href="/admin/" class="flex flex-col items-center gap-2">
            <img src="/logo.png" alt="Arbre Bio Africa" class="h-12 w-auto rounded-lg bg-white/10 p-1" />
            <span class="font-semibold text-sm tracking-wide text-white/80">Admin Panel</span>
        </a>
    </div>

    <nav class="flex-1 py-6 px-3 space-y-1 overflow-y-auto">
        {
            menuItems.map((item) => {
                const isActive =
                    currentPath === item.href ||
                    (item.href !== "/admin/" &&
                        currentPath.startsWith(item.href));
                return (
                    <a
                        href={item.href}
                        class:list={[
                            "flex items-center gap-3 px-4 py-3 rounded-lg transition-colors duration-200 group",
                            isActive
                                ? "bg-[#2a5e59] text-white shadow-md"
                                : "text-gray-300 hover:bg-[#2a5e59] hover:text-white",
                        ]}
                    >
                        <i
                            class={`fas ${item.icon} w-5 text-center ${isActive ? "text-[#4ade80]" : "text-gray-400 group-hover:text-white"}`}
                        />
                        <span class="font-medium">{item.name}</span>
                    </a>
                );
            })
        }

        <div class="pt-3 mt-3 border-t border-[#2a5e59]/60">
            <button
                id="terrain-link-btn"
                type="button"
                class="flex items-center gap-3 px-4 py-3 w-full text-left rounded-lg transition-colors duration-200 group text-gray-300 hover:bg-[#2a5e59] hover:text-white"
                title="Manage field projects, technicians and engineers — uses your admin login"
            >
                <i class="fas fa-map-marked-alt w-5 text-center text-gray-400 group-hover:text-white" />
                <span class="font-medium">Terrain (Field Ops)</span>
                <i id="terrain-link-spinner" class="fas fa-circle-notch fa-spin text-[10px] text-gray-500 ml-auto hidden" />
            </button>
        </div>
    </nav>

    <div class="p-4 border-t border-[#2a5e59]">
        <button
            id="logout-btn"
            class="flex items-center gap-3 px-4 py-3 w-full text-left text-red-300 hover:bg-red-900/20 hover:text-red-200 rounded-lg transition-colors"
        >
            <i class="fas fa-sign-out-alt w-5 text-center"></i>
            <span class="font-medium">Logout</span>
        </button>
    </div>
</aside>

<script>
    import { supabase } from "../../lib/supabase";

    const logoutBtn = document.getElementById("logout-btn");
    if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
            await supabase.auth.signOut();
            window.location.href = "/admin/login/";
        });
    }

    // Single sign-on into the Terrain field-ops platform: reuse this admin's
    // own Supabase session instead of sending them to a separate login.
    const terrainBtn = document.getElementById("terrain-link-btn");
    const terrainSpinner = document.getElementById("terrain-link-spinner");
    if (terrainBtn) {
        terrainBtn.addEventListener("click", async () => {
            terrainBtn.setAttribute("disabled", "true");
            terrainSpinner?.classList.remove("hidden");
            try {
                const { data: { session } } = await supabase.auth.getSession();
                if (!session?.access_token) {
                    window.location.href = "/admin/login/";
                    return;
                }
                const res = await fetch("/api/admin/terrain-link/", {
                    method: "POST",
                    headers: { Authorization: `Bearer ${session.access_token}` },
                });
                if (!res.ok) throw new Error("Failed to link Terrain account");
                const data = await res.json();
                localStorage.setItem("terrainToken", session.access_token);
                localStorage.setItem("terrainProfile", JSON.stringify(data.profile));
                window.location.href = "/terrain/admin/dashboard/";
            } catch {
                terrainBtn.removeAttribute("disabled");
                terrainSpinner?.classList.add("hidden");
                alert("Could not open the Terrain platform. Please try again.");
            }
        });
    }
</script>
