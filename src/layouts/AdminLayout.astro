---
import Sidebar from "../components/admin/Sidebar.astro";
import Header from "../components/admin/Header.astro";
import "../styles/base.css"; // Ensure global styles are loaded

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Arbre Bio Africa Admin Panel" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
        />
        <title>{title} | Arbre Bio Admin</title>
    </head>
    <body class="bg-gray-50 font-sans text-gray-900">
        <div class="flex min-h-screen">
            <!-- Sidebar -->
            <div class="hidden lg:block">
                <Sidebar />
            </div>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
                <Header />

                <main class="flex-1 overflow-y-auto p-6">
                    <!-- Back button — always visible on sub-pages -->
                    <div id="admin-back-bar" style="display:none" class="mb-5">
                        <button onclick="history.length > 1 ? history.back() : (window.location.href='/admin')"
                            class="inline-flex items-center gap-2 bg-white border border-gray-200 shadow-sm text-sm font-medium text-gray-600 hover:text-[#194642] hover:border-[#194642] px-4 py-2 rounded-lg transition-all">
                            <i class="fas fa-arrow-left text-xs"></i>
                            Return
                        </button>
                    </div>
                    <slot />
                </main>
            </div>
        </div>

        <!-- Auth Check Script -->
        <script>
            import { supabase } from "../lib/supabase";

            const checkAuth = async () => {
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) window.location.href = "/admin/login";
            };
            checkAuth();

            // Show Return button on all admin sub-pages (not on /admin dashboard)
            const backBar = document.getElementById('admin-back-bar');
            if (backBar) {
                const path = window.location.pathname.replace(/\/$/, '');
                if (path !== '/admin') {
                    backBar.style.display = 'block';
                }
            }
        </script>
    </body>
</html>
