# Environment Variables for Arbre Bio Africa

# Supabase Configuration
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
PUBLIC_ADMIN_EMAIL=farms@arbrebio.com
PUBLIC_SENDER_NAME=Arbre Bio Africa

# Security Tokens (Generate secure random tokens)
ADMIN_TOKEN=your_secure_admin_token_here
NEWSLETTER_ADMIN_TOKEN=your_secure_newsletter_admin_token_here
STATS_TOKEN=your_secure_stats_token_here
EXPORT_TOKEN=your_secure_export_token_here

# Site Configuration
SITE=https://arbrebio.com

# SEO / Analytics
# Get this from Google Search Console > Settings > Ownership verification > HTML tag
# (paste only the "content" value of the meta tag, not the whole tag)
PUBLIC_GSC_VERIFICATION=your_google_search_console_verification_code
# Get this from Google Analytics > Admin > Data Streams > your stream > Measurement ID
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook/Instagram) Ads — Events Manager > Datasets > your pixel > Overview (ID shown at top)
PUBLIC_META_PIXEL_ID=your_meta_pixel_dataset_id
# Events Manager > your pixel > Settings > Conversions API > Generate access token
META_CAPI_ACCESS_TOKEN=your_meta_conversions_api_access_token
# Business Manager > Brand Safety > Domains > your domain > Add a meta-tag (content value only)
PUBLIC_FB_DOMAIN_VERIFICATION=your_facebook_domain_verification_code